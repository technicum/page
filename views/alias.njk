<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ metaDesc }}">
<link rel="canonical" href="{{ app_url }}/{{ citySlug }}/{{ aliasSlug }}">

<!-- Open Graph -->
<meta property="og:type"        content="website">
<meta property="og:title"       content="{{ title }}">
<meta property="og:description" content="{{ metaDesc }}">
<meta property="og:url"         content="{{ app_url }}/{{ citySlug }}/{{ aliasSlug }}">

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary">
<meta name="twitter:title"       content="{{ title }}">
<meta name="twitter:description" content="{{ metaDesc }}">

<!-- JSON-LD: ItemList -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "{{ h1 }}",
  "description": "{{ metaDesc }}",
  "url": "{{ app_url }}/{{ citySlug }}/{{ aliasSlug }}",
  "numberOfItems": {{ results.length }},
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"{{ app_url }}/"},
      {"@type":"ListItem","position":2,"name":"{{ cityName }}","item":"{{ app_url }}/{{ citySlug }}"},
      {"@type":"ListItem","position":3,"name":"{{ aliasKeyword }}","item":"{{ app_url }}/{{ citySlug }}/{{ aliasSlug }}"}
    ]
  }
}
</script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1a18;--ink-muted:#6b6b66;--ink-faint:#b0afa8;
  --white:#fff;--off:#f8f7f4;--paper:#f2f0eb;
  --border:rgba(26,26,24,0.1);--border-md:rgba(26,26,24,0.18);
  --blue:#2563eb;--blue-light:#eff4ff;--blue-mid:#c7d9fd;
  --radius-sm:8px;--radius-md:12px;--radius-lg:18px;
}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);min-height:100vh;}

/* ── Nav ── */
nav{background:var(--white);border-bottom:1px solid var(--border);padding:0 40px;height:60px;display:flex;align-items:center;justify-content:space-between;gap:16px;position:sticky;top:0;z-index:100;}
.logo{font-family:'DM Serif Display',serif;font-size:20px;color:var(--ink);text-decoration:none;}
.logo em{font-style:italic;color:var(--blue);}
.nav-right a{font-size:13px;color:var(--ink-muted);text-decoration:none;}
.nav-right a:hover{color:var(--ink);}

/* ── Hero ── */
.alias-hero{background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 60%,#3b82f6 100%);padding:52px 40px 44px;text-align:center;}
.breadcrumb{display:flex;align-items:center;justify-content:center;gap:6px;font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:20px;flex-wrap:wrap;}
.breadcrumb a{color:rgba(255,255,255,0.7);text-decoration:none;}
.breadcrumb a:hover{color:#fff;}
.breadcrumb-sep{opacity:0.4;}
.alias-hero-title{font-family:'DM Serif Display',serif;font-size:clamp(26px,5vw,46px);font-weight:400;color:#fff;letter-spacing:-0.5px;margin-bottom:10px;line-height:1.1;}
.alias-hero-title em{font-style:italic;opacity:0.85;}
.alias-hero-sub{font-size:15px;color:rgba(255,255,255,0.72);margin-bottom:28px;}
.alias-search-bar{display:flex;max-width:560px;margin:0 auto;border-radius:40px;overflow:hidden;background:var(--white);box-shadow:0 8px 32px rgba(0,0,0,0.22);}
.alias-search-inp{flex:1;border:none;outline:none;font-size:15px;font-family:'DM Sans',sans-serif;padding:16px 20px;color:var(--ink);background:transparent;}
.alias-search-inp::placeholder{color:var(--ink-faint);}
.alias-search-btn{background:var(--blue);color:#fff;border:none;padding:0 28px;font-size:15px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background 0.2s;white-space:nowrap;border-radius:40px;margin:5px;}
.alias-search-btn:hover{background:#1d4ed8;}

/* ── Stats strip ── */
.stats-strip{background:var(--white);border-bottom:1px solid var(--border);padding:14px 40px;}
.stats-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;gap:24px;flex-wrap:wrap;}
.stat-pill{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--ink-muted);}
.stat-pill strong{color:var(--ink);font-weight:600;}
.stat-sep{color:var(--border-md);}

/* ── Page wrap ── */
.page-wrap{max-width:1100px;margin:0 auto;padding:28px 40px 80px;}

/* ── Category pills ── */
.filter-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--border);}
.filter-pill{font-size:13px;padding:6px 14px;border-radius:20px;border:1px solid var(--border-md);background:var(--white);color:var(--ink-muted);cursor:pointer;text-decoration:none;transition:all 0.15s;white-space:nowrap;}
.filter-pill:hover{border-color:var(--blue);color:var(--blue);}
.filter-pill.active{background:var(--blue);color:#fff;border-color:var(--blue);}

/* ── Section header ── */
.section-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.section-hd h2{font-family:'DM Serif Display',serif;font-size:22px;font-weight:400;color:var(--ink);letter-spacing:-0.3px;}
.results-count{font-size:14px;color:var(--ink-muted);}
.results-count strong{color:var(--ink);}

/* ── Cards ── */
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;}
.provider-card{background:var(--white);border:1px solid var(--border);border-radius:16px;overflow:hidden;text-decoration:none;display:flex;flex-direction:column;transition:box-shadow 0.2s;position:relative;}
.provider-card:hover{box-shadow:0 8px 28px rgba(0,0,0,0.1);border-color:var(--border-md);}
.card-band{height:72px;flex-shrink:0;position:relative;display:flex;justify-content:center;}
.card-avatar-wrap{position:absolute;bottom:-24px;display:flex;align-items:center;justify-content:center;}
.card-icon-wrap{width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px;border:2px solid var(--white);box-shadow:0 1px 6px rgba(0,0,0,0.08);}
.card-logo{width:50px;height:50px;border-radius:50%;object-fit:cover;border:2px solid var(--white);box-shadow:0 1px 6px rgba(0,0,0,0.08);}
.card-body{padding:32px 18px 12px;text-align:center;flex:1;display:flex;flex-direction:column;}
.card-name{font-size:14px;font-weight:600;color:var(--ink);line-height:1.35;margin-bottom:3px;}
.card-cat{font-size:11px;color:var(--ink-muted);margin-bottom:6px;}
.card-stars{display:flex;align-items:center;gap:4px;justify-content:center;margin-bottom:8px;}
.stars-filled{color:#f59e0b;font-size:12px;letter-spacing:1px;}
.stars-empty{color:#e5e7eb;font-size:12px;letter-spacing:1px;}
.rating-count{font-size:11px;color:var(--ink-faint);}
.card-desc{font-size:12px;color:var(--ink-muted);line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-top:auto;}
.card-foot{padding:11px 16px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;margin-top:12px;}
.card-location{font-size:12px;color:var(--ink-faint);display:flex;align-items:center;gap:4px;}
.card-visit{font-size:12px;font-weight:600;color:var(--blue);}

/* ── Empty ── */
.empty{text-align:center;padding:60px 20px;}
.empty-icon{font-size:48px;margin-bottom:16px;}
.empty h2{font-family:'DM Serif Display',serif;font-size:22px;font-weight:400;color:var(--ink);margin-bottom:8px;}
.empty p{font-size:14px;color:var(--ink-muted);margin-bottom:20px;}
.btn-primary{background:var(--blue);color:#fff;border:none;padding:11px 24px;border-radius:var(--radius-md);font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;display:inline-block;}

/* ── CTA ── */
.cta-band{background:var(--ink);padding:52px 40px;text-align:center;margin-top:64px;}
.cta-band h2{font-family:'DM Serif Display',serif;font-size:clamp(22px,3vw,32px);font-weight:400;color:#fff;letter-spacing:-0.5px;margin-bottom:10px;}
.cta-band h2 em{font-style:italic;color:#93c5fd;}
.cta-band p{font-size:15px;color:rgba(255,255,255,0.5);margin-bottom:28px;}
.btn-white{background:#fff;color:var(--ink);border:none;padding:13px 28px;border-radius:var(--radius-md);font-size:15px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;display:inline-block;transition:opacity 0.2s;}
.btn-white:hover{opacity:0.9;}

/* ── Footer ── */
footer{padding:28px 40px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--white);}
.footer-logo{font-family:'DM Serif Display',serif;font-size:18px;color:var(--ink);text-decoration:none;}
.footer-logo em{font-style:italic;color:var(--blue);}
.footer-copy{font-size:13px;color:var(--ink-faint);}

@media(max-width:768px){
  nav,footer{padding-left:20px;padding-right:20px;}
  .alias-hero{padding:36px 20px 32px;}
  .stats-strip{padding:12px 20px;}
  .page-wrap{padding:20px 16px 60px;}
  .cards-grid{grid-template-columns:repeat(2,1fr);}
  .cta-band{padding:40px 20px;}
}
</style>
</head>
<body>

<nav>
  <a class="logo" href="/">page<em>zaper</em></a>
  <div class="nav-right">
    {% if user %}<a href="/dashboard">Dashboard</a>{% else %}<a href="/register">Create site →</a>{% endif %}
  </div>
</nav>

<!-- Hero -->
<div class="alias-hero">
  <div class="breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb-sep">›</span>
    <a href="/{{ citySlug }}">{{ cityName }}</a>
    <span class="breadcrumb-sep">›</span>
    <span>{{ aliasKeyword }}</span>
  </div>
  <h1 class="alias-hero-title">{{ h1 | replace(cityName, '<em>' + cityName + '</em>') | safe }}</h1>
  <p class="alias-hero-sub">{{ metaDesc }}</p>
  <form class="alias-search-bar" action="/search" method="GET">
    <input type="hidden" name="city"        value="{{ cityName }}">
    <input type="hidden" name="category_id" value="{{ catId }}">
    <input class="alias-search-inp" type="text" name="q" placeholder="Search within {{ aliasKeyword }}…" autocomplete="off">
    <button class="alias-search-btn" type="submit">Search</button>
  </form>
</div>

<!-- Stats strip -->
<div class="stats-strip">
  <div class="stats-inner">
    <div class="stat-pill">📍 <strong>{{ cityName }}</strong></div>
    <span class="stat-sep">|</span>
    <div class="stat-pill">{{ catIcon }} <strong>{{ catName }}</strong></div>
    <span class="stat-sep">|</span>
    <div class="stat-pill"><strong>{{ results.length }}</strong> listed</div>
  </div>
</div>

<!-- Main content -->
<div class="page-wrap">

  <!-- Category filter pills — link to other aliases in same city -->
  <div class="filter-row">
    <a class="filter-pill active" href="/{{ citySlug }}/{{ aliasSlug }}">{{ aliasKeyword }}</a>
    {% for cat in categories %}
    <a class="filter-pill" href="/search?city={{ cityName | urlencode }}&category_id={{ cat.id }}">
      {{ cat.icon }} {{ cat.name }}
    </a>
    {% endfor %}
  </div>

  <!-- Results header -->
  <div class="section-hd">
    <h2>{{ h1 }}</h2>
    <span class="results-count"><strong>{{ results.length }}</strong> result{{ 's' if results.length != 1 }}</span>
  </div>

  <!-- Cards -->
  {% if results.length %}
  <div class="cards-grid">
    {% for site in results %}
    {% set ci = loop.index0 % 6 %}
    {% set bands    = ['#dbeafe','#d1fae5','#fef3c7','#fce7f3','#ede9fe','#ccfbf1'] %}
    {% set avatarbg = ['#bfdbfe','#a7f3d0','#fde68a','#fbcfe8','#ddd6fe','#99f6e4'] %}
    {% set logo = site.settings.logo or (site.settings.profile and site.settings.profile.avatar) %}
    <a class="provider-card" href="https://{{ site.subdomain }}.{{ base_domain }}" target="_blank">
      <div class="card-band" style="background:{{ bands[ci] }};">
        <div class="card-avatar-wrap">
          {% if logo %}
            <img class="card-logo" src="{{ logo }}" alt="{{ site.title }}"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="card-icon-wrap" style="background:{{ avatarbg[ci] }};display:none;">{{ site.cat_icon or site.title[0] | upper }}</div>
          {% else %}
            <div class="card-icon-wrap" style="background:{{ avatarbg[ci] }};">{{ site.cat_icon or site.title[0] | upper }}</div>
          {% endif %}
        </div>
      </div>
      <div class="card-body">
        <div class="card-name">{{ site.title }}</div>
        <div class="card-cat">{{ site.cat_name or catName }}</div>
        {% if site.avg_rating %}
        <div class="card-stars">
          <span class="stars-filled">{% for i in range(0, site.avg_rating | round) %}★{% endfor %}</span>
          <span class="stars-empty">{% for i in range(0, 5 - site.avg_rating | round) %}★{% endfor %}</span>
          <span class="rating-count">{{ site.avg_rating }} ({{ site.review_count }})</span>
        </div>
        {% endif %}
        <div class="card-desc">{{ site.settings.description or ('Visit ' + site.subdomain + '.' + base_domain) }}</div>
      </div>
      <div class="card-foot">
        <div class="card-location">
          <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {{ cityName }}
        </div>
        <span class="card-visit">Visit →</span>
      </div>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <div class="empty">
    <div class="empty-icon">{{ catIcon }}</div>
    <h2>No {{ aliasKeyword }} in {{ cityName }} yet</h2>
    <p>Be the first to list your {{ aliasKeyword | lower }} business here — it's free.</p>
    <a class="btn-primary" href="/register">Create your free page →</a>
  </div>
  {% endif %}

</div>

<!-- CTA -->
<div class="cta-band">
  <h2>Own a <em>{{ aliasKeyword | lower }}</em> in {{ cityName }}?</h2>
  <p>Create your free mini site and get found by customers searching right now.</p>
  {% if user %}
    <a class="btn-white" href="/dashboard">Go to dashboard →</a>
  {% else %}
    <a class="btn-white" href="/register">Create free site →</a>
  {% endif %}
</div>

<footer>
  <a class="footer-logo" href="/">page<em>zaper</em></a>
  <span class="footer-copy">© 2026 PageZaper</span>
</footer>

</body>
</html>

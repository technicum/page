{% extends "layouts/base.njk" %}
{% block head %}
<style>
*{box-sizing:border-box;}
body{font-family:"Inter",system-ui,sans-serif;background:#f7f7f8;margin:0;}
.dash-main{flex:1;display:flex;flex-direction:column;min-width:0;overflow:hidden;}

/* ── Topbar ── */
.topbar{height:56px;background:#fff;border-bottom:1px solid #e5e7eb;display:flex;align-items:center;padding:0 24px;gap:12px;position:sticky;top:0;z-index:100;flex-shrink:0;}
.topbar-title{font-size:15px;font-weight:700;color:#111827;flex:1;}
.btn-primary{display:inline-flex;align-items:center;gap:6px;background:#111827;color:#fff;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;border:none;cursor:pointer;font-family:inherit;transition:opacity .15s;}
.btn-primary:hover{opacity:.85;}
.btn-collections{display:inline-flex;align-items:center;gap:5px;background:#fff;color:#374151;padding:8px 14px;border-radius:8px;font-size:13px;font-weight:500;border:1.5px solid #e5e7eb;cursor:pointer;font-family:inherit;transition:all .15s;}
.btn-collections:hover{border-color:#6366f1;color:#6366f1;}

/* ── Page ── */
.page{max-width:960px;margin:0 auto;padding:32px 24px 60px;width:100%;}

/* ── Type tabs ── */
.type-tabs{display:flex;gap:6px;margin-bottom:16px;flex-wrap:wrap;}
.type-tab{padding:7px 16px;border-radius:20px;font-size:13px;font-weight:500;color:#6b7280;cursor:pointer;border:1.5px solid #e5e7eb;background:#fff;transition:all .15s;font-family:inherit;}
.type-tab:hover{border-color:#6366f1;color:#6366f1;}
.type-tab.active{background:#6366f1;color:#fff;border-color:#6366f1;}
.type-tab .count{display:inline-block;background:rgba(255,255,255,.25);padding:1px 7px;border-radius:20px;font-size:11px;margin-left:4px;}
.type-tab:not(.active) .count{background:#f3f4f6;color:#9ca3af;}

/* ── Collection chips ── */
.collection-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px;}
.col-chip{padding:5px 12px;border-radius:20px;font-size:12px;font-weight:500;color:#6b7280;cursor:pointer;border:1.5px solid #e5e7eb;background:#fff;transition:all .15s;font-family:inherit;}
.col-chip:hover{border-color:#6366f1;color:#6366f1;}
.col-chip.active{background:#f5f3ff;color:#6366f1;border-color:#c4b5fd;}

/* ── Product grid ── */
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:14px;}
.product-card{background:#fff;border:1px solid #e5e7eb;border-radius:14px;overflow:hidden;display:flex;flex-direction:column;transition:border-color .2s,box-shadow .2s;position:relative;}
.product-card:hover{border-color:#d1d5db;box-shadow:0 2px 12px rgba(0,0,0,.07);}
.product-card.inactive{opacity:.5;}

/* image — 4:3 ratio */
.pc-img{width:100%;aspect-ratio:4/3;background:#f3f4f6;display:flex;align-items:center;justify-content:center;font-size:42px;flex-shrink:0;overflow:hidden;position:relative;}
.pc-img img{width:100%;height:100%;object-fit:cover;}

/* type badge top-left */
.pc-type{position:absolute;top:9px;left:9px;font-size:10px;font-weight:600;padding:3px 9px;border-radius:20px;letter-spacing:.2px;}
.pc-type.physical{background:#fff7ed;color:#c2410c;}
.pc-type.digital{background:#eff6ff;color:#1d4ed8;}
.pc-type.service{background:#f0fdf4;color:#15803d;}
.pc-type.job{background:#faf5ff;color:#7c3aed;}

/* status dot top-right */
.pc-status{position:absolute;top:11px;right:11px;width:8px;height:8px;border-radius:50%;}
.pc-status.active{background:#22c55e;}
.pc-status.inactive{background:#d1d5db;}

.pc-body{padding:12px 14px 10px;flex:1;display:flex;flex-direction:column;gap:3px;}
.pc-name{font-size:13px;font-weight:600;color:#111827;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.pc-desc{font-size:11px;color:#9ca3af;line-height:1.45;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;}
.pc-collection{display:inline-flex;align-items:center;gap:3px;font-size:10px;color:#6366f1;background:#eef2ff;padding:2px 8px;border-radius:20px;margin-top:4px;align-self:flex-start;font-weight:500;}
.pc-price-row{display:flex;align-items:center;gap:7px;margin-top:8px;}
.pc-price{font-size:15px;font-weight:700;color:#111827;}
.pc-compare{font-size:11px;color:#9ca3af;text-decoration:line-through;}
.pc-duration{font-size:10px;color:#6b7280;background:#f3f4f6;padding:2px 7px;border-radius:10px;}
.pc-stock{font-size:10px;font-weight:600;color:#ef4444;margin-top:2px;}

/* job card specific */
.job-badge{display:inline-block;font-size:10px;font-weight:600;background:#f3e8ff;color:#7c3aed;padding:2px 8px;border-radius:10px;margin-top:3px;}
.pc-location{font-size:11px;color:#6b7280;margin-top:3px;}
.pc-apply-btn{display:inline-flex;align-items:center;gap:4px;padding:5px 12px;border:1.5px solid #6366f1;color:#6366f1;border-radius:20px;font-size:11px;font-weight:600;text-decoration:none;transition:all .15s;margin-top:8px;align-self:flex-start;}
.pc-apply-btn:hover{background:#6366f1;color:#fff;}

.pc-actions{display:flex;gap:6px;padding:10px 13px;border-top:1px solid #f3f4f6;}
.btn-edit-sm{flex:1;padding:6px 10px;background:#fff;color:#374151;border:1px solid #e5e7eb;border-radius:7px;font-size:12px;font-weight:500;cursor:pointer;font-family:inherit;transition:background .15s;}
.btn-edit-sm:hover{background:#f9fafb;}
.btn-del-sm{width:30px;height:30px;border:1px solid #e5e7eb;background:#fff;color:#9ca3af;border-radius:7px;font-size:14px;cursor:pointer;font-family:inherit;transition:all .15s;display:flex;align-items:center;justify-content:center;}
.btn-del-sm:hover{border-color:#fca5a5;color:#ef4444;background:#fef2f2;}

/* ── Collections modal ── */
.col-mgr-list{list-style:none;margin:0;padding:0;}
.col-mgr-item{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f3f4f6;}
.col-mgr-item:last-child{border-bottom:none;}
.col-mgr-name{font-size:13px;font-weight:500;color:#111827;}
.col-mgr-count{font-size:11px;color:#9ca3af;margin-left:6px;}
.col-mgr-del{border:none;background:none;color:#9ca3af;cursor:pointer;font-size:14px;padding:2px 6px;border-radius:4px;transition:all .15s;}
.col-mgr-del:hover{color:#ef4444;background:#fef2f2;}
.col-add-row{display:flex;gap:8px;margin-top:16px;}
.col-add-row input{flex:1;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:13px;font-family:inherit;outline:none;transition:border-color .15s;}
.col-add-row input:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.08);}
.col-add-btn{padding:9px 16px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;white-space:nowrap;transition:opacity .15s;}
.col-add-btn:hover{opacity:.85;}

/* ── Empty state ── */
.empty-state{text-align:center;padding:80px 32px;background:#fff;border:2px dashed #e5e7eb;border-radius:16px;margin-top:4px;}
.empty-icon{font-size:52px;margin-bottom:16px;}
.empty-state h3{font-size:18px;font-weight:700;color:#111827;margin-bottom:8px;}
.empty-state p{font-size:14px;color:#9ca3af;margin-bottom:24px;max-width:360px;margin-left:auto;margin-right:auto;}

/* ── Modal ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:900;backdrop-filter:blur(2px);}
.modal-overlay.open{display:flex;align-items:center;justify-content:center;}
.modal-box{background:#fff;border-radius:16px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 64px rgba(0,0,0,.2);margin:16px;}
.modal-head{display:flex;align-items:center;justify-content:space-between;padding:20px 22px 16px;border-bottom:1px solid #f0f0f3;position:sticky;top:0;background:#fff;z-index:1;}
.modal-title{font-size:16px;font-weight:700;color:#111827;}
.modal-close{border:none;background:none;font-size:20px;cursor:pointer;color:#9ca3af;line-height:1;padding:0 4px;}
.modal-close:hover{color:#374151;}
.modal-body{padding:22px;}
.modal-foot{padding:14px 22px;border-top:1px solid #f0f0f3;display:flex;align-items:center;justify-content:flex-end;gap:10px;position:sticky;bottom:0;background:#fff;}
.modal-msg{font-size:12px;margin-right:auto;}
.modal-msg.ok{color:#16a34a;}
.modal-msg.err{color:#ef4444;}

/* type selector */
.type-selector{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:16px;}
.type-opt{border:2px solid #e5e7eb;border-radius:10px;padding:12px 10px;text-align:center;cursor:pointer;transition:all .15s;}
.type-opt:hover{border-color:#6366f1;}
.type-opt.selected{border-color:#6366f1;background:#eef2ff;}
.type-opt-icon{font-size:20px;margin-bottom:4px;}
.type-opt-label{font-size:12px;font-weight:600;color:#374151;}
.type-opt-sub{font-size:10px;color:#9ca3af;margin-top:2px;}

/* form fields */
.field{margin-bottom:14px;}
.field label{display:block;font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px;}
.field input,.field select,.field textarea{width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:13px;font-family:inherit;color:#111827;outline:none;transition:border-color .15s;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.08);}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.field-hint{font-size:11px;color:#9ca3af;margin-top:4px;}

.conditional{display:none;}
.conditional.show{display:block;}

/* image upload */
.img-upload-wrap{width:100%;height:140px;border:2px dashed #e5e7eb;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:border-color .15s,background .15s;overflow:hidden;position:relative;}
.img-upload-wrap:hover{border-color:#6366f1;background:#f5f3ff;}
.img-upload-wrap.has-img{border-style:solid;border-color:#e5e7eb;}

.btn-save{background:#111827;color:#fff;border:none;padding:10px 24px;border-radius:8px;font-size:13px;font-weight:600;font-family:inherit;cursor:pointer;transition:opacity .2s;}
.btn-save:hover{opacity:.85;}
.btn-save:disabled{opacity:.5;cursor:not-allowed;}
.btn-cancel{background:none;border:1.5px solid #e5e7eb;color:#6b7280;padding:10px 18px;border-radius:8px;font-size:13px;font-family:inherit;cursor:pointer;}
.btn-cancel:hover{border-color:#374151;color:#374151;}

@media(max-width:640px){
  .product-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));}
  .field-row{grid-template-columns:1fr;}
  .type-selector{grid-template-columns:1fr 1fr;}
  .page{padding:20px 14px 50px;}
}
</style>
{% endblock %}

{% block body %}
<div class="layout">
  {% include "dashboard/_sidebar.njk" %}

  <div class="dash-main">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-title">Products</div>
      <button class="btn-collections" onclick="openCollectionsModal()" title="Manage Collections">🗂 Collections</button>
      <button class="btn-primary" onclick="openAddModal()">+ Add</button>
    </div>

    <div class="page">

      <!-- Type tabs -->
      <div class="type-tabs">
        <button class="type-tab active" data-filter="all" onclick="filterType('all',this)">
          All <span class="count" id="cnt-all">{{ products.length }}</span>
        </button>
        <button class="type-tab" data-filter="physical" onclick="filterType('physical',this)">
          📦 Physical <span class="count" id="cnt-physical">0</span>
        </button>
        <button class="type-tab" data-filter="digital" onclick="filterType('digital',this)">
          💾 Digital <span class="count" id="cnt-digital">0</span>
        </button>
        <button class="type-tab" data-filter="service" onclick="filterType('service',this)">
          🛠 Service <span class="count" id="cnt-service">0</span>
        </button>
        <button class="type-tab" data-filter="job" onclick="filterType('job',this)">
          💼 Jobs <span class="count" id="cnt-job">0</span>
        </button>
      </div>

      <!-- Collection filter chips (shown for non-job tabs) -->
      <div class="collection-tabs" id="collection-tabs" style="display:none;"></div>

      <!-- Product grid -->
      {% if products.length %}
      <div class="product-grid" id="product-grid">
        {% for p in products %}
        <div class="product-card {% if not p.status %}inactive{% endif %}" data-type="{{ p.type }}" data-id="{{ p.id }}">

          {% if p.type == 'job' %}
          <!-- ── Job card ── -->
          <div class="pc-img" style="background:#faf5ff;">
            {% if p.image_url %}
            <img src="{{ p.image_url }}" alt="{{ p.name }}" onerror="this.style.display='none';this.parentNode.innerHTML='💼'">
            {% else %}💼{% endif %}
            <span class="pc-type job">Job</span>
            <span class="pc-status {{ 'active' if p.status else 'inactive' }}"></span>
          </div>
          <div class="pc-body">
            <div class="pc-name">{{ p.name }}</div>
            {% if p.duration %}<span class="job-badge">{{ p.duration }}</span>{% endif %}
            {% if p.collection %}<div class="pc-location">📍 {{ p.collection }}</div>{% endif %}
            {% if p.description %}<div class="pc-desc">{{ p.description | truncate(80) }}</div>{% endif %}
            {% if p.file_url %}<a href="{{ p.file_url }}" target="_blank" class="pc-apply-btn">Apply →</a>{% endif %}
          </div>

          {% else %}
          <!-- ── Product card ── -->
          {% set _bg = '#fff7ed' if p.type=='physical' else ('#eff6ff' if p.type=='digital' else '#f0fdf4') %}
          {% set _em = '📦' if p.type=='physical' else ('💾' if p.type=='digital' else '🛠') %}
          <div class="pc-img" style="background:{{ _bg }};">
            {% if p.image_url %}
            <img src="{{ p.image_url }}" alt="{{ p.name }}" onerror="this.style.display='none';this.parentNode.innerHTML='{{ _em }}'">
            {% else %}{{ _em }}{% endif %}
            <span class="pc-type {{ p.type }}">{{ 'Physical' if p.type=='physical' else ('Digital' if p.type=='digital' else 'Service') }}</span>
            <span class="pc-status {{ 'active' if p.status else 'inactive' }}"></span>
          </div>
          <div class="pc-body">
            <div class="pc-name">{{ p.name }}</div>
            {% if p.description %}<div class="pc-desc">{{ p.description | truncate(80) }}</div>{% endif %}
            {% if p.collection %}<span class="pc-collection">{{ p.collection }}</span>{% endif %}
            <div class="pc-price-row">
              {% if p.price %}
              <span class="pc-price">₹{{ p.price | int }}</span>
              {% if p.compare_price and p.compare_price > p.price %}<span class="pc-compare">₹{{ p.compare_price | int }}</span>{% endif %}
              {% else %}
              <span class="pc-price" style="color:#d1d5db;font-weight:400;font-size:13px;">No price</span>
              {% endif %}
              {% if p.duration %}<span class="pc-duration">{{ p.duration }}</span>{% endif %}
            </div>
            {% if p.type == 'physical' and not p.in_stock %}<div class="pc-stock">Out of stock</div>{% endif %}
          </div>
          {% endif %}

          <div class="pc-actions">
            <button class="btn-edit-sm" onclick="openEditModal({{ p.id }})">Edit</button>
            <button class="btn-del-sm" onclick="deleteProduct({{ p.id }}, this)" title="Delete">🗑</button>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="empty-state" id="empty-state">
        <div class="empty-icon">📦</div>
        <h3>Nothing here yet</h3>
        <p>Add physical products, digital downloads, services, or job listings.</p>
        <button class="btn-primary" onclick="openAddModal()">+ Add your first item</button>
      </div>
      {% endif %}

    </div>{# end .page #}
  </div>{# end .dash-main #}
</div>{# end .layout #}

<!-- ── Add / Edit Modal ── -->
<div class="modal-overlay" id="product-modal">
  <div class="modal-box">
    <div class="modal-head">
      <div class="modal-title" id="modal-title-text">Add product</div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="p-id">

      <!-- Type selector -->
      <div id="type-selector-wrap">
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Type</div>
        <div class="type-selector">
          <div class="type-opt selected" data-type="physical" onclick="selectType('physical')">
            <div class="type-opt-icon">📦</div>
            <div class="type-opt-label">Physical</div>
            <div class="type-opt-sub">Ships to customer</div>
          </div>
          <div class="type-opt" data-type="digital" onclick="selectType('digital')">
            <div class="type-opt-icon">💾</div>
            <div class="type-opt-label">Digital</div>
            <div class="type-opt-sub">PDF, course, file</div>
          </div>
          <div class="type-opt" data-type="service" onclick="selectType('service')">
            <div class="type-opt-icon">🛠</div>
            <div class="type-opt-label">Service</div>
            <div class="type-opt-sub">Consultation, work</div>
          </div>
          <div class="type-opt" data-type="job" onclick="selectType('job')">
            <div class="type-opt-icon">💼</div>
            <div class="type-opt-label">Job</div>
            <div class="type-opt-sub">Hiring listing</div>
          </div>
        </div>
      </div>
      <input type="hidden" id="p-type" value="physical">

      <!-- Name -->
      <div class="field">
        <label id="p-name-label">Name *</label>
        <input type="text" id="p-name" placeholder="e.g. Handmade Candle Set">
      </div>

      <!-- Description -->
      <div class="field">
        <label id="p-desc-label">Description</label>
        <textarea id="p-description" rows="2" placeholder="Short description..." style="resize:vertical;"></textarea>
      </div>

      <!-- Price row (hidden for jobs) -->
      <div class="field-row" id="price-row-wrap">
        <div class="field">
          <label>Price (₹)</label>
          <input type="number" id="p-price" placeholder="499" min="0" step="0.01">
        </div>
        <div class="field">
          <label>Compare at price (₹)</label>
          <input type="number" id="p-compare" placeholder="999 (crossed out)" min="0" step="0.01">
        </div>
      </div>

      <!-- Image upload -->
      <div class="field">
        <label id="p-image-label">Product Image</label>
        <div class="img-upload-wrap" id="img-upload-wrap" onclick="document.getElementById('p-img-file').click()">
          <img id="p-img-preview" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:8px;">
          <div id="p-img-placeholder">
            <div style="font-size:28px;margin-bottom:6px;">📷</div>
            <div style="font-size:12px;color:#9ca3af;">Click to upload image</div>
          </div>
        </div>
        <input type="file" id="p-img-file" accept="image/*" style="display:none;" onchange="uploadProductImage(this)">
        <input type="hidden" id="p-image" value="">
        <div id="p-img-status" style="font-size:11px;color:#9ca3af;margin-top:4px;display:none;"></div>
      </div>

      <!-- Digital only: file URL -->
      <div class="field conditional" id="field-file">
        <label>Download link / File URL</label>
        <input type="url" id="p-file" placeholder="https://example.com/product.pdf">
        <div class="field-hint">Customers receive this link after purchase.</div>
      </div>

      <!-- Service only: duration -->
      <div class="field conditional" id="field-duration">
        <label>Duration</label>
        <input type="text" id="p-duration" placeholder="e.g. 1 hour, 30 min">
      </div>

      <!-- Physical only: stock -->
      <div class="field conditional" id="field-stock">
        <label style="display:flex;align-items:center;gap:8px;text-transform:none;letter-spacing:0;font-weight:500;font-size:13px;color:#374151;cursor:pointer;">
          <input type="checkbox" id="p-in-stock" checked style="width:auto;accent-color:#6366f1;">
          In stock
        </label>
      </div>

      <!-- Job only: job type -->
      <div class="field conditional" id="field-jobtype">
        <label>Job Type</label>
        <select id="p-jobtype">
          <option value="">Select type...</option>
          <option value="Full-time">Full-time</option>
          <option value="Part-time">Part-time</option>
          <option value="Remote">Remote</option>
          <option value="Contract">Contract</option>
          <option value="Internship">Internship</option>
        </select>
      </div>

      <!-- Job only: location -->
      <div class="field conditional" id="field-location">
        <label>Location</label>
        <input type="text" id="p-location" placeholder="e.g. Mumbai, Bangalore, Remote">
      </div>

      <!-- Job only: apply URL -->
      <div class="field conditional" id="field-apply">
        <label>Apply URL</label>
        <input type="url" id="p-apply" placeholder="https://forms.google.com/... or mailto:hr@company.com">
        <div class="field-hint">Link or email where candidates can apply.</div>
      </div>

      <!-- Collection (hidden for jobs — location used instead) -->
      <div class="field" id="field-collection">
        <label style="display:flex;align-items:center;justify-content:space-between;">
          <span>Collection</span>
          <button type="button" onclick="openCollectionsModal()" style="background:none;border:none;font-size:11px;color:#6366f1;cursor:pointer;font-family:inherit;font-weight:600;padding:0;">+ Manage</button>
        </label>
        <select id="p-collection">
          <option value="">— No collection —</option>
        </select>
      </div>

      <!-- Status -->
      <div class="field conditional show" id="field-status">
        <label style="display:flex;align-items:center;gap:8px;text-transform:none;letter-spacing:0;font-weight:500;font-size:13px;color:#374151;cursor:pointer;">
          <input type="checkbox" id="p-status" checked style="width:auto;accent-color:#6366f1;">
          Active (visible)
        </label>
      </div>
    </div>
    <div class="modal-foot">
      <span class="modal-msg" id="modal-msg"></span>
      <button class="btn-cancel" onclick="closeModal()">Cancel</button>
      <button class="btn-save" id="modal-save-btn" onclick="saveProduct()">Add product</button>
    </div>
  </div>
</div>

<!-- ── Collections Modal ── -->
<div class="modal-overlay" id="collections-modal">
  <div class="modal-box" style="max-width:420px;">
    <div class="modal-head">
      <div class="modal-title">Manage Collections</div>
      <button class="modal-close" onclick="closeCollectionsModal()">✕</button>
    </div>
    <div class="modal-body" style="padding-bottom:8px;">
      <p style="font-size:13px;color:#6b7280;margin:0 0 16px;">Collections help you group products. Pick a collection when adding a product.</p>

      <!-- Add new collection -->
      <div class="col-add-row">
        <input type="text" id="col-new-name" placeholder="Collection name, e.g. Skincare" maxlength="100"
               onkeydown="if(event.key==='Enter') addCollection()">
        <button class="col-add-btn" onclick="addCollection()">Add</button>
      </div>
      <div id="col-add-msg" style="font-size:11px;margin-top:6px;min-height:16px;"></div>

      <!-- Existing list -->
      <div style="margin-top:16px;">
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">Your collections</div>
        <ul class="col-mgr-list" id="col-mgr-list">
          <li style="font-size:13px;color:#9ca3af;padding:10px 0;" id="col-empty-msg">No collections yet.</li>
        </ul>
      </div>
    </div>
    <div class="modal-foot" style="justify-content:flex-end;">
      <button class="btn-cancel" onclick="closeCollectionsModal()">Done</button>
    </div>
  </div>
</div>

<script type="application/json" id="pz-collections-json">{{ collections | dump | safe }}</script>
<script type="application/json" id="pz-products-json">{{ products | dump | safe }}</script>
<script>
var ALL_PRODUCTS   = JSON.parse(document.getElementById('pz-products-json').textContent || '[]');
var ALL_COLLECTIONS = JSON.parse(document.getElementById('pz-collections-json').textContent || '[]');
var editingId = null;
var currentType = 'physical';
var activeFilter = 'all';
var activeCollection = 'all';

document.addEventListener('DOMContentLoaded', function(){
  updateCounts();
  buildCollectionChips('all');
  rebuildCollectionSelect();
  renderCollectionsList();
  // Auto-filter by collection if ?collection= param present
  var urlCol = new URLSearchParams(window.location.search).get('collection');
  if (urlCol) {
    setTimeout(function(){
      buildCollectionChips('all');
      var chips = document.querySelectorAll('.col-chip');
      chips.forEach(function(chip){
        if (chip.textContent.trim() === urlCol) chip.click();
      });
    }, 50);
  }
});

/* ── Type filter ── */
function filterType(type, btn) {
  activeFilter = type;
  activeCollection = 'all';
  document.querySelectorAll('.type-tab').forEach(function(t){ t.classList.remove('active'); });
  btn.classList.add('active');
  document.querySelectorAll('.product-card').forEach(function(card){
    card.style.display = (type === 'all' || card.dataset.type === type) ? '' : 'none';
  });
  buildCollectionChips(type);
  checkEmpty();
}

/* ── Collection chips ── */
function buildCollectionChips(typeFilter) {
  var container = document.getElementById('collection-tabs');
  // Don't show chips for job tab or if no non-job products
  if (typeFilter === 'job') { container.style.display = 'none'; return; }
  var cols = new Set();
  ALL_PRODUCTS.forEach(function(p) {
    if ((typeFilter === 'all' || p.type === typeFilter) && p.type !== 'job' && p.collection && p.collection.trim()) {
      cols.add(p.collection.trim());
    }
  });
  if (cols.size === 0) { container.style.display = 'none'; return; }
  container.innerHTML = '';
  container.style.display = 'flex';
  var allChip = document.createElement('button');
  allChip.className = 'col-chip active';
  allChip.textContent = 'All collections';
  allChip.onclick = function() { filterCollection('all', this); };
  container.appendChild(allChip);
  cols.forEach(function(col) {
    var chip = document.createElement('button');
    chip.className = 'col-chip';
    chip.textContent = col;
    chip.onclick = function() { filterCollection(col, this); };
    container.appendChild(chip);
  });
}

function filterCollection(col, btn) {
  activeCollection = col;
  document.querySelectorAll('.col-chip').forEach(function(c){ c.classList.remove('active'); });
  btn.classList.add('active');
  document.querySelectorAll('.product-card').forEach(function(card){
    if (card.dataset.type === 'job') return; // never filter jobs by collection
    var hidden = (activeFilter !== 'all' && card.dataset.type !== activeFilter);
    if (hidden) { card.style.display = 'none'; return; }
    if (col === 'all') { card.style.display = ''; return; }
    var p = ALL_PRODUCTS.find(function(x){ return String(x.id) === String(card.dataset.id); });
    card.style.display = (p && p.collection && p.collection.trim() === col) ? '' : 'none';
  });
  checkEmpty();
}

function checkEmpty() {
  var emptyState = document.getElementById('empty-state');
  if (!emptyState) return;
  var shown = 0;
  document.querySelectorAll('.product-card').forEach(function(c){ if(c.style.display !== 'none') shown++; });
  emptyState.style.display = shown === 0 ? 'block' : 'none';
}

/* ── Type select in modal ── */
function selectType(type) {
  currentType = type;
  document.getElementById('p-type').value = type;
  document.querySelectorAll('.type-opt').forEach(function(o){ o.classList.toggle('selected', o.dataset.type === type); });

  var isJob = type === 'job';

  // product-type conditionals
  document.getElementById('field-file').classList.toggle('show', type === 'digital');
  document.getElementById('field-duration').classList.toggle('show', type === 'service');
  document.getElementById('field-stock').classList.toggle('show', type === 'physical');

  // job-type conditionals
  document.getElementById('field-jobtype').classList.toggle('show', isJob);
  document.getElementById('field-location').classList.toggle('show', isJob);
  document.getElementById('field-apply').classList.toggle('show', isJob);

  // shared fields: hide for job
  document.getElementById('field-collection').style.display = isJob ? 'none' : '';
  document.getElementById('price-row-wrap').style.display = isJob ? 'none' : '';

  // dynamic labels
  document.getElementById('p-name-label').textContent = isJob ? 'Job Title *' : 'Name *';
  document.getElementById('p-desc-label').textContent = isJob ? 'Job Description / Requirements' : 'Description';
  document.getElementById('p-image-label').textContent = isJob ? 'Company Logo (optional)' : 'Product Image';
  document.getElementById('p-name').placeholder = isJob ? 'e.g. Sales Manager' : 'e.g. Handmade Candle Set';
  document.getElementById('p-description').placeholder = isJob ? 'What we\'re looking for...' : 'Short description...';
}

/* ── Open add modal ── */
function openAddModal() {
  editingId = null;
  document.getElementById('modal-title-text').textContent = 'Add item';
  document.getElementById('modal-save-btn').textContent = 'Add';
  document.getElementById('type-selector-wrap').style.display = '';
  clearForm();
  // Pre-select type based on active tab
  var preType = (activeFilter === 'all' || !activeFilter) ? 'physical' : activeFilter;
  selectType(preType);
  document.getElementById('field-status').classList.remove('show');
  document.getElementById('modal-msg').textContent = '';
  document.getElementById('product-modal').classList.add('open');
  setTimeout(function(){ document.getElementById('p-name').focus(); }, 80);
}

/* ── Open edit modal ── */
function openEditModal(id) {
  var p = ALL_PRODUCTS.find(function(x){ return x.id === id; });
  if (!p) return;
  editingId = id;
  var isJob = p.type === 'job';
  document.getElementById('modal-title-text').textContent = isJob ? 'Edit job' : 'Edit product';
  document.getElementById('modal-save-btn').textContent = 'Save changes';
  document.getElementById('type-selector-wrap').style.display = 'none';
  document.getElementById('p-type').value = p.type;
  document.getElementById('p-id').value = p.id;
  document.getElementById('p-name').value = p.name || '';
  document.getElementById('p-description').value = p.description || '';

  // Set labels
  document.getElementById('p-name-label').textContent = isJob ? 'Job Title *' : 'Name *';
  document.getElementById('p-desc-label').textContent = isJob ? 'Job Description / Requirements' : 'Description';
  document.getElementById('p-image-label').textContent = isJob ? 'Company Logo (optional)' : 'Product Image';

  // Show/hide sections
  document.getElementById('price-row-wrap').style.display = isJob ? 'none' : '';
  document.getElementById('field-collection').style.display = isJob ? 'none' : '';
  document.getElementById('field-file').classList.toggle('show', p.type === 'digital');
  document.getElementById('field-duration').classList.toggle('show', p.type === 'service');
  document.getElementById('field-stock').classList.toggle('show', p.type === 'physical');
  document.getElementById('field-jobtype').classList.toggle('show', isJob);
  document.getElementById('field-location').classList.toggle('show', isJob);
  document.getElementById('field-apply').classList.toggle('show', isJob);

  if (isJob) {
    document.getElementById('p-jobtype').value = p.duration || '';
    document.getElementById('p-location').value = p.collection || '';
    document.getElementById('p-apply').value = p.file_url || '';
  } else {
    document.getElementById('p-price').value = p.price || '';
    document.getElementById('p-compare').value = p.compare_price || '';
    document.getElementById('p-file').value = p.file_url || '';
    document.getElementById('p-duration').value = p.duration || '';
    document.getElementById('p-collection').value = p.collection || '';
  }

  setImagePreview(p.image_url || '');
  document.getElementById('p-in-stock').checked = p.in_stock != '0';
  document.getElementById('p-status').checked = p.status != '0';
  document.getElementById('field-status').classList.add('show');
  document.getElementById('modal-msg').textContent = '';
  document.getElementById('product-modal').classList.add('open');
}

function closeModal(){ document.getElementById('product-modal').classList.remove('open'); }
document.getElementById('product-modal').addEventListener('click', function(e){ if(e.target===this) closeModal(); });

function clearForm(){
  ['p-id','p-name','p-description','p-price','p-compare','p-image','p-file','p-duration','p-collection','p-apply','p-location'].forEach(function(id){
    document.getElementById(id).value = '';
  });
  document.getElementById('p-jobtype').value = '';
  document.getElementById('p-in-stock').checked = true;
  document.getElementById('p-status').checked = true;
  setImagePreview('');
}

function setImagePreview(url) {
  var preview = document.getElementById('p-img-preview');
  var placeholder = document.getElementById('p-img-placeholder');
  var wrap = document.getElementById('img-upload-wrap');
  document.getElementById('p-image').value = url;
  if (url) {
    preview.src = url;
    preview.style.display = 'block';
    placeholder.style.display = 'none';
    wrap.classList.add('has-img');
  } else {
    preview.src = '';
    preview.style.display = 'none';
    placeholder.style.display = 'flex';
    placeholder.style.flexDirection = 'column';
    placeholder.style.alignItems = 'center';
    wrap.classList.remove('has-img');
  }
  document.getElementById('p-img-file').value = '';
}

function uploadProductImage(input) {
  if (!input.files || !input.files[0]) return;
  var status = document.getElementById('p-img-status');
  status.textContent = 'Uploading…'; status.style.display = 'block'; status.style.color = '#9ca3af';
  var fd = new FormData();
  fd.append('image', input.files[0]);
  fetch('/dashboard/products/upload-image', { method: 'POST', body: fd })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (!d.ok) { status.textContent = d.error || 'Upload failed'; status.style.color = '#ef4444'; return; }
      setImagePreview(d.url);
      status.textContent = '✓ Uploaded'; status.style.color = '#16a34a';
      setTimeout(function(){ status.style.display = 'none'; }, 2000);
    })
    .catch(function(){ status.textContent = 'Upload failed'; status.style.color = '#ef4444'; });
}

/* ── Save ── */
function saveProduct() {
  var btn = document.getElementById('modal-save-btn');
  var msg = document.getElementById('modal-msg');
  var name = document.getElementById('p-name').value.trim();
  if (!name) { msg.textContent = 'Title / name is required.'; msg.className = 'modal-msg err'; return; }

  btn.disabled = true;
  btn.textContent = 'Saving…';
  msg.textContent = '';

  var url = editingId ? '/dashboard/products/update' : '/dashboard/products/create';
  var type = document.getElementById('p-type').value;
  var isJob = type === 'job';

  var payload = {
    id: editingId || undefined,
    type: type,
    name: name,
    description: document.getElementById('p-description').value,
    image_url: document.getElementById('p-image').value,
    status: document.getElementById('p-status').checked ? '1' : '0'
  };

  if (isJob) {
    payload.duration   = document.getElementById('p-jobtype').value;
    payload.collection = document.getElementById('p-location').value;
    payload.file_url   = document.getElementById('p-apply').value;
    payload.price      = '';
    payload.compare_price = '';
    payload.in_stock   = '1';
  } else {
    payload.price        = document.getElementById('p-price').value;
    payload.compare_price = document.getElementById('p-compare').value;
    payload.file_url     = document.getElementById('p-file').value;
    payload.duration     = document.getElementById('p-duration').value;
    payload.collection   = document.getElementById('p-collection').value;
    payload.in_stock     = document.getElementById('p-in-stock').checked ? '1' : '0';
  }

  fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    btn.disabled = false;
    btn.textContent = editingId ? 'Save changes' : 'Add';
    if (!d.ok) { msg.textContent = d.error || 'Error saving.'; msg.className = 'modal-msg err'; return; }
    window.location.reload();
  })
  .catch(function(){
    btn.disabled = false;
    btn.textContent = editingId ? 'Save changes' : 'Add';
    msg.textContent = 'Network error.'; msg.className = 'modal-msg err';
  });
}

/* ── Delete ── */
function deleteProduct(id, btn) {
  if (!confirm('Delete this item?')) return;
  btn.textContent = '…'; btn.disabled = true;
  fetch('/dashboard/products/delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: id })
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (!d.ok) { btn.textContent = '🗑'; btn.disabled = false; alert(d.error || 'Could not delete.'); return; }
    var card = document.querySelector('.product-card[data-id="' + id + '"]');
    if (card) card.remove();
    ALL_PRODUCTS = ALL_PRODUCTS.filter(function(p){ return p.id !== id; });
    updateCounts();
    buildCollectionChips(activeFilter);
    checkEmpty();
  })
  .catch(function(){ btn.textContent = '🗑'; btn.disabled = false; });
}

/* ── Collections: rebuild select in product modal ── */
function rebuildCollectionSelect() {
  var sel = document.getElementById('p-collection');
  var prev = sel.value;
  sel.innerHTML = '<option value="">— No collection —</option>';
  ALL_COLLECTIONS.forEach(function(c) {
    var opt = document.createElement('option');
    opt.value = c.name;
    opt.textContent = c.name;
    sel.appendChild(opt);
  });
  // Restore previously selected value if still exists
  if (prev) sel.value = prev;
}

/* ── Collections modal ── */
function openCollectionsModal() {
  renderCollectionsList();
  document.getElementById('col-new-name').value = '';
  document.getElementById('col-add-msg').textContent = '';
  document.getElementById('collections-modal').classList.add('open');
  setTimeout(function(){ document.getElementById('col-new-name').focus(); }, 80);
}
function closeCollectionsModal() {
  document.getElementById('collections-modal').classList.remove('open');
}
document.getElementById('collections-modal').addEventListener('click', function(e){ if(e.target===this) closeCollectionsModal(); });

function renderCollectionsList() {
  var list = document.getElementById('col-mgr-list');
  var emptyMsg = document.getElementById('col-empty-msg');
  list.innerHTML = '';
  if (ALL_COLLECTIONS.length === 0) {
    list.innerHTML = '<li style="font-size:13px;color:#9ca3af;padding:10px 0;">No collections yet.</li>';
    return;
  }
  ALL_COLLECTIONS.forEach(function(c) {
    var li = document.createElement('li');
    li.className = 'col-mgr-item';
    // count how many products use this collection
    var count = ALL_PRODUCTS.filter(function(p){ return p.collection === c.name; }).length;
    li.innerHTML = '<span class="col-mgr-name">' + c.name + ' <span class="col-mgr-count">(' + count + ' product' + (count===1?'':'s') + ')</span></span>' +
      '<button class="col-mgr-del" onclick="removeCollection(' + c.id + ',this)" title="Delete">✕</button>';
    list.appendChild(li);
  });
}

function addCollection() {
  var input = document.getElementById('col-new-name');
  var msg   = document.getElementById('col-add-msg');
  var name  = input.value.trim();
  if (!name) { msg.style.color='#ef4444'; msg.textContent='Enter a name.'; return; }
  if (ALL_COLLECTIONS.some(function(c){ return c.name.toLowerCase()===name.toLowerCase(); })) {
    msg.style.color='#ef4444'; msg.textContent='That collection already exists.'; return;
  }
  msg.style.color='#9ca3af'; msg.textContent='Adding…';
  fetch('/dashboard/products/collections/create', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({name: name})
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (!d.ok) { msg.style.color='#ef4444'; msg.textContent=d.error||'Error'; return; }
    ALL_COLLECTIONS.push(d.collection);
    input.value = '';
    msg.style.color='#16a34a'; msg.textContent='✓ Collection added';
    setTimeout(function(){ msg.textContent=''; }, 2000);
    renderCollectionsList();
    rebuildCollectionSelect();
    buildCollectionChips(activeFilter);
  })
  .catch(function(){ msg.style.color='#ef4444'; msg.textContent='Network error'; });
}

function removeCollection(id, btn) {
  if (!confirm('Delete this collection? Products using it will lose their collection tag.')) return;
  btn.textContent='…'; btn.disabled=true;
  fetch('/dashboard/products/collections/delete', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({id: id})
  })
  .then(function(r){ return r.json(); })
  .then(function(d){
    if (!d.ok) { btn.textContent='✕'; btn.disabled=false; alert(d.error||'Error'); return; }
    ALL_COLLECTIONS = ALL_COLLECTIONS.filter(function(c){ return c.id !== id; });
    renderCollectionsList();
    rebuildCollectionSelect();
    buildCollectionChips(activeFilter);
  })
  .catch(function(){ btn.textContent='✕'; btn.disabled=false; });
}

/* ── Update counts ── */
function updateCounts() {
  var types = ['physical','digital','service','job'];
  document.getElementById('cnt-all').textContent = document.querySelectorAll('.product-card').length;
  types.forEach(function(t){
    var el = document.getElementById('cnt-' + t);
    if (el) el.textContent = document.querySelectorAll('.product-card[data-type="' + t + '"]').length;
  });
}
</script>
{% endblock %}

{% extends "layouts/base.njk" %}
{% block head %}
<style>
*{box-sizing:border-box;}
body{font-family:"Inter",system-ui,sans-serif;background:#f7f7f8;margin:0;}
.dash-main{flex:1;display:flex;flex-direction:column;min-width:0;}
.topbar{height:56px;background:#fff;border-bottom:1px solid #e5e7eb;display:flex;align-items:center;padding:0 24px;gap:12px;position:sticky;top:0;z-index:100;flex-shrink:0;}
.topbar-title{font-size:15px;font-weight:700;color:#111827;flex:1;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;transition:all .15s;border:none;cursor:pointer;font-family:inherit;}
.btn-dark{background:#111827;color:#fff;}.btn-dark:hover{background:#374151;}
.btn-outline{background:#fff;color:#374151;border:1.5px solid #e5e7eb;}.btn-outline:hover{border-color:#6366f1;color:#6366f1;}
.btn-red{background:#fee2e2;color:#ef4444;border:none;}.btn-red:hover{background:#fecaca;}
.page{max-width:900px;margin:0 auto;padding:32px 24px 60px;width:100%;}
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;}
.page-title{font-size:22px;font-weight:700;color:#111827;}
.page-sub{font-size:13px;color:#9ca3af;margin-top:2px;}

/* ── Website cards ─── */
.site-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;}
.site-card{background:#fff;border:1.5px solid #e5e7eb;border-radius:16px;overflow:hidden;transition:box-shadow .15s,border-color .15s;}
.site-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.08);border-color:#c7d2fe;}
.site-thumb{height:140px;background:linear-gradient(135deg,#6366f1 0%,#8b5cf6 100%);display:flex;align-items:center;justify-content:center;font-size:40px;position:relative;}
.site-pub-badge{position:absolute;top:10px;right:10px;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;letter-spacing:.3px;}
.site-pub-badge.live{background:#dcfce7;color:#16a34a;}
.site-pub-badge.draft{background:#f3f4f6;color:#6b7280;}
.site-info{padding:16px;}
.site-name{font-size:15px;font-weight:700;color:#111827;margin:0 0 4px;}
.site-url{font-size:12px;color:#9ca3af;margin:0 0 12px;}
.site-actions{display:flex;gap:8px;}

/* ── Empty state ─── */
.empty{text-align:center;padding:80px 20px;}
.empty-icon{font-size:52px;margin-bottom:16px;}
.empty-title{font-size:20px;font-weight:700;color:#111827;margin-bottom:8px;}
.empty-sub{font-size:14px;color:#9ca3af;margin-bottom:24px;}

/* ── Create modal ─── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:500;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:#fff;border-radius:16px;padding:28px;width:460px;max-width:92vw;}
.modal-title{font-size:18px;font-weight:700;color:#111827;margin:0 0 6px;}
.modal-sub{font-size:13px;color:#9ca3af;margin:0 0 20px;}
.form-group{margin-bottom:16px;}
.form-label{display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;}
.form-input{width:100%;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:14px;font-family:inherit;outline:none;transition:border-color .15s;}
.form-input:focus{border-color:#6366f1;}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;margin-top:20px;}
/* ── Theme picker in create modal ─── */
.wl-theme-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:4px;max-height:260px;overflow-y:auto;padding:2px;}
.wlt-card{border:2px solid #e5e7eb;border-radius:10px;overflow:hidden;cursor:pointer;transition:border-color .15s,box-shadow .15s;}
.wlt-card:hover{border-color:#a5b4fc;}
.wlt-card.selected{border-color:#6366f1;box-shadow:0 0 0 3px #e0e7ff;}
.wlt-thumb{height:78px;position:relative;overflow:hidden;padding:0;}
.wlt-nav{height:14px;display:flex;align-items:center;padding:0 7px;gap:4px;}
.wlt-nav-logo{height:5px;border-radius:2px;flex:1;max-width:28px;opacity:.8;}
.wlt-nav-links{display:flex;gap:3px;margin-left:auto;}
.wlt-nav-link{height:4px;border-radius:2px;width:14px;opacity:.4;}
.wlt-hero{margin:3px 7px;border-radius:4px;height:26px;}
.wlt-body{padding:5px 7px;display:flex;flex-direction:column;gap:3px;}
.wlt-line{border-radius:2px;height:3px;}
.wlt-name{font-size:11px;font-weight:600;color:#374151;padding:5px 8px;text-align:center;background:#fff;border-top:1px solid #f1f5f9;}
</style>
{% endblock %}

{% block body %}
<div class="layout">
  {% include "dashboard/_sidebar.njk" %}
  <div class="dash-main">
    <div class="topbar">
      <span class="topbar-title">🌐 Website Builder</span>
      <button class="btn btn-dark" onclick="openCreate()">+ New Website</button>
    </div>
    <div class="page">
      {% if websites.length %}
      <div class="page-header">
        <div>
          <div class="page-title">Your Websites</div>
          <div class="page-sub">{{ websites.length }} website{{ 's' if websites.length != 1 }}</div>
        </div>
      </div>
      <div class="site-grid">
        {% for w in websites %}
        <div class="site-card">
          <div class="site-thumb" style="background:linear-gradient(135deg,{{ w.settings.primary or '#6366f1' }},{{ w.settings.primary or '#8b5cf6' }}88);">
            🌐
            <span class="site-pub-badge {{ 'live' if w.is_published else 'draft' }}">
              {{ 'Live' if w.is_published else 'Draft' }}
            </span>
          </div>
          <div class="site-info">
            <div class="site-name">{{ w.title }}</div>
            <div class="site-url">pagezaper.com/w/{{ w.subdomain }}</div>
            <div class="site-actions">
              <a href="/dashboard/website/{{ w.id }}/editor" class="btn btn-dark" style="flex:1;justify-content:center;">✏️ Edit</a>
              {% if w.is_published %}
              <a href="/w/{{ w.subdomain }}" target="_blank" class="btn btn-outline">↗ View</a>
              {% endif %}
              <form method="POST" action="/dashboard/website/{{ w.id }}/delete" onsubmit="return confirm('Delete this website?')">
                <button type="submit" class="btn btn-red">🗑</button>
              </form>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
      {% else %}
      <div class="empty">
        <div class="empty-icon">🌐</div>
        <div class="empty-title">No websites yet</div>
        <div class="empty-sub">Build a multi-page website with hero sections, galleries, contact forms and more.</div>
        <button class="btn btn-dark" onclick="openCreate()">+ Create your first website</button>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<!-- Create Modal -->
<div class="modal-overlay" id="createModal" onclick="if(event.target===this)closeCreate()">
  <div class="modal">
    <form method="POST" action="/dashboard/website/create" id="wlForm">
      <!-- Step 1: Name -->
      <div id="wlStep1">
        <div class="modal-title">Create new website</div>
        <div class="modal-sub">Give your website a name to get started.</div>
        <div class="form-group">
          <label class="form-label">Website Name</label>
          <input class="form-input" id="wlNameInput" name="title" placeholder="e.g. My Online Store" required>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline" onclick="closeCreate()">Cancel</button>
          <button type="button" class="btn btn-dark" onclick="wlNext()">Next: Pick a Theme →</button>
        </div>
      </div>
      <!-- Step 2: Theme picker -->
      <div id="wlStep2" style="display:none;">
        <div class="modal-title">Pick a theme</div>
        <div class="modal-sub">Choosing a theme for "<span id="wlNamePreview" style="color:#111827;font-weight:600;"></span>" — you can change it anytime.</div>
        <div class="wl-theme-grid" id="wlThemeGrid"></div>
        <input type="hidden" name="theme" id="wlThemeInput" value="default">
        <div class="modal-footer">
          <button type="button" class="btn btn-outline" onclick="wlBack()">← Back</button>
          <button type="submit" class="btn btn-dark">Create Website →</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
var WL_THEMES = [
  { id:'default',    name:'Default',      bg:'#f8fafc', nav:'#ffffff', primary:'#6366f1', text:'#111827' },
  { id:'minimal',   name:'Elegant',      bg:'#fdf8f0', nav:'#fdf8f0', primary:'#b45309', text:'#1c1917' },
  { id:'bold',      name:'Dark',         bg:'#0f0f1a', nav:'#1a1a2e', primary:'#8b5cf6', text:'#e2e8f0' },
  { id:'ecom-fresh',name:'Fresh Market', bg:'#ffffff', nav:'#f8fafc', primary:'#059669', text:'#111827' },
  { id:'ecom-luxe', name:'Luxe',         bg:'#0a0a0f', nav:'#1a1a28', primary:'#d4af37', text:'#f5f0e8' },
  { id:'ecom-spark',name:'Spark',        bg:'#ffffff', nav:'#f8fafc', primary:'#f43f5e', text:'#0f172a' }
];
var _wlSelected = 'default';

function openCreate(){
  document.getElementById('createModal').classList.add('open');
  setTimeout(function(){ document.getElementById('wlNameInput').focus(); }, 80);
}
function closeCreate(){
  document.getElementById('createModal').classList.remove('open');
  // Reset steps
  document.getElementById('wlStep1').style.display = '';
  document.getElementById('wlStep2').style.display = 'none';
  document.getElementById('wlNameInput').value = '';
  _wlSelected = 'default';
  document.getElementById('wlThemeInput').value = 'default';
}
function wlNext(){
  var name = document.getElementById('wlNameInput').value.trim();
  if (!name) { document.getElementById('wlNameInput').focus(); return; }
  document.getElementById('wlNamePreview').textContent = name;
  renderWlGrid();
  document.getElementById('wlStep1').style.display = 'none';
  document.getElementById('wlStep2').style.display = '';
}
function wlBack(){
  document.getElementById('wlStep2').style.display = 'none';
  document.getElementById('wlStep1').style.display = '';
  setTimeout(function(){ document.getElementById('wlNameInput').focus(); }, 80);
}
function wlPickTheme(id){
  _wlSelected = id;
  document.getElementById('wlThemeInput').value = id;
  document.querySelectorAll('.wlt-card').forEach(function(c){
    c.classList.toggle('selected', c.dataset.tid === id);
  });
}
function renderWlGrid(){
  var html = WL_THEMES.map(function(t){
    var bg = t.bg, nav = t.nav, p = t.primary, tx = t.text;
    return '<div class="wlt-card' + (_wlSelected===t.id?' selected':'') + '" data-tid="' + t.id + '" onclick="wlPickTheme(\'' + t.id + '\')">' +
      '<div class="wlt-thumb" style="background:' + bg + ';">' +
        '<div class="wlt-nav" style="background:' + nav + ';">' +
          '<div class="wlt-nav-logo" style="background:' + p + ';"></div>' +
          '<div class="wlt-nav-links">' +
            '<div class="wlt-nav-link" style="background:' + tx + ';"></div>' +
            '<div class="wlt-nav-link" style="background:' + tx + ';"></div>' +
            '<div class="wlt-nav-link" style="background:' + p + ';border-radius:3px;opacity:1;"></div>' +
          '</div>' +
        '</div>' +
        '<div class="wlt-hero" style="background:' + p + ';"></div>' +
        '<div class="wlt-body">' +
          '<div class="wlt-line" style="background:' + tx + ';opacity:.25;width:72%;"></div>' +
          '<div class="wlt-line" style="background:' + tx + ';opacity:.15;width:48%;"></div>' +
          '<div class="wlt-line" style="background:' + p + ';opacity:.6;width:30%;height:5px;border-radius:3px;margin-top:2px;"></div>' +
        '</div>' +
      '</div>' +
      '<div class="wlt-name">' + t.name + '</div>' +
    '</div>';
  }).join('');
  document.getElementById('wlThemeGrid').innerHTML = html;
}
</script>
{% endblock %}

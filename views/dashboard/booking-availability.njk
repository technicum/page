{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{font-family:"DM Sans",sans-serif;}
.layout{display:flex;min-height:100vh;}
.sidebar{width:220px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;}
.sidebar-logo{font-family:"DM Serif Display",serif;font-size:20px;padding:22px 24px;border-bottom:1px solid var(--border);text-decoration:none;color:var(--ink);display:block;}
.sidebar-logo em{font-style:italic;color:var(--blue);}
.sidebar-nav{padding:16px 12px;flex:1;}
.nav-label{font-size:11px;font-weight:700;color:var(--ink-faint);text-transform:uppercase;letter-spacing:0.06em;padding:10px 12px 4px;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius);font-size:14px;color:var(--ink-muted);text-decoration:none;margin-bottom:2px;}
.nav-item:hover{background:var(--off);color:var(--ink);}
.nav-item.active{background:var(--blue-light);color:var(--blue);font-weight:500;}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border);}
.user-avatar{width:32px;height:32px;border-radius:50%;background:var(--blue-light);color:var(--blue);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;}
.logout-link{display:block;font-size:13px;color:var(--ink-faint);padding:6px 12px;margin-top:4px;}
.content{flex:1;padding:36px 40px;min-width:0;}
.page-title{font-family:"DM Serif Display",serif;font-size:26px;font-weight:400;margin-bottom:4px;}
.page-sub{font-size:14px;color:var(--ink-muted);margin-bottom:28px;}
.back-btn{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--ink-muted);text-decoration:none;margin-bottom:20px;padding:7px 14px;border-radius:var(--radius);border:1px solid var(--border);background:var(--white);}
.back-btn:hover{background:var(--off);}
.avail-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;max-width:600px;}
.avail-row{display:flex;align-items:center;gap:16px;padding:14px 20px;border-bottom:1px solid var(--border);}
.avail-row:last-child{border-bottom:none;}
.toggle{position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0;}
.toggle input{display:none;}
.toggle-slider{position:absolute;inset:0;background:#d1d5db;border-radius:22px;transition:0.2s;cursor:pointer;}
.toggle-slider:before{content:'';position:absolute;width:16px;height:16px;background:#fff;border-radius:50%;top:3px;left:3px;transition:0.2s;}
.toggle input:checked+.toggle-slider{background:var(--blue);}
.toggle input:checked+.toggle-slider:before{transform:translateX(18px);}
.day-name{width:100px;font-size:14px;font-weight:600;flex-shrink:0;}
.time-inputs{display:flex;align-items:center;gap:10px;flex:1;}
.time-input{padding:7px 10px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;font-family:inherit;width:110px;background:var(--bg);color:var(--ink);}
.time-input:focus{outline:none;border-color:var(--blue);}
.time-sep{font-size:12px;color:var(--ink-muted);}
.unavail-label{font-size:13px;color:var(--ink-faint);flex:1;}
.save-btn{display:inline-block;padding:11px 28px;background:var(--blue);color:#fff;border:none;border-radius:var(--radius);font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:opacity 0.15s;margin-top:20px;}
.save-btn:hover{opacity:0.88;}
.alert-ok{background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;padding:10px 14px;border-radius:var(--radius);font-size:13px;margin-bottom:20px;}
</style>
{% endblock %}
{% block body %}
{% set activePage = 'booking' %}
{% set bookingSiteId = site.id %}
{% set bookingPage = 'availability' %}
<div class="layout">
  {% include "dashboard/_sidebar.njk" %}
  <main class="content">
    <a class="back-btn" href="/dashboard/booking/{{ site.id }}">← Overview</a>
    <div class="page-title">Availability</div>
    <div class="page-sub">Set which days and hours you're available for bookings.</div>

    {% if saved %}<div class="alert-ok">✅ Availability saved.</div>{% endif %}

    <form method="POST" action="/dashboard/booking/{{ site.id }}/availability/save">
      <div class="avail-card">
        {% for day in days %}
        <div class="avail-row" id="row-{{ day.day_of_week }}">
          <label class="toggle">
            <input type="checkbox" name="avail[{{ day.day_of_week }}][on]" value="1"
              {% if day.is_available %}checked{% endif %}
              onchange="toggleDay({{ day.day_of_week }}, this.checked)">
            <span class="toggle-slider"></span>
          </label>
          <div class="day-name">{{ day.day_name }}</div>
          <div class="time-inputs" id="times-{{ day.day_of_week }}" style="{{ 'display:none' if not day.is_available else '' }}">
            <input class="time-input" type="time" name="avail[{{ day.day_of_week }}][start]"
              value="{{ day.start_time | string | truncate(5, true, '') }}">
            <span class="time-sep">to</span>
            <input class="time-input" type="time" name="avail[{{ day.day_of_week }}][end]"
              value="{{ day.end_time | string | truncate(5, true, '') }}">
          </div>
          <div class="unavail-label" id="off-{{ day.day_of_week }}" style="{{ '' if not day.is_available else 'display:none' }}">Unavailable</div>
        </div>
        {% endfor %}
      </div>
      <button type="submit" class="save-btn">Save Availability</button>
    </form>
  </main>
</div>
<script>
function toggleDay(dow, on) {
  document.getElementById('times-' + dow).style.display = on ? '' : 'none';
  document.getElementById('off-' + dow).style.display = on ? 'none' : '';
}
</script>
{% endblock %}

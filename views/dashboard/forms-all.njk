{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{font-family:"DM Sans",sans-serif;background:var(--off);}
.content{flex:1;padding:40px;min-width:0;overflow-y:auto;}

/* Header */
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;}
.page-title{font-family:"DM Serif Display",serif;font-size:30px;font-weight:400;letter-spacing:-0.5px;}
.page-sub{font-size:13px;color:var(--ink-muted);margin-top:3px;}
.btn-primary{display:inline-flex;align-items:center;gap:7px;background:var(--blue);color:#fff;padding:10px 20px;border-radius:var(--radius);font-size:14px;font-weight:600;text-decoration:none;border:none;cursor:pointer;font-family:inherit;transition:opacity 0.15s;}
.btn-primary:hover{opacity:0.9;}

/* Search / filter bar */
.toolbar{display:flex;align-items:center;gap:12px;margin-bottom:20px;}
.search-input{flex:1;max-width:320px;padding:9px 14px;border:1px solid var(--border);border-radius:var(--radius);font-size:14px;font-family:inherit;outline:none;background:var(--white);color:var(--ink);}
.search-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);}
.count-badge{font-size:13px;color:var(--ink-muted);margin-left:auto;}

/* Table */
.forms-table-wrap{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;}
.forms-table{width:100%;border-collapse:collapse;}
.forms-table thead{background:var(--off);border-bottom:1px solid var(--border);}
.forms-table th{padding:12px 18px;text-align:left;font-size:11px;font-weight:700;color:var(--ink-faint);text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;}
.forms-table td{padding:14px 18px;border-bottom:1px solid #f3f4f6;font-size:14px;vertical-align:middle;}
.forms-table tbody tr:last-child td{border-bottom:none;}
.forms-table tbody tr{transition:background 0.12s;cursor:default;}
.forms-table tbody tr:hover{background:#fafafa;}

.form-name-cell{font-weight:600;color:var(--ink);max-width:260px;}
.form-name-link{color:var(--ink);text-decoration:none;}
.form-name-link:hover{color:var(--blue);}
.form-id-chip{display:inline-flex;align-items:center;gap:4px;background:#f5f3ff;border:1px solid #ddd6fe;border-radius:5px;padding:2px 7px;font-size:11px;font-family:monospace;color:#6d28d9;cursor:pointer;margin-top:4px;}
.form-id-chip:hover{background:#ede9fe;}
.form-link-chip{display:inline-flex;align-items:center;gap:4px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:5px;padding:2px 7px;font-size:11px;font-family:monospace;color:#16a34a;cursor:pointer;margin-top:4px;margin-left:4px;}
.form-link-chip:hover{background:#dcfce7;}
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:500;}
.badge-blue{background:var(--blue-light);color:var(--blue);}
.badge-green{background:#f0fdf4;color:#16a34a;}
.td-muted{font-size:13px;color:var(--ink-muted);}
.td-date{font-size:12px;color:var(--ink-faint);white-space:nowrap;}

/* Row actions */
.row-actions{display:flex;gap:6px;opacity:0;transition:opacity 0.12s;}
.forms-table tbody tr:hover .row-actions{opacity:1;}
.btn-row{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:6px;font-size:12px;font-weight:500;text-decoration:none;border:1px solid var(--border);background:var(--white);color:var(--ink-muted);cursor:pointer;font-family:inherit;transition:all 0.12s;white-space:nowrap;}
.btn-row:hover{background:var(--off);color:var(--ink);border-color:var(--ink-muted);}
.btn-row.danger{color:#ef4444;border-color:#fecaca;}
.btn-row.danger:hover{background:#fef2f2;}

/* Empty state */
.empty-state{text-align:center;padding:80px 40px;background:var(--white);border:2px dashed var(--border-md);border-radius:var(--radius-lg);}
.empty-icon{font-size:48px;margin-bottom:18px;}
.empty-state h3{font-family:"DM Serif Display",serif;font-size:24px;margin-bottom:10px;}
.empty-state p{font-size:14px;color:var(--ink-muted);margin-bottom:24px;}

@media(max-width:1024px){
  .content{padding:20px 16px;}
  .row-actions{opacity:1;}
}
</style>
{% endblock %}

{% block body %}
{% set activePage = 'forms' %}
<div class="layout">
  {% include "dashboard/_sidebar.njk" %}

  <main class="content">
    <div class="page-header">
      <div>
        <div class="page-title">Forms</div>
        <p class="page-sub">Create forms once, embed them on any site</p>
      </div>
      <a class="btn-primary" href="/dashboard/forms/new">+ Create Form</a>
    </div>

    {% if forms.length %}
    <div class="toolbar">
      <input class="search-input" type="text" id="form-search" placeholder="Search forms…" oninput="filterForms(this.value)">
      <span class="count-badge" id="form-count">{{ forms.length }} form{{ 's' if forms.length != 1 }}</span>
    </div>

    <div class="forms-table-wrap">
      <table class="forms-table" id="forms-table">
        <thead>
          <tr>
            <th style="width:35%;">Name</th>
            <th>Fields</th>
            <th>Submissions</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="forms-tbody">
          {% for form in forms %}
          <tr class="form-row" data-name="{{ form.name | lower }}">
            <td class="form-name-cell">
              <a class="form-name-link" href="/dashboard/forms/edit/{{ form.id }}">{{ form.name }}</a>
              <br>
              <span class="form-id-chip" onclick="copyId({{ form.id }}, this)" title="Click to copy Form ID">
                ID: {{ form.id }} 📋
              </span><span class="form-link-chip" onclick="copyLink({{ form.id }}, this)" title="Click to copy public form URL">
                🔗 Copy Link
              </span>
            </td>
            <td class="td-muted">
              <span class="badge badge-blue">{{ form.fields | length if form.fields else 0 }} fields</span>
            </td>
            <td class="td-muted">
              <span class="badge badge-green">{{ form.entry_count }} {{ 'entry' if form.entry_count == 1 else 'entries' }}</span>
            </td>
            <td class="td-date">{{ form.created_at | string | truncate(10, true, '') }}</td>
            <td>
              <div class="row-actions">
                <a class="btn-row" href="/dashboard/forms/edit/{{ form.id }}">✏️ Edit</a>
                <a class="btn-row" href="/dashboard/forms/entries/{{ form.id }}">📥 Entries</a>
                <form method="POST" action="/dashboard/forms/delete/{{ form.id }}" style="display:inline;" onsubmit="return confirm('Delete this form and all its entries?')">
                  <button type="submit" class="btn-row danger">🗑</button>
                </form>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% else %}
    <div class="empty-state">
      <div class="empty-icon">📋</div>
      <h3>No forms yet</h3>
      <p>Create a form and embed it on any of your sites using the site builder.</p>
      <a class="btn-primary" href="/dashboard/forms/new">+ Create your first form</a>
    </div>
    {% endif %}
  </main>
</div>

<script>
function filterForms(q) {
  const rows = document.querySelectorAll('.form-row');
  let visible = 0;
  rows.forEach(r => {
    const match = r.dataset.name.includes(q.toLowerCase());
    r.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  document.getElementById('form-count').textContent = visible + ' form' + (visible !== 1 ? 's' : '');
}
function copyId(id, el) {
  navigator.clipboard.writeText(String(id)).then(() => {
    const orig = el.innerHTML;
    el.innerHTML = '✓ Copied!';
    setTimeout(() => { el.innerHTML = orig; }, 1500);
  });
}
function copyLink(id, el) {
  const url = window.location.origin + '/f/' + id;
  navigator.clipboard.writeText(url).then(() => {
    const orig = el.innerHTML;
    el.innerHTML = '✓ Copied!';
    setTimeout(() => { el.innerHTML = orig; }, 1500);
  });
}
</script>
{% endblock %}

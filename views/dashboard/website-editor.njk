<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="generator" content="PageZaper Website Builder">
<title>{{ website.title }} — Website Builder</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/canvas-base.css">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;font-family:'Inter',system-ui,sans-serif;font-size:13px;color:#111827;background:#f1f5f9;}

/* ════════════════════════════════════════════
   TOP BAR
════════════════════════════════════════════ */
.wb-topbar{
  height:52px;background:#fff;border-bottom:1px solid #e5e7eb;
  display:flex;align-items:center;padding:0 16px;gap:8px;
  position:fixed;top:0;left:0;right:0;z-index:200;
}
.wb-logo{font-family:'Inter',sans-serif;font-size:13px;font-weight:700;color:#111827;text-decoration:none;display:flex;align-items:center;gap:6px;padding-right:12px;border-right:1px solid #e5e7eb;margin-right:4px;}
.wb-logo em{color:#6366f1;font-style:normal;}
.wb-site-name{font-size:13px;font-weight:600;color:#374151;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.wb-divider{width:1px;height:20px;background:#e5e7eb;flex-shrink:0;}
.wb-topbar-mid{flex:1;display:flex;align-items:center;justify-content:center;gap:4px;}
.device-btn{width:34px;height:34px;border:none;background:transparent;cursor:pointer;border-radius:7px;display:flex;align-items:center;justify-content:center;color:#9ca3af;font-size:16px;transition:all .15s;}
.device-btn:hover{background:#f3f4f6;color:#374151;}
.device-btn.active{background:#eef2ff;color:#6366f1;}
.wb-icon-btn{width:34px;height:34px;border:none;background:transparent;cursor:pointer;border-radius:7px;display:flex;align-items:center;justify-content:center;color:#6b7280;font-size:14px;transition:all .15s;}
.wb-icon-btn:hover{background:#f3f4f6;color:#374151;}
.wb-topbar-right{display:flex;align-items:center;gap:8px;}
.tb-btn{padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:inherit;transition:all .15s;}
.tb-btn-ghost{background:transparent;color:#374151;border:1.5px solid #e5e7eb;}
.tb-btn-ghost:hover{border-color:#6366f1;color:#6366f1;}
.tb-btn-primary{background:#6366f1;color:#fff;}
.tb-btn-primary:hover{background:#4f46e5;}
.tb-saved{font-size:11px;color:#9ca3af;font-weight:500;}
.tb-saved.saving{color:#f59e0b;}
.tb-saved.saved{color:#10b981;}

/* ════════════════════════════════════════════
   BODY LAYOUT
════════════════════════════════════════════ */
.wb-body{
  display:flex;height:calc(100vh - 52px);margin-top:52px;
}

/* ════════════════════════════════════════════
   ICON RAIL (left)
════════════════════════════════════════════ */
.wb-rail{
  width:54px;background:#1e1b4b;display:flex;flex-direction:column;align-items:center;
  padding:8px 0;gap:2px;flex-shrink:0;z-index:100;
}
.rail-btn{
  width:42px;height:42px;border:none;background:transparent;cursor:pointer;
  border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;color:rgba(255,255,255,.5);transition:all .15s;padding:0;
}
.rail-btn:hover{background:rgba(255,255,255,.1);color:rgba(255,255,255,.9);}
.rail-btn.active{background:#6366f1;color:#fff;}
.rail-btn .ri{font-size:18px;line-height:1;}
.rail-btn .rl{font-size:9px;font-weight:600;letter-spacing:.2px;line-height:1;}
.rail-sep{width:30px;height:1px;background:rgba(255,255,255,.1);margin:4px 0;}
.rail-bottom{margin-top:auto;display:flex;flex-direction:column;align-items:center;gap:2px;padding-bottom:8px;}

/* ════════════════════════════════════════════
   SIDE PANEL
════════════════════════════════════════════ */
.wb-panel{
  width:0;overflow:hidden;background:#fff;border-right:1px solid #e5e7eb;
  transition:width .2s ease;flex-shrink:0;display:flex;flex-direction:column;
}
.wb-panel.open{width:280px;}
.panel-head{
  padding:14px 16px;border-bottom:1px solid #f3f4f6;
  display:flex;align-items:center;gap:8px;flex-shrink:0;
}
.panel-title{font-size:14px;font-weight:700;color:#111827;flex:1;}
.panel-close{width:26px;height:26px;border:none;background:#f3f4f6;border-radius:6px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;color:#6b7280;}
.panel-close:hover{background:#e5e7eb;}
.panel-body{flex:1;overflow-y:auto;padding:14px;}
.panel-section{display:none;}
.panel-section.active{display:block;}

/* ── Pages panel ── */
.page-item{
  display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:9px;
  cursor:pointer;transition:background .1s;margin-bottom:2px;
}
.page-item:hover{background:#f9fafb;}
.page-item.active{background:#eef2ff;color:#6366f1;}
.page-item-icon{font-size:14px;flex-shrink:0;}
.page-item-name{flex:1;font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.page-item-home{font-size:9px;background:#fef9c3;color:#92400e;padding:2px 5px;border-radius:3px;font-weight:700;flex-shrink:0;}
.page-item-del{width:22px;height:22px;border:none;background:transparent;cursor:pointer;color:#ef4444;border-radius:5px;font-size:12px;opacity:0;display:flex;align-items:center;justify-content:center;}
.page-item:hover .page-item-del{opacity:1;}
.page-item-del:hover{background:#fee2e2;}
.add-page-btn{
  display:flex;align-items:center;gap:6px;width:100%;padding:9px 10px;
  border:1.5px dashed #e5e7eb;border-radius:9px;background:transparent;
  cursor:pointer;font-size:12px;color:#9ca3af;font-family:inherit;
  transition:all .15s;margin-top:8px;
}
.add-page-btn:hover{border-color:#6366f1;color:#6366f1;}
.panel-label{font-size:10px;font-weight:700;color:#9ca3af;letter-spacing:.6px;text-transform:uppercase;margin:12px 0 8px;}

/* ── Elements panel ── */
.sec-type-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.sec-type-card{
  padding:14px 8px;border:1.5px solid #f3f4f6;border-radius:10px;
  background:#fafafa;cursor:pointer;text-align:center;
  transition:all .15s;display:flex;flex-direction:column;align-items:center;gap:5px;
}
.sec-type-card:hover{border-color:#6366f1;background:#eef2ff;}
.stc-icon{font-size:24px;}
.stc-label{font-size:11px;font-weight:600;color:#374151;}

/* ── Styles panel ── */
.style-row{margin-bottom:14px;}
.style-label{display:block;font-size:11px;font-weight:600;color:#374151;margin-bottom:6px;}
.style-input,.style-select{width:100%;padding:8px 10px;border:1.5px solid #e5e7eb;border-radius:7px;font-size:13px;font-family:inherit;outline:none;transition:border-color .15s;}
.style-input:focus,.style-select:focus{border-color:#6366f1;}
.color-pair{display:flex;gap:8px;align-items:center;}
/* ── Theme picker ── */
.theme-card{display:flex;align-items:center;gap:10px;padding:10px 12px;border:2px solid #e5e7eb;border-radius:10px;cursor:pointer;transition:all .15s;background:#fff;}
.theme-card:hover{border-color:#a5b4fc;}
.theme-card.selected{border-color:#6366f1;background:#eef2ff;}
.theme-card-dots{display:flex;gap:4px;flex-shrink:0;}
.theme-card-dots span{width:14px;height:14px;border-radius:50%;display:inline-block;}
.theme-card-name{font-size:13px;font-weight:700;color:#111827;}
.theme-card-desc{font-size:11px;color:#6b7280;margin-top:1px;}
.color-pick{width:36px;height:36px;border-radius:7px;border:1.5px solid #e5e7eb;cursor:pointer;flex-shrink:0;}

/* ── Section edit panel ── */
.sec-edit-back{display:flex;align-items:center;gap:6px;padding:8px 0;color:#6b7280;cursor:pointer;font-size:12px;font-weight:500;margin-bottom:10px;border:none;background:transparent;font-family:inherit;}
.sec-edit-back:hover{color:#111827;}
.field-group{margin-bottom:14px;}
.fl{display:block;font-size:11px;font-weight:600;color:#374151;margin-bottom:5px;}
.fi{width:100%;padding:8px 10px;border:1.5px solid #e5e7eb;border-radius:7px;font-size:13px;font-family:inherit;outline:none;transition:border-color .15s;}
.fi:focus{border-color:#6366f1;}
.ft{resize:vertical;min-height:70px;}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.fi-color{width:32px;height:32px;border-radius:6px;border:1.5px solid #e5e7eb;cursor:pointer;}
.color-row{display:flex;align-items:center;gap:8px;}
/* items list */
.it-list{display:flex;flex-direction:column;gap:6px;margin-bottom:8px;}
.it-card{background:#f9fafb;border:1px solid #f3f4f6;border-radius:7px;padding:8px;position:relative;}
.it-del{position:absolute;top:6px;right:6px;width:20px;height:20px;border:none;background:transparent;cursor:pointer;color:#ef4444;font-size:12px;border-radius:4px;}
.it-del:hover{background:#fee2e2;}
.it-card .fi{margin-top:4px;}
.it-card .fi:first-of-type{margin-top:0;}
.add-it-btn{display:flex;align-items:center;gap:4px;padding:7px 10px;border:1.5px dashed #e5e7eb;border-radius:7px;background:transparent;cursor:pointer;font-size:12px;color:#9ca3af;font-family:inherit;width:100%;transition:all .15s;}
.add-it-btn:hover{border-color:#6366f1;color:#6366f1;}

/* ════════════════════════════════════════════
   CANVAS AREA
════════════════════════════════════════════ */
.wb-canvas-wrap{
  flex:1;overflow:auto;background:#e5e7eb;
  display:flex;flex-direction:column;align-items:center;
  padding:24px 24px 80px;min-width:0;
}
.wb-device{
  width:100%;max-width:1100px;background:#fff;
  border-radius:8px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.12);
  transition:max-width .25s ease,border-radius .25s;
  min-height:600px;position:relative;
}
.wb-device.tablet{max-width:768px;border-radius:14px;}
.wb-device.mobile{max-width:390px;border-radius:18px;box-shadow:0 8px 32px rgba(0,0,0,.2);}

/* (old cs-* section CSS removed — replaced by .sec-wrap system in canvas CSS below) */

/* ── Empty canvas state ── */
.canvas-empty{
  padding:80px 40px;text-align:center;color:#9ca3af;
}
.canvas-empty-icon{font-size:48px;margin-bottom:12px;}
.canvas-empty-title{font-size:18px;font-weight:700;color:#374151;margin-bottom:8px;}
.canvas-empty-sub{font-size:14px;margin-bottom:24px;}
.canvas-empty-btn{
  padding:10px 22px;background:#6366f1;color:#fff;border:none;border-radius:9px;
  font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;
}

/* canvas CSS moved to /css/canvas-base.css (loaded via link tag in head) */

/* ════════════════════════════════════════════
   BOTTOM SAVE BAR (mobile-style)
════════════════════════════════════════════ */
.wb-publish-bar{
  position:fixed;bottom:0;left:54px;right:0;
  background:#1e1b4b;padding:10px 20px;
  display:flex;align-items:center;justify-content:flex-end;gap:10px;
  z-index:100;
}
.wb-publish-bar button{padding:7px 18px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;border:none;font-family:inherit;}
.pub-preview-btn{background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);}
.pub-preview-btn:hover{background:rgba(255,255,255,.2);}
.pub-save-btn{background:#6366f1;color:#fff;}
.pub-save-btn:hover{background:#4f46e5;}
.pub-update-btn{background:#10b981;color:#fff;}
.pub-update-btn:hover{background:#059669;}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════
  TOP BAR
═══════════════════════════════════════════ -->
<div class="wb-topbar">
  <a class="wb-logo" href="/dashboard/website">page<em>zaper</em></a>
  <span class="wb-site-name">{{ website.title }}</span>
  <span class="wb-divider"></span>

  <div class="wb-topbar-mid">
    <button class="device-btn active" id="d-desktop" onclick="setDevice('desktop')" title="Desktop">🖥</button>
    <button class="device-btn" id="d-tablet"  onclick="setDevice('tablet')"  title="Tablet">📲</button>
    <button class="device-btn" id="d-mobile"  onclick="setDevice('mobile')"  title="Mobile">📱</button>
    <span class="wb-divider" style="margin:0 4px;"></span>
    <button class="wb-icon-btn" onclick="undo()" title="Undo">↩</button>
    <button class="wb-icon-btn" onclick="redo()" title="Redo">↪</button>
  </div>

  <div class="wb-topbar-right">
    <span class="tb-saved" id="saveStatus">All changes saved</span>
    <button class="tb-btn tb-btn-ghost" onclick="openPreview()">Preview</button>
    {% if website.is_published %}
    <button class="tb-btn tb-btn-primary" onclick="saveAndPublish()" style="background:#10b981;">✓ Update Website</button>
    {% else %}
    <button class="tb-btn tb-btn-primary" onclick="saveAndPublish()">🚀 Publish</button>
    {% endif %}
  </div>
</div>

<!-- ═══════════════════════════════════════════
  BODY
═══════════════════════════════════════════ -->
<div class="wb-body">

  <!-- ICON RAIL -->
  <div class="wb-rail">
    <button class="rail-btn" id="rb-pages"    onclick="togglePanel('pages')"    title="Pages">
      <span class="ri">📄</span><span class="rl">Pages</span>
    </button>
    <button class="rail-btn" id="rb-elements" onclick="togglePanel('elements')" title="Add Section">
      <span class="ri">➕</span><span class="rl">Add</span>
    </button>
    <button class="rail-btn" id="rb-styles"   onclick="togglePanel('styles')"   title="Styles">
      <span class="ri">🎨</span><span class="rl">Styles</span>
    </button>
    <div class="rail-sep"></div>
    <button class="rail-btn" id="rb-seo"      onclick="togglePanel('seo')"      title="SEO">
      <span class="ri">🔍</span><span class="rl">SEO</span>
    </button>
    <button class="rail-btn" id="rb-settings" onclick="togglePanel('settings')" title="Settings">
      <span class="ri">⚙️</span><span class="rl">Setup</span>
    </button>
  </div>

  <!-- SIDE PANEL -->
  <div class="wb-panel" id="wbPanel">
    <div class="panel-head">
      <span class="panel-title" id="panelTitle">Pages</span>
      <button class="panel-close" onclick="closePanel()">✕</button>
    </div>
    <div class="panel-body">

      <!-- Pages -->
      <div class="panel-section active" id="ps-pages">
        <div id="pageListEl"></div>
        <button class="add-page-btn" onclick="addPage()">+ Add page</button>
      </div>

      <!-- Elements / Add section -->
      <div class="panel-section" id="ps-elements">
        <div class="panel-label">Sections</div>
        <div class="sec-type-grid">
          <button class="sec-type-card" onclick="addSection('hero')"><span class="stc-icon">🦸</span><span class="stc-label">Hero</span></button>
          <button class="sec-type-card" onclick="addSection('about')"><span class="stc-icon">👤</span><span class="stc-label">About</span></button>
          <button class="sec-type-card" onclick="addSection('services')"><span class="stc-icon">⚡</span><span class="stc-label">Services</span></button>
          <button class="sec-type-card" onclick="addSection('gallery')"><span class="stc-icon">🖼</span><span class="stc-label">Gallery</span></button>
          <button class="sec-type-card" onclick="addSection('testimonials')"><span class="stc-icon">💬</span><span class="stc-label">Testimonials</span></button>
          <button class="sec-type-card" onclick="addSection('team')"><span class="stc-icon">👥</span><span class="stc-label">Team</span></button>
          <button class="sec-type-card" onclick="addSection('faq')"><span class="stc-icon">❓</span><span class="stc-label">FAQ</span></button>
          <button class="sec-type-card" onclick="addSection('cta')"><span class="stc-icon">📣</span><span class="stc-label">CTA Banner</span></button>
          <button class="sec-type-card" onclick="addSection('contact')"><span class="stc-icon">📬</span><span class="stc-label">Contact</span></button>
        </div>
      </div>

      <!-- Styles -->
      <div class="panel-section" id="ps-styles">
        <div class="panel-label">Brand Color</div>
        <div class="style-row">
          <label class="style-label">Primary color</label>
          <div class="color-pair">
            <input type="color" class="color-pick" id="sy-primary" value="{{ website.settings.primary or '#6366f1' }}" oninput="onStyleChange('primary',this.value)">
            <input class="style-input" id="sy-primary-hex" value="{{ website.settings.primary or '#6366f1' }}" style="flex:1;" oninput="document.getElementById('sy-primary').value=this.value;onStyleChange('primary',this.value)">
          </div>
        </div>
        <div class="panel-label">Typography</div>
        <div class="style-row">
          <label class="style-label">Font</label>
          <select class="style-select" id="sy-font" onchange="onStyleChange('font',this.value)">
            {% for f in ['Inter','Poppins','Playfair Display','DM Sans','Lato','Montserrat','Nunito','Raleway','Roboto'] %}
            <option value="{{ f }}" {{ 'selected' if (website.settings.font or 'Inter') == f }}>{{ f }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="panel-label">Theme</div>
        <div class="style-row">
          <div style="display:flex;flex-direction:column;gap:8px;">
            <div class="theme-card {{ 'selected' if (website.settings.theme or 'default') == 'default' }}" onclick="selectTheme('default')" id="tc-default">
              <div class="theme-card-dots">
                <span style="background:#6366f1;"></span>
                <span style="background:#ffffff;border:1px solid #e5e7eb;"></span>
                <span style="background:#111827;"></span>
              </div>
              <div class="theme-card-info">
                <div class="theme-card-name">Default</div>
                <div class="theme-card-desc">Clean modern with soft cards</div>
              </div>
            </div>
            <div class="theme-card {{ 'selected' if website.settings.theme == 'minimal' }}" onclick="selectTheme('minimal')" id="tc-minimal">
              <div class="theme-card-dots">
                <span style="background:#18181b;"></span>
                <span style="background:#ffffff;border:1px solid #e4e4e7;"></span>
                <span style="background:#f4f4f5;border:1px solid #e4e4e7;"></span>
              </div>
              <div class="theme-card-info">
                <div class="theme-card-name">Elegant</div>
                <div class="theme-card-desc">Warm cream, serif fonts, gold accents</div>
              </div>
            </div>
            <div class="theme-card {{ 'selected' if website.settings.theme == 'bold' }}" onclick="selectTheme('bold')" id="tc-bold">
              <div class="theme-card-dots">
                <span style="background:#7c3aed;"></span>
                <span style="background:#0f0f0f;"></span>
                <span style="background:#1c1c1e;"></span>
              </div>
              <div class="theme-card-info">
                <div class="theme-card-name">Dark</div>
                <div class="theme-card-desc">Full dark, glass cards, neon glow</div>
              </div>
            </div>
          </div>
        </div>
        <button onclick="saveStyles()" style="width:100%;padding:9px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;margin-top:8px;">Save Styles</button>
      </div>

      <!-- SEO -->
      <div class="panel-section" id="ps-seo">
        <div class="panel-label">Page SEO</div>
        <div class="field-group">
          <label class="fl">SEO Title</label>
          <input class="fi" id="seo-title" placeholder="Page title for Google">
        </div>
        <div class="field-group">
          <label class="fl">Meta Description</label>
          <textarea class="fi ft" id="seo-desc" placeholder="160-char page description"></textarea>
        </div>
        <button onclick="saveSEO()" style="width:100%;padding:9px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;">Save SEO</button>
      </div>

      <!-- Settings -->
      <div class="panel-section" id="ps-settings">
        <div class="panel-label">Site Info</div>
        <div class="field-group">
          <label class="fl">Website Name</label>
          <input class="fi" id="st-title" value="{{ website.title }}">
        </div>
        <div class="field-group">
          <label class="fl">Tagline</label>
          <input class="fi" id="st-tagline" value="{{ website.settings.tagline or '' }}">
        </div>
        <div class="field-group">
          <label class="fl">Logo URL</label>
          <input class="fi" id="st-logo" value="{{ website.settings.logo or '' }}" placeholder="https://...">
        </div>
        <button onclick="saveSettings()" style="width:100%;padding:9px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;">Save Settings</button>
      </div>

      <!-- Section Edit (dynamic) -->
      <div class="panel-section" id="ps-section-edit">
        <button class="sec-edit-back" onclick="backFromEdit()">← Back to sections</button>
        <div id="sec-edit-fields"></div>
      </div>

    </div>
  </div>

  <!-- CANVAS AREA -->
  <div class="wb-canvas-wrap" id="canvasWrap">
    <div class="wb-device" id="wbDevice">
      <div id="canvasRoot"></div>
    </div>
  </div>

</div>

<!-- BOTTOM BAR -->
<div class="wb-publish-bar">
  <button class="pub-preview-btn" onclick="openPreview()">Preview ↗</button>
  <button class="pub-save-btn" id="mainSaveBtn" onclick="saveSections()">💾 Save</button>
  <button class="pub-update-btn" id="publishBtn" onclick="saveAndPublish()">🌐 {{ 'Unpublish' if website.is_published else 'Publish' }}</button>
</div>

<!-- Nunjucks data — rendered server-side -->
<script>
const WEBSITE_ID  = {{ website.id }};
const SUBDOMAIN   = '{{ website.subdomain }}';
const PRIMARY     = '{{ website.settings.primary or "#6366f1" }}';

var currentPageId   = {{ activeSitePage.id if activeSitePage else 'null' }};
var sections        = {{ (activeSitePage.sections | dump | safe) if activeSitePage else '[]' }};
var allPages        = {{ (pages | dump | safe) if pages else '[]' }};
var isPublished     = {{ 'true' if website.is_published else 'false' }};
var selectedSecId   = null;
var activePanel     = null;
var undoStack       = [JSON.stringify(sections)];
var undoIdx         = 0;
var siteSettings    = {
  primary: '{{ website.settings.primary or "#6366f1" }}',
  font:    '{{ website.settings.font or "Inter" }}',
  tagline: '{{ website.settings.tagline or "" }}',
  logo:    '{{ website.settings.logo or "" }}'
};
var SITE_THEME = '{{ website.settings.theme or "default" }}';
</script>

<!-- SortableJS for drag & drop section reordering -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>
<!-- Scoped theme CSS for canvas preview -->
<style id="canvas-theme-css"></style>
<!-- Builder logic — external file avoids Nunjucks escaping issues -->
<script src="/js/website-builder.js"></script>
</body>
</html>

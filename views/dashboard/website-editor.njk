          <label class="fl">Logo URL</label>
          <input class="fi" id="st-logo" value="{{ website.settings.logo or '' }}" placeholder="https://...">
        </div>
        <button onclick="saveSettings()" style="width:100%;padding:9px;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;">Save Settings</button>
      </div>

      <!-- Section Edit (dynamic) -->
      <div class="panel-section" id="ps-section-edit">
        <button class="sec-edit-back" onclick="backFromEdit()">← Back to sections</button>
        <div id="sec-edit-fields"></div>

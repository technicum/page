{% extends "layouts/base.njk" %}
{% block body %}
<div style="max-width:900px;margin:40px auto;padding:0 24px;">

  <!-- Header -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;gap:16px;">
    <div>
      <div style="font-size:12px;color:var(--ink-faint,#9ca3af);margin-bottom:4px;">
        <a href="/dashboard" style="color:var(--ink-muted,#6b7280);text-decoration:none;">Dashboard</a>
        / <a href="/dashboard/site/{{ site.id }}" style="color:var(--ink-muted,#6b7280);text-decoration:none;">{{ site.title }}</a>
        / Media Library
      </div>
      <h1 style="font-size:22px;font-weight:600;color:var(--ink,#111827);margin:0;">🖼 Media Library</h1>
    </div>
    <label id="uploadBtn" style="padding:10px 20px;background:#111827;color:#fff;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;white-space:nowrap;">
      + Upload Image
      <input type="file" id="uploadInput" accept="image/*" style="display:none">
    </label>
  </div>

  <!-- Upload progress -->
  <div id="uploadStatus" style="display:none;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:14px;color:#166534;"></div>
  <div id="uploadError" style="display:none;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:14px;color:#991b1b;"></div>

  <!-- Toggle view -->
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
    <div id="fileCount" style="font-size:13px;color:#6b7280;">{{ files | length }} file{% if files | length != 1 %}s{% endif %}</div>
    <div style="display:flex;gap:6px;">
      <button onclick="setView('table')" id="btnTable" style="padding:6px 12px;border-radius:6px;border:1px solid #e5e7eb;background:#111827;color:#fff;font-size:13px;cursor:pointer;">Table</button>
      <button onclick="setView('grid')" id="btnGrid" style="padding:6px 12px;border-radius:6px;border:1px solid #e5e7eb;background:#fff;color:#374151;font-size:13px;cursor:pointer;">Grid</button>
    </div>
  </div>

  <!-- TABLE VIEW -->
  <div id="tableView">
    {% if files | length %}
    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:14px;">
        <thead>
          <tr style="background:#f9fafb;border-bottom:1px solid #e5e7eb;">
            <th style="padding:12px 16px;text-align:left;font-weight:600;color:#374151;width:56px;">Preview</th>
            <th style="padding:12px 16px;text-align:left;font-weight:600;color:#374151;">Filename</th>
            <th style="padding:12px 16px;text-align:left;font-weight:600;color:#374151;white-space:nowrap;">Size</th>
            <th style="padding:12px 16px;text-align:left;font-weight:600;color:#374151;white-space:nowrap;">Date</th>
            <th style="padding:12px 16px;text-align:right;font-weight:600;color:#374151;">Actions</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          {% for f in files %}
          <tr data-name="{{ f.name }}" style="border-bottom:{{ 'none' if loop.last else '1px solid #f3f4f6' }};">
            <td style="padding:10px 16px;">
              <img src="{{ f.url }}" alt="{{ f.name }}"
                style="width:40px;height:40px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb;">
            </td>
            <td style="padding:10px 16px;max-width:300px;">
              <div style="font-size:13px;color:#111827;word-break:break-all;font-weight:500;">{{ f.name }}</div>
              <div style="font-size:11px;color:#9ca3af;margin-top:2px;">{{ f.url }}</div>
            </td>
            <td style="padding:10px 16px;color:#6b7280;white-space:nowrap;">{{ f.sizeLabel }}</td>
            <td style="padding:10px 16px;color:#6b7280;white-space:nowrap;">{{ f.modified }}</td>
            <td style="padding:10px 16px;text-align:right;white-space:nowrap;">
              <button onclick="copyUrl('{{ f.url }}')"
                style="padding:5px 10px;border-radius:6px;border:1px solid #e5e7eb;background:#fff;color:#374151;font-size:12px;cursor:pointer;margin-right:6px;">
                Copy URL
              </button>
              <button onclick="deleteFile('{{ f.name }}', this)"
                style="padding:5px 10px;border-radius:6px;border:1px solid #fecaca;background:#fff;color:#dc2626;font-size:12px;cursor:pointer;">
                Delete
              </button>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <div id="emptyState" style="text-align:center;padding:60px 24px;background:#fff;border:2px dashed #e5e7eb;border-radius:12px;">
      <div style="font-size:40px;margin-bottom:12px;">📁</div>
      <div style="font-size:15px;font-weight:600;color:#374151;margin-bottom:6px;">No images yet</div>
      <div style="font-size:13px;color:#9ca3af;">Upload images to use them in your pages</div>
    </div>
    {% endif %}
  </div>

  <!-- GRID VIEW -->
  <div id="gridView" style="display:none;">
    <div id="gridContainer" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;">
      {% for f in files %}
      <div data-name="{{ f.name }}" style="background:#fff;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;">
        <div style="position:relative;">
          <img src="{{ f.url }}" alt="{{ f.name }}"
            style="width:100%;height:120px;object-fit:cover;display:block;">
          <button onclick="deleteFile('{{ f.name }}', this)"
            style="position:absolute;top:6px;right:6px;width:24px;height:24px;border-radius:50%;border:none;background:rgba(0,0,0,0.5);color:#fff;font-size:14px;line-height:1;cursor:pointer;padding:0;">×</button>
        </div>
        <div style="padding:8px 10px;">
          <div style="font-size:11px;color:#374151;word-break:break-all;line-height:1.3;margin-bottom:6px;font-weight:500;">{{ f.name | truncate(30) }}</div>
          <div style="font-size:10px;color:#9ca3af;margin-bottom:6px;">{{ f.sizeLabel }}</div>
          <button onclick="copyUrl('{{ f.url }}')"
            style="width:100%;padding:5px;border-radius:5px;border:1px solid #e5e7eb;background:#f9fafb;color:#374151;font-size:11px;cursor:pointer;">
            Copy URL
          </button>
        </div>
      </div>
      {% endfor %}
    </div>
    {% if not files | length %}
    <div style="text-align:center;padding:60px 24px;background:#fff;border:2px dashed #e5e7eb;border-radius:12px;">
      <div style="font-size:40px;margin-bottom:12px;">📁</div>
      <div style="font-size:15px;font-weight:600;color:#374151;">No images yet</div>
    </div>
    {% endif %}
  </div>

  <!-- Copy toast -->
  <div id="copyToast" style="position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:#111827;color:#fff;padding:9px 18px;border-radius:24px;font-size:12px;font-weight:500;opacity:0;transition:opacity 0.2s;pointer-events:none;z-index:999;white-space:nowrap;">
    ✓ URL copied to clipboard
  </div>

</div>

<script>
const SITE_ID = {{ siteId }};

// View toggle
function setView(v) {
  document.getElementById('tableView').style.display = v === 'table' ? '' : 'none';
  document.getElementById('gridView').style.display  = v === 'grid'  ? '' : 'none';
  document.getElementById('btnTable').style.background = v === 'table' ? '#111827' : '#fff';
  document.getElementById('btnTable').style.color = v === 'table' ? '#fff' : '#374151';
  document.getElementById('btnGrid').style.background  = v === 'grid'  ? '#111827' : '#fff';
  document.getElementById('btnGrid').style.color  = v === 'grid'  ? '#fff' : '#374151';
  localStorage.setItem('pz_media_view', v);
}
// Restore last view
(function(){ var v = localStorage.getItem('pz_media_view') || 'table'; setView(v); })();

// Copy URL
function copyUrl(url) {
  var full = location.origin + url;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(full);
  } else {
    var ta = document.createElement('textarea');
    ta.value = full; document.body.appendChild(ta); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta);
  }
  var t = document.getElementById('copyToast');
  t.style.opacity = '1';
  setTimeout(function(){ t.style.opacity = '0'; }, 2000);
}

// Delete file
function deleteFile(name, btn) {
  if (!confirm('Delete ' + name + '?')) return;
  btn.disabled = true;
  fetch('/dashboard/media/' + SITE_ID + '/' + encodeURIComponent(name), { method: 'DELETE' })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        // Remove row from table
        var tableRow = document.querySelector('#tableBody tr[data-name="' + name + '"]');
        if (tableRow) tableRow.remove();
        // Remove card from grid
        var gridCard = document.querySelector('#gridContainer [data-name="' + name + '"]');
        if (gridCard) gridCard.remove();
        // Update count
        var remaining = document.querySelectorAll('#tableBody tr').length;
        document.getElementById('fileCount').textContent = remaining + ' file' + (remaining !== 1 ? 's' : '');
      }
    })
    .catch(function(){ btn.disabled = false; });
}

// Upload
document.getElementById('uploadInput').addEventListener('change', function(e) {
  var file = e.target.files[0];
  if (!file) return;
  var status = document.getElementById('uploadStatus');
  var errEl  = document.getElementById('uploadError');
  status.style.display = 'none';
  errEl.style.display  = 'none';

  var fd = new FormData();
  fd.append('image', file);
  status.textContent = 'Uploading…';
  status.style.display = '';

  fetch('/dashboard/media/' + SITE_ID + '/upload', { method: 'POST', body: fd })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        status.textContent = '✓ Uploaded: ' + d.name;
        // Reload to show new file
        setTimeout(function(){ location.reload(); }, 800);
      } else {
        status.style.display = 'none';
        errEl.textContent = d.error || 'Upload failed';
        errEl.style.display = '';
      }
    })
    .catch(function(err){
      status.style.display = 'none';
      errEl.textContent = 'Upload failed';
      errEl.style.display = '';
    });

  // Reset input
  e.target.value = '';
});
</script>
{% endblock %}

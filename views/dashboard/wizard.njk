<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Create your site — {{ app_name }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1a18;--ink-muted:#6b6b66;--ink-faint:#b0afa8;--white:#fff;--off:#f8f7f4;--paper:#f2f0eb;
  --border:rgba(26,26,24,0.1);--border-md:rgba(26,26,24,0.18);
  --blue:#2563eb;--blue-light:#eff4ff;--blue-mid:#c7d9fd;
  --green:#16a34a;--green-light:#f0fdf4;
  --red:#dc2626;--red-light:#fef2f2;
  --radius:10px;--radius-lg:16px;--radius-xl:24px;
}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);min-height:100vh;}

nav{display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:58px;background:var(--white);border-bottom:1px solid var(--border);}
.logo{font-family:'DM Serif Display',serif;font-size:20px;text-decoration:none;color:var(--ink);}
.logo em{font-style:italic;color:var(--blue);}
.nav-user{font-size:13px;color:var(--ink-muted);}
.nav-user a{color:var(--ink-faint);text-decoration:none;}

.progress-wrap{padding:32px 40px 0;max-width:720px;margin:0 auto;}
.steps-bar{display:flex;align-items:center;gap:0;margin-bottom:8px;}
.step-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;flex-shrink:0;transition:all 0.3s;}
.step-dot.done{background:var(--ink);color:var(--white);}
.step-dot.active{background:var(--blue);color:var(--white);}
.step-dot.pending{background:var(--paper);color:var(--ink-faint);border:1px solid var(--border);}
.step-line{flex:1;height:1px;background:var(--border);}
.step-line.done{background:var(--ink);}
.steps-labels{display:flex;justify-content:space-between;margin-top:8px;}
.steps-labels span{font-size:12px;color:var(--ink-faint);text-align:center;flex:1;}
.steps-labels span.active{color:var(--blue);font-weight:500;}
.steps-labels span.done{color:var(--ink-muted);}

.main{max-width:720px;margin:32px auto;padding:0 40px 80px;}

.step-panel{display:none;}
.step-panel.active{display:block;animation:fadeUp 0.35s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

.step-heading{font-family:'DM Serif Display',serif;font-size:28px;font-weight:400;letter-spacing:-0.5px;margin-bottom:6px;}
.step-sub{font-size:15px;color:var(--ink-muted);margin-bottom:32px;}

/* Single type card */
.single-type{background:var(--blue-light);border:2px solid var(--blue);border-radius:var(--radius-lg);padding:24px 22px;display:flex;align-items:center;gap:18px;margin-bottom:24px;}
.st-icon{width:52px;height:52px;border-radius:12px;background:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.st-icon i{font-size:24px;color:#fff;}
.st-text{}
.st-name{font-size:16px;font-weight:600;color:var(--ink);margin-bottom:3px;}
.st-desc{font-size:13px;color:var(--ink-muted);}
.st-check{margin-left:auto;width:24px;height:24px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.st-check i{font-size:13px;color:#fff;}

.info-strip{display:flex;align-items:center;gap:10px;padding:11px 14px;background:var(--white);border:1px solid var(--border-md);border-radius:var(--radius);font-size:13px;color:var(--ink-muted);margin-bottom:28px;}
.info-strip i{color:var(--blue);font-size:16px;flex-shrink:0;}

/* Fields */
.field{margin-bottom:20px;}
.field label{display:block;font-size:13px;font-weight:500;color:var(--ink-muted);margin-bottom:7px;}
.field input,.field textarea,.field select{width:100%;padding:11px 14px;border:1px solid var(--border-md);border-radius:var(--radius);font-size:15px;font-family:'DM Sans',sans-serif;color:var(--ink);background:var(--white);outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);}
.field textarea{resize:vertical;min-height:80px;}
.field-hint{font-size:12px;color:var(--ink-faint);margin-top:5px;}

.subdomain-wrap{display:flex;align-items:center;border:1px solid var(--border-md);border-radius:var(--radius);overflow:hidden;background:var(--white);}
.subdomain-suffix{padding:11px 14px;background:var(--paper);font-size:14px;color:var(--ink-muted);border-left:1px solid var(--border);white-space:nowrap;flex-shrink:0;}
.subdomain-wrap input{border:none;outline:none;padding:11px 14px;font-size:15px;font-family:'DM Sans',sans-serif;color:var(--ink);flex:1;background:transparent;}
.subdomain-wrap:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);}

/* ── Embedded theme marketplace (mirrors templates.njk exactly) ─────────── */
.tm-search-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.tm-search-row input{flex:1;height:40px;border:1px solid var(--border-md);border-radius:var(--radius);background:var(--white);color:var(--ink);padding:0 14px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none;}
.tm-search-row input:focus{border-color:var(--blue);}
.tm-search-row input::placeholder{color:var(--ink-faint);}
.tm-search-row select{height:40px;border:1px solid var(--border-md);border-radius:var(--radius);background:var(--white);color:var(--ink);padding:0 12px;font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;min-width:140px;outline:none;}
.tm-filter-bar{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:8px 12px;display:flex;align-items:center;gap:6px;overflow-x:auto;scrollbar-width:none;margin-bottom:8px;}
.tm-filter-bar::-webkit-scrollbar{display:none;}
.tm-filter-label{font-size:12px;color:var(--ink-faint);margin-right:4px;white-space:nowrap;flex-shrink:0;}
.tm-tag{font-size:12px;padding:5px 13px;border-radius:20px;border:1px solid var(--border-md);background:transparent;color:var(--ink-muted);cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;flex-shrink:0;transition:all 0.15s;}
.tm-tag:hover{border-color:var(--ink);color:var(--ink);}
.tm-tag.active{background:var(--ink);color:var(--white);border-color:var(--ink);}
.tm-main{display:flex;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;max-height:500px;}
.tm-sidebar{width:180px;min-width:180px;border-right:1px solid var(--border);background:var(--white);padding:16px 12px;overflow-y:auto;}
.tm-sidebar-section{margin-bottom:20px;}
.tm-sidebar-label{font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:8px;padding:0 6px;}
.tm-sidebar-item{display:flex;align-items:center;justify-content:space-between;padding:7px 8px;border-radius:var(--radius);cursor:pointer;font-size:13px;color:var(--ink-muted);margin-bottom:2px;user-select:none;}
.tm-sidebar-item:hover{background:var(--off);color:var(--ink);}
.tm-sidebar-item.active{background:var(--blue-light);color:var(--blue);font-weight:500;}
.tm-count{font-size:11px;color:var(--ink-faint);background:var(--off);border-radius:10px;padding:1px 7px;min-width:22px;text-align:center;}
.tm-sidebar-item.active .tm-count{background:rgba(37,99,235,0.12);color:var(--blue);}
.tm-content{flex:1;padding:16px;min-width:0;overflow-y:auto;background:var(--off);}
.tm-result-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.tm-result-count{font-size:13px;color:var(--ink-muted);}
.tm-sort-row{display:flex;align-items:center;gap:8px;}
.tm-sort-row label{font-size:12px;color:var(--ink-faint);}
.tm-sort-row select{font-size:13px;border:1px solid var(--border-md);border-radius:var(--radius);background:var(--white);color:var(--ink);padding:5px 10px;cursor:pointer;font-family:'DM Sans',sans-serif;outline:none;}
.tm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px;}
.tm-card{background:var(--white);border:2px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;cursor:pointer;transition:border-color 0.15s,box-shadow 0.15s;position:relative;}
.tm-card:hover{border-color:var(--blue);box-shadow:0 4px 20px rgba(37,99,235,0.1);}
.tm-card.tm-selected{border-color:var(--blue);}
.tm-selected-badge{position:absolute;top:10px;right:10px;background:var(--blue);color:#fff;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;z-index:5;}
.tm-thumb{height:140px;background:var(--off);position:relative;overflow:hidden;}
.tm-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.tm-thumb iframe{width:200%;height:200%;transform:scale(0.5);transform-origin:top left;pointer-events:none;border:none;background:#fff;}
.tm-thumb-overlay{position:absolute;inset:0;background:rgba(0,0,0,0);display:flex;align-items:center;justify-content:center;transition:background 0.2s;opacity:0;}
.tm-card:hover .tm-thumb-overlay{background:rgba(0,0,0,0.35);opacity:1;}
.tm-preview-btn{padding:7px 18px;background:var(--white);color:var(--ink);border:none;border-radius:var(--radius);font-size:13px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;}
.tm-card-body{padding:12px 14px 8px;}
.tm-card-name{font-size:14px;font-weight:500;color:var(--ink);margin-bottom:3px;}
.tm-card-desc{font-size:12px;color:var(--ink-muted);line-height:1.5;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.tm-card-tags{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px;}
.tm-card-tag{font-size:10px;padding:2px 7px;border-radius:10px;background:var(--off);color:var(--ink-faint);}
.tm-card-footer{padding:0 14px 12px;display:flex;gap:6px;}
.tm-card-preview{flex:1;font-size:12px;padding:6px 0;border-radius:var(--radius);border:1px solid var(--border-md);background:transparent;color:var(--ink-muted);cursor:pointer;font-family:'DM Sans',sans-serif;text-align:center;}
.tm-card-preview:hover{border-color:var(--ink);color:var(--ink);}
.tm-card-select{flex:1;font-size:12px;padding:6px 0;border-radius:var(--radius);border:none;background:var(--ink);color:var(--white);cursor:pointer;font-family:'DM Sans',sans-serif;text-align:center;font-weight:500;}
.tm-card-select:hover{opacity:0.85;}
.tm-card.tm-selected .tm-card-select{background:var(--blue);}
.tm-empty{display:none;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;text-align:center;}
.tm-empty-icon{font-size:40px;margin-bottom:12px;opacity:0.4;}
.tm-empty-title{font-size:16px;font-weight:500;color:var(--ink);margin-bottom:6px;}
.tm-empty-sub{font-size:13px;color:var(--ink-muted);}
.tm-empty-reset{margin-top:16px;font-size:13px;padding:8px 18px;border:1px solid var(--border-md);border-radius:var(--radius);background:transparent;color:var(--ink-muted);cursor:pointer;font-family:'DM Sans',sans-serif;}
.tm-empty-reset:hover{border-color:var(--ink);color:var(--ink);}

/* Buttons */
.btn-row{display:flex;gap:12px;margin-top:32px;}
.btn{padding:13px 28px;border-radius:var(--radius);font-size:15px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all 0.2s;border:none;}
.btn-primary{background:var(--ink);color:var(--white);}
.btn-primary:hover{opacity:0.85;}
.btn-secondary{background:var(--white);color:var(--ink);border:1px solid var(--border-md);}
.btn-secondary:hover{background:var(--paper);}
.btn-success{background:var(--green);color:var(--white);}
.btn-success:hover{opacity:0.9;}
.btn-success:disabled{opacity:0.6;cursor:not-allowed;}

.errors-box{background:var(--red-light);border:1px solid rgba(220,38,38,0.2);border-radius:var(--radius);padding:14px 16px;margin-bottom:24px;}
.errors-box p{font-size:14px;color:var(--red);line-height:1.6;}

@media(max-width:640px){
  nav{padding:0 20px;}
  .progress-wrap,.main{padding-left:20px;padding-right:20px;}
  .tm-sidebar{display:none;}
  .tm-filter-bar{display:none;}
  .tm-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr));}
  .tm-thumb{height:100px;}
}
</style>
</head>
<body>

<nav>
  <a class="logo" href="/">{{ app_name | lower }}<em>.</em></a>
  <span class="nav-user">Hi, {{ user.name }} &nbsp;·&nbsp; <a href="/logout">Logout</a></span>
</nav>

<div class="progress-wrap">
  <div class="steps-bar">
    <div class="step-dot active" id="dot1">1</div>
    <div class="step-line" id="line1"></div>
    <div class="step-dot pending" id="dot2">2</div>
    <div class="step-line" id="line2"></div>
    <div class="step-dot pending" id="dot3">3</div>
  </div>
  <div class="steps-labels">
    <span class="active" id="label1">Choose type</span>
    <span id="label2">Add details</span>
    <span id="label3">Go live</span>
  </div>
</div>

<div class="main">

  {% if flash_errors and flash_errors.length %}
  <div class="errors-box" id="flash-errors">
    {% for e in flash_errors %}
    <p>{{ e }}</p>
    {% endfor %}
  </div>
  {% endif %}

  <form method="POST" action="/dashboard/site/create" id="wizard-form">
    <input type="hidden" name="site_type" value="linktree">
    <input type="hidden" name="template_id" id="template_id" value="minimal">

    <!-- STEP 1: Type -->
    <div class="step-panel active" id="step1">
      <div class="step-heading">What are you building?</div>
      <div class="step-sub">Your personal page with all your links and info.</div>

      <div class="single-type">
        <div class="st-icon"><i class="ti ti-link"></i></div>
        <div class="st-text">
          <div class="st-name">Biolink / Mini site</div>
          <div class="st-desc">Your links, services, social, and more — all in one page</div>
        </div>
        <div class="st-check"><i class="ti ti-check"></i></div>
      </div>

      <div class="info-strip">
        <i class="ti ti-arrow-right"></i>
        After setup you'll land in the <strong style="color:var(--ink);margin-left:4px;">Biolink builder</strong> to customise your page
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-primary" onclick="goStep(2)">Continue →</button>
      </div>
    </div>

    <!-- STEP 2: Details -->
    <div class="step-panel" id="step2">
      <div class="step-heading">Tell us about yourself</div>
      <div class="step-sub">A few details to get your page started.</div>

      <div class="field">
        <label>Your name</label>
        <input type="text" name="title" id="title-input" placeholder="e.g. Abhi Singh" autocomplete="off">
      </div>
      <div class="field">
        <label>Bio</label>
        <textarea name="bio" placeholder="Creator · Photographer · Based in India"></textarea>
      </div>
      <div class="field">
        <label>Short description <span style="font-weight:400;color:var(--ink-faint)">(optional)</span></label>
        <textarea name="description" placeholder="Tell visitors what you do in 1–2 sentences..." style="min-height:70px;"></textarea>
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-secondary" onclick="goStep(1)">← Back</button>
        <button type="button" class="btn btn-primary" onclick="goStep(3)">Continue →</button>
      </div>
    </div>

    <!-- STEP 3: Theme + subdomain -->
    <div class="step-panel" id="step3">
      <div class="step-heading">Almost there!</div>
      <div class="step-sub">Pick your theme and web address.</div>

      <div class="field">
        <label>Choose a theme</label>
        <!-- Search row -->
        <div class="tm-search-row">
          <input type="text" id="tm-search" placeholder="Search themes…">
          <select id="tm-cat-select">
            <option value="all">All categories</option>
          </select>
        </div>
        <!-- Tag filter bar -->
        <div class="tm-filter-bar" id="tm-filter-bar">
          <span class="tm-filter-label">Filter:</span>
          <button type="button" class="tm-tag active" data-tag="all" onclick="filterByTag('all',this)">All</button>
        </div>
        <!-- Marketplace layout: sidebar + content -->
        <div class="tm-main">
          <aside class="tm-sidebar">
            <div class="tm-sidebar-section" id="tm-cat-sidebar">
              <div class="tm-sidebar-label">Category</div>
              <div class="tm-sidebar-item active" data-cat="all" onclick="filterByCategory('all',this)">
                All themes <span class="tm-count" id="count-all">0</span>
              </div>
            </div>
            <div class="tm-sidebar-section" id="tm-tag-sidebar">
              <div class="tm-sidebar-label">Style</div>
            </div>
          </aside>
          <main class="tm-content">
            <div class="tm-result-row">
              <span class="tm-result-count" id="tm-result-count">Loading…</span>
              <div class="tm-sort-row">
                <label>Sort:</label>
                <select id="tm-sort" onchange="sortThemes(this.value)">
                  <option value="default">Default order</option>
                  <option value="name">Name A–Z</option>
                </select>
              </div>
            </div>
            <div class="tm-grid" id="tm-grid"></div>
            <div id="tm-empty" class="tm-empty">
              <div class="tm-empty-icon">🎨</div>
              <div class="tm-empty-title">No themes found</div>
              <div class="tm-empty-sub">Try a different category or clear the filter.</div>
              <button type="button" class="tm-empty-reset" onclick="resetFilters()">Clear filters</button>
            </div>
          </main>
        </div>
      </div>

      <div class="field">
        <label>Your web address</label>
        <div class="subdomain-wrap">
          <input type="text" name="subdomain" id="subdomain-input" placeholder="yourname" autocomplete="off">
          <span class="subdomain-suffix">.{{ base_domain }}</span>
        </div>
        <div class="field-hint">Lowercase letters, numbers, hyphens only.</div>
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-secondary" onclick="goStep(2)">← Back</button>
        <button type="submit" class="btn btn-success" id="launch-btn">🚀 Launch my site</button>
      </div>
    </div>

  </form>
</div>

<script>
var currentStep = 1;
var ALL_THEMES = {{ themes | dump | safe }};

// ── Theme marketplace (mirrors templates.njk JS, adapted for wizard) ────────
var allCards      = [];
var activeCategory = 'all';
var activeTag      = 'all';
var searchQuery    = '';

function cap(s) {
  return s.replace(/-/g,' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); });
}

function updateResultCount() {
  var visible = allCards.filter(function(c){ return c.style.display !== 'none'; }).length;
  var el = document.getElementById('tm-result-count');
  if (el) el.textContent = visible === allCards.length
    ? 'Showing all ' + allCards.length + ' theme' + (allCards.length !== 1 ? 's' : '')
    : 'Showing ' + visible + ' of ' + allCards.length + ' themes';
  var emptyEl = document.getElementById('tm-empty');
  if (emptyEl) emptyEl.style.display = visible === 0 ? 'flex' : 'none';
}

function applyFilters() {
  var q = searchQuery.toLowerCase().trim();
  allCards.forEach(function(card) {
    var catVals = (card.dataset.cats || '').split(',');
    var tagVals = (card.dataset.tags || '').split(',');
    var name    = card.dataset.name || '';
    var catMatch = activeCategory === 'all' || catVals.indexOf(activeCategory) > -1;
    var tagMatch = activeTag === 'all' || tagVals.indexOf(activeTag) > -1;
    var qMatch   = !q || name.indexOf(q) > -1 || (card.dataset.tags||'').indexOf(q) > -1;
    card.style.display = (catMatch && tagMatch && qMatch) ? '' : 'none';
  });
  updateResultCount();
}

function filterByCategory(cat, el) {
  activeCategory = cat;
  var cs = document.getElementById('tm-cat-select');
  if (cs) cs.value = cat;
  document.querySelectorAll('.tm-sidebar-item[data-cat]').forEach(function(s){ s.classList.remove('active'); });
  var target = (el && el.dataset && el.dataset.cat) ? el : document.querySelector('.tm-sidebar-item[data-cat="'+cat+'"]');
  if (target) target.classList.add('active');
  applyFilters();
}

function filterByTag(tag, el) {
  activeTag = tag;
  document.querySelectorAll('.tm-tag').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.tm-tag[data-tag="'+tag+'"]').forEach(function(t){ t.classList.add('active'); });
  document.querySelectorAll('.tm-sidebar-item[data-tag]').forEach(function(s){ s.classList.remove('active'); });
  var sItem = document.querySelector('.tm-sidebar-item[data-tag="'+tag+'"]');
  if (sItem) sItem.classList.add('active');
  applyFilters();
}

function sortThemes(val) {
  var grid = document.getElementById('tm-grid');
  var cards = Array.from(grid.querySelectorAll('.tm-card'));
  if (val === 'name') {
    cards.sort(function(a,b){ return (a.dataset.name||'').localeCompare(b.dataset.name||''); });
  } else {
    cards.sort(function(a,b){ return (parseInt(a.dataset.order||99))-(parseInt(b.dataset.order||99)); });
  }
  cards.forEach(function(c){ grid.appendChild(c); });
}

function resetFilters() {
  activeCategory = 'all';
  activeTag = 'all';
  searchQuery = '';
  var srch = document.getElementById('tm-search');
  if (srch) srch.value = '';
  var cs = document.getElementById('tm-cat-select');
  if (cs) cs.value = 'all';
  document.querySelectorAll('.tm-sidebar-item').forEach(function(s){ s.classList.remove('active'); });
  var allCat = document.querySelector('.tm-sidebar-item[data-cat="all"]');
  if (allCat) allCat.classList.add('active');
  document.querySelectorAll('.tm-tag').forEach(function(t){ t.classList.remove('active'); });
  var allTag = document.querySelector('.tm-tag[data-tag="all"]');
  if (allTag) allTag.classList.add('active');
  applyFilters();
}

function selectTemplate(slug, name) {
  allCards.forEach(function(c) {
    c.classList.remove('tm-selected');
    var badge = c.querySelector('.tm-selected-badge');
    if (badge) badge.remove();
  });
  var card = document.querySelector('.tm-card[data-slug="'+slug+'"]');
  if (card) {
    card.classList.add('tm-selected');
    card.insertAdjacentHTML('afterbegin','<div class="tm-selected-badge">✓ Selected</div>');
  }
  document.getElementById('template_id').value = slug;
}

function previewTheme(e, slug) {
  e.stopPropagation();
  window.open('/template-preview?id=' + slug, '_blank', 'width=420,height=800,noopener');
}

function renderTemplatePicker() {
  var grid       = document.getElementById('tm-grid');
  var catSidebar = document.getElementById('tm-cat-sidebar');
  var tagSidebar = document.getElementById('tm-tag-sidebar');
  var filterBar  = document.getElementById('tm-filter-bar');
  var catSelect  = document.getElementById('tm-cat-select');
  grid.innerHTML = '';

  var themes = ALL_THEMES.slice().sort(function(a,b){ return (a.order||99)-(b.order||99); });

  // Count categories + tags
  var catCounts = {};
  var tagCounts = {};
  themes.forEach(function(t) {
    (t.categories||['other']).forEach(function(c){ catCounts[c]=(catCounts[c]||0)+1; });
    (t.tags||[]).forEach(function(g){ tagCounts[g]=(tagCounts[g]||0)+1; });
  });

  // All themes count
  document.getElementById('count-all').textContent = themes.length;

  // Category sidebar + dropdown
  Object.keys(catCounts)
    .sort(function(a,b){ return catCounts[b]-catCounts[a]; })
    .forEach(function(cat) {
      var opt = document.createElement('option');
      opt.value = cat; opt.textContent = cap(cat);
      catSelect.appendChild(opt);
      var item = document.createElement('div');
      item.className = 'tm-sidebar-item';
      item.dataset.cat = cat;
      item.innerHTML = cap(cat) + ' <span class="tm-count">' + catCounts[cat] + '</span>';
      item.onclick = (function(c,el){ return function(){ filterByCategory(c,el); }; })(cat,item);
      catSidebar.appendChild(item);
    });

  // Tag pills (filter bar) + Style sidebar
  Object.keys(tagCounts)
    .sort(function(a,b){ return tagCounts[b]-tagCounts[a]; })
    .forEach(function(tag) {
      var pill = document.createElement('button');
      pill.type = 'button'; pill.className = 'tm-tag';
      pill.dataset.tag = tag; pill.textContent = cap(tag);
      pill.onclick = (function(g,el){ return function(){ filterByTag(g,el); }; })(tag,pill);
      filterBar.appendChild(pill);
      var item = document.createElement('div');
      item.className = 'tm-sidebar-item';
      item.dataset.tag = tag;
      item.innerHTML = cap(tag) + ' <span class="tm-count">' + tagCounts[tag] + '</span>';
      item.onclick = (function(g,el){ return function(){ filterByTag(g,el); }; })(tag,item);
      tagSidebar.appendChild(item);
    });

  // Build cards with iframe previews (same as marketplace)
  themes.forEach(function(t, idx) {
    var slug = t.slug;
    var name = t.name || t.slug;
    var card = document.createElement('div');
    card.className = 'tm-card' + (idx === 0 ? ' tm-selected' : '');
    card.dataset.slug  = slug;
    card.dataset.name  = name.toLowerCase();
    card.dataset.cats  = (t.categories||['other']).join(',');
    card.dataset.tags  = (t.tags||[]).join(',');
    card.dataset.order = t.order || 99;
    card.onclick = (function(s,n){ return function(){ selectTemplate(s,n); }; })(slug,name);

    var thumbHtml = t.hasPreview
      ? '<img src="'+t.previewUrl+'" alt="'+name+'" loading="lazy">'
      : '<iframe src="/template-preview?id='+slug+'" loading="lazy" scrolling="no" title="'+name+' preview"></iframe>';

    var tags = (t.tags||[]).slice(0,3).map(function(tag){ return '<span class="tm-card-tag">'+tag+'</span>'; }).join('');
    var safeName = name.replace(/\\/g,'\\\\').replace(/'/g,"\\'");

    card.innerHTML =
      (idx===0 ? '<div class="tm-selected-badge">✓ Selected</div>' : '') +
      '<div class="tm-thumb">' +
        thumbHtml +
        '<div class="tm-thumb-overlay">' +
          '<button type="button" class="tm-preview-btn" onclick="previewTheme(event,\''+slug+'\')">Preview</button>' +
        '</div>' +
      '</div>' +
      '<div class="tm-card-body">' +
        '<div class="tm-card-name">'+name+'</div>' +
        (t.description ? '<div class="tm-card-desc">'+t.description+'</div>' : '') +
        (tags ? '<div class="tm-card-tags">'+tags+'</div>' : '') +
      '</div>' +
      '<div class="tm-card-footer">' +
        '<button type="button" class="tm-card-preview" onclick="previewTheme(event,\''+slug+'\')">Preview</button>' +
        '<button type="button" class="tm-card-select" onclick="selectTemplate(\''+slug+'\',\''+safeName+'\')">Select</button>' +
      '</div>';

    grid.appendChild(card);
  });

  allCards = Array.from(grid.querySelectorAll('.tm-card'));

  // Set default selection
  if (themes.length) {
    document.getElementById('template_id').value = themes[0].slug;
  }

  // Wire search + cat dropdown
  document.getElementById('tm-search').addEventListener('input', function(){ searchQuery = this.value; applyFilters(); });
  document.getElementById('tm-cat-select').addEventListener('change', function(){ filterByCategory(this.value); });

  updateResultCount();
}

// ── Step navigation ───────────────────────────────────────────────────────
function goStep(n) {
  if (n === 3) {
    var title = document.getElementById('title-input').value.trim();
    if (!title) {
      document.getElementById('title-input').focus();
      document.getElementById('title-input').style.borderColor = '#dc2626';
      return;
    }
    // Auto-suggest subdomain from name
    var suggestion = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    var subInput = document.getElementById('subdomain-input');
    if (!subInput.value && suggestion) subInput.value = suggestion;

    // Render themes once
    if (!document.querySelector('.tm-card')) {
      renderTemplatePicker();
    }
  }

  document.querySelectorAll('.step-panel').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('step' + n).classList.add('active');
  currentStep = n;

  for (var i = 1; i <= 3; i++) {
    var dot   = document.getElementById('dot' + i);
    var label = document.getElementById('label' + i);
    dot.className   = 'step-dot ' + (i < n ? 'done' : i === n ? 'active' : 'pending');
    label.className = i < n ? 'done' : i === n ? 'active' : '';
    if (i < 3) {
      document.getElementById('line' + i).className = 'step-line' + (i < n ? ' done' : '');
    }
  }

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Sanitize subdomain
document.getElementById('subdomain-input').addEventListener('input', function() {
  this.value = this.value.toLowerCase().replace(/[^a-z0-9-]/g, '');
});

// Clear red border on title focus
document.getElementById('title-input').addEventListener('input', function() {
  this.style.borderColor = '';
});

// Prevent double-submit
document.getElementById('wizard-form').addEventListener('submit', function() {
  var btn = document.getElementById('launch-btn');
  btn.disabled = true;
  btn.textContent = 'Launching…';
});

{% if flash_errors and flash_errors.length %}
window.addEventListener('DOMContentLoaded', function() {
  var el = document.getElementById('flash-errors');
  if (el) el.scrollIntoView({ behavior: 'smooth' });
});
{% endif %}
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Create your site — {{ app_name }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1a18;--ink-muted:#6b6b66;--ink-faint:#b0afa8;--white:#fff;--off:#f8f7f4;--paper:#f2f0eb;
  --border:rgba(26,26,24,0.1);--border-md:rgba(26,26,24,0.18);
  --blue:#2563eb;--blue-light:#eff4ff;--blue-mid:#c7d9fd;
  --green:#16a34a;--green-light:#f0fdf4;
  --red:#dc2626;--red-light:#fef2f2;
  --radius:10px;--radius-lg:16px;--radius-xl:24px;
}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);min-height:100vh;}

nav{display:flex;align-items:center;justify-content:space-between;padding:0 40px;height:58px;background:var(--white);border-bottom:1px solid var(--border);}
.logo{font-family:'DM Serif Display',serif;font-size:20px;text-decoration:none;color:var(--ink);}
.logo em{font-style:italic;color:var(--blue);}
.nav-user{font-size:13px;color:var(--ink-muted);}
.nav-user a{color:var(--ink-faint);text-decoration:none;}

.progress-wrap{padding:32px 40px 0;max-width:680px;margin:0 auto;}
.steps-bar{display:flex;align-items:center;gap:0;margin-bottom:8px;}
.step-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;flex-shrink:0;transition:all 0.3s;}
.step-dot.done{background:var(--ink);color:var(--white);}
.step-dot.active{background:var(--blue);color:var(--white);}
.step-dot.pending{background:var(--paper);color:var(--ink-faint);border:1px solid var(--border);}
.step-line{flex:1;height:1px;background:var(--border);}
.step-line.done{background:var(--ink);}
.steps-labels{display:flex;justify-content:space-between;margin-top:8px;}
.steps-labels span{font-size:12px;color:var(--ink-faint);text-align:center;flex:1;}
.steps-labels span.active{color:var(--blue);font-weight:500;}
.steps-labels span.done{color:var(--ink-muted);}

.main{max-width:680px;margin:32px auto;padding:0 40px 80px;}

.step-panel{display:none;}
.step-panel.active{display:block;animation:fadeUp 0.35s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

.step-heading{font-family:'DM Serif Display',serif;font-size:28px;font-weight:400;letter-spacing:-0.5px;margin-bottom:6px;}
.step-sub{font-size:15px;color:var(--ink-muted);margin-bottom:32px;}

.type-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:32px;}
.type-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius-lg);padding:20px 16px;cursor:pointer;transition:all 0.2s;text-align:center;user-select:none;}
.type-card:hover{border-color:var(--border-md);transform:translateY(-2px);}
.type-card.selected{border-color:var(--blue);background:var(--blue-light);}
.type-card input{display:none;}
.type-emoji{font-size:28px;margin-bottom:10px;display:block;}
.type-name{font-size:14px;font-weight:500;color:var(--ink);margin-bottom:3px;}
.type-desc{font-size:12px;color:var(--ink-faint);}

.field{margin-bottom:20px;}
.field label{display:block;font-size:13px;font-weight:500;color:var(--ink-muted);margin-bottom:7px;}
.field input,.field textarea,.field select{width:100%;padding:11px 14px;border:1px solid var(--border-md);border-radius:var(--radius);font-size:15px;font-family:'DM Sans',sans-serif;color:var(--ink);background:var(--white);outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
.field input:focus,.field textarea:focus,.field select:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);}
.field textarea{resize:vertical;min-height:90px;}
.field-hint{font-size:12px;color:var(--ink-faint);margin-top:5px;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}

.subdomain-wrap{display:flex;align-items:center;border:1px solid var(--border-md);border-radius:var(--radius);overflow:hidden;background:var(--white);}
.subdomain-suffix{padding:11px 14px;background:var(--paper);font-size:14px;color:var(--ink-muted);border-left:1px solid var(--border);white-space:nowrap;flex-shrink:0;}
.subdomain-wrap input{border:none;outline:none;padding:11px 14px;font-size:15px;font-family:'DM Sans',sans-serif;color:var(--ink);flex:1;background:transparent;}
.subdomain-wrap:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);}

.theme-grid{display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap;}
.theme-swatch{width:48px;height:48px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all 0.2s;position:relative;}
.theme-swatch.selected{border-color:var(--ink);transform:scale(1.1);}
.theme-swatch input{display:none;}

/* Template card */
.tpl-card{background:var(--white);border:2px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;cursor:pointer;transition:all 0.2s;user-select:none;}
.tpl-card:hover{border-color:var(--border-md);transform:translateY(-2px);}
.tpl-card.selected{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.1);}
.tpl-thumb{width:100%;aspect-ratio:16/9;background:var(--paper);display:flex;align-items:center;justify-content:center;font-size:28px;overflow:hidden;}
.tpl-thumb img{width:100%;height:100%;object-fit:cover;}
.tpl-info{padding:10px 12px;}
.tpl-name{font-size:13px;font-weight:600;color:var(--ink);}
.tpl-desc{font-size:11px;color:var(--ink-faint);margin-top:2px;}

.btn-row{display:flex;gap:12px;margin-top:32px;}
.btn{padding:13px 28px;border-radius:var(--radius);font-size:15px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all 0.2s;border:none;}
.btn-primary{background:var(--ink);color:var(--white);}
.btn-primary:hover{opacity:0.85;}
.btn-secondary{background:var(--white);color:var(--ink);border:1px solid var(--border-md);}
.btn-secondary:hover{background:var(--paper);}
.btn-success{background:var(--green);color:var(--white);}
.btn-success:hover{opacity:0.9;}
.btn-success:disabled{opacity:0.6;cursor:not-allowed;}

.errors-box{background:var(--red-light);border:1px solid rgba(220,38,38,0.2);border-radius:var(--radius);padding:14px 16px;margin-bottom:24px;}
.errors-box p{font-size:14px;color:var(--red);line-height:1.6;}

@media(max-width:600px){
  nav{padding:0 20px;}
  .progress-wrap,.main{padding-left:20px;padding-right:20px;}
  .type-grid{grid-template-columns:repeat(2,1fr);}
  .field-row{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<nav>
  <a class="logo" href="/">{{ app_name | lower }}<em>.</em></a>
  <span class="nav-user">Hi, {{ user.name }} &nbsp;·&nbsp; <a href="/logout">Logout</a></span>
</nav>

<div class="progress-wrap">
  <div class="steps-bar">
    <div class="step-dot active" id="dot1">1</div>
    <div class="step-line" id="line1"></div>
    <div class="step-dot pending" id="dot2">2</div>
    <div class="step-line" id="line2"></div>
    <div class="step-dot pending" id="dot3">3</div>
  </div>
  <div class="steps-labels">
    <span class="active" id="label1">Choose type</span>
    <span id="label2">Add details</span>
    <span id="label3">Go live</span>
  </div>
</div>

<div class="main">

  {% if flash_errors and flash_errors.length %}
  <div class="errors-box" id="flash-errors">
    {% for e in flash_errors %}
    <p>{{ e }}</p>
    {% endfor %}
  </div>
  {% endif %}

  <form method="POST" action="/dashboard/site/create" id="wizard-form">
    <input type="hidden" name="template_id" id="template_id" value="minimal">

    <!-- STEP 1: What are you building? -->
    <div class="step-panel active" id="step1">
      <div class="step-heading">What are you building?</div>
      <div class="step-sub">Pick a type — we'll set things up for you.</div>
      <div class="type-grid">
        <label class="type-card" onclick="selectType(this,'business')">
          <input type="radio" name="site_type" value="business">
          <span class="type-emoji">🏪</span>
          <div class="type-name">Business</div>
          <div class="type-desc">Shop, salon, clinic, restaurant</div>
        </label>
        <label class="type-card" onclick="selectType(this,'freelancer')">
          <input type="radio" name="site_type" value="freelancer">
          <span class="type-emoji">💼</span>
          <div class="type-name">Freelancer</div>
          <div class="type-desc">Portfolio &amp; services</div>
        </label>
        <label class="type-card" onclick="selectType(this,'linktree')">
          <input type="radio" name="site_type" value="linktree">
          <span class="type-emoji">🔗</span>
          <div class="type-name">Link in Bio</div>
          <div class="type-desc">All your links in one place</div>
        </label>
        <label class="type-card" onclick="selectType(this,'blog')">
          <input type="radio" name="site_type" value="blog">
          <span class="type-emoji">✍️</span>
          <div class="type-name">Blog</div>
          <div class="type-desc">Articles &amp; content</div>
        </label>
        <label class="type-card" onclick="selectType(this,'product')">
          <input type="radio" name="site_type" value="product">
          <span class="type-emoji">📦</span>
          <div class="type-name">Product</div>
          <div class="type-desc">Showcase what you sell</div>
        </label>
        <label class="type-card" onclick="selectType(this,'other')">
          <input type="radio" name="site_type" value="other">
          <span class="type-emoji">✨</span>
          <div class="type-name">Other</div>
          <div class="type-desc">Something else entirely</div>
        </label>
      </div>
      <div class="btn-row">
        <button type="button" class="btn btn-primary" onclick="goStep(2)">Continue →</button>
      </div>
    </div>

    <!-- STEP 2: Details -->
    <div class="step-panel" id="step2">
      <div class="step-heading">Tell us about it</div>
      <div class="step-sub" id="step2-sub">A few details to get started.</div>

      <div class="field">
        <label id="title-label">Business name</label>
        <input type="text" name="title" id="title-input" placeholder="e.g. Glamour Studio" autocomplete="off">
      </div>

      <!-- Business fields -->
      <div id="fields-business">
        <div class="field-row">
          <div class="field">
            <label>Category</label>
            <select name="category">
              <option value="">Select category</option>
              <option>Salon &amp; Beauty</option>
              <option>Gym &amp; Fitness</option>
              <option>Restaurant &amp; Food</option>
              <option>Health &amp; Clinic</option>
              <option>Education &amp; Tutor</option>
              <option>Legal Services</option>
              <option>Home Services</option>
              <option>Retail Shop</option>
              <option>Other</option>
            </select>
          </div>
          <div class="field">
            <label>City</label>
            <input type="text" name="city" placeholder="e.g. Ludhiana">
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label>Phone number</label>
            <input type="text" name="phone" placeholder="+91 98765 43210">
          </div>
          <div class="field">
            <label>WhatsApp number</label>
            <input type="text" name="whatsapp" placeholder="+91 98765 43210">
          </div>
        </div>
        <div class="field">
          <label>Address</label>
          <input type="text" name="address" placeholder="Model Town, Ludhiana">
        </div>
      </div>

      <!-- Freelancer fields -->
      <div id="fields-freelancer" style="display:none">
        <div class="field">
          <label>Your skills</label>
          <input type="text" name="skills" placeholder="Web design, Photography, Writing...">
        </div>
        <div class="field">
          <label>City</label>
          <input type="text" name="city_freelancer" placeholder="e.g. Ludhiana">
        </div>
      </div>

      <!-- Link-in-bio fields -->
      <div id="fields-linktree" style="display:none">
        <div class="field">
          <label>Your bio</label>
          <textarea name="bio" placeholder="Creator · Photographer · Based in India"></textarea>
        </div>
      </div>

      <!-- Blog fields -->
      <div id="fields-blog" style="display:none">
        <div class="field">
          <label>Blog topic</label>
          <input type="text" name="blog_topic" placeholder="Travel, Tech, Finance...">
        </div>
        <div class="field">
          <label>Author name</label>
          <input type="text" name="author" placeholder="Your name">
        </div>
      </div>

      <!-- Product fields -->
      <div id="fields-product" style="display:none">
        <div class="field">
          <label>What do you sell?</label>
          <textarea name="product_desc" placeholder="Describe your product or service in a few lines..."></textarea>
        </div>
        <div class="field">
          <label>City</label>
          <input type="text" name="city_product" placeholder="e.g. Ludhiana">
        </div>
      </div>

      <div class="field">
        <label>Short description</label>
        <textarea name="description" placeholder="Tell visitors what you do in 1–2 sentences..."></textarea>
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-secondary" onclick="goStep(1)">← Back</button>
        <button type="button" class="btn btn-primary" onclick="goStep(3)">Continue →</button>
      </div>
    </div>

    <!-- STEP 3: Go live -->
    <div class="step-panel" id="step3">
      <div class="step-heading">Almost there!</div>
      <div class="step-sub">Pick your design and web address.</div>

      <!-- Template picker -->
      <div class="field">
        <label>Choose a design</label>
        <div id="template-grid" style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:4px;"></div>
        <p id="no-themes-msg" style="display:none;font-size:13px;color:var(--ink-muted);padding:8px 0;">No themes available for this type yet.</p>
      </div>

      <div class="field">
        <label>Your web address</label>
        <div class="subdomain-wrap">
          <input type="text" name="subdomain" id="subdomain-input" placeholder="yourname" autocomplete="off">
          <span class="subdomain-suffix">.{{ base_domain }}</span>
        </div>
        <div class="field-hint">Lowercase letters, numbers, hyphens only. Your URL: yourname.{{ base_domain }}</div>
      </div>

      <div class="field">
        <label>Color theme</label>
        <div class="theme-grid">
          <label class="theme-swatch selected" style="background:#1a1a18;" title="Ink" onclick="selectTheme(this,'ink')">
            <input type="radio" name="theme" value="ink" checked>
          </label>
          <label class="theme-swatch" style="background:#2563eb;" title="Blue" onclick="selectTheme(this,'blue')">
            <input type="radio" name="theme" value="blue">
          </label>
          <label class="theme-swatch" style="background:#16a34a;" title="Green" onclick="selectTheme(this,'green')">
            <input type="radio" name="theme" value="green">
          </label>
          <label class="theme-swatch" style="background:#dc2626;" title="Red" onclick="selectTheme(this,'red')">
            <input type="radio" name="theme" value="red">
          </label>
          <label class="theme-swatch" style="background:#7c3aed;" title="Purple" onclick="selectTheme(this,'purple')">
            <input type="radio" name="theme" value="purple">
          </label>
          <label class="theme-swatch" style="background:#d97706;" title="Amber" onclick="selectTheme(this,'amber')">
            <input type="radio" name="theme" value="amber">
          </label>
        </div>
      </div>

      <div class="btn-row">
        <button type="button" class="btn btn-secondary" onclick="goStep(2)">← Back</button>
        <button type="submit" class="btn btn-success" id="launch-btn">🚀 Launch my site</button>
      </div>
    </div>

  </form>
</div>

<script>
var currentType = '';
var currentStep = 1;

// ── All themes from server (injected by dashController) ──────────────────────
var ALL_THEMES = {{ themes | dump | safe }};

// ── Theme picker ──────────────────────────────────────────────────────────────
function renderTemplatePicker(siteType) {
  var grid  = document.getElementById('template-grid');
  var noMsg = document.getElementById('no-themes-msg');
  grid.innerHTML = '';

  var filtered = ALL_THEMES.filter(function(t) {
    return t.for.includes('all') || t.for.includes(siteType);
  });

  if (!filtered.length) {
    noMsg.style.display = '';
    return;
  }
  noMsg.style.display = 'none';

  filtered.forEach(function(t, idx) {
    var card = document.createElement('div');
    card.className = 'tpl-card' + (idx === 0 ? ' selected' : '');
    card.dataset.slug = t.slug;
    card.onclick = function() { selectTemplate(t.slug); };

    var thumb = '<div class="tpl-thumb">';
    if (t.hasPreview) {
      thumb += '<img src="' + t.previewUrl + '" alt="' + t.name + '" loading="lazy">';
    } else {
      thumb += '🎨';
    }
    thumb += '</div>';

    card.innerHTML = thumb +
      '<div class="tpl-info">' +
        '<div class="tpl-name">' + t.name + '</div>' +
        (t.description ? '<div class="tpl-desc">' + t.description + '</div>' : '') +
      '</div>';

    grid.appendChild(card);
  });

  // Auto-select first
  if (filtered.length) {
    document.getElementById('template_id').value = filtered[0].slug;
  }
}

function selectTemplate(slug) {
  document.querySelectorAll('.tpl-card').forEach(function(c){ c.classList.remove('selected'); });
  var card = document.querySelector('.tpl-card[data-slug="' + slug + '"]');
  if (card) card.classList.add('selected');
  document.getElementById('template_id').value = slug;
}

// ── Site type selection ───────────────────────────────────────────────────────
function selectType(el, type) {
  document.querySelectorAll('.type-card').forEach(function(c){ c.classList.remove('selected'); });
  el.classList.add('selected');
  currentType = type;

  var labels = {
    business: 'Business name', freelancer: 'Your name', linktree: 'Your name',
    blog: 'Blog name', product: 'Brand / business name', other: 'Site name'
  };
  var subs = {
    business: 'Tell us about your business.', freelancer: 'Tell us about your work.',
    linktree: 'Set up your link in bio page.', blog: 'Set up your blog.',
    product: 'Tell us about your product.', other: 'Tell us about your site.'
  };
  var placeholders = {
    business: 'e.g. Glamour Studio', freelancer: 'e.g. Abhi Singh', linktree: 'e.g. Abhi Singh',
    blog: 'e.g. The Daily Grind', product: 'e.g. FreshBox', other: 'e.g. My Site'
  };

  document.getElementById('title-label').textContent = labels[type] || 'Name';
  document.getElementById('step2-sub').textContent = subs[type] || 'A few details.';
  document.getElementById('title-input').placeholder = placeholders[type] || '';

  ['fields-business','fields-freelancer','fields-linktree','fields-blog','fields-product']
    .forEach(function(id){ document.getElementById(id).style.display = 'none'; });

  var map = {
    business:'fields-business', freelancer:'fields-freelancer', linktree:'fields-linktree',
    blog:'fields-blog', product:'fields-product'
  };
  if (map[type]) document.getElementById(map[type]).style.display = 'block';

  // Update template picker for the new type
  renderTemplatePicker(type);
}

function selectTheme(el, theme) {
  document.querySelectorAll('.theme-swatch').forEach(function(s){ s.classList.remove('selected'); });
  el.classList.add('selected');
}

function goStep(n) {
  if (n === 2 && !currentType) {
    alert('Please select a site type first.');
    return;
  }
  if (n === 3) {
    var title = document.getElementById('title-input').value.trim();
    if (!title) {
      document.getElementById('title-input').focus();
      document.getElementById('title-input').style.borderColor = 'var(--red)';
      return;
    }
    // Auto-fill subdomain suggestion from title
    var suggestion = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    var subInput = document.getElementById('subdomain-input');
    if (!subInput.value && suggestion) subInput.value = suggestion;

    // Render template picker if not already done
    if (!document.querySelector('.tpl-card')) {
      renderTemplatePicker(currentType || 'business');
    }
  }

  document.querySelectorAll('.step-panel').forEach(function(p){ p.classList.remove('active'); });
  document.getElementById('step' + n).classList.add('active');
  currentStep = n;

  for (var i = 1; i <= 3; i++) {
    var dot   = document.getElementById('dot' + i);
    var label = document.getElementById('label' + i);
    dot.className = 'step-dot ' + (i < n ? 'done' : i === n ? 'active' : 'pending');
    label.className = i < n ? 'done' : i === n ? 'active' : '';
    if (i < 3) {
      document.getElementById('line' + i).className = 'step-line' + (i < n ? ' done' : '');
    }
  }

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Sanitize subdomain input in real-time
document.getElementById('subdomain-input').addEventListener('input', function() {
  this.value = this.value.toLowerCase().replace(/[^a-z0-9-]/g, '');
});

// Prevent double-submit
document.getElementById('wizard-form').addEventListener('submit', function() {
  var btn = document.getElementById('launch-btn');
  btn.disabled = true;
  btn.textContent = 'Launching…';
});

{% if flash_errors and flash_errors.length %}
window.addEventListener('DOMContentLoaded', function() {
  document.getElementById('flash-errors').scrollIntoView({ behavior: 'smooth' });
});
{% endif %}
</script>
</body>
</html>

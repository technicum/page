<!-- ── SEO Settings modal ── -->
<div class="modal-overlay" id="seo-modal">
  <div class="modal-box">
    <div class="modal-head">
      <div class="modal-title">🔍 SEO Settings</div>
      <button class="modal-close" onclick="closeSeoModal()">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="seo-site-id">
      <p style="font-size:13px;color:var(--ink-muted);margin-bottom:20px;padding:10px 14px;background:var(--off);border-radius:var(--radius);border-left:3px solid var(--blue);">
        Help your bio link appear in Google, WhatsApp previews, and social media.
      </p>
      <div class="modal-field">
        <label>SEO Title <span style="font-weight:400;color:var(--ink-faint);">(shown in search results — defaults to your name)</span></label>
        <input type="text" id="seo-title" placeholder="e.g. Rahul Sharma — Hair Stylist in Ludhiana" maxlength="70">
      </div>
      <div class="modal-field">
        <label>Meta Description <span style="font-weight:400;color:var(--ink-faint);">(snippet shown in Google — aim for 120–160 chars)</span></label>
        <textarea id="seo-description" rows="3" style="resize:vertical;" placeholder="e.g. Book Rahul Sharma for expert hair styling in Ludhiana. 10+ years experience. Walk-ins welcome."></textarea>
      </div>
      <div class="modal-field">
        <label>Social Share Image URL <span style="font-weight:400;color:var(--ink-faint);">(WhatsApp, Facebook, LinkedIn preview image)</span></label>

{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{font-family:"DM Sans",sans-serif;background:var(--off);}
.layout{display:flex;min-height:100vh;}
.sidebar{width:240px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;box-shadow:2px 0 8px rgba(0,0,0,0.03);}
.sidebar-logo{font-family:"DM Serif Display",serif;font-size:20px;padding:28px 24px;border-bottom:1px solid var(--border);text-decoration:none;color:var(--ink);display:block;font-weight:600;}
.sidebar-logo em{font-style:italic;color:var(--blue);}
.sidebar-nav{padding:20px 12px;flex:1;}
.nav-item{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:var(--radius);font-size:14px;color:var(--ink-muted);text-decoration:none;transition:all 0.15s;margin-bottom:4px;font-weight:500;}
.nav-item:hover{background:var(--off);color:var(--ink);}
.nav-item.active{background:var(--blue-light);color:var(--blue);font-weight:600;}
.nav-item::before{font-size:16px;}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border);background:var(--off);}
.user-chip{display:flex;align-items:center;gap:12px;padding:12px;border-radius:var(--radius);background:var(--white);transition:all 0.15s;}
.user-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg, var(--blue), var(--blue-light));color:var(--white);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;flex-shrink:0;}
.user-name{font-size:13px;font-weight:600;color:var(--ink);}
.user-plan{font-size:11px;color:var(--ink-muted);}
.logout-link{display:block;font-size:13px;color:var(--ink-faint);padding:8px 12px;margin-top:8px;border-radius:var(--radius);transition:all 0.15s;}
.logout-link:hover{color:var(--red);background:rgba(255,0,0,0.05);}
.content{flex:1;padding:40px;min-width:0;overflow-y:auto;}
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:36px;gap:20px;}
.page-title{font-family:"DM Serif Display",serif;font-size:32px;font-weight:400;letter-spacing:-0.5px;}
.btn-new{display:inline-flex;align-items:center;gap:8px;background:var(--blue);color:var(--white);padding:11px 24px;border-radius:var(--radius);font-size:14px;font-weight:600;transition:all 0.2s;border:none;cursor:pointer;white-space:nowrap;}
.btn-new:hover{background:var(--blue);opacity:0.9;transform:translateY(-1px);box-shadow:0 4px 12px rgba(59,130,246,0.3);}
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:36px;}
.stat-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;transition:all 0.2s;}
.stat-card:hover{border-color:var(--blue);box-shadow:0 4px 12px rgba(59,130,246,0.1);}
.stat-num{font-family:"DM Serif Display",serif;font-size:36px;font-weight:600;color:var(--blue);letter-spacing:-1px;margin-bottom:8px;}
.stat-label{font-size:13px;color:var(--ink-muted);font-weight:500;}
.flash-success{background:linear-gradient(135deg, rgba(22,163,74,0.1), rgba(34,197,94,0.05));border:1px solid rgba(22,163,74,0.3);border-radius:var(--radius);padding:14px 18px;font-size:14px;color:var(--green);margin-bottom:24px;display:flex;align-items:center;gap:10px;}
.flash-success::before{content:"✓";font-weight:bold;font-size:16px;}
.sites-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;}
.site-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:0;transition:all 0.25s;overflow:hidden;display:flex;flex-direction:column;}
.site-card:hover{border-color:var(--blue);box-shadow:0 8px 24px rgba(59,130,246,0.15);transform:translateY(-2px);}
.site-card-header{padding:20px 22px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;justify-content:space-between;gap:12px;}
.site-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;flex:1;}
.site-badge{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;background:var(--blue-light);color:var(--blue);text-transform:uppercase;letter-spacing:0.3px;}
.site-status{font-size:11px;padding:4px 10px;border-radius:20px;font-weight:600;}
.site-status.live{background:rgba(34,197,94,0.1);color:var(--green);display:flex;align-items:center;gap:4px;}
.site-status.live::before{content:"●";font-size:8px;}
.site-name{font-size:16px;font-weight:600;margin-bottom:6px;color:var(--ink);line-height:1.3;}
.site-url{font-size:13px;color:var(--blue);display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;transition:color 0.2s;}
.site-card:hover .site-url{color:var(--blue);}
.site-card-body{padding:18px 22px;flex:1;font-size:13px;color:var(--ink-muted);line-height:1.5;}
.site-meta{display:flex;gap:16px;flex-wrap:wrap;}
.site-meta-item{display:flex;gap:4px;align-items:center;}
.site-meta-label{color:var(--ink-muted);font-size:12px;}
.site-meta-value{color:var(--ink);font-weight:500;}
.site-actions{display:grid;grid-template-columns:1fr 1fr;gap:1px;border-top:1px solid var(--border);background:var(--border);}
.btn-action{padding:12px;border-radius:0;font-size:13px;font-weight:600;cursor:pointer;text-align:center;border:none;background:var(--white);color:var(--blue);font-family:"DM Sans",sans-serif;transition:all 0.15s;}
.btn-action:hover{background:var(--off);color:var(--blue);}
.btn-action.danger{color:var(--red);}
.btn-action.danger:hover{background:rgba(255,0,0,0.05);}
.btn-action-group-primary{display:flex;gap:1px;flex:1;}
.btn-action-group-primary .btn-action{flex:1;border-right:1px solid var(--border);}
.btn-action-group-primary .btn-action:last-child{border-right:none;}
.empty-state{text-align:center;padding:80px 40px;background:var(--white);border:2px dashed var(--border-md);border-radius:var(--radius-lg);margin:20px 0;}
.empty-icon{font-size:48px;margin-bottom:20px;}
.empty-state h3{font-family:"DM Serif Display",serif;font-size:24px;font-weight:600;margin-bottom:12px;color:var(--ink);}
.empty-state p{font-size:14px;color:var(--ink-muted);margin-bottom:28px;max-width:400px;margin-left:auto;margin-right:auto;}
@media(max-width:1024px){
  .layout{flex-direction:column;}
  .sidebar{width:100%;height:auto;position:relative;}
  .sidebar-nav{display:flex;gap:12px;overflow-x:auto;padding:12px;}
  .nav-item{margin-bottom:0;white-space:nowrap;}
  .content{padding:28px 20px;}
  .sites-grid{grid-template-columns:repeat(auto-fill,minmax(280px,1fr));}
  .page-title{font-size:24px;}
}
.sites-table{width:100%;border-collapse:collapse;background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;}
.sites-table thead{background:var(--off);border-bottom:1px solid var(--border);}
.sites-table th{padding:16px 20px;text-align:left;font-weight:600;font-size:13px;color:var(--ink-muted);text-transform:uppercase;letter-spacing:0.3px;}
.sites-table td{padding:16px 20px;border-bottom:1px solid var(--border);font-size:14px;}
.sites-table tbody tr{transition:background 0.15s;}
.sites-table tbody tr:hover{background:var(--off);}
.sites-table tbody tr:last-child td{border-bottom:none;}
.table-site-name{font-weight:600;color:var(--ink);}
.table-site-url{color:var(--blue);text-decoration:none;transition:color 0.2s;}
.table-site-url:hover{color:var(--blue);text-decoration:underline;}
.table-badge{font-size:11px;font-weight:600;padding:4px 8px;border-radius:16px;background:var(--blue-light);color:var(--blue);display:inline-block;}
.table-actions{display:flex;gap:8px;}
.btn-table-action{padding:6px 12px;border-radius:var(--radius);font-size:12px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:var(--white);color:var(--blue);transition:all 0.15s;white-space:nowrap;}
.btn-table-action:hover{background:var(--blue-light);border-color:var(--blue);}
.btn-table-action.danger{color:var(--red);border-color:var(--red);}
.btn-table-action.danger:hover{background:rgba(255,0,0,0.05);border-color:var(--red);}
.load-more-container{display:flex;justify-content:center;margin-top:32px;}
.btn-load-more{display:inline-flex;align-items:center;gap:8px;background:var(--white);color:var(--blue);padding:12px 28px;border-radius:var(--radius);font-size:14px;font-weight:600;transition:all 0.2s;border:1px solid var(--border);cursor:pointer;}
.btn-load-more:hover{background:var(--off);border-color:var(--blue);}
.btn-load-more.loading{opacity:0.6;cursor:not-allowed;}
.empty-table{text-align:center;padding:48px 20px;color:var(--ink-muted);}
.pagination-info{font-size:13px;color:var(--ink-muted);margin-bottom:16px;text-align:center;}
/* Info modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:900;backdrop-filter:blur(2px);}
.modal-overlay.open{display:flex;align-items:center;justify-content:center;}
.modal-box{background:var(--white);border-radius:var(--radius-lg);width:100%;max-width:480px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 60px rgba(0,0,0,0.18);margin:16px;}
.modal-head{display:flex;align-items:center;justify-content:space-between;padding:22px 24px 18px;border-bottom:1px solid var(--border);}
.modal-title{font-family:"DM Serif Display",serif;font-size:20px;font-weight:400;color:var(--ink);}
.modal-close{border:none;background:none;font-size:22px;cursor:pointer;color:var(--ink-faint);line-height:1;padding:0 4px;}
.modal-close:hover{color:var(--ink);}
.modal-body{padding:24px;}
.modal-field{margin-bottom:18px;}
.modal-field label{display:block;font-size:13px;font-weight:500;color:var(--ink-muted);margin-bottom:6px;}
.modal-field input,.modal-field select,.modal-field textarea{width:100%;padding:10px 13px;border:1px solid var(--border-md);border-radius:var(--radius);font-size:14px;font-family:"DM Sans",sans-serif;color:var(--ink);outline:none;transition:border-color 0.2s;}
.modal-field input:focus,.modal-field select:focus,.modal-field textarea:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);}
.modal-field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.modal-foot{padding:16px 24px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:flex-end;gap:10px;}
.btn-modal-save{background:var(--blue);color:#fff;border:none;padding:10px 24px;border-radius:var(--radius);font-size:14px;font-weight:600;font-family:"DM Sans",sans-serif;cursor:pointer;transition:opacity 0.2s;}
.btn-modal-save:hover{opacity:0.88;}
.btn-modal-save:disabled{opacity:0.5;cursor:not-allowed;}
.btn-modal-cancel{background:none;border:1px solid var(--border-md);color:var(--ink-muted);padding:10px 20px;border-radius:var(--radius);font-size:14px;font-family:"DM Sans",sans-serif;cursor:pointer;}
.modal-msg{font-size:13px;margin-right:auto;}
.modal-msg.ok{color:var(--green);}
.modal-msg.err{color:var(--red);}
@media(max-width:640px){
  .page-header{flex-direction:column;align-items:stretch;margin-bottom:24px;}
  .page-title{font-size:20px;}
  .btn-new{width:100%;}
  .sidebar{width:100%;}
  .sites-table{font-size:12px;}
  .sites-table th,.sites-table td{padding:12px 10px;}
  .btn-table-action{padding:4px 8px;font-size:11px;}
  .stat-card{padding:16px;}
  .stat-num{font-size:28px;}
  .content{padding:16px;}
}
</style>
{% endblock %}
{% block body %}
<div class="layout">
  <aside class="sidebar">
    <a class="sidebar-logo" href="/">page<em>zaper</em></a>
    <nav class="sidebar-nav">
      <a class="nav-item active" href="/dashboard">🏠 Dashboard</a>
      <a class="nav-item" href="/dashboard/wizard">✨ New Site</a>
      <a class="nav-item" href="/dashboard/forms">📋 Forms</a>
      <a class="nav-item" href="/dashboard/booking">📅 Booking</a>
      <a class="nav-item" href="/dashboard/settings">⚙️ Settings</a>
      {% if user.is_admin %}
      <a class="nav-item" href="/admin" style="margin-top:12px;border-top:1px solid var(--border);padding-top:16px;">🔧 Admin Panel</a>
      {% endif %}
    </nav>
    <div class="sidebar-bottom">
      <div class="user-chip">
        <div class="user-avatar">{{ user.name[0] | upper }}</div>
        <div><div class="user-name">{{ user.name }}</div><div class="user-plan">{{ user.plan | capitalize }} plan</div></div>
      </div>
      <a class="logout-link" href="/logout">← Logout</a>
    </div>
  </aside>
  <main class="content">
    <div class="page-header">
      <div>
        <div class="page-title">Dashboard</div>
        <p style="color:var(--ink-muted);margin-top:4px;font-size:14px;">Welcome back! Manage your sites and content.</p>
      </div>
      <a class="btn-new" href="/dashboard/wizard">+ Create New Site</a>
    </div>
    {% if flash_success and flash_success.length %}
    <div class="flash-success">{{ flash_success[0] }}</div>
    {% endif %}
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-num">{{ sites.length }}</div>
        <div class="stat-label">Total Sites</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">∞</div>
        <div class="stat-label">Possibilities</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{{ user.plan | capitalize }}</div>
        <div class="stat-label">Current Plan</div>
      </div>
    </div>
    {% if not sites.length %}
    <div class="empty-state">
      <div class="empty-icon">🚀</div>
      <h3>Ready to create your first site?</h3>
      <p>Get started in minutes with our intuitive builder. Choose from stunning templates or start from scratch.</p>
      <a class="btn-new" href="/dashboard/wizard">Launch Your First Site</a>
    </div>
    {% else %}
    <div style="margin-bottom:20px;">
      <h2 style="font-family:'DM Serif Display',serif;font-size:20px;font-weight:600;color:var(--ink);margin-bottom:4px;">Your Sites</h2>
      <p style="color:var(--ink-muted);font-size:13px;">Manage and edit your websites</p>
    </div>
    <div class="pagination-info">
      Showing <span id="showing-count">{{ [sites.length, 10] | min }}</span> of {{ sites.length }} sites
    </div>
    <table class="sites-table" id="sites-table">
      <thead>
        <tr>
          <th style="width:35%;">Site Name</th>
          <th style="width:20%;">URL</th>
          <th style="width:15%;">Category</th>
          <th style="width:15%;">Status</th>
          <th style="width:15%;">Actions</th>
        </tr>
      </thead>
      <tbody id="sites-tbody">
        {% for site in sites.slice(0, 10) %}
        {% set settings = site.settings | safe %}
        <tr class="site-row">
          <td>
            <div class="table-site-name">{{ site.title }}</div>
            <div style="font-size:12px;color:var(--ink-muted);margin-top:2px;">{{ site.template_id or "Default" }}</div>
          </td>
          <td><a class="table-site-url" href="https://{{ site.subdomain }}.{{ base_domain }}" target="_blank">{{ site.subdomain }}.{{ base_domain }}</a></td>
          <td><span class="table-badge">{{ site.category or "Site" }}</span></td>
          <td><span style="color:var(--green);font-weight:500;display:flex;align-items:center;gap:4px;"><span style="font-size:8px;">●</span> Live</span></td>
          <td>
            <div class="table-actions">
              <a class="btn-table-action" href="/dashboard/site/{% if 'biolink' in site.template_id %}biolink-builder{% else %}builder{% endif %}?id={{ site.id }}">Edit</a>
              <a class="btn-table-action" href="/dashboard/site/templates?id={{ site.id }}">Theme</a>
              <button type="button" class="btn-table-action" onclick="openInfoModal({{ site.id }})">Info</button>
              <a class="btn-table-action" href="/dashboard/booking/{{ site.id }}">Booking</a>
              <form method="POST" action="/dashboard/site/delete" style="display:inline;" onsubmit="return confirm('Are you sure? This action cannot be undone.')">
                <input type="hidden" name="site_id" value="{{ site.id }}">
                <button type="submit" class="btn-table-action danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if sites.length > 10 %}
    <div class="load-more-container">
      <button class="btn-load-more" id="load-more-btn" onclick="loadMoreSites()">
        <span>Load More Sites</span>
        <span id="load-more-count">({{ sites.length - 10 }} remaining)</span>
      </button>
    </div>
    {% endif %}
    <script>
      let currentIndex = 10;
      const allSites = {{ sites | tojson }};
      const totalSites = {{ sites.length }};

      function loadMoreSites() {
        const btn = document.getElementById('load-more-btn');
        const tbody = document.getElementById('sites-tbody');
        const itemsPerLoad = 10;
        const nextIndex = Math.min(currentIndex + itemsPerLoad, totalSites);

        btn.classList.add('loading');
        btn.disabled = true;

        // Simulate slight delay for better UX
        setTimeout(() => {
          for (let i = currentIndex; i < nextIndex; i++) {
            const site = allSites[i];
            const row = document.createElement('tr');
            row.className = 'site-row';
            row.innerHTML = `
              <td>
                <div class="table-site-name">${site.title}</div>
                <div style="font-size:12px;color:var(--ink-muted);margin-top:2px;">${site.template_id || 'Default'}</div>
              </td>
              <td><a class="table-site-url" href="https://${site.subdomain}.{{ base_domain }}" target="_blank">${site.subdomain}.{{ base_domain }}</a></td>
              <td><span class="table-badge">${site.category || 'Site'}</span></td>
              <td><span style="color:var(--green);font-weight:500;display:flex;align-items:center;gap:4px;"><span style="font-size:8px;">●</span> Live</span></td>
              <td>
                <div class="table-actions">
                  <a class="btn-table-action" href="/dashboard/site/${site.template_id && site.template_id.includes('biolink') ? 'biolink-builder' : 'builder'}?id=${site.id}">Edit</a>
                  <a class="btn-table-action" href="/dashboard/site/templates?id=${site.id}">Theme</a>
                  <button type="button" class="btn-table-action" onclick="openInfoModal(${site.id})">Info</button>
                  <a class="btn-table-action" href="/dashboard/booking/${site.id}">Booking</a>
                  <form method="POST" action="/dashboard/site/delete" style="display:inline;" onsubmit="return confirm('Are you sure? This action cannot be undone.')">
                    <input type="hidden" name="site_id" value="${site.id}">
                    <button type="submit" class="btn-table-action danger">Delete</button>
                  </form>
                </div>
              </td>
            `;
            tbody.appendChild(row);
          }

          currentIndex = nextIndex;

          // Update pagination info
          document.getElementById('showing-count').textContent = currentIndex;

          // Update or hide load more button
          if (currentIndex >= totalSites) {
            btn.style.display = 'none';
          } else {
            btn.classList.remove('loading');
            btn.disabled = false;
            document.getElementById('load-more-count').textContent = `(${totalSites - currentIndex} remaining)`;
          }
        }, 300);
      }
    </script>
    {% endif %}
  </main>
</div>

<!-- ── Info / Edit modal ── -->
<div class="modal-overlay" id="info-modal">
  <div class="modal-box">
    <div class="modal-head">
      <div class="modal-title">Edit Site Info</div>
      <button class="modal-close" onclick="closeInfoModal()">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="info-site-id">
      <div class="modal-field">
        <label>Business Name</label>
        <input type="text" id="info-title" placeholder="e.g. Glamour Studio">
      </div>
      <div class="modal-field">
        <label>Category</label>
        <select id="info-category">
          <option value="">— No category —</option>
          {% for cat in categories %}
          <option value="{{ cat.id }}">{{ cat.icon }} {{ cat.name }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="modal-field">
        <label>Description</label>
        <input type="text" id="info-description" placeholder="Short description of your business">
      </div>
      <div class="modal-field-row">
        <div class="modal-field" style="margin-bottom:0">
          <label>City</label>
          <input type="text" id="info-city" placeholder="e.g. Ludhiana">
        </div>
        <div class="modal-field" style="margin-bottom:0">
          <label>Phone</label>
          <input type="text" id="info-phone" placeholder="+91 98765 43210">
        </div>
      </div>
      <div class="modal-field-row" style="margin-top:18px;">
        <div class="modal-field" style="margin-bottom:0">
          <label>WhatsApp</label>
          <input type="text" id="info-whatsapp" placeholder="+91 98765 43210">
        </div>
        <div class="modal-field" style="margin-bottom:0">
          <label>Address</label>
          <input type="text" id="info-address" placeholder="Model Town, Ludhiana">
        </div>
      </div>
    </div>
    <div class="modal-foot">
      <span class="modal-msg" id="info-msg"></span>
      <button class="btn-modal-cancel" onclick="closeInfoModal()">Cancel</button>
      <button class="btn-modal-save" id="info-save-btn" onclick="saveInfo()">Save Changes</button>
    </div>
  </div>
</div>

<script>
var ALL_SITES_DATA = {{ sites | tojson }};

function openInfoModal(siteId) {
  var site = ALL_SITES_DATA.find(function(s){ return s.id === siteId })
  if (!site) return
  var st = {}
  try { st = JSON.parse(site.settings || '{}') } catch(e) {}

  document.getElementById('info-site-id').value    = site.id
  document.getElementById('info-title').value       = site.title || ''
  document.getElementById('info-description').value = st.description || ''
  document.getElementById('info-city').value        = st.city        || ''
  document.getElementById('info-phone').value       = st.phone       || ''
  document.getElementById('info-whatsapp').value    = st.whatsapp    || ''
  document.getElementById('info-address').value     = st.address     || ''

  var catSel = document.getElementById('info-category')
  catSel.value = site.category_id || ''

  document.getElementById('info-msg').textContent = ''
  document.getElementById('info-modal').classList.add('open')
}

function closeInfoModal() {
  document.getElementById('info-modal').classList.remove('open')
}

// Close on overlay click
document.getElementById('info-modal').addEventListener('click', function(e) {
  if (e.target === this) closeInfoModal()
})

function saveInfo() {
  var btn = document.getElementById('info-save-btn')
  var msg = document.getElementById('info-msg')
  btn.disabled = true
  btn.textContent = 'Saving…'
  msg.textContent = ''
  msg.className = 'modal-msg'

  fetch('/dashboard/site/update-info', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      site_id:     document.getElementById('info-site-id').value,
      title:       document.getElementById('info-title').value,
      category_id: document.getElementById('info-category').value,
      description: document.getElementById('info-description').value,
      city:        document.getElementById('info-city').value,
      phone:       document.getElementById('info-phone').value,
      whatsapp:    document.getElementById('info-whatsapp').value,
      address:     document.getElementById('info-address').value
    })
  })
  .then(function(r){ return r.json() })
  .then(function(d) {
    btn.disabled = false
    btn.textContent = 'Save Changes'
    if (d.ok) {
      msg.textContent = '✓ Saved successfully'
      msg.className = 'modal-msg ok'
      // Update local allSites data so re-open shows fresh values
      var siteId = parseInt(document.getElementById('info-site-id').value)
      var site = ALL_SITES_DATA.find(function(s){ return s.id === siteId })
      if (site) {
        site.title = document.getElementById('info-title').value
        site.category_id = document.getElementById('info-category').value
        var st = {}
        try { st = JSON.parse(site.settings || '{}') } catch(e) {}
        st.description = document.getElementById('info-description').value
        st.city        = document.getElementById('info-city').value
        st.phone       = document.getElementById('info-phone').value
        st.whatsapp    = document.getElementById('info-whatsapp').value
        st.address     = document.getElementById('info-address').value
        site.settings  = JSON.stringify(st)
      }
      setTimeout(closeInfoModal, 1200)
    } else {
      msg.textContent = d.error || 'Something went wrong.'
      msg.className = 'modal-msg err'
    }
  })
  .catch(function() {
    btn.disabled = false
    btn.textContent = 'Save Changes'
    msg.textContent = 'Network error. Try again.'
    msg.className = 'modal-msg err'
  })
}
</script>

{% endblock %}
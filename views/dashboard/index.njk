<!-- ── Reviews modal ── -->
<div class="modal-overlay" id="reviews-modal">
  <div class="modal-box" style="max-width:600px;">
    <div class="modal-head">
      <div class="modal-title">⭐ Reviews</div>
      <button class="modal-close" onclick="closeReviewsModal()">✕</button>
    </div>
    <div style="padding:24px;">
      <!-- Stats bar -->
      <div id="reviews-stats" style="background:var(--off);border-radius:var(--radius);padding:16px 20px;display:flex;align-items:center;gap:16px;margin-bottom:20px;">
        <div style="text-align:center;">
          <div id="reviews-avg" style="font-family:'DM Serif Display',serif;font-size:36px;color:var(--ink);line-height:1;">—</div>
          <div id="reviews-stars-disp" style="color:#f59e0b;font-size:18px;letter-spacing:2px;">☆☆☆☆☆</div>
          <div id="reviews-total" style="font-size:12px;color:var(--ink-muted);margin-top:2px;">No reviews yet</div>
        </div>
        <div style="flex:1;border-left:1px solid var(--border);padding-left:16px;">
          <div style="font-size:13px;color:var(--ink-muted);margin-bottom:8px;">Share review link:</div>
          <div style="display:flex;gap:8px;">
            <input id="reviews-link" type="text" readonly style="flex:1;border:1px solid var(--border-md);border-radius:var(--radius-sm);padding:8px 12px;font-size:12px;font-family:'DM Sans',sans-serif;color:var(--ink);background:var(--white);min-width:0;">
            <button onclick="copyReviewLink()" style="padding:8px 14px;background:var(--blue);color:#fff;border:none;border-radius:var(--radius-sm);font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;">Copy</button>
          </div>
        </div>
      </div>
      <!-- Reviews list -->
      <div id="reviews-list" style="max-height:380px;overflow-y:auto;display:flex;flex-direction:column;gap:10px;">
        <div style="text-align:center;padding:32px;color:var(--ink-faint);font-size:14px;">Loading…</div>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="pz-sites-json">{{ sites | dump | safe }}</script>
<script>
var ALL_SITES_DATA = JSON.parse(document.getElementById('pz-sites-json').textContent || '[]');

function openInfoModal(siteId) {
  var site = ALL_SITES_DATA.find(function(s){ return s.id === siteId })
  if (!site) return
  var st = {}
  try { st = JSON.parse(site.settings || '{}') } catch(e) {}

  document.getElementById('info-site-id').value    = site.id
  document.getElementById('info-title').value       = site.title || ''
  document.getElementById('info-description').value = st.description || ''
  document.getElementById('info-city').value        = st.city        || ''
  document.getElementById('info-phone').value       = st.phone       || ''
  document.getElementById('info-whatsapp').value    = st.whatsapp    || ''
  document.getElementById('info-address').value     = st.address     || ''
  document.getElementById('info-logo').value        = st.logo        || ''

  var catSel = document.getElementById('info-category')
  catSel.value = site.category_id || ''

  document.getElementById('info-msg').textContent = ''
  document.getElementById('info-modal').classList.add('open')
}

function closeInfoModal() {
  document.getElementById('info-modal').classList.remove('open')
}

// Close on overlay click
document.getElementById('info-modal').addEventListener('click', function(e) {
  if (e.target === this) closeInfoModal()
})
document.getElementById('staff-modal').addEventListener('click', function(e) {
  if (e.target === this) closeStaffModal()
})
document.getElementById('seo-modal').addEventListener('click', function(e) {
  if (e.target === this) closeSeoModal()
})
document.getElementById('reviews-modal').addEventListener('click', function(e) {
  if (e.target === this) closeReviewsModal()
})

// ── Reviews modal ─────────────────────────────────────────────────────────────
var _reviewSiteId = null, _reviewSubdomain = null

function openReviewsModal(siteId, subdomain) {
  _reviewSiteId   = siteId
  _reviewSubdomain = subdomain
  document.getElementById('reviews-modal').classList.add('open')
  document.getElementById('reviews-link').value = window.location.origin + '/review/' + subdomain
  loadReviews(siteId)
}

function closeReviewsModal() {
  document.getElementById('reviews-modal').classList.remove('open')
}

function copyReviewLink() {
  var inp = document.getElementById('reviews-link')
  inp.select(); document.execCommand('copy')
  inp.blur()
}

function loadReviews(siteId) {
  var list = document.getElementById('reviews-list')
  list.innerHTML = '<div style="text-align:center;padding:32px;color:var(--ink-faint);font-size:14px;">Loading…</div>'
  fetch('/dashboard/site/reviews?id=' + siteId)
    .then(function(r){ return r.json() })
    .then(function(d) {
      if (!d.ok) { list.innerHTML = '<div style="color:var(--red);padding:16px;">Error loading reviews.</div>'; return }

      // Stats
      var avg   = d.stats && d.stats.avg_rating ? parseFloat(d.stats.avg_rating) : 0
      var total = d.stats && d.stats.total ? d.stats.total : 0
      document.getElementById('reviews-avg').textContent   = avg ? avg.toFixed(1) : '—'
      document.getElementById('reviews-total').textContent = total ? total + ' review' + (total !== 1 ? 's' : '') : 'No reviews yet'
      var filled = Math.round(avg), empty = 5 - filled
      document.getElementById('reviews-stars-disp').textContent = '★'.repeat(filled) + '☆'.repeat(empty)

      if (!d.reviews.length) {
        list.innerHTML = '<div style="text-align:center;padding:32px;color:var(--ink-faint);font-size:14px;">No reviews yet. Share your review link to start collecting feedback!</div>'
        return
      }
      list.innerHTML = d.reviews.map(function(r) {
        var stars = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating)
        var date  = new Date(r.created_at).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })
        return '<div style="background:var(--off);border-radius:var(--radius);padding:14px 16px;">' +
          '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">' +
            '<div style="display:flex;align-items:center;gap:8px;">' +
              '<span style="font-size:14px;font-weight:600;color:var(--ink);">' + r.reviewer_name + '</span>' +
              '<span style="color:#f59e0b;font-size:13px;">' + stars + '</span>' +
            '</div>' +
            '<div style="display:flex;align-items:center;gap:8px;">' +
              '<span style="font-size:11px;color:var(--ink-faint);">' + date + '</span>' +
              '<button onclick="deleteReview(' + r.id + ',' + siteId + ',this)" style="font-size:11px;color:var(--red);background:none;border:none;cursor:pointer;padding:0;">Delete</button>' +
            '</div>' +
          '</div>' +
          (r.comment ? '<div style="font-size:13px;color:var(--ink-muted);line-height:1.6;margin-top:6px;">' + r.comment + '</div>' : '') +
        '</div>'
      }).join('')
    })
    .catch(function(){ list.innerHTML = '<div style="color:var(--red);padding:16px;">Could not load reviews.</div>' })
}

function deleteReview(reviewId, siteId, btn) {
  if (!confirm('Delete this review?')) return
  btn.textContent = '…'
  fetch('/dashboard/site/reviews/delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ review_id: reviewId, site_id: siteId })
  })
    .then(function(r){ return r.json() })
    .then(function(d){
      if (d.ok) loadReviews(siteId)
      else alert('Could not delete review.')
    })
}

function saveInfo() {
  var btn = document.getElementById('info-save-btn')
  var msg = document.getElementById('info-msg')
  btn.disabled = true
  btn.textContent = 'Saving…'
  msg.textContent = ''
  msg.className = 'modal-msg'

  fetch('/dashboard/site/update-info', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      site_id:     document.getElementById('info-site-id').value,
      title:       document.getElementById('info-title').value,
      category_id: document.getElementById('info-category').value,
      description: document.getElementById('info-description').value,
      city:        document.getElementById('info-city').value,
      phone:       document.getElementById('info-phone').value,
      whatsapp:    document.getElementById('info-whatsapp').value,
      address:     document.getElementById('info-address').value,
      logo:        document.getElementById('info-logo').value
    })
  })
  .then(function(r){ return r.json() })
  .then(function(d) {
    btn.disabled = false
    btn.textContent = 'Save Changes'
    if (d.ok) {
      msg.textContent = '✓ Saved successfully'
      msg.className = 'modal-msg ok'
      // Update local allSites data so re-open shows fresh values
      var siteId = parseInt(document.getElementById('info-site-id').value)
      var site = ALL_SITES_DATA.find(function(s){ return s.id === siteId })
      if (site) {
        site.title = document.getElementById('info-title').value
        site.category_id = document.getElementById('info-category').value
        var st = {}
        try { st = JSON.parse(site.settings || '{}') } catch(e) {}
        st.description = document.getElementById('info-description').value
        st.city        = document.getElementById('info-city').value
        st.phone       = document.getElementById('info-phone').value
        st.whatsapp    = document.getElementById('info-whatsapp').value
        st.address     = document.getElementById('info-address').value
        st.logo        = document.getElementById('info-logo').value
        site.settings  = JSON.stringify(st)
      }
      setTimeout(closeInfoModal, 1200)
    } else {
      msg.textContent = d.error || 'Something went wrong.'
      msg.className = 'modal-msg err'
    }
  })
  .catch(function() {
    btn.disabled = false
    btn.textContent = 'Save Changes'
    msg.textContent = 'Network error. Try again.'
    msg.className = 'modal-msg err'
  })
}

// ── Publish / Draft toggle ───────────────────────────────────────────────────
function togglePublish(siteId, currentlyPublished) {
  var action = currentlyPublished ? 'unpublish (set to draft)' : 'publish'
  if (!confirm('Are you sure you want to ' + action + ' this site?')) return

  fetch('/dashboard/site/toggle-publish', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body:    JSON.stringify({ site_id: siteId })
  })
  .then(function(r){ return r.json() })
  .then(function(d) {
    if (!d.ok) { alert(d.error || 'Failed to update status.'); return }
    var btn = document.getElementById('status-' + siteId)
    if (!btn) return
    if (d.is_published) {
      btn.className = 'status-btn live'
      btn.innerHTML = '<span style="font-size:8px;">●</span> Live'
      btn.setAttribute('onclick', 'togglePublish(' + siteId + ', 1)')
    } else {
      btn.className = 'status-btn draft'
      btn.innerHTML = '<span style="font-size:8px;">◌</span> Draft'
      btn.setAttribute('onclick', 'togglePublish(' + siteId + ', 0)')
    }
    // Update stat counters
    var liveCount  = document.querySelectorAll('.status-btn.live').length
    var draftCount = document.querySelectorAll('.status-btn.draft').length
    var statNums = document.querySelectorAll('.stat-num')
    if (statNums[1]) statNums[1].textContent = liveCount
    if (statNums[2]) statNums[2].textContent = draftCount
  })
  .catch(function(){ alert('Network error. Please try again.') })
}

// ── Staff Bio Link modal ──────────────────────────────────────────────────────
var _staffParentSub = ''

function openAddStaffModal(parentId, parentTitle, parentSub) {
  _staffParentSub = parentSub
  document.getElementById('staff-parent-id').value = parentId
  document.getElementById('staff-modal-parent-label').textContent = '📁 Business: ' + parentTitle
  document.getElementById('staff-parent-sub-preview').textContent = parentSub
  document.getElementById('staff-name').value      = ''
  document.getElementById('staff-subdomain').value = ''
  document.getElementById('staff-sub-preview').textContent = '…'
  document.getElementById('staff-msg').textContent  = ''
  document.getElementById('staff-msg').className    = 'modal-msg'
  document.getElementById('staff-save-btn').disabled    = false
  document.getElementById('staff-save-btn').textContent = 'Create & Edit'
  document.getElementById('staff-modal').classList.add('open')
  setTimeout(function(){ document.getElementById('staff-name').focus() }, 100)
}

function closeStaffModal() {
  document.getElementById('staff-modal').classList.remove('open')
}

function staffAutoSlug() {
  var name = document.getElementById('staff-name').value
  var slug = name.toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .substring(0, 40)
  document.getElementById('staff-subdomain').value    = slug
  document.getElementById('staff-sub-preview').textContent = slug || '…'
}

function staffSlugPreview() {
  document.getElementById('staff-sub-preview').textContent =
    document.getElementById('staff-subdomain').value || '…'
}

// ── SEO modal ────────────────────────────────────────────────────────────────
function openSeoModal(siteId) {
  var site = ALL_SITES_DATA.find(function(s){ return s.id === siteId })
  if (!site) return
  var st = {}
  try { st = JSON.parse(site.settings || '{}') } catch(e) {}
  var seo = st.seo || {}

  document.getElementById('seo-site-id').value        = site.id
  document.getElementById('seo-title').value           = seo.title       || ''
  document.getElementById('seo-description').value    = seo.description || ''
  document.getElementById('seo-og-image').value       = seo.og_image    || ''
  document.getElementById('seo-noindex').checked      = !!seo.noindex
  document.getElementById('seo-msg').textContent      = ''
  document.getElementById('seo-msg').className        = 'modal-msg'
  document.getElementById('seo-save-btn').disabled    = false
  document.getElementById('seo-save-btn').textContent = 'Save SEO'
  document.getElementById('seo-modal').classList.add('open')
  setTimeout(function(){ document.getElementById('seo-title').focus() }, 100)
}

function closeSeoModal() {
  document.getElementById('seo-modal').classList.remove('open')
}

function saveSeoSettings() {
  var btn = document.getElementById('seo-save-btn')
  var msg = document.getElementById('seo-msg')
  btn.disabled    = true
  btn.textContent = 'Saving…'
  msg.textContent = ''
  msg.className   = 'modal-msg'

  fetch('/dashboard/site/update-seo', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      site_id:         document.getElementById('seo-site-id').value,
      seo_title:       document.getElementById('seo-title').value,
      seo_description: document.getElementById('seo-description').value,
      seo_og_image:    document.getElementById('seo-og-image').value,
      seo_noindex:     document.getElementById('seo-noindex').checked ? '1' : '0'
    })
  })
  .then(function(r){ return r.json() })
  .then(function(d) {
    btn.disabled    = false
    btn.textContent = 'Save SEO'
    if (d.ok) {
      msg.textContent = '✓ SEO settings saved'
      msg.className   = 'modal-msg ok'
      // Update local data so re-open shows fresh values
      var siteId = parseInt(document.getElementById('seo-site-id').value)
      var site   = ALL_SITES_DATA.find(function(s){ return s.id === siteId })
      if (site) {
        var st = {}
        try { st = JSON.parse(site.settings || '{}') } catch(e) {}
        st.seo = {
          title:       document.getElementById('seo-title').value,
          description: document.getElementById('seo-description').value,
          og_image:    document.getElementById('seo-og-image').value,
          noindex:     document.getElementById('seo-noindex').checked
        }
        site.settings = JSON.stringify(st)
      }
      setTimeout(closeSeoModal, 1200)
    } else {
      msg.textContent = d.error || 'Something went wrong.'
      msg.className   = 'modal-msg err'
    }
  })
  .catch(function() {
    btn.disabled    = false
    btn.textContent = 'Save SEO'
    msg.textContent = 'Network error. Try again.'
    msg.className   = 'modal-msg err'
  })
}

function saveStaffSite() {
  var btn = document.getElementById('staff-save-btn')
  var msg = document.getElementById('staff-msg')
  btn.disabled    = true
  btn.textContent = 'Creating…'
  msg.textContent = ''
  msg.className   = 'modal-msg'

  fetch('/dashboard/site/create-staff', {
    method:  'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      parent_site_id: document.getElementById('staff-parent-id').value,
      employee_name:  document.getElementById('staff-name').value,
      path_slug:      document.getElementById('staff-subdomain').value
    })
  })
  .then(function(r){ return r.json() })
  .then(function(d) {
    if (d.ok) {
      msg.textContent = '✓ Created! Opening editor…'
      msg.className   = 'modal-msg ok'
      setTimeout(function(){ window.location.href = d.redirect }, 700)
    } else {
      btn.disabled    = false
      btn.textContent = 'Create & Edit'
      msg.textContent = d.error || 'Something went wrong.'
      msg.className   = 'modal-msg err'
    }
  })
  .catch(function() {
    btn.disabled    = false
    btn.textContent = 'Create & Edit'
    msg.textContent = 'Network error. Try again.'
    msg.className   = 'modal-msg err'
  })
}
</script>

{% endblock %}
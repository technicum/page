{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{font-family:"DM Sans",sans-serif;}
.layout{display:flex;min-height:100vh;}
.sidebar{width:220px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;}
.sidebar-logo{font-family:"DM Serif Display",serif;font-size:20px;padding:22px 24px;border-bottom:1px solid var(--border);text-decoration:none;color:var(--ink);display:block;}
.sidebar-logo em{font-style:italic;color:var(--blue);}
.sidebar-nav{padding:16px 12px;flex:1;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius);font-size:14px;color:var(--ink-muted);text-decoration:none;transition:all 0.15s;margin-bottom:2px;}
.nav-item:hover{background:var(--off);color:var(--ink);}
.nav-item.active{background:var(--blue-light);color:var(--blue);font-weight:500;}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border);}
.user-chip{display:flex;align-items:center;gap:10px;padding:8px 12px;}
.user-avatar{width:32px;height:32px;border-radius:50%;background:var(--blue-light);color:var(--blue);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;flex-shrink:0;}
.user-name{font-size:13px;font-weight:500;color:var(--ink);}
.user-plan{font-size:11px;color:var(--ink-faint);}
.logout-link{display:block;font-size:13px;color:var(--ink-faint);padding:6px 12px;margin-top:4px;border-radius:var(--radius);}
.logout-link:hover{color:var(--red);}
.content{flex:1;padding:36px 40px;min-width:0;}
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;}
.page-title{font-family:"DM Serif Display",serif;font-size:28px;font-weight:400;letter-spacing:-0.5px;}
.btn-new{display:inline-flex;align-items:center;gap:8px;background:var(--ink);color:var(--white);padding:10px 20px;border-radius:var(--radius);font-size:14px;font-weight:500;transition:opacity 0.2s;}
.btn-new:hover{opacity:0.85;}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px;}
.stat-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 22px;}
.stat-num{font-family:"DM Serif Display",serif;font-size:32px;font-weight:400;color:var(--ink);letter-spacing:-1px;margin-bottom:4px;}
.stat-label{font-size:13px;color:var(--ink-muted);}
.flash-success{background:var(--green-light);border:1px solid rgba(22,163,74,0.2);border-radius:var(--radius);padding:12px 16px;font-size:14px;color:var(--green);margin-bottom:24px;}
.sites-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
.site-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;transition:box-shadow 0.2s;}
.site-card:hover{box-shadow:0 4px 16px rgba(0,0,0,0.06);}
.site-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;}
.site-badge{font-size:11px;font-weight:500;padding:3px 10px;border-radius:20px;background:var(--blue-light);color:var(--blue);}
.site-status{font-size:11px;padding:3px 10px;border-radius:20px;}
.site-status.live{background:var(--green-light);color:var(--green);}
.site-name{font-size:16px;font-weight:500;margin-bottom:4px;}
.site-url{font-size:13px;color:var(--blue);display:block;margin-bottom:14px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.site-actions{display:flex;gap:8px;border-top:1px solid var(--border);padding-top:14px;}
.btn-action{flex:1;padding:8px;border-radius:var(--radius);font-size:13px;font-weight:500;cursor:pointer;text-align:center;border:1px solid var(--border-md);background:var(--white);color:var(--ink-muted);font-family:"DM Sans",sans-serif;}
.btn-action:hover{background:var(--off);}
.empty-state{text-align:center;padding:64px 24px;background:var(--white);border:1px dashed var(--border-md);border-radius:var(--radius-lg);}
.empty-icon{font-size:40px;margin-bottom:16px;}
.empty-state h3{font-family:"DM Serif Display",serif;font-size:22px;font-weight:400;margin-bottom:8px;}
.empty-state p{font-size:14px;color:var(--ink-muted);margin-bottom:24px;}
</style>
{% endblock %}
{% block body %}
<div class="layout">
  <aside class="sidebar">
    <a class="sidebar-logo" href="/">page<em>zaper</em></a>
    <nav class="sidebar-nav">
      <a class="nav-item active" href="/dashboard">🏠 Dashboard</a>
      <a class="nav-item" href="/dashboard/wizard">✨ New Site</a>
      <a class="nav-item" href="/dashboard/settings">⚙️ Settings</a>
    </nav>
    <div class="sidebar-bottom">
      <div class="user-chip">
        <div class="user-avatar">{{ user.name[0] | upper }}</div>
        <div><div class="user-name">{{ user.name }}</div><div class="user-plan">{{ user.plan | capitalize }} plan</div></div>
      </div>
      <a class="logout-link" href="/logout">← Logout</a>
    </div>
  </aside>
  <main class="content">
    <div class="page-header">
      <div class="page-title">Dashboard</div>
      <a class="btn-new" href="/dashboard/wizard">+ New site</a>
    </div>
    {% if flash_success and flash_success.length %}
    <div class="flash-success">✓ {{ flash_success[0] }}</div>
    {% endif %}
    <div class="stats-row">
      <div class="stat-card"><div class="stat-num">{{ sites.length }}</div><div class="stat-label">Total sites</div></div>
      <div class="stat-card"><div class="stat-num">{{ sites.length }}</div><div class="stat-label">Live sites</div></div>
      <div class="stat-card"><div class="stat-num">{{ user.plan | capitalize }}</div><div class="stat-label">Current plan</div></div>
    </div>
    {% if not sites.length %}
    <div class="empty-state">
      <div class="empty-icon">🌐</div>
      <h3>No sites yet</h3>
      <p>Create your first mini site in under 2 minutes.</p>
      <a class="btn-new" href="/dashboard/wizard">Create your first site</a>
    </div>
    {% else %}
    <div class="sites-grid">
      {% for site in sites %}
      {% set settings = site.settings | safe %}
      <div class="site-card">
        <div class="site-card-top">
          <span class="site-badge">{{ site.category or "Site" }}</span>
          <span class="site-status live">● Live</span>
        </div>
        <div class="site-name">{{ site.title }}</div>
        <a class="site-url" href="{{ app_url }}" target="_blank">{{ site.subdomain }}.{{ base_domain }}</a>
        <div class="site-actions">
          <a class="btn-action" href="/dashboard/site/builder?id={{ site.id }}">Edit</a>
          <a class="btn-action" href="/dashboard/site/templates?id={{ site.id }}">Theme</a>
          <a class="btn-action" href="/dashboard/blog/{{ site.id }}">Blog</a>
          <a class="btn-action" href="/dashboard/forms/{{ site.id }}">Forms</a>
          <form method="POST" action="/dashboard/site/delete" style="flex:1;" onsubmit="return confirm('Delete this site?')">
            <input type="hidden" name="site_id" value="{{ site.id }}">
            <button type="submit" class="btn-action" style="width:100%;color:var(--red);">Delete</button>
          </form>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </main>
</div>
{% endblock %}
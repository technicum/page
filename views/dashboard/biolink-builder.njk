      (function(pid){
        item.onclick=function(){
          block[pid]='';
          markDirty(); debouncedPreview(); render();
          // Focus the newly added input
          setTimeout(function(){
            var inputs=wrap.querySelectorAll('input');
            for(var i=inputs.length-1;i>=0;i--){ inputs[i].focus(); break; }
          },50);
        };
      })(p.id);
      picker.appendChild(item);
    });
    wrap.appendChild(picker);

    var pickerOpen=false;
    addBtn.onclick=function(){
      pickerOpen=!pickerOpen;
      picker.style.display=pickerOpen?'grid':'none';
      addBtn.innerHTML=pickerOpen?'<span>✕</span><span>Close</span>':'<span>+</span><span>Add platform</span>';

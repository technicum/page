<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>{{ site.title }} — Bio Link Editor</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',system-ui,sans-serif;background:#f0f0f3;overflow:hidden;color:#1a1a1a;}

/* ── Topbar ──────────────────────────────────── */
.topbar{display:flex;align-items:center;gap:8px;height:48px;background:#fff;border-bottom:1px solid #e5e7eb;padding:0 14px;position:fixed;top:0;left:0;right:0;z-index:300;}
.tb-back{font-size:12px;color:#6b7280;text-decoration:none;padding:5px 10px;border-radius:7px;border:1px solid #e5e7eb;display:flex;align-items:center;gap:4px;transition:all .15s;white-space:nowrap;}
.tb-back:hover{background:#f9fafb;color:#374151;}
.tb-sep{width:1px;height:18px;background:#e5e7eb;flex-shrink:0;}
.tb-site{font-size:13px;font-weight:600;color:#111827;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:140px;}
.tb-urlbadge{display:flex;align-items:center;gap:4px;font-size:11px;color:#6366f1;background:#eef2ff;padding:4px 8px;border-radius:6px;text-decoration:none;white-space:nowrap;max-width:180px;overflow:hidden;text-overflow:ellipsis;transition:opacity .15s;cursor:pointer;border:none;font-family:inherit;}
.tb-urlbadge:hover{opacity:.75;}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px;flex-shrink:0;}
.save-status{display:flex;align-items:center;gap:5px;font-size:11px;color:#9ca3af;}
.save-dot{width:6px;height:6px;border-radius:50%;background:#d1d5db;transition:background .3s;}
.save-dot.dirty{background:#f59e0b;}
.save-dot.saved{background:#22c55e;}
.btn-publish{padding:7px 16px;background:#111827;color:#fff;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;transition:all .15s;white-space:nowrap;}
.btn-publish:hover{background:#374151;}
.btn-publish:disabled{opacity:.5;cursor:not-allowed;}

/* ── Main layout ─────────────────────────────── */
.main{display:flex;height:calc(100vh - 48px);margin-top:48px;}

/* ── Left panel ──────────────────────────────── */
.panel{flex:0 0 50%;width:50%;background:#fff;border-right:1px solid #e5e7eb;display:flex;flex-direction:column;overflow:hidden;}

/* ── Panel tabs ──────────────────────────────── */
.panel-tabs{display:flex;border-bottom:1px solid #e5e7eb;flex-shrink:0;background:#fafafa;}
.pt{flex:1;padding:12px 0;font-size:13px;font-weight:600;color:#6b7280;background:transparent;border:none;cursor:pointer;font-family:inherit;transition:color .15s;border-bottom:2px solid transparent;margin-bottom:-1px;}
.pt.active{color:#111827;border-bottom-color:#111827;background:#fff;}
.pt:hover:not(.active){color:#374151;}

/* ── Tab content ─────────────────────────────── */
.tab-content{flex:1;overflow-y:auto;display:none;}
.tab-content.active{display:block;}
.tab-content::-webkit-scrollbar{width:3px;}
.tab-content::-webkit-scrollbar-thumb{background:#e5e7eb;border-radius:2px;}

/* ── Accordion ───────────────────────────────── */
.acc{border-bottom:1px solid #f0f0f3;}
.acc-head{display:flex;align-items:center;gap:8px;padding:13px 16px;cursor:pointer;background:#fff;transition:background .1s;user-select:none;}
.acc-head:hover{background:#fafafa;}
.acc-icon{font-size:15px;flex-shrink:0;}
.acc-label{font-size:13px;font-weight:600;color:#111827;flex:1;}
.acc-chevron{font-size:10px;color:#9ca3af;transition:transform .2s;}
.acc-body{display:none;padding:0 16px 16px;}
.acc.open .acc-chevron{transform:rotate(90deg);}
.acc.open .acc-body{display:block;}

/* ── Form fields ─────────────────────────────── */
.fg{margin-bottom:12px;}
.fg:last-child{margin-bottom:0;}
.fg-label{display:block;font-size:10px;font-weight:700;color:#9ca3af;margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px;}
.fg-input{width:100%;padding:8px 10px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:13px;color:#1f2937;background:#fff;outline:none;transition:border-color .15s;font-family:inherit;}
.fg-input:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.08);}
.fg-textarea{min-height:68px;resize:vertical;line-height:1.5;}
.fg-select{width:100%;padding:8px 10px;border:1.5px solid #e5e7eb;border-radius:8px;font-size:13px;color:#1f2937;background:#fff;outline:none;font-family:inherit;cursor:pointer;}
.fg-select:focus{border-color:#6366f1;}

/* ── URL badge display ───────────────────────── */
.url-display{display:flex;align-items:center;gap:8px;background:#f9fafb;border:1.5px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:12px;color:#6366f1;margin-bottom:8px;}
.url-display span{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.url-copy-btn{padding:4px 8px;background:#eef2ff;border:none;border-radius:5px;font-size:11px;color:#6366f1;cursor:pointer;font-family:inherit;white-space:nowrap;transition:background .15s;}
.url-copy-btn:hover{background:#e0e7ff;}
.url-note{font-size:11px;color:#9ca3af;line-height:1.4;}

/* ── Theme grid ──────────────────────────────── */
.theme-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.theme-card{border:2px solid #e5e7eb;border-radius:10px;padding:12px 10px;cursor:pointer;text-align:center;transition:all .15s;background:#fafafa;}
.theme-card:hover{border-color:#a5b4fc;background:#f5f5ff;}
.theme-card.active{border-color:#6366f1;background:#eef2ff;}
.theme-card-name{font-size:12px;font-weight:600;color:#374151;margin-top:4px;}
.theme-card-dot{width:24px;height:24px;border-radius:50%;margin:0 auto;background:#6366f1;}

/* ── Style chips ─────────────────────────────── */
.chip-row{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:6px;margin-bottom:12px;}
.chip{padding:8px 4px;border:2px solid #e5e7eb;border-radius:8px;text-align:center;cursor:pointer;font-size:11px;font-weight:600;color:#6b7280;transition:all .15s;background:#fafafa;}
.chip:hover{border-color:#a5b4fc;color:#6366f1;}
.chip.active{border-color:#6366f1;background:#eef2ff;color:#6366f1;}

/* ── Radius row ──────────────────────────────── */
.radius-row{display:flex;gap:6px;}
.rad-chip{flex:1;padding:8px 0;border:2px solid #e5e7eb;border-radius:8px;text-align:center;cursor:pointer;font-size:11px;color:#6b7280;transition:all .15s;background:#fafafa;}
.rad-chip:hover{border-color:#a5b4fc;}
.rad-chip.active{border-color:#6366f1;background:#eef2ff;color:#6366f1;}

/* ── Background tabs ─────────────────────────── */
.bg-tabs{display:flex;gap:4px;margin-bottom:12px;background:#f3f4f6;border-radius:8px;padding:3px;}
.bg-tab{flex:1;padding:6px;text-align:center;font-size:11px;font-weight:600;color:#6b7280;cursor:pointer;border-radius:6px;border:none;background:transparent;font-family:inherit;transition:all .15s;}
.bg-tab.active{background:#fff;color:#111827;box-shadow:0 1px 3px rgba(0,0,0,.08);}
.bg-tab-pane{display:none;}
.bg-tab-pane.active{display:block;}

/* ── Style presets ───────────────────────────── */
.preset-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;}
.preset-btn:hover{transform:scale(1.03);}

/* ── Animation chips ─────────────────────────── */
.anim-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:2px;}
.anim-chip{border:1.5px solid #e5e7eb;border-radius:8px;padding:7px 4px;cursor:pointer;text-align:center;transition:all .15s;background:#fff;font-family:inherit;}
.anim-chip:hover{border-color:#a5b4fc;background:#f5f3ff;}
.anim-chip.active{border-color:#6366f1;background:#eef2ff;}
.anim-chip-icon{font-size:14px;line-height:1;}
.anim-chip-label{font-size:10px;font-weight:600;color:#374151;margin-top:2px;line-height:1.2;}
.anim-chip.active .anim-chip-label{color:#6366f1;}
.btn-apply-anim{width:100%;margin-top:8px;padding:8px;background:#f3f4f6;border:1px solid #e5e7eb;border-radius:8px;font-size:12px;font-weight:600;color:#374151;cursor:pointer;font-family:inherit;transition:all .15s;}
.btn-apply-anim:hover{background:#e5e7eb;}
.anim-block-sep{border-top:1px solid #f0f0f3;margin-top:10px;padding-top:10px;}
.anim-block-row{display:flex;gap:8px;}

/* ── Gradient chips ──────────────────────────── */
.grad-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:6px;}
.grad-chip{height:40px;border-radius:8px;cursor:pointer;border:2.5px solid transparent;transition:all .15s;}
.grad-chip.active{border-color:#111827;box-shadow:0 0 0 2px rgba(0,0,0,.15);}
.grad-chip:hover{transform:scale(1.04);}

/* ── Font row ────────────────────────────────── */
.font-row{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.font-chip{padding:9px;border:2px solid #e5e7eb;border-radius:8px;text-align:center;cursor:pointer;font-size:12px;color:#374151;transition:all .15s;background:#fafafa;}
.font-chip:hover{border-color:#a5b4fc;}
.font-chip.active{border-color:#6366f1;background:#eef2ff;color:#6366f1;}

/* ── Toggle (checkbox) ───────────────────────── */
.toggle-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.toggle-label{font-size:13px;color:#374151;}
.toggle-switch{position:relative;width:36px;height:20px;flex-shrink:0;}
.toggle-switch input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;inset:0;background:#d1d5db;border-radius:20px;cursor:pointer;transition:background .2s;}
.toggle-slider::before{content:'';position:absolute;width:14px;height:14px;background:#fff;border-radius:50%;top:3px;left:3px;transition:transform .2s;}
.toggle-switch input:checked + .toggle-slider{background:#6366f1;}
.toggle-switch input:checked + .toggle-slider::before{transform:translateX(16px);}

/* ── Color picker ────────────────────────────── */
.color-pair{display:flex;align-items:center;gap:8px;}
.color-swatch{width:32px;height:32px;border-radius:8px;border:1.5px solid #e5e7eb;cursor:pointer;flex-shrink:0;position:relative;overflow:hidden;}
.color-swatch input[type=color]{position:absolute;inset:-4px;opacity:0;cursor:pointer;width:calc(100%+8px);height:calc(100%+8px);}

/* ── Image field ─────────────────────────────── */
.img-row{display:flex;gap:8px;align-items:center;}
.img-thumb{width:40px;height:40px;border-radius:8px;background:#f3f4f6;border:1.5px solid #e5e7eb;display:flex;align-items:center;justify-content:center;font-size:16px;overflow:hidden;flex-shrink:0;}
.img-thumb img{width:100%;height:100%;object-fit:cover;}
.img-inputs{flex:1;display:flex;flex-direction:column;gap:5px;}
.btn-upload{padding:5px 9px;background:#f9fafb;border:1px solid #e5e7eb;border-radius:6px;font-size:11px;font-weight:600;color:#374151;cursor:pointer;white-space:nowrap;font-family:inherit;transition:all .15s;}
.btn-upload:hover{background:#eef2ff;border-color:#c7d2fe;color:#6366f1;}

/* ── Blocks tab ──────────────────────────────── */
.blocks-header{padding:12px 14px;border-bottom:1px solid #f0f0f3;flex-shrink:0;display:none;}
.tab-content.active .blocks-header{display:block;}
.btn-add-block{width:100%;padding:10px;background:#111827;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:background .15s;display:flex;align-items:center;justify-content:center;gap:6px;}
.btn-add-block:hover{background:#374151;}

#blockList{padding:8px 10px 60px;}
.blk-card{background:#fafafa;border:1.5px solid #e5e7eb;border-radius:10px;margin-bottom:6px;overflow:hidden;transition:border-color .15s;}
.blk-card:hover{border-color:#d1d5db;}
.blk-card.open{border-color:#6366f1;background:#fff;}
.blk-card.disabled{opacity:.55;}
.blk-card.dragging{opacity:.35;}
.blk-card.drag-over{border:2px dashed #6366f1;background:#f5f5ff;}
.blk-head{display:flex;align-items:center;gap:7px;padding:10px 10px;cursor:pointer;}
.blk-drag{font-size:13px;color:#d1d5db;cursor:grab;flex-shrink:0;padding:0 2px;user-select:none;touch-action:none;}
.blk-type-icon{font-size:16px;flex-shrink:0;width:22px;text-align:center;}
.blk-label{font-size:12px;font-weight:600;color:#374151;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.blk-sublabel{font-size:11px;color:#9ca3af;font-weight:400;}
.blk-actions{display:flex;align-items:center;gap:2px;flex-shrink:0;}
.blk-btn{width:26px;height:26px;border:none;background:transparent;cursor:pointer;border-radius:6px;font-size:13px;display:flex;align-items:center;justify-content:center;transition:background .15s;color:#9ca3af;font-family:inherit;}
.blk-btn:hover{background:#f3f4f6;color:#374151;}
.blk-btn.del:hover{background:#fee2e2;color:#ef4444;}
.blk-body{padding:12px 12px 4px;border-top:1px solid #f0f0f3;display:none;}
.blk-card.open .blk-body{display:block;}
.blk-done{width:100%;margin-top:10px;padding:8px;background:#f3f4f6;border:none;border-radius:7px;font-size:12px;font-weight:600;color:#374151;cursor:pointer;font-family:inherit;transition:all .15s;}
.blk-done:hover{background:#e5e7eb;}

/* ── Hours grid ──────────────────────────────── */
.hours-grid{display:grid;grid-template-columns:auto 1fr 10px 1fr;gap:4px 6px;align-items:center;}
.hours-day{font-size:11px;font-weight:600;color:#6b7280;white-space:nowrap;}
.hours-sep{font-size:11px;color:#9ca3af;text-align:center;}
.hours-inp{padding:5px 7px;border:1.5px solid #e5e7eb;border-radius:6px;font-size:11px;font-family:inherit;outline:none;width:100%;}
.hours-inp:focus{border-color:#6366f1;}

/* ── Empty blocks state ──────────────────────── */
.blocks-empty{text-align:center;padding:40px 20px;color:#9ca3af;}
.blocks-empty-icon{font-size:36px;margin-bottom:10px;}
.blocks-empty-text{font-size:13px;line-height:1.5;}

/* ── Add block modal ─────────────────────────── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;display:none;align-items:flex-end;justify-content:center;}
.modal-overlay.open{display:flex;}
@media(min-width:480px){.modal-overlay{align-items:center;}}
.modal-box{background:#fff;border-radius:16px 16px 0 0;width:100%;max-width:480px;max-height:85vh;overflow-y:auto;padding:20px 20px 32px;}
@media(min-width:480px){.modal-box{border-radius:14px;max-height:80vh;}}
.modal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.modal-title{font-size:15px;font-weight:700;color:#111827;}
.modal-close{width:28px;height:28px;border:none;background:#f3f4f6;border-radius:50%;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;color:#6b7280;}
.modal-cat{font-size:10px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.7px;margin-bottom:8px;margin-top:14px;}
.modal-cat:first-of-type{margin-top:0;}
.modal-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.modal-block-btn{display:flex;align-items:center;gap:10px;padding:12px 12px;border:1.5px solid #e5e7eb;border-radius:10px;cursor:pointer;background:#fafafa;transition:all .15s;text-align:left;font-family:inherit;}
.modal-block-btn:hover{border-color:#a5b4fc;background:#f5f5ff;}
.mbb-icon{font-size:20px;flex-shrink:0;}
.mbb-text{flex:1;min-width:0;}
.mbb-name{font-size:12px;font-weight:600;color:#111827;display:block;}
.mbb-desc{font-size:10px;color:#9ca3af;display:block;margin-top:1px;}

/* ── Preview ─────────────────────────────────── */
.preview-area{flex:1;background:#e8e8ed;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.preview-toolbar{position:absolute;top:12px;right:14px;display:flex;gap:6px;z-index:10;}
.ptb-btn{padding:5px 11px;background:rgba(255,255,255,.95);border:1px solid rgba(0,0,0,.1);border-radius:7px;font-size:11px;font-weight:600;color:#374151;cursor:pointer;font-family:inherit;transition:all .15s;backdrop-filter:blur(4px);}
.ptb-btn:hover{background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.12);}
.phone-frame{width:300px;height:min(650px,calc(100vh - 110px));aspect-ratio:9/19.5;border-radius:44px;border:10px solid #1c1c1e;box-shadow:0 28px 70px rgba(0,0,0,.4),0 0 0 1px rgba(255,255,255,.08) inset;overflow:hidden;background:#fff;position:relative;flex-shrink:0;}
.phone-notch{position:absolute;top:0;left:50%;transform:translateX(-50%);width:90px;height:26px;background:#1c1c1e;border-radius:0 0 18px 18px;z-index:10;pointer-events:none;}
.phone-frame iframe{width:100%;height:100%;border:none;display:block;}
.preview-loading{position:absolute;inset:0;background:rgba(232,232,237,.7);display:flex;align-items:center;justify-content:center;font-size:12px;color:#9ca3af;pointer-events:none;opacity:0;transition:opacity .2s;}
.preview-loading.show{opacity:1;}
.preview-hint{position:absolute;bottom:14px;font-size:10px;color:#9ca3af;letter-spacing:.3px;}

/* ── Mobile ──────────────────────────────────── */
@media(max-width:768px){
  body{overflow:hidden;}
  .main{flex-direction:row;height:calc(100vh - 48px);}
  .panel{width:200px;}
  .tb-site{max-width:90px;}
  .tb-urlbadge{display:none;}
  .save-status{display:none;}
  .btn-publish{padding:6px 12px;font-size:11px;}
  .preview-area{flex:1;min-width:0;}
  .phone-frame{width:calc(100% - 12px);height:calc(100% - 12px);max-width:none;border-radius:12px;border:2px solid #d1d5db;box-shadow:0 2px 8px rgba(0,0,0,.12);}
  .phone-notch{display:none;}
  .preview-hint{display:none;}
  .preview-toolbar{top:6px;right:8px;gap:4px;}
  .modal-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- ── Topbar ───────────────────────────────────── -->
<div class="topbar">
  <a class="tb-back" href="/dashboard">← Back</a>
  <div class="tb-sep"></div>
  <span class="tb-site">{{ site.title }}</span>
  <button class="tb-urlbadge" onclick="copyUrl()" title="Copy URL">
    🔗 {{ site.subdomain }}.{{ baseDomain }}
  </button>
  <div class="tb-right">
    <div class="save-status">
      <div class="save-dot" id="saveDot"></div>
      <span id="saveLabel">Saved</span>
    </div>
    <button class="btn-publish" id="saveBtn" onclick="saveAll()">Publish</button>
  </div>
</div>

<div class="main">

<!-- ── Left panel ──────────────────────────────── -->
<div class="panel">
  <div class="panel-tabs">
    <button class="pt active" id="tabBtnBlocks" onclick="showTab('blocks')">Blocks</button>
    <button class="pt" id="tabBtnSettings" onclick="showTab('settings')">Settings</button>
  </div>

  <!-- SETTINGS TAB -->
  <div class="tab-content" id="tabSettings">

    <!-- Style Presets -->
    <div class="acc open" id="accPresets">
      <div class="acc-head" onclick="toggleAcc('accPresets')">
        <span class="acc-icon">🎨</span>
        <span class="acc-label">Style Preset</span>
        <span class="acc-chevron">›</span>
      </div>
      <div class="acc-body">
        <div class="preset-grid" id="presetGrid"></div>
      </div>
    </div>

    <!-- URL & Slug -->
    <div class="acc open" id="accUrl">
      <div class="acc-head" onclick="toggleAcc('accUrl')">
        <span class="acc-icon">🔗</span>
        <span class="acc-label">URL</span>
        <span class="acc-chevron">›</span>
      </div>
      <div class="acc-body">
        <div class="url-display">
          <span>{{ site.subdomain }}.{{ baseDomain }}</span>
          <button class="url-copy-btn" onclick="copyUrl()">Copy</button>
        </div>
        <p class="url-note">To change your URL, go to <a href="/dashboard/site/settings?id={{ site.id }}" style="color:#6366f1;">Site Settings</a>.</p>
      </div>
    </div>

    <!-- Button Style -->
    <div class="acc" id="accBtn">
      <div class="acc-head" onclick="toggleAcc('accBtn')">
        <span class="acc-icon">🖲️</span>
        <span class="acc-label">Button Style</span>
        <span class="acc-chevron">›</span>
      </div>
      <div class="acc-body">
        <div class="fg">
          <label class="fg-label">Style</label>
          <div class="chip-row" id="btnStyleRow"></div>
        </div>
        <div class="fg">
          <label class="fg-label">Corner Radius</label>
          <div class="radius-row" id="btnRadiusRow"></div>
        </div>
        <div class="fg">
          <label class="fg-label">Button Color</label>
          <div class="color-pair">
            <div class="color-swatch" id="btnColorSwatch">
              <input type="color" id="btnColorPicker" oninput="setApp('btnColor',this.value)">
            </div>
            <input class="fg-input" id="btnColorHex" placeholder="#6366f1" oninput="onHexInput('btnColor',this.value)">
          </div>
        </div>
        <div class="fg">
          <label class="fg-label">Text Color</label>
          <div class="color-pair">
            <div class="color-swatch" id="btnTextColorSwatch">
              <input type="color" id="btnTextColorPicker" oninput="setApp('btnTextColor',this.value)">
            </div>
            <input class="fg-input" id="btnTextColorHex" placeholder="#ffffff" oninput="onHexInput('btnTextColor',this.value)">
          </div>
        </div>
      </div>
    </div>

    <!-- Background -->
    <div class="acc" id="accBg">
      <div class="acc-head" onclick="toggleAcc('accBg')">

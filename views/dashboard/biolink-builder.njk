        +'<span style="font-size:12px;font-weight:600;color:#4338ca;min-width:60px;">'+p.label+'</span>';
      var val=document.createElement('input');
      val.className='fg-input';
      val.style.cssText='flex:1;font-size:12px;margin:0;padding:4px 8px;';
      val.value=block[p.id]||'';
      val.placeholder=p.ph;
      (function(pid){ val.addEventListener('input',function(){block[pid]=this.value;markDirty();debouncedPreview();}); })(p.id);
      var rm=document.createElement('button');
      rm.innerHTML='✕';
      rm.style.cssText='background:none;border:none;color:#6366f1;cursor:pointer;font-size:12px;padding:0 2px;opacity:.7;';
      (function(pid){ rm.onclick=function(){delete block[pid];markDirty();debouncedPreview();render();}; })(p.id);
      chip.appendChild(val); chip.appendChild(rm);
      wrap.appendChild(chip);
    });

    if(!hasAny){
      var empty=document.createElement('div');
      empty.style.cssText='font-size:12px;color:#aaa;text-align:center;padding:8px 0 12px;';
      empty.textContent='No platforms added yet';
      wrap.appendChild(empty);
    }

    // Platform picker toggle
    var addBtn=document.createElement('button');
    addBtn.style.cssText='width:100%;padding:8px;border:1px dashed #d1d5db;border-radius:8px;background:transparent;font-size:12px;color:#6b7280;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;';
    addBtn.innerHTML='<span>+</span><span>Add platform</span>';
    wrap.appendChild(addBtn);

    // Picker grid (hidden by default)
    var picker=document.createElement('div');
    picker.style.cssText='display:none;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:8px;padding-top:8px;border-top:1px solid #f3f4f6;';
    SOCIAL_PLATFORMS.forEach(function(p){
      if(p.id in block) return; // already added
      var item=document.createElement('button');
      item.style.cssText='display:flex;flex-direction:column;align-items:center;gap:3px;padding:8px 4px;border-radius:8px;border:1px solid #e5e7eb;background:#fafafa;cursor:pointer;';

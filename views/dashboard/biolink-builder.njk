<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.title }} — Bio Link Editor</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:#0f0f1a;overflow:hidden;}

/* ── Topbar ── */
.topbar{display:flex;align-items:center;gap:10px;height:46px;background:#0f0f1a;border-bottom:1px solid rgba(255,255,255,0.05);padding:0 14px;position:fixed;top:0;left:0;right:0;z-index:300;}
.tb-back{font-size:12px;color:rgba(255,255,255,0.45);text-decoration:none;padding:5px 10px;border-radius:6px;transition:all 0.15s;}
.tb-back:hover{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.7);}
.tb-sep{width:1px;height:16px;background:rgba(255,255,255,0.1);flex-shrink:0;}
.tb-title{font-size:13px;font-weight:500;color:#fff;}
.tb-url{font-size:11px;color:rgba(255,255,255,0.3);text-decoration:none;padding:4px 8px;border-radius:5px;transition:all 0.15s;}
.tb-url:hover{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.6);}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px;}
.tb-status{display:flex;align-items:center;gap:5px;font-size:11px;color:rgba(255,255,255,0.3);}
.status-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.2);transition:background 0.3s;}
.status-dot.dirty{background:#f59e0b;}
.status-dot.saved{background:#22c55e;}
.btn-save{padding:7px 16px;background:#7c3aed;color:#fff;border:none;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;}
.btn-save:hover{background:#6d28d9;}
.btn-save:disabled{opacity:0.5;cursor:not-allowed;}

/* ── Layout ── */
.main{display:flex;height:calc(100vh - 46px);margin-top:46px;}

/* ── Editor ── */
.editor{width:360px;flex-shrink:0;background:#1e1e2e;display:flex;flex-direction:column;overflow:hidden;border-right:1px solid rgba(255,255,255,0.07);}
.tabs{display:flex;border-bottom:1px solid rgba(255,255,255,0.07);flex-shrink:0;overflow-x:auto;}
.tabs::-webkit-scrollbar{display:none;}
.tab{padding:11px 10px;font-size:11px;font-weight:600;cursor:pointer;background:transparent;border:none;font-family:inherit;color:rgba(255,255,255,0.35);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all 0.15s;white-space:nowrap;flex-shrink:0;}
.tab:hover{color:rgba(255,255,255,0.6);}
.tab.active{color:#818cf8;border-bottom-color:#6366f1;}
.tab-pane{display:none;flex:1;overflow-y:auto;padding:16px 14px 80px;}
.tab-pane::-webkit-scrollbar{width:3px;}
.tab-pane::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px;}
.tab-pane.active{display:block;}

/* ── Fields ── */
.fg{margin-bottom:14px;}
.fg-label{display:block;font-size:10px;font-weight:600;color:rgba(255,255,255,0.4);margin-bottom:5px;letter-spacing:0.5px;text-transform:uppercase;}
.fg-input{width:100%;padding:8px 10px;border:1px solid rgba(255,255,255,0.12);border-radius:6px;font-size:13px;font-family:inherit;color:#e5e7eb;background:rgba(255,255,255,0.06);outline:none;transition:border-color 0.15s;}
.fg-input:focus{border-color:#6366f1;}
.fg-textarea{min-height:72px;resize:vertical;line-height:1.55;}

/* ── Avatar ── */
.avatar-toggle{display:flex;gap:4px;margin-bottom:12px;}
.atog{flex:1;padding:7px;border:1px solid rgba(255,255,255,0.1);border-radius:6px;font-size:11px;font-weight:600;cursor:pointer;background:transparent;color:rgba(255,255,255,0.35);font-family:inherit;transition:all 0.12s;}
.atog.on{background:rgba(99,102,241,0.2);color:#818cf8;border-color:rgba(99,102,241,0.5);}
.avatar-preview-box{display:flex;align-items:center;gap:12px;padding:12px;background:rgba(255,255,255,0.03);border-radius:10px;border:1px solid rgba(255,255,255,0.07);margin-bottom:12px;}
.avatar-circle{width:56px;height:56px;border-radius:50%;background:rgba(99,102,241,0.2);border:2px solid rgba(99,102,241,0.3);display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;overflow:hidden;}
.avatar-circle img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.avatar-hint{font-size:11px;color:rgba(255,255,255,0.35);line-height:1.5;}
.btn-upload{width:100%;padding:10px;border:1px dashed rgba(99,102,241,0.4);border-radius:8px;background:rgba(99,102,241,0.07);color:#818cf8;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;display:flex;align-items:center;justify-content:center;gap:6px;}
.btn-upload:hover{background:rgba(99,102,241,0.14);}
.upload-note{font-size:10px;color:rgba(255,255,255,0.25);margin-top:5px;text-align:center;}

/* ── Links ── */
.link-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:10px;margin-bottom:8px;}
.link-top{display:flex;align-items:center;gap:6px;margin-bottom:7px;}
.link-emoji-in{width:38px;padding:7px 6px;text-align:center;border:1px solid rgba(255,255,255,0.12);border-radius:6px;font-size:16px;font-family:inherit;background:rgba(255,255,255,0.06);color:#e5e7eb;outline:none;}
.link-label-in{flex:1;padding:7px 10px;border:1px solid rgba(255,255,255,0.12);border-radius:6px;font-size:12px;font-family:inherit;color:#e5e7eb;background:rgba(255,255,255,0.06);outline:none;}
.link-emoji-in:focus,.link-label-in:focus{border-color:#6366f1;}
.link-del{width:28px;height:28px;border:none;background:transparent;color:rgba(255,255,255,0.2);cursor:pointer;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:12px;transition:all 0.12s;flex-shrink:0;}
.link-del:hover{background:rgba(239,68,68,0.15);color:#fca5a5;}
.link-url-in{width:100%;padding:6px 10px;border:1px solid rgba(255,255,255,0.1);border-radius:6px;font-size:11px;font-family:inherit;color:rgba(255,255,255,0.45);background:rgba(255,255,255,0.04);outline:none;margin-bottom:7px;}
.link-url-in:focus{border-color:#6366f1;color:#e5e7eb;}
.link-styles{display:flex;gap:4px;}
.ls-chip{flex:1;padding:5px 4px;border:1px solid rgba(255,255,255,0.1);border-radius:5px;font-size:10px;font-weight:600;cursor:pointer;background:transparent;color:rgba(255,255,255,0.3);font-family:inherit;transition:all 0.12s;text-align:center;}
.ls-chip:hover{border-color:#6366f1;color:#818cf8;}
.ls-chip.on{background:rgba(99,102,241,0.2);color:#818cf8;border-color:rgba(99,102,241,0.5);}
.btn-add-link{width:100%;padding:10px;border:1px dashed rgba(99,102,241,0.35);border-radius:8px;background:rgba(99,102,241,0.06);color:#818cf8;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;margin-top:2px;}
.btn-add-link:hover{background:rgba(99,102,241,0.14);}

/* ── Socials ── */
.social-row{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.social-icon{width:28px;text-align:center;font-size:16px;flex-shrink:0;}
.social-in{flex:1;padding:8px 10px;border:1px solid rgba(255,255,255,0.12);border-radius:6px;font-size:12px;font-family:inherit;color:#e5e7eb;background:rgba(255,255,255,0.06);outline:none;}
.social-in:focus{border-color:#6366f1;}

/* ── Accent colors ── */
.colors-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;}
.c-swatch{width:32px;height:32px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all 0.15s;flex-shrink:0;}
.c-swatch:hover{transform:scale(1.15);}
.c-swatch.on{border-color:#fff;box-shadow:0 0 0 2px rgba(255,255,255,0.3);}

/* ── Page themes ── */
.theme-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;}
.pg-theme{border-radius:10px;overflow:hidden;cursor:pointer;border:2px solid transparent;transition:all 0.15s;}
.pg-theme:hover{border-color:rgba(99,102,241,0.5);}
.pg-theme.on{border-color:#818cf8;box-shadow:0 0 0 2px rgba(99,102,241,0.3);}
.pg-theme-preview{height:56px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;padding:8px;}
.pg-theme-label{font-size:10px;font-weight:600;color:rgba(255,255,255,0.6);padding:4px 0;text-align:center;background:rgba(0,0,0,0.25);}

/* ── Template picker ── */
.tpl-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:8px;}
.tpl-card{border-radius:10px;overflow:hidden;cursor:pointer;border:2px solid rgba(255,255,255,0.08);transition:all 0.15s;background:rgba(255,255,255,0.03);}
.tpl-card:hover{border-color:rgba(99,102,241,0.5);}
.tpl-card.on{border-color:#818cf8;box-shadow:0 0 0 2px rgba(99,102,241,0.3);}
.tpl-preview{height:52px;display:flex;align-items:center;justify-content:center;font-size:22px;}
.tpl-label{font-size:10px;font-weight:600;color:rgba(255,255,255,0.5);padding:4px 0;text-align:center;background:rgba(0,0,0,0.2);border-top:1px solid rgba(255,255,255,0.06);}
.tpl-card.on .tpl-label{color:#818cf8;}

/* ── Section dividers ── */
.sec-title{font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,0.25);margin:18px 0 10px;padding-top:14px;border-top:1px solid rgba(255,255,255,0.06);}
.sec-title:first-child{border-top:none;margin-top:0;padding-top:0;}

/* ── Preview ── */
.preview-area{flex:1;background:#e8e8ec;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.phone-frame{width:360px;height:720px;border-radius:48px;border:10px solid #1a1a18;box-shadow:0 0 0 1px rgba(255,255,255,0.05) inset,0 28px 80px rgba(0,0,0,0.45);overflow:hidden;background:#fff;position:relative;flex-shrink:0;}
.phone-notch{position:absolute;top:0;left:50%;transform:translateX(-50%);width:110px;height:26px;background:#1a1a18;border-radius:0 0 18px 18px;z-index:10;}
.phone-frame iframe{width:100%;height:100%;border:none;display:block;}
</style>
</head>
<body>

<div class="topbar">
  <a class="tb-back" href="/dashboard">← Dashboard</a>
  <div class="tb-sep"></div>
  <div class="tb-title">{{ site.title }}</div>
  <a class="tb-url" href="https://{{ site.subdomain }}.{{ baseDomain }}" target="_blank">↗ {{ site.subdomain }}.{{ baseDomain }}</a>
  <div class="tb-right">
    <div class="tb-status">
      <div class="status-dot" id="saveDot"></div>
      <span id="saveLabel">Saved</span>
    </div>
    <button class="btn-save" id="saveBtn" onclick="saveAll()">Save changes</button>
  </div>
</div>

<div class="main">
  <div class="editor">
    <div class="tabs">
      <button class="tab active" onclick="switchTab('profile',this)">👤 Profile</button>
      <button class="tab"        onclick="switchTab('links',this)">🔗 Links</button>
      <button class="tab"        onclick="switchTab('shop',this)">🛍️ Shop</button>
      <button class="tab"        onclick="switchTab('socials',this)">📱 Socials</button>
      <button class="tab"        onclick="switchTab('contact',this)">📇 Contact</button>
      <button class="tab"        onclick="switchTab('engage',this)">🎬 Engage</button>
      <button class="tab"        onclick="switchTab('style',this)">🎨 Style</button>
    </div>

    <!-- ── Profile ── -->
    <div class="tab-pane active" id="tab-profile">
      <div class="fg">
        <label class="fg-label">Avatar Type</label>
        <div class="avatar-toggle">
          <button id="atog-emoji" class="atog on" onclick="setAvatarMode('emoji',this)">😀 Emoji</button>
          <button id="atog-image" class="atog"    onclick="setAvatarMode('image',this)">📷 Photo</button>
        </div>
      </div>
      <div id="avatar-emoji-wrap">
        <div class="avatar-preview-box">
          <div class="avatar-circle" id="avatarCircle">✨</div>
          <div><div style="font-size:12px;font-weight:500;color:#e5e7eb;">Avatar Emoji</div><div class="avatar-hint">Paste any emoji</div></div>
        </div>
        <div class="fg">
          <label class="fg-label">Emoji</label>
          <input class="fg-input" id="f-avatar" type="text" placeholder="✨" maxlength="8"
            oninput="profile.avatar_emoji=this.value;profile.avatar_url='';updateAvatarUI();dirty();debouncedPreview()">
        </div>
      </div>
      <div id="avatar-image-wrap" style="display:none">
        <div class="avatar-preview-box">
          <div class="avatar-circle" id="avatarCircleImg">
            <img id="avatarImgEl" src="" alt="" style="display:none">
            <span id="avatarImgPh">📷</span>
          </div>
          <div><div style="font-size:12px;font-weight:500;color:#e5e7eb;">Profile Photo</div><div class="avatar-hint">JPG, PNG · square recommended</div></div>
        </div>
        <input type="file" id="avatarFile" accept="image/*" style="display:none" onchange="handleAvatarUpload(this)">
        <button class="btn-upload" onclick="document.getElementById('avatarFile').click()">📷 Upload Photo</button>
        <div class="upload-note" id="uploadNote"></div>
      </div>

      <div class="sec-title">Info</div>
      <div class="fg">
        <label class="fg-label">Display Name</label>
        <input class="fg-input" id="f-name" type="text" placeholder="Your Name" oninput="profile.name=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Tagline / Handle</label>
        <input class="fg-input" id="f-tagline" type="text" placeholder="@yourhandle" oninput="profile.tagline=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Bio</label>
        <textarea class="fg-input fg-textarea" id="f-bio" placeholder="Creator · Photographer · Based in India" oninput="profile.bio=this.value;dirty();debouncedPreview()"></textarea>
      </div>
    </div>

    <!-- ── Shop tab ── -->
    <div class="tab-pane" id="tab-shop">
      <div class="sec-title">Products & Services</div>
      <div class="fg">
        <label class="fg-label">Section Heading</label>
        <input class="fg-input" id="f-prod-heading" type="text" placeholder="Products & Services" oninput="shop.heading=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Display Mode</label>
        <div style="display:flex;gap:8px;">
          <button id="dm-grid" onclick="setDisplayMode('grid')" style="flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(99,102,241,0.3);color:#a5b4fc;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;">⊞ Grid</button>
          <button id="dm-slider" onclick="setDisplayMode('slider')" style="flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(255,255,255,0.4);font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;">▶ Slider</button>
        </div>
      </div>
      <div class="fg" id="autoScrollRow" style="display:none;">
        <label class="fg-label">Auto Scroll</label>
        <div style="display:flex;gap:8px;">
          <button id="as-no"  onclick="setAutoScroll('no')"  style="flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(99,102,241,0.3);color:#a5b4fc;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;">✕ Off</button>
          <button id="as-yes" onclick="setAutoScroll('yes')" style="flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(255,255,255,0.4);font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;">▶ On</button>
        </div>
      </div>
      <div class="fg">
        <label class="fg-label">📲 WhatsApp Order Number</label>
        <input class="fg-input" id="f-prod-wa" type="text" placeholder="+91 98765 43210" oninput="shop.wa_phone=this.value;dirty();debouncedPreview()">
      </div>
      <div id="productsList"></div>
      <button class="btn-add-link" onclick="addProduct()">＋ Add Product / Service</button>

      <div class="sec-title">UPI Payment</div>
      <div class="fg">
        <label class="fg-label">UPI ID</label>
        <input class="fg-input" id="f-upi-id" type="text" placeholder="yourname@upi" oninput="upi.upi_id=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Display Name</label>
        <input class="fg-input" id="f-upi-name" type="text" placeholder="Your Name" oninput="upi.display_name=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Fixed Amount (optional — leave blank for any amount)</label>
        <input class="fg-input" id="f-upi-amount" type="text" placeholder="499" oninput="upi.amount=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Button Label</label>
        <input class="fg-input" id="f-upi-btn" type="text" placeholder="💳 Pay with UPI" oninput="upi.btn_label=this.value;dirty();debouncedPreview()">
      </div>
    </div>

    <!-- ── Links ── -->
    <div class="tab-pane" id="tab-links">
      <div id="linksList"></div>
      <button class="btn-add-link" onclick="addLink()">＋ Add Link</button>
    </div>

    <!-- ── Socials ── -->
    <div class="tab-pane" id="tab-socials">
      <div class="sec-title">Social Profiles</div>
      <div class="social-row"><span class="social-icon">📸</span><input class="social-in" id="f-instagram" type="text" placeholder="https://instagram.com/…" oninput="socials.instagram=this.value;dirty();debouncedPreview()"></div>
      <div class="social-row"><span class="social-icon">▶️</span><input class="social-in" id="f-youtube"   type="text" placeholder="https://youtube.com/…"   oninput="socials.youtube=this.value;dirty();debouncedPreview()"></div>
      <div class="social-row"><span class="social-icon">𝕏</span><input class="social-in" id="f-twitter"   type="text" placeholder="https://twitter.com/…"   oninput="socials.twitter=this.value;dirty();debouncedPreview()"></div>
      <div class="social-row"><span class="social-icon">🎵</span><input class="social-in" id="f-tiktok"    type="text" placeholder="https://tiktok.com/@…"    oninput="socials.tiktok=this.value;dirty();debouncedPreview()"></div>
      <div class="social-row"><span class="social-icon">💼</span><input class="social-in" id="f-linkedin"  type="text" placeholder="https://linkedin.com/in/…" oninput="socials.linkedin=this.value;dirty();debouncedPreview()"></div>
      <div class="social-row"><span class="social-icon">🐙</span><input class="social-in" id="f-github"    type="text" placeholder="https://github.com/…"     oninput="socials.github=this.value;dirty();debouncedPreview()"></div>
    </div>

    <!-- ── Contact ── -->
    <div class="tab-pane" id="tab-contact">
      <div class="sec-title">Contact Details</div>
      <div class="fg">
        <label class="fg-label">📞 Phone Number</label>
        <input class="fg-input" id="f-phone" type="text" placeholder="+91 98765 43210" oninput="contact.phone=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">✉️ Email Address</label>
        <input class="fg-input" id="f-email" type="text" placeholder="hello@yourname.com" oninput="contact.email=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">🌐 Website</label>
        <input class="fg-input" id="f-website" type="text" placeholder="https://yourwebsite.com" oninput="contact.website=this.value;dirty();debouncedPreview()">
      </div>
      <div class="sec-title">Location & Directions</div>
      <div class="fg">
        <label class="fg-label">📍 Address</label>
        <input class="fg-input" id="f-address" type="text" placeholder="123 Main St, Mumbai" oninput="contact.address=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Directions URL <span style="opacity:0.5;font-weight:400;text-transform:none;letter-spacing:0">(optional — auto-generates from address)</span></label>
        <input class="fg-input" id="f-maps-url" type="text" placeholder="https://maps.google.com/…" oninput="contact.maps_url=this.value;dirty();debouncedPreview()">
      </div>
      <div class="sec-title">Save to Phone Button</div>
      <div class="fg">
        <label class="fg-label">Button Label</label>
        <input class="fg-input" id="f-save-label" type="text" placeholder="💾 Save Contact" oninput="contact.save_label=this.value;dirty();debouncedPreview()">
      </div>
      <div style="background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.2);border-radius:8px;padding:10px 12px;font-size:11px;color:rgba(255,255,255,0.5);line-height:1.6;">
        💡 Visitors tap this button to download a contact card (.vcf) they can save directly to their phone contacts.
      </div>
    </div>

    <!-- ── Engage tab ── -->
    <div class="tab-pane" id="tab-engage">
      <div class="sec-title">Embed Form</div>
      <div style="font-size:12px;color:rgba(255,255,255,0.45);margin-bottom:12px;line-height:1.5;">
        Create a form in the <a href="/dashboard/forms" target="_blank" style="color:#818cf8;">Forms module</a>, then paste its Form ID below to embed it here.
      </div>
      <div class="fg">
        <label class="fg-label">Form ID</label>
        <input class="fg-input" id="f-form-id" type="text" placeholder="e.g. 1" oninput="formEmbed.form_id=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Heading (optional)</label>
        <input class="fg-input" id="f-form-heading" type="text" placeholder="Get in Touch" oninput="formEmbed.heading=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Subheading (optional)</label>
        <input class="fg-input" id="f-form-subheading" type="text" placeholder="Fill in the form below" oninput="formEmbed.subheading=this.value;dirty();debouncedPreview()">
      </div>

      <div class="sec-title" style="margin-top:20px;">Video Embed</div>
      <div class="fg">
        <label class="fg-label">YouTube URL</label>
        <input class="fg-input" id="f-video-url" type="text" placeholder="https://youtube.com/watch?v=..." oninput="video.url=this.value;dirty();debouncedPreview()">
      </div>
      <div class="fg">
        <label class="fg-label">Caption (optional)</label>
        <input class="fg-input" id="f-video-caption" type="text" placeholder="Watch my latest video" oninput="video.caption=this.value;dirty();debouncedPreview()">
      </div>
    </div>

    <!-- ── Style ── -->
    <div class="tab-pane" id="tab-style">
      <div class="fg">
        <label class="fg-label">Theme Template</label>
        <div class="tpl-grid" id="tplGrid"></div>
      </div>
      <div class="fg" style="margin-top:18px;">
        <label class="fg-label">Page Background</label>
        <div class="theme-grid" id="themeGrid"></div>
      </div>
      <div class="fg" style="margin-top:18px;">
        <label class="fg-label">Accent Color</label>
        <div class="colors-row" id="colorsRow"></div>
      </div>
    </div>
  </div>

  <!-- ── Phone preview ── -->
  <div class="preview-area">
    <div class="phone-frame">
      <div class="phone-notch"></div>
      <iframe id="previewFrame" sandbox="allow-scripts allow-same-origin" title="Preview"></iframe>
    </div>
  </div>
</div>

<script>
const SITE_ID     = {{ site.id }};
const BASE_DOMAIN = {{ baseDomain | dump | safe }};

const ACCENT_COLORS = [
  {id:'violet',hex:'#7c3aed'},{id:'rose',hex:'#e11d48'},{id:'sky',hex:'#0284c7'},
  {id:'emerald',hex:'#059669'},{id:'amber',hex:'#d97706'},{id:'ink',hex:'#1a1a18'},
  {id:'slate',hex:'#475569'},{id:'pink',hex:'#db2777'},{id:'cyan',hex:'#06b6d4'},
  {id:'lime',hex:'#84cc16'}
];

const PAGE_THEMES = [
  {id:'light',  label:'Light',   bg:'linear-gradient(160deg,#eff4ff,#fff)',          dot:'rgba(99,102,241,0.4)'},
  {id:'dark',   label:'Dark',    bg:'#0f0f1a',                                       dot:'rgba(99,102,241,0.7)'},
  {id:'warm',   label:'Warm',    bg:'linear-gradient(160deg,#fef3c7,#fce7f3)',        dot:'rgba(217,119,6,0.6)'},
  {id:'glass',  label:'Glass',   bg:'linear-gradient(135deg,#667eea,#764ba2)',        dot:'rgba(255,255,255,0.7)'},
  {id:'minimal',label:'Minimal', bg:'#ffffff',                                       dot:'rgba(0,0,0,0.25)'},
  {id:'forest', label:'Forest',  bg:'linear-gradient(160deg,#d1fae5,#ecfdf5)',       dot:'rgba(5,150,105,0.5)'}
];

const TEMPLATES = [
  {id:'biolink',      label:'Classic', emoji:'✨', bg:'linear-gradient(160deg,#eff4ff,#fff)'},
  {id:'biolink-neon', label:'Neon',    emoji:'⚡', bg:'#050510'},
  {id:'biolink-card', label:'Card',    emoji:'🃏', bg:'#f4f4f0'}
];

// ── Flatten sections ──────────────────────────────────────────────────────────
function flattenSections(raw) {
  const out = [];
  for (const s of (raw || [])) {
    if (s._isRow && s.columns) { for (const col of s.columns) for (const sec of (col||[])) out.push(sec); }
    else if (!s._isRow) out.push(s);
  }
  return out;
}

const rawSections = {{ (settings.sections or []) | dump | safe }};
const flat = flattenSections(rawSections);
function savedFields(id, def) {
  const s = flat.find(x => x.id === id);
  return s ? Object.assign({}, def, s.fields || {}) : Object.assign({}, def);
}

// ── State ─────────────────────────────────────────────────────────────────────
let profile  = savedFields('profile',      {avatar_emoji:'✨',avatar_url:'',name:'',tagline:'',bio:''});
let links    = Array.from(savedFields('links', {items:[]}).items || []);
let socials  = savedFields('socials',      {instagram:'',youtube:'',twitter:'',tiktok:'',linkedin:'',github:''});
let contact  = savedFields('contact_card', {phone:'',email:'',website:'',address:'',maps_url:'',save_label:'💾 Save Contact'});
let shop     = savedFields('products',     {heading:'Products & Services',display_mode:'grid',auto_scroll:'no',wa_phone:'',items:[]});
let shopItems = Array.from(shop.items || []);
let upi      = savedFields('upi_pay',      {upi_id:'',display_name:'',amount:'',btn_label:'💳 Pay with UPI'});
let formEmbed = savedFields('form_embed', {form_id:'',heading:'',subheading:''});
let video    = savedFields('video_embed',  {url:'',caption:''});
let currentAccent    = {{ (settings.theme or 'violet') | dump | safe }};
let currentPageTheme = {{ (settings.biolink_theme or 'light') | dump | safe }};
let currentTemplate  = {{ (site.template_id or 'biolink') | dump | safe }};
let avatarMode   = (profile.avatar_url ? 'image' : 'emoji');
let previewTimer = null;

// ── Init ──────────────────────────────────────────────────────────────────────
function init() {
  setv('f-avatar',     profile.avatar_emoji);
  setv('f-name',       profile.name);
  setv('f-tagline',    profile.tagline);
  setv('f-bio',        profile.bio);
  setv('f-instagram',  socials.instagram);
  setv('f-youtube',    socials.youtube);
  setv('f-twitter',    socials.twitter);
  setv('f-tiktok',     socials.tiktok);
  setv('f-linkedin',   socials.linkedin);
  setv('f-github',     socials.github);
  setv('f-prod-heading', shop.heading);
  setv('f-prod-wa',      shop.wa_phone);
  setDisplayMode(shop.display_mode || 'grid', true);
  setAutoScroll(shop.auto_scroll || 'no', true);
  setv('f-upi-id',       upi.upi_id);
  setv('f-upi-name',     upi.display_name);
  setv('f-upi-amount',   upi.amount);
  setv('f-upi-btn',      upi.btn_label);
  setv('f-form-id',         formEmbed.form_id);
  setv('f-form-heading',    formEmbed.heading);
  setv('f-form-subheading', formEmbed.subheading);
  setv('f-video-url',    video.url);
  setv('f-video-caption',video.caption);
  renderProducts();
  setv('f-phone',      contact.phone);
  setv('f-email',      contact.email);
  setv('f-website',    contact.website);
  setv('f-address',    contact.address);
  setv('f-maps-url',   contact.maps_url);
  setv('f-save-label', contact.save_label);
  setAvatarMode(avatarMode, document.getElementById('atog-'+avatarMode), true);
  updateAvatarUI();
  renderLinks();
  renderAccentColors();
  renderPageThemes();
  renderTemplates();
  refreshPreview();
}
function setv(id, val) { const el = document.getElementById(id); if(el) el.value = val || ''; }

// ── Avatar ────────────────────────────────────────────────────────────────────
function setAvatarMode(mode, el, silent) {
  avatarMode = mode;
  document.querySelectorAll('.atog').forEach(b => b.classList.remove('on'));
  if(el) el.classList.add('on');
  document.getElementById('avatar-emoji-wrap').style.display = mode==='emoji' ? 'block' : 'none';
  document.getElementById('avatar-image-wrap').style.display = mode==='image' ? 'block' : 'none';
  if(!silent){ dirty(); debouncedPreview(); }
}
function updateAvatarUI() {
  document.getElementById('avatarCircle').textContent = profile.avatar_emoji || '✨';
  const img = document.getElementById('avatarImgEl');
  const ph  = document.getElementById('avatarImgPh');
  if(profile.avatar_url){ img.src=profile.avatar_url; img.style.display='block'; ph.style.display='none'; }
  else { img.style.display='none'; ph.style.display='block'; }
}
async function handleAvatarUpload(input) {
  const file = input.files[0]; if(!file) return;
  const note = document.getElementById('uploadNote');
  note.textContent = 'Uploading…';
  const fd = new FormData(); fd.append('image', file);
  try {
    const r = await fetch(`/dashboard/media/${SITE_ID}/upload`,{method:'POST',body:fd});
    const d = await r.json();
    if(d.ok){ profile.avatar_url=d.url; profile.avatar_emoji=''; note.textContent='✓ Uploaded'; setTimeout(()=>note.textContent='',2000); updateAvatarUI(); dirty(); debouncedPreview(); }
    else note.textContent = 'Failed: '+(d.error||'error');
  } catch(err){ note.textContent='Failed: '+err.message; }
  input.value='';
}

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(id, el) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+id).classList.add('active');
}

// ── Links ─────────────────────────────────────────────────────────────────────
function renderLinks() {
  const list = document.getElementById('linksList'); list.innerHTML='';
  links.forEach((lk,i) => {
    const d = document.createElement('div'); d.className='link-card';
    d.innerHTML=`<div class="link-top">
      <input class="link-label-in" value="${h(lk.label||'')}" placeholder="Label" oninput="links[${i}].label=this.value;dirty();debouncedPreview()">
      <button class="link-del" onclick="delLink(${i})">✕</button></div>
    <input class="link-url-in" value="${h(lk.url||'')}" placeholder="https://..." oninput="links[${i}].url=this.value;dirty();debouncedPreview()">
    <div class="link-styles">
      <button class="ls-chip ${(lk.style||'solid')==='solid'?'on':''}" onclick="setStyle(${i},'solid')">Solid</button>
      <button class="ls-chip ${lk.style==='outline'?'on':''}" onclick="setStyle(${i},'outline')">Outline</button>
      <button class="ls-chip ${lk.style==='ghost'?'on':''}" onclick="setStyle(${i},'ghost')">Ghost</button>
    </div>`;
    list.appendChild(d);
  });
}
function h(s){ return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }
function addLink(){ links.push({emoji:'🌐',label:'New Link',url:'https://',style:'solid'}); renderLinks(); dirty(); debouncedPreview(); }
function delLink(i){ links.splice(i,1); renderLinks(); dirty(); debouncedPreview(); }
function setStyle(i,s){ links[i].style=s; renderLinks(); dirty(); debouncedPreview(); }

// ── Products ─────────────────────────────────────────────────────────────────
function renderProducts() {
  const list = document.getElementById('productsList'); list.innerHTML='';
  shopItems.forEach((p,i) => {
    const d = document.createElement('div'); d.className='link-card'; d.style.marginBottom='8px';
    d.innerHTML=`<div class="link-top" style="margin-bottom:6px;">
      <input class="link-emoji-in" value="${h(p.emoji||'📦')}" maxlength="4" oninput="shopItems[${i}].emoji=this.value;dirty();debouncedPreview()">
      <input class="link-label-in" value="${h(p.name||'')}" placeholder="Product name" oninput="shopItems[${i}].name=this.value;dirty();debouncedPreview()">
      <button class="link-del" onclick="delProduct(${i})">✕</button></div>
    <input class="link-url-in" value="${h(p.price||'')}" placeholder="Price e.g. ₹999" style="margin-bottom:5px;" oninput="shopItems[${i}].price=this.value;dirty();debouncedPreview()">
    <input class="link-url-in" value="${h(p.desc||'')}" placeholder="Short description" style="margin-bottom:5px;" oninput="shopItems[${i}].desc=this.value;dirty();debouncedPreview()">
    <div style="display:flex;gap:6px;align-items:center;margin-bottom:2px;">
      <input class="link-url-in" id="prod-img-${i}" value="${h(p.image||'')}" placeholder="Image URL" style="flex:1;margin-bottom:0;" oninput="shopItems[${i}].image=this.value;dirty();debouncedPreview()">
      <label style="flex-shrink:0;padding:6px 10px;background:rgba(99,102,241,0.15);border:1px solid rgba(99,102,241,0.3);border-radius:6px;font-size:11px;color:#818cf8;cursor:pointer;white-space:nowrap;">
        📷 Upload
        <input type="file" accept="image/*" style="display:none;" onchange="uploadProductImage(this,${i})">
      </label>
    </div>
    <div id="prod-img-preview-${i}" style="${p.image?'':'display:none;'}margin-top:4px;">
      <img src="${h(p.image||'')}" style="width:100%;max-height:100px;object-fit:cover;border-radius:6px;border:1px solid rgba(255,255,255,0.1);">
    </div>`;
    list.appendChild(d);
  });
}
function setDisplayMode(mode, silent) {
  shop.display_mode = mode;
  const gBtn = document.getElementById('dm-grid');
  const sBtn = document.getElementById('dm-slider');
  const asRow = document.getElementById('autoScrollRow');
  if (gBtn && sBtn) {
    const on  = 'flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(99,102,241,0.3);color:#a5b4fc;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;';
    const off = 'flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(255,255,255,0.4);font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;';
    gBtn.style.cssText = mode === 'grid'   ? on : off;
    sBtn.style.cssText = mode === 'slider' ? on : off;
  }
  if (asRow) asRow.style.display = mode === 'slider' ? '' : 'none';
  if (!silent) { dirty(); debouncedPreview(); }
}
function setAutoScroll(val, silent) {
  shop.auto_scroll = val;
  const noBtn  = document.getElementById('as-no');
  const yesBtn = document.getElementById('as-yes');
  if (noBtn && yesBtn) {
    const on  = 'flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(99,102,241,0.3);color:#a5b4fc;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;';
    const off = 'flex:1;padding:8px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(255,255,255,0.4);font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;';
    noBtn.style.cssText  = val === 'no'  ? on : off;
    yesBtn.style.cssText = val === 'yes' ? on : off;
  }
  if (!silent) { dirty(); debouncedPreview(); }
}
function addProduct()  { shopItems.push({emoji:'📦',name:'New Product',price:'₹999',desc:'',image:''}); renderProducts(); dirty(); debouncedPreview(); }
function delProduct(i) { shopItems.splice(i,1); renderProducts(); dirty(); debouncedPreview(); }
function uploadProductImage(input, i) {
  const file = input.files[0]; if (!file) return;
  const fd = new FormData(); fd.append('image', file);
  const siteId = {{ site.id }};
  fetch('/dashboard/media/' + siteId + '/upload', { method:'POST', body:fd })
    .then(r => r.json())
    .then(d => {
      if (d.url) {
        shopItems[i].image = d.url;
        const urlInput = document.getElementById('prod-img-' + i);
        if (urlInput) urlInput.value = d.url;
        const preview = document.getElementById('prod-img-preview-' + i);
        if (preview) { preview.style.display=''; preview.querySelector('img').src = d.url; }
        dirty(); debouncedPreview();
      }
    })
    .catch(() => alert('Upload failed. Please try again.'));
}

// ── Colors ────────────────────────────────────────────────────────────────────
function renderAccentColors() {
  const row = document.getElementById('colorsRow'); row.innerHTML='';
  ACCENT_COLORS.forEach(c => {
    const sw = document.createElement('div');
    sw.className='c-swatch'+(c.id===currentAccent?' on':'');
    sw.style.background=c.hex; sw.title=c.id;
    sw.onclick=()=>{ currentAccent=c.id; renderAccentColors(); dirty(); debouncedPreview(); };
    row.appendChild(sw);
  });
}

// ── Page themes ───────────────────────────────────────────────────────────────
function renderPageThemes() {
  const grid = document.getElementById('themeGrid'); grid.innerHTML='';
  PAGE_THEMES.forEach(t => {
    const card = document.createElement('div');
    card.className='pg-theme'+(t.id===currentPageTheme?' on':'');
    card.innerHTML=`<div class="pg-theme-preview" style="background:${t.bg}">
      <div style="width:22px;height:22px;border-radius:50%;background:${t.dot};"></div>
      <div style="display:flex;flex-direction:column;gap:3px;width:70%;">
        <div style="height:4px;border-radius:2px;background:rgba(255,255,255,0.3);"></div>
        <div style="height:4px;border-radius:2px;background:rgba(255,255,255,0.2);width:65%;"></div>
      </div></div>
    <div class="pg-theme-label">${t.label}</div>`;
    card.onclick=()=>{ currentPageTheme=t.id; renderPageThemes(); dirty(); debouncedPreview(); };
    grid.appendChild(card);
  });
}

// ── Template picker ───────────────────────────────────────────────────────────
function renderTemplates() {
  const grid = document.getElementById('tplGrid'); grid.innerHTML='';
  TEMPLATES.forEach(t => {
    const card = document.createElement('div');
    card.className='tpl-card'+(t.id===currentTemplate?' on':'');
    card.innerHTML=`<div class="tpl-preview" style="background:${t.bg}">${t.emoji}</div>
      <div class="tpl-label">${t.label}</div>`;
    card.onclick=()=>switchTemplate(t.id);
    grid.appendChild(card);
  });
}
async function switchTemplate(tplId) {
  if(tplId===currentTemplate) return;
  try {
    const r = await fetch('/dashboard/site/set-template',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({site_id:SITE_ID,template_id:tplId})});
    const d = await r.json();
    if(d.ok){ currentTemplate=tplId; renderTemplates(); debouncedPreview(); }
    else alert('Could not switch template.');
  } catch(e){ alert('Error: '+e.message); }
}

// ── Dirty / saved ─────────────────────────────────────────────────────────────
function dirty(){ document.getElementById('saveDot').className='status-dot dirty'; document.getElementById('saveLabel').textContent='Unsaved'; }
function markSaved(){ document.getElementById('saveDot').className='status-dot saved'; document.getElementById('saveLabel').textContent='Saved'; setTimeout(()=>{ document.getElementById('saveDot').className='status-dot'; },2000); }

// ── Build sections ────────────────────────────────────────────────────────────
function buildSections() {
  return [
    {id:'profile',      fields:{...profile, avatar_url: avatarMode==='image'?(profile.avatar_url||''):''}},
    {id:'links',        fields:{items:links.map(l=>({...l}))}},
    {id:'products',     fields:{...shop, items:shopItems.map(p=>({...p}))}},
    {id:'upi_pay',      fields:{...upi}},
    {id:'form_embed',   fields:{...formEmbed}},
    {id:'video_embed',  fields:{...video}},
    {id:'socials',      fields:{...socials}},
    {id:'contact_card', fields:{...contact}}
  ];
}

// ── Preview ───────────────────────────────────────────────────────────────────
function debouncedPreview(){ clearTimeout(previewTimer); previewTimer=setTimeout(refreshPreview,350); }
function refreshPreview() {
  fetch('/dashboard/site/builder-preview',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({site_id:SITE_ID,sections:JSON.stringify(buildSections()),theme:currentAccent,biolink_theme:currentPageTheme})
  }).then(r=>r.text()).then(html=>{ document.getElementById('previewFrame').srcdoc=html; }).catch(()=>{});
}

// ── Save ──────────────────────────────────────────────────────────────────────
async function saveAll() {
  const btn = document.getElementById('saveBtn');
  btn.textContent='Saving…'; btn.disabled=true;
  try {
    const r = await fetch('/dashboard/site/biolink-save',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({site_id:SITE_ID,sections:JSON.stringify(buildSections()),theme:currentAccent,biolink_theme:currentPageTheme})});
    const d = await r.json();
    if(d.ok) markSaved(); else alert('Save failed — please try again.');
  } catch(err){ alert('Save failed: '+err.message); }
  btn.textContent='Save changes'; btn.disabled=false;
}

init();
</script>
</body>
</html>

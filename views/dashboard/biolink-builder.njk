}

/* ── Image upload ────────────────────────────── */
var _imgCb=null;
document.getElementById('hiddenFileInput').addEventListener('change',function(){
  var file=this.files[0];
  if(!file||!_imgCb) return;
  var fd=new FormData(); fd.append('image',file); fd.append('site_id',SITE_ID);
  fetch('/dashboard/media/'+SITE_ID+'/upload',{method:'POST',body:fd})
    .then(function(r){return r.json();})
    .then(function(d){if(d.url)_imgCb(d.url);});
  this.value='';
});
function triggerUpload(cb){_imgCb=cb;document.getElementById('hiddenFileInput').click();}

/* ── Block helpers ───────────────────────────── */
function genId(){return 'b'+(Date.now()).toString(36)+Math.random().toString(36).slice(2,5);}
function getBlockSummary(block){
  switch(block.type){
    case 'avatar': return block.name||'Avatar';
    case 'link': return block.title||'Link';
    case 'heading': return block.text||'Heading';
    case 'paragraph': return (block.text||'').slice(0,28)||'Paragraph';
    case 'image': return 'Image';
    case 'socials': return 'Social icons';
    case 'email_collector': return 'Email collector';
    case 'phone_collector': return 'Phone collector';
    case 'contact_form': return 'Contact form';
    case 'business_hours': return 'Business hours';
    case 'video': return block.url ? block.url.slice(0,36)+'…' : 'Video';
    case 'divider': return 'Divider';
    case 'product': return block.title||'Product';
    case 'banner': return block.text||'Banner';
    case 'testimonial': return block.name||'Testimonial';
    case 'faq': return 'FAQ ('+(block.items?block.items.length:0)+' items)';
    case 'reviews': return 'Reviews ('+(block.items?block.items.length:0)+')';
    case 'map': return 'Map';
    case 'html': return 'Custom HTML';
    case 'service': return block.title||'Service';
    default: return block.type;
  }
}

/* ── Add block ───────────────────────────────── */
function addBlock(type){
  var bt=BLOCK_TYPES[type];
  if(!bt) return;
  var block=Object.assign({id:genId(),type:type,enabled:true},bt.defaults);
  BLOCKS.push(block);
  markDirty(); debouncedPreview(); renderBlocks();
  // Auto-open new block
  setTimeout(function(){
    var cards=document.querySelectorAll('.blk-card');
    var last=cards[cards.length-1];
    if(last){last.classList.add('open');last.scrollIntoView({behavior:'smooth',block:'nearest'});}
    showTab('blocks');
  },50);
}

/* ── Toggle block enabled ────────────────────── */
function toggleBlock(id, btn){
  var block=BLOCKS.find(function(b){return b.id===id;});
  if(!block) return;
  block.enabled=!block.enabled;
  var card=btn.closest('.blk-card');
  if(card) card.classList.toggle('disabled',!block.enabled);
  btn.textContent=block.enabled?'👁':'🚫';
  markDirty(); debouncedPreview();
}

/* ── Delete block ────────────────────────────── */
function deleteBlock(id){
  BLOCKS=BLOCKS.filter(function(b){return b.id!==id;});
  markDirty(); debouncedPreview(); renderBlocks();
}

/* ── Apply global animation to all blocks ────── */
function applyAnimToAll(){
  BLOCKS.forEach(function(b){ b.animation=APP.animationStyle; });
  markDirty(); debouncedPreview(); renderBlocks();
}

/* ── Build block edit fields ─────────────────── */
function buildBlockFields(block, container){
  var bt=BLOCK_TYPES[block.type];
  if(!bt) return;

  // Hours grid type needs special handling
  var fields=bt.fields.filter(function(f){return f.type!=='hours';});
  var hasHours=bt.fields.some(function(f){return f.type==='hours';});

  fields.forEach(function(f){
    var fg=document.createElement('div');
    fg.className='fg';
    var lbl=document.createElement('label');
    lbl.className='fg-label';
    lbl.textContent=f.label;
    fg.appendChild(lbl);

    if(f.type==='toggle'){
      var tr=document.createElement('div');
      tr.className='toggle-row';
      tr.style.marginBottom='0';
      var tl=document.createElement('span');
      tl.className='toggle-label'; tl.textContent=f.label;
      var tsw=document.createElement('label');
      tsw.className='toggle-switch';
      var tinp=document.createElement('input');
      tinp.type='checkbox'; tinp.checked=!!block[f.id];
      tinp.addEventListener('change',function(){
        block[f.id]=this.checked; markDirty(); debouncedPreview();
      });
      var tsl=document.createElement('span'); tsl.className='toggle-slider';
      tsw.appendChild(tinp); tsw.appendChild(tsl);
      tr.appendChild(tl); tr.appendChild(tsw);
      fg.removeChild(lbl); fg.appendChild(tr);
    } else if(f.type==='image'){
      var irow=document.createElement('div'); irow.className='img-row';
      var ithumb=document.createElement('div'); ithumb.className='img-thumb';
      var curU=block[f.id]||'';
      if(curU){var ii=document.createElement('img');ii.src=curU;ithumb.appendChild(ii);}
      else{ithumb.textContent='🖼️';}
      var iinputs=document.createElement('div'); iinputs.className='img-inputs';
      var iinp=document.createElement('input'); iinp.className='fg-input';
      iinp.placeholder='https://…'; iinp.value=curU;
      iinp.addEventListener('input',function(){
        block[f.id]=this.value;
        ithumb.innerHTML='';
        if(this.value){var ii2=document.createElement('img');ii2.src=this.value;ithumb.appendChild(ii2);}
        else{ithumb.textContent='🖼️';}
        markDirty(); debouncedPreview();
      });
      var iubtn=document.createElement('button'); iubtn.className='btn-upload'; iubtn.textContent='📷 Upload';
      (function(inputEl,thumbEl,fid){
        iubtn.onclick=function(){
          triggerUpload(function(url){
            inputEl.value=url; block[fid]=url;
            thumbEl.innerHTML=''; var ii3=document.createElement('img');ii3.src=url;thumbEl.appendChild(ii3);
            markDirty(); debouncedPreview();
          });
        };
      })(iinp,ithumb,f.id);
      iinputs.appendChild(iinp); iinputs.appendChild(iubtn);
      irow.appendChild(ithumb); irow.appendChild(iinputs);
      fg.appendChild(irow);
    } else if(f.type==='textarea'){
      var ta=document.createElement('textarea');
      ta.className='fg-input fg-textarea'; ta.style.minHeight='60px';
      ta.placeholder=f.ph||''; ta.value=block[f.id]||'';
      ta.addEventListener('input',function(){block[f.id]=this.value; markDirty(); debouncedPreview();});
      fg.appendChild(ta);
    } else if(f.type==='select'){
      var sel=document.createElement('select'); sel.className='fg-select';
      (f.opts||[]).forEach(function(o){
        var opt=document.createElement('option');
        opt.value=o.v; opt.textContent=o.l;
        if(block[f.id]===o.v) opt.selected=true;
        sel.appendChild(opt);
      });
      sel.addEventListener('change',function(){block[f.id]=this.value; markDirty(); debouncedPreview();});
      fg.appendChild(sel);
    } else if(f.type==='color'){
      // Inline color picker: swatch + hex input
      var cpair=document.createElement('div'); cpair.className='color-pair';
      var cswatch=document.createElement('div'); cswatch.className='color-swatch';
      cswatch.style.background=block[f.id]||f.ph||'#cccccc';
      var cnative=document.createElement('input'); cnative.type='color'; cnative.value=block[f.id]||f.ph||'#cccccc';
      cswatch.appendChild(cnative);
      var chex=document.createElement('input'); chex.className='fg-input'; chex.placeholder=f.ph||'#000000'; chex.value=block[f.id]||'';
      var _fid=f.id;
      function mkColorHandler(sw,pk,hx,bid){
        function setC(v){ block[bid]=v; sw.style.background=v; pk.value=v; hx.value=v; markDirty(); debouncedPreview(); }
        pk.addEventListener('input',function(){setC(this.value);});
        hx.addEventListener('input',function(){if(/^#[0-9a-fA-F]{6}$/.test(this.value))setC(this.value);});
      }
      mkColorHandler(cswatch,cnative,chex,_fid);
      cpair.appendChild(cswatch); cpair.appendChild(chex);
      fg.appendChild(cpair);
    } else if(f.type==='items'){
      // Mini repeater for list items (FAQ, etc.)
      if(!block[f.id]) block[f.id]=[];
      var iListWrap=document.createElement('div');
      var iAddBtn=document.createElement('button'); iAddBtn.className='btn-upload'; iAddBtn.style.marginBottom='8px'; iAddBtn.textContent='+ Add item';
      var iList=document.createElement('div'); iList.style.cssText='display:flex;flex-direction:column;gap:6px;';
      (function(blk,fld,listEl){
        function renderIList(){
          listEl.innerHTML='';
          (blk[fld.id]||[]).forEach(function(item,idx){
            var icard=document.createElement('div');
            icard.style.cssText='background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:8px 10px;position:relative;';
            fld.item_fields.forEach(function(iField){
              var iel=document.createElement(iField.type==='textarea'?'textarea':'input');
              iel.className='fg-input'; iel.placeholder=iField.ph||''; iel.value=item[iField.id]||'';
              iel.style.marginBottom='4px'; iel.style.fontSize='12px';
              if(iField.type==='textarea'){iel.style.minHeight='50px'; iel.style.resize='vertical';}
              (function(i,fid){
                iel.addEventListener('input',function(){blk[fld.id][i][fid]=this.value;markDirty();debouncedPreview();});
              })(idx,iField.id);
              icard.appendChild(iel);
            });
            var idel=document.createElement('button');
            idel.style.cssText='position:absolute;top:6px;right:6px;background:none;border:none;color:#d1d5db;cursor:pointer;font-size:13px;padding:0;';
            idel.textContent='✕';
            (function(i){idel.onclick=function(){blk[fld.id].splice(i,1);markDirty();debouncedPreview();renderIList();};})(idx);
            icard.appendChild(idel);
            listEl.appendChild(icard);
          });
        }
        iAddBtn.onclick=function(){
          var blank={};
          fld.item_fields.forEach(function(iField){blank[iField.id]='';});
          blk[fld.id].push(blank);
          markDirty();debouncedPreview();renderIList();
        };
        renderIList();
      })(block,f,iList);
      fg.removeChild(lbl); // label shown via iAddBtn layout
      var iheadrow=document.createElement('div'); iheadrow.style.cssText='display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;';
      var ilbl2=document.createElement('span'); ilbl2.className='fg-label'; ilbl2.textContent=f.label; ilbl2.style.margin='0';
      iheadrow.appendChild(ilbl2); iheadrow.appendChild(iAddBtn);
      fg.appendChild(iheadrow); fg.appendChild(iList);
      iListWrap.appendChild(fg);
      container.appendChild(iListWrap);
      return; // forEach: skip the container.appendChild(fg) at the bottom
    } else {
      var inp=document.createElement('input'); inp.className='fg-input';
      inp.type='text'; inp.placeholder=f.ph||''; inp.value=block[f.id]||'';
      inp.addEventListener('input',function(){block[f.id]=this.value; markDirty(); debouncedPreview();});
      fg.appendChild(inp);
    }
    container.appendChild(fg);
  });

  // Hours grid
  if(hasHours){
    var hfg=document.createElement('div'); hfg.className='fg';
    var hlbl=document.createElement('label'); hlbl.className='fg-label'; hlbl.textContent='Hours (leave blank if closed)';
    hfg.appendChild(hlbl);
    var hgrid=document.createElement('div'); hgrid.className='hours-grid';
    var days=[{k:'mon',l:'Mon'},{k:'tue',l:'Tue'},{k:'wed',l:'Wed'},{k:'thu',l:'Thu'},{k:'fri',l:'Fri'},{k:'sat',l:'Sat'},{k:'sun',l:'Sun'}];
    days.forEach(function(d){
      var dayEl=document.createElement('div'); dayEl.className='hours-day'; dayEl.textContent=d.l;
      var inpO=document.createElement('input'); inpO.className='hours-inp'; inpO.placeholder='9:00 AM'; inpO.value=block[d.k+'_open']||'';
      inpO.addEventListener('input',function(){block[d.k+'_open']=this.value;markDirty();debouncedPreview();});
      var sep=document.createElement('div'); sep.className='hours-sep'; sep.textContent='–';
      var inpC=document.createElement('input'); inpC.className='hours-inp'; inpC.placeholder='6:00 PM'; inpC.value=block[d.k+'_close']||'';
      inpC.addEventListener('input',function(){block[d.k+'_close']=this.value;markDirty();debouncedPreview();});
      hgrid.appendChild(dayEl); hgrid.appendChild(inpO); hgrid.appendChild(sep); hgrid.appendChild(inpC);
    });
    hfg.appendChild(hgrid);
    container.appendChild(hfg);
  }

  // ── Per-block settings ────────────────────────
  var _bsep=document.createElement('div');
  _bsep.style.cssText='border-top:1.5px solid #f0f0f3;margin-top:14px;padding-top:12px;';
  var _bsHead=document.createElement('div');
  _bsHead.style.cssText='font-size:10px;font-weight:700;color:#c4c9d4;text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;display:flex;align-items:center;gap:4px;';
  _bsHead.innerHTML='<span>⚙</span><span>Block Settings</span>';
  _bsep.appendChild(_bsHead);
  container.appendChild(_bsep);

  // Helper: make pill chip
  function _mkChip(label,active){
    var c=document.createElement('button'); c.type='button';
    c.textContent=label;
    c.style.cssText='padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;border:1.5px solid '+(active?'#6366f1':'#e5e7eb')+';background:'+(active?'#eef2ff':'#fafafa')+';color:'+(active?'#6366f1':'#6b7280')+';cursor:pointer;font-family:inherit;transition:all .12s;white-space:nowrap;line-height:1.5;';

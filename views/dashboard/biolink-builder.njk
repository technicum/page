        block.card_style=val;
        _activateChip(chip,_crow);
        _ccfg.style.display=(val==='color')?'block':'none';
        markDirty();debouncedPreview();
      };
    })(c,o.v);
    _crow.appendChild(c);
  });
  _cfg.appendChild(_crow);
  container.appendChild(_cfg);

  // Card custom color
  var _ccfg=document.createElement('div'); _ccfg.className='fg';
  _ccfg.style.display=(block.card_style==='color')?'block':'none';
  var _cclbl=document.createElement('label'); _cclbl.className='fg-label'; _cclbl.textContent='Card color';
  var _ccpair=document.createElement('div'); _ccpair.className='color-pair';
  var _ccsw=document.createElement('div'); _ccsw.className='color-swatch'; _ccsw.style.background=block.card_color||'#f9fafb';
  var _ccnat=document.createElement('input'); _ccnat.type='color'; _ccnat.value=block.card_color||'#f9fafb';
  _ccsw.appendChild(_ccnat);
  var _cchex=document.createElement('input'); _cchex.className='fg-input'; _cchex.placeholder='#f9fafb'; _cchex.value=block.card_color||'';
  (function(sw,nat,hex,blk){
    function _setCC(v){blk.card_color=v;sw.style.background=v;nat.value=v;hex.value=v;markDirty();debouncedPreview();}
    nat.addEventListener('input',function(){_setCC(this.value);});
    hex.addEventListener('input',function(){if(/^#[0-9a-fA-F]{6}$/.test(this.value))_setCC(this.value);});
  })(_ccsw,_ccnat,_cchex,block);
  _ccpair.appendChild(_ccsw); _ccpair.appendChild(_cchex);
  _ccfg.appendChild(_cclbl); _ccfg.appendChild(_ccpair);
  container.appendChild(_ccfg);

  // Done button
  var done=document.createElement('button'); done.className='blk-done'; done.textContent='Done ✓';
  done.onclick=function(){done.closest('.blk-card').classList.remove('open');};
  container.appendChild(done);
}

/* ── Render block list ───────────────────────── */
var _dragSrcIdx=null;

function renderBlocks(){
  var list=document.getElementById('blockList');
  var empty=document.getElementById('blocksEmpty');
  list.innerHTML='';
  empty.style.display=BLOCKS.length?'none':'block';

  BLOCKS.forEach(function(block,idx){
    var bt=BLOCK_TYPES[block.type]||{label:block.type,icon:'⚙️'};
    var card=document.createElement('div');
    card.className='blk-card'+(block.enabled===false?' disabled':'');

    // Head
    var head=document.createElement('div'); head.className='blk-head';

    // Drag handle
    var drag=document.createElement('span'); drag.className='blk-drag'; drag.textContent='⠿';
    drag.title='Drag to reorder';

    // Type icon
    var ico=document.createElement('span'); ico.className='blk-type-icon'; ico.textContent=bt.icon;

    // Label
    var lbl=document.createElement('span'); lbl.className='blk-label';
    var summary=getBlockSummary(block);
    lbl.innerHTML='<span style="font-size:10px;color:#9ca3af;font-weight:500;">'+bt.label+'</span><br>'+escHtml(summary);

    // Actions
    var acts=document.createElement('div'); acts.className='blk-actions';

    var eyeBtn=document.createElement('button'); eyeBtn.className='blk-btn';
    eyeBtn.textContent=block.enabled!==false?'👁':'🚫';
    eyeBtn.title=block.enabled!==false?'Hide block':'Show block';
    (function(bid,btn){eyeBtn.onclick=function(e){e.stopPropagation();toggleBlock(bid,btn);};})(block.id,eyeBtn);

    var delBtn=document.createElement('button'); delBtn.className='blk-btn del'; delBtn.textContent='✕'; delBtn.title='Delete block';
    (function(bid){delBtn.onclick=function(e){e.stopPropagation();if(confirm('Delete this block?'))deleteBlock(bid);};})(block.id);

    acts.appendChild(eyeBtn); acts.appendChild(delBtn);
    head.appendChild(drag); head.appendChild(ico); head.appendChild(lbl); head.appendChild(acts);

    // Body (edit fields)
    var body=document.createElement('div'); body.className='blk-body';
    buildBlockFields(block, body);

    // Toggle open on head click
    head.addEventListener('click',function(e){
      if(e.target.tagName==='BUTTON') return;
      card.classList.toggle('open');
      if(card.classList.contains('open')){
        card.scrollIntoView({behavior:'smooth',block:'nearest'});
      }
    });

    // Drag-and-drop
    (function(i,c){
      drag.addEventListener('mousedown',function(e){e.stopPropagation();c.setAttribute('draggable','true');});
      c.addEventListener('dragstart',function(e){
        _dragSrcIdx=i; e.dataTransfer.effectAllowed='move';
        setTimeout(function(){c.classList.add('dragging');},0);
      });
      c.addEventListener('dragend',function(){
        c.removeAttribute('draggable'); c.classList.remove('dragging');
        list.querySelectorAll('.blk-card').forEach(function(x){x.classList.remove('drag-over');});
      });
      c.addEventListener('dragover',function(e){
        e.preventDefault();
        if(_dragSrcIdx!==null&&_dragSrcIdx!==i){
          list.querySelectorAll('.blk-card').forEach(function(x){x.classList.remove('drag-over');});
          c.classList.add('drag-over');
        }
      });
      c.addEventListener('dragleave',function(e){if(!c.contains(e.relatedTarget))c.classList.remove('drag-over');});
      c.addEventListener('drop',function(e){
        e.preventDefault(); c.classList.remove('drag-over');
        if(_dragSrcIdx===null||_dragSrcIdx===i){_dragSrcIdx=null;return;}
        var moved=BLOCKS.splice(_dragSrcIdx,1)[0];
        BLOCKS.splice(i,0,moved);
        _dragSrcIdx=null;
        markDirty(); debouncedPreview(); renderBlocks();
      });
    })(idx,card);

    card.appendChild(head); card.appendChild(body);
    list.appendChild(card);
  });
}

function escHtml(str){
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ── Add block modal ─────────────────────────── */
function openAddModal(){
  document.getElementById('addModal').classList.add('open');
}
function closeAddModal(e){
  if(!e||e.target===document.getElementById('addModal')){
    document.getElementById('addModal').classList.remove('open');
  }
}

/* ── Live preview ────────────────────────────── */
var previewTimer=null, previewInflight=false;
var LIVE_URL='https://'+SITE_SUB+'.'+BASE_DOMAIN;
function debouncedPreview(){
  clearTimeout(previewTimer);
  previewTimer=setTimeout(refreshPreview,700);
}
function reloadLivePreview(){
  var f=document.getElementById('previewFrame');
  f.src=LIVE_URL+'?_t='+Date.now(); // cache-bust
}
function refreshPreview(){
  if(previewInflight) return;
  previewInflight=true;
  document.getElementById('previewLoading').classList.add('show');
  var payload={
    site_id:SITE_ID,
    settings:{
      template_id:CURRENT_THEME,
      blocks:BLOCKS,
      appearance:APP,
      seo:SEO
    }
  };
  fetch('/dashboard/site/biolink-preview',{
    method:'POST',
    credentials:'same-origin',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify(payload)
  })
  .then(function(r){
    if(!r.ok) return null; // non-200: skip update, keep showing live site
    return r.text();
  })
  .then(function(html){
    if(!html) return; // skip on error
    // Only apply if the response looks like a real biolink theme page
    // (contains the page-wrap class injected by ALL biolink templates)
    if(html.indexOf('page-wrap')===-1){
      // Response is not a biolink page (likely redirected to builder/dashboard)
      // Just reload the live site in the iframe
      var f=document.getElementById('previewFrame');
      f.src='https://'+SITE_SUB+'.'+BASE_DOMAIN;
      return;
    }
    document.getElementById('previewFrame').srcdoc=html;
  })
  .catch(function(){
    // On failure, reload the live site so user sees actual published state
    var f=document.getElementById('previewFrame');
    f.src='https://'+SITE_SUB+'.'+BASE_DOMAIN;
  })
  .finally(function(){
    previewInflight=false;
    document.getElementById('previewLoading').classList.remove('show');
  });
}

/* ── Save ────────────────────────────────────── */
function saveAll(){
  var btn=document.getElementById('saveBtn');
  btn.disabled=true; btn.textContent='Publishing…';
  var payload={
    site_id:SITE_ID,
    settings:{
      template_id:CURRENT_THEME,
      blocks:BLOCKS,
      appearance:APP,
      seo:SEO
    }
  };
  fetch('/dashboard/site/biolink-save',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify(payload)
  })
  .then(function(r){return r.json();})
  .then(function(d){
    if(d.ok){
      isDirty=false;
      document.getElementById('saveDot').className='save-dot saved';
      document.getElementById('saveLabel').textContent='Published';
      // Reload live preview to show just-saved changes
      setTimeout(function(){
        reloadLivePreview();
        document.getElementById('saveLabel').textContent='Saved';
        document.getElementById('saveDot').className='save-dot';
      },800);
    }
  })
  .finally(function(){btn.disabled=false;btn.textContent='Publish';});
}

/* ── Init ────────────────────────────────────── */
buildSettingsUI();
renderBlocks();
// Kick off preview immediately so the phone frame shows current blocks on load
debouncedPreview();
</script>
</body>
</html>

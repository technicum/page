<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>{{ site.title }} — Bio Link Editor</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:#0f0f1a;overflow:hidden;}

/* Topbar */
.topbar{display:flex;align-items:center;gap:10px;height:46px;background:#0f0f1a;border-bottom:1px solid rgba(255,255,255,0.05);padding:0 14px;position:fixed;top:0;left:0;right:0;z-index:300;}
.tb-back{font-size:12px;color:rgba(255,255,255,0.45);text-decoration:none;padding:5px 10px;border-radius:6px;transition:all 0.15s;}
.tb-back:hover{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.7);}
.tb-sep{width:1px;height:16px;background:rgba(255,255,255,0.1);flex-shrink:0;}
.tb-title{font-size:13px;font-weight:500;color:#fff;}
.tb-url{font-size:11px;color:rgba(255,255,255,0.3);text-decoration:none;padding:4px 8px;border-radius:5px;transition:all 0.15s;}
.tb-url:hover{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.6);}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px;}
.tb-status{display:flex;align-items:center;gap:5px;font-size:11px;color:rgba(255,255,255,0.3);}
.status-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,0.2);transition:background 0.3s;}
.status-dot.dirty{background:#f59e0b;}
.status-dot.saved{background:#22c55e;}
.btn-save{padding:7px 16px;background:#7c3aed;color:#fff;border:none;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;}
.btn-save:hover{background:#6d28d9;}
.btn-save:disabled{opacity:0.5;cursor:not-allowed;}

/* Layout */
.main{display:flex;height:calc(100vh - 46px);margin-top:46px;}

/* Editor */
.editor{width:320px;flex-shrink:0;background:#1e1e2e;display:flex;flex-direction:column;overflow:hidden;border-right:1px solid rgba(255,255,255,0.07);}
.tabs{display:flex;border-bottom:1px solid rgba(255,255,255,0.07);flex-shrink:0;overflow-x:auto;}
.tabs::-webkit-scrollbar{display:none;}
.tab{padding:11px 10px;font-size:11px;font-weight:600;cursor:pointer;background:transparent;border:none;font-family:inherit;color:rgba(255,255,255,0.35);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all 0.15s;white-space:nowrap;flex-shrink:0;}
.tab:hover{color:rgba(255,255,255,0.6);}
.tab.active{color:#818cf8;border-bottom-color:#6366f1;}
.tab-pane{display:none;flex:1;overflow-y:auto;padding:16px 14px 80px;}
.tab-pane::-webkit-scrollbar{width:3px;}
.tab-pane::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px;}
.tab-pane.active{display:block;}

/* Fields */
.fg{margin-bottom:14px;}
.fg-label{display:block;font-size:10px;font-weight:600;color:rgba(255,255,255,0.4);margin-bottom:5px;letter-spacing:0.5px;text-transform:uppercase;}
.fg-input{width:100%;padding:8px 10px;border:1px solid rgba(255,255,255,0.12);border-radius:6px;font-size:13px;font-family:inherit;color:#e5e7eb;background:rgba(255,255,255,0.06);outline:none;transition:border-color 0.15s;}
.fg-input:focus{border-color:#6366f1;}
.fg-textarea{min-height:72px;resize:vertical;line-height:1.55;}
.fg-color{display:flex;align-items:center;gap:8px;}
.fg-color input[type=color]{width:36px;height:36px;border:none;border-radius:6px;cursor:pointer;padding:2px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);}

/* Image field */
.img-field{display:flex;gap:8px;align-items:center;}
.img-field .fg-input{flex:1;}
.btn-img-upload{padding:8px 10px;background:rgba(99,102,241,0.15);border:1px solid rgba(99,102,241,0.3);border-radius:6px;color:#818cf8;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;font-family:inherit;}
.btn-img-upload:hover{background:rgba(99,102,241,0.25);}

/* Repeater */
.repeater-items{display:flex;flex-direction:column;gap:8px;margin-bottom:8px;}
.rep-item{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.09);border-radius:8px;padding:10px;}
.rep-item-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;cursor:pointer;}
.rep-item-title{font-size:11px;font-weight:600;color:rgba(255,255,255,0.5);}
.rep-item-del{background:transparent;border:none;color:rgba(255,255,255,0.2);cursor:pointer;font-size:14px;padding:2px 6px;border-radius:4px;transition:all 0.15s;}
.rep-item-del:hover{background:rgba(239,68,68,0.15);color:#fca5a5;}
.btn-add-item{width:100%;padding:9px;border:1px dashed rgba(99,102,241,0.35);border-radius:8px;background:rgba(99,102,241,0.06);color:#818cf8;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all 0.15s;margin-top:4px;}
.btn-add-item:hover{background:rgba(99,102,241,0.14);}

/* Section divider */
.sec-divider{font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,0.2);margin:16px 0 10px;padding-top:14px;border-top:1px solid rgba(255,255,255,0.06);}

/* Preview */
.preview-area{flex:1;background:#e8e8ec;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.phone-frame{width:360px;height:720px;border-radius:48px;border:10px solid #1a1a18;box-shadow:0 0 0 1px rgba(255,255,255,0.05) inset,0 28px 80px rgba(0,0,0,0.45);overflow:hidden;background:#fff;position:relative;flex-shrink:0;}
.phone-notch{position:absolute;top:0;left:50%;transform:translateX(-50%);width:110px;height:26px;background:#1a1a18;border-radius:0 0 18px 18px;z-index:10;}
.phone-frame iframe{width:100%;height:100%;border:none;display:block;}
</style>
</head>
<body>

<div class="topbar">
  <a class="tb-back" href="/dashboard">← Dashboard</a>
  <div class="tb-sep"></div>
  <div class="tb-title">{{ site.title }}</div>
  <a class="tb-url" href="https://{{ site.subdomain }}.{{ baseDomain }}" target="_blank">↗ {{ site.subdomain }}.{{ baseDomain }}</a>
  <div class="tb-right">
    <div class="tb-status">
      <div class="status-dot" id="saveDot"></div>
      <span id="saveLabel">Saved</span>
    </div>
    <button class="btn-save" id="saveBtn" onclick="saveAll()">Save changes</button>
  </div>
</div>

<div class="main">
  <div class="editor">

    <!-- Tabs (generated from theme sections) -->
    <div class="tabs" id="tabBar"></div>

    <!-- Panes (generated dynamically) -->
    <div id="tabPanes" style="flex:1;overflow:hidden;display:flex;flex-direction:column;"></div>

  </div>

  <div class="preview-area">
    <div class="phone-frame">
      <div class="phone-notch"></div>
      <iframe id="previewFrame" src="https://{{ site.subdomain }}.{{ baseDomain }}"></iframe>
    </div>
  </div>
</div>

<input type="file" id="hiddenFileInput" accept="image/*" style="display:none">

<script>
// ── Theme sections from server ──────────────────────────────────────────────
var SECTIONS = {{ sections | dump | safe }};
var SITE_ID  = {{ site.id }};
var SITE_SUB = '{{ site.subdomain }}';
var BASE     = '{{ baseDomain }}';

// ── Current settings state ──────────────────────────────────────────────────
var S = {{ settings | dump | safe }} || {};
// Ensure each section key exists
SECTIONS.forEach(function(sec) {
  if (!S[sec.id]) S[sec.id] = {};
  sec.fields.forEach(function(f) {
    if (f.type === 'repeater') {
      if (!S[sec.id][f.id]) S[sec.id][f.id] = f.default || [];
    } else {
      if (S[sec.id][f.id] === undefined) S[sec.id][f.id] = f.default || '';
    }
  });
});

// ── Dirty state ─────────────────────────────────────────────────────────────
var isDirty = false;
function dirty() {
  isDirty = true;
  document.getElementById('saveDot').className = 'status-dot dirty';
  document.getElementById('saveLabel').textContent = 'Unsaved';
}

// ── Preview ──────────────────────────────────────────────────────────────────
var previewTimer = null;
function debouncedPreview() {
  clearTimeout(previewTimer);
  previewTimer = setTimeout(refreshPreview, 900);
}
function refreshPreview() {
  var frame = document.getElementById('previewFrame');
  frame.src = 'https://' + SITE_SUB + '.' + BASE + '?t=' + Date.now();
}

// ── Save ────────────────────────────────────────────────────────────────────
function saveAll() {
  var btn = document.getElementById('saveBtn');
  btn.disabled = true;
  btn.textContent = 'Saving…';
  fetch('/dashboard/site/biolink-save', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ site_id: SITE_ID, settings: S })
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (d.ok) {
      isDirty = false;
      document.getElementById('saveDot').className = 'status-dot saved';
      document.getElementById('saveLabel').textContent = 'Saved';
      refreshPreview();
    }
  })
  .finally(function() {
    btn.disabled = false;
    btn.textContent = 'Save changes';
  });
}

// ── Tab switching ────────────────────────────────────────────────────────────
function switchTab(id) {
  document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });
  document.querySelector('.tab[data-sec="' + id + '"]').classList.add('active');
  document.getElementById('pane-' + id).classList.add('active');
}

// ── Image upload helper ──────────────────────────────────────────────────────
var _imgCallback = null;
document.getElementById('hiddenFileInput').addEventListener('change', function() {
  var file = this.files[0];
  if (!file || !_imgCallback) return;
  var fd = new FormData();
  fd.append('file', file);
  fd.append('site_id', SITE_ID);
  fetch('/dashboard/media/' + SITE_ID + '/upload', { method: 'POST', body: fd })
    .then(function(r) { return r.json(); })
    .then(function(d) { if (d.url) _imgCallback(d.url); });
  this.value = '';
});
function triggerImageUpload(cb) {
  _imgCallback = cb;
  document.getElementById('hiddenFileInput').click();
}

// ── Render a single field ────────────────────────────────────────────────────
function renderField(secId, field, container) {
  var fg = document.createElement('div');
  fg.className = 'fg';

  if (field.type === 'repeater') {
    renderRepeater(secId, field, container);
    return;
  }

  var label = document.createElement('label');
  label.className = 'fg-label';
  label.textContent = field.label;
  fg.appendChild(label);

  if (field.type === 'color') {
    var row = document.createElement('div');
    row.className = 'fg-color';
    var inp = document.createElement('input');
    inp.type = 'color';
    inp.value = S[secId][field.id] || field.default || '#2563eb';
    inp.addEventListener('input', function() {
      S[secId][field.id] = this.value;
      dirty(); debouncedPreview();
    });
    row.appendChild(inp);
    var hex = document.createElement('input');
    hex.className = 'fg-input';
    hex.style.flex = '1';
    hex.value = inp.value;
    hex.addEventListener('input', function() {
      inp.value = this.value;
      S[secId][field.id] = this.value;
      dirty(); debouncedPreview();
    });
    inp.addEventListener('input', function() { hex.value = this.value; });
    row.appendChild(hex);
    fg.appendChild(row);

  } else if (field.type === 'image') {
    var row = document.createElement('div');
    row.className = 'img-field';
    var inp = document.createElement('input');
    inp.className = 'fg-input';
    inp.placeholder = 'https://…';
    inp.value = S[secId][field.id] || '';
    inp.addEventListener('input', function() {
      S[secId][field.id] = this.value;
      dirty(); debouncedPreview();
    });
    var uploadBtn = document.createElement('button');
    uploadBtn.className = 'btn-img-upload';
    uploadBtn.textContent = '📷 Upload';
    (function(inputEl, sId, fId) {
      uploadBtn.onclick = function() {
        triggerImageUpload(function(url) {
          inputEl.value = url;
          S[sId][fId] = url;
          dirty(); debouncedPreview();
        });
      };
    })(inp, secId, field.id);
    row.appendChild(inp);
    row.appendChild(uploadBtn);
    fg.appendChild(row);

  } else if (field.type === 'textarea') {
    var inp = document.createElement('textarea');
    inp.className = 'fg-input fg-textarea';
    inp.placeholder = field.default || '';
    inp.value = S[secId][field.id] || '';
    inp.addEventListener('input', function() {
      S[secId][field.id] = this.value;
      dirty(); debouncedPreview();
    });
    fg.appendChild(inp);

  } else {
    // text / select / toggle — default to text input
    var inp = document.createElement('input');
    inp.className = 'fg-input';
    inp.type = 'text';
    inp.placeholder = field.default || '';
    inp.value = S[secId][field.id] || '';
    inp.addEventListener('input', function() {
      S[secId][field.id] = this.value;
      dirty(); debouncedPreview();
    });
    fg.appendChild(inp);
  }

  container.appendChild(fg);
}

// ── Render a repeater field ──────────────────────────────────────────────────
function renderRepeater(secId, field, container) {
  var wrap = document.createElement('div');
  var title = document.createElement('div');
  title.className = 'sec-divider';
  title.textContent = field.label;
  wrap.appendChild(title);

  var itemsEl = document.createElement('div');
  itemsEl.className = 'repeater-items';
  wrap.appendChild(itemsEl);

  function renderItems() {
    itemsEl.innerHTML = '';
    var items = S[secId][field.id] || [];
    items.forEach(function(item, idx) {
      var card = document.createElement('div');
      card.className = 'rep-item';

      var header = document.createElement('div');
      header.className = 'rep-item-header';
      var itemTitle = document.createElement('span');
      itemTitle.className = 'rep-item-title';
      itemTitle.textContent = (item[field.item_fields[0].id] || field.label + ' ' + (idx + 1));
      var delBtn = document.createElement('button');
      delBtn.className = 'rep-item-del';
      delBtn.textContent = '✕';
      delBtn.onclick = function() {
        S[secId][field.id].splice(idx, 1);
        dirty(); debouncedPreview(); renderItems();
      };
      header.appendChild(itemTitle);
      header.appendChild(delBtn);
      card.appendChild(header);

      // Render each item field
      field.item_fields.forEach(function(iField) {
        var fg = document.createElement('div');
        fg.className = 'fg';
        var lbl = document.createElement('label');
        lbl.className = 'fg-label';
        lbl.textContent = iField.label;
        fg.appendChild(lbl);

        if (iField.type === 'image') {
          var row = document.createElement('div');
          row.className = 'img-field';
          var inp = document.createElement('input');
          inp.className = 'fg-input';
          inp.placeholder = 'https://…';
          inp.value = item[iField.id] || '';
          inp.addEventListener('input', function() {
            S[secId][field.id][idx][iField.id] = this.value;
            dirty(); debouncedPreview();
            itemTitle.textContent = S[secId][field.id][idx][field.item_fields[0].id] || field.label + ' ' + (idx+1);
          });
          var ubtn = document.createElement('button');
          ubtn.className = 'btn-img-upload';
          ubtn.textContent = '📷';
          (function(inputEl, i, fid) {
            ubtn.onclick = function() {
              triggerImageUpload(function(url) {
                inputEl.value = url;
                S[secId][field.id][i][fid] = url;
                dirty(); debouncedPreview();
              });
            };
          })(inp, idx, iField.id);
          row.appendChild(inp);
          row.appendChild(ubtn);
          fg.appendChild(row);
        } else {
          var inp = document.createElement('input');
          inp.className = 'fg-input';
          inp.type = 'text';
          inp.placeholder = iField.default || '';
          inp.value = item[iField.id] || '';
          inp.addEventListener('input', function() {
            S[secId][field.id][idx][iField.id] = this.value;
            dirty(); debouncedPreview();
            itemTitle.textContent = S[secId][field.id][idx][field.item_fields[0].id] || field.label + ' ' + (idx+1);
          });
          fg.appendChild(inp);
        }
        card.appendChild(fg);
      });

      itemsEl.appendChild(card);
    });
  }

  var addBtn = document.createElement('button');
  addBtn.className = 'btn-add-item';
  addBtn.textContent = '＋ Add ' + field.label.replace(/s$/, '');
  addBtn.onclick = function() {
    var blank = {};
    field.item_fields.forEach(function(f) { blank[f.id] = f.default || ''; });
    if (!S[secId][field.id]) S[secId][field.id] = [];
    S[secId][field.id].push(blank);
    dirty(); debouncedPreview(); renderItems();
  };

  renderItems();
  wrap.appendChild(addBtn);
  container.appendChild(wrap);
}

// ── Build all tabs & panes from SECTIONS ────────────────────────────────────
function buildEditor() {
  var tabBar   = document.getElementById('tabBar');
  var panesEl  = document.getElementById('tabPanes');

  SECTIONS.forEach(function(sec, idx) {
    // Tab
    var tab = document.createElement('button');
    tab.className = 'tab' + (idx === 0 ? ' active' : '');
    tab.dataset.sec = sec.id;
    tab.textContent = sec.label;
    tab.onclick = function() { switchTab(sec.id); };
    tabBar.appendChild(tab);

    // Pane
    var pane = document.createElement('div');
    pane.className = 'tab-pane' + (idx === 0 ? ' active' : '');
    pane.id = 'pane-' + sec.id;
    pane.style.flex = '1';
    pane.style.overflowY = 'auto';
    pane.style.padding = '16px 14px 80px';
    panesEl.appendChild(pane);

    // Fields
    sec.fields.forEach(function(field) {
      renderField(sec.id, field, pane);
    });
  });
}

buildEditor();
</script>
</body>
</html>

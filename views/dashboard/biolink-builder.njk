          <button class="bg-tab" id="bgTabImage" onclick="setBgType('image')">Image</button>
        </div>
        <div class="bg-tab-pane" id="bgPaneColor">
          <div class="fg">
            <label class="fg-label">Background Color</label>
            <div class="color-pair">
              <div class="color-swatch" id="bgColorSwatch">
                <input type="color" id="bgColorPicker" oninput="setApp('bgColor',this.value)">
              </div>
              <input class="fg-input" id="bgColorHex" placeholder="#ffffff" oninput="onHexInput('bgColor',this.value)">

/* ── Dirty / save state ──────────────────────── */
var isDirty = false;
function markDirty(){
  isDirty = true;
  document.getElementById('saveDot').className='save-dot dirty';
  document.getElementById('saveLabel').textContent='Unsaved';
}

/* ── Accordion ───────────────────────────────── */
function toggleAcc(id){
  var el=document.getElementById(id);
  el.classList.toggle('open');
}

/* ── Tabs ────────────────────────────────────── */
function showTab(tab){
  document.getElementById('tabSettings').classList.toggle('active', tab==='settings');
  document.getElementById('tabBlocks').classList.toggle('active', tab==='blocks');
  document.getElementById('tabBtnSettings').classList.toggle('active', tab==='settings');
  document.getElementById('tabBtnBlocks').classList.toggle('active', tab==='blocks');
}

/* ── Copy URL ────────────────────────────────── */
function copyUrl(){
  navigator.clipboard.writeText('https://'+SITE_SUB+'.'+BASE_DOMAIN).then(function(){
    var b=document.querySelector('.url-copy-btn, .tb-urlbadge');
    var orig=b?b.textContent:'';
    if(b){b.textContent='Copied!';}
    setTimeout(function(){if(b)b.textContent=orig;},1500);
  });
}

/* ── Appearance helpers ──────────────────────── */
function setApp(key, val){
  APP[key]=val;
  syncAppUI();
  markDirty();
  debouncedPreview();
}
function onHexInput(key, val){
  if(/^#[0-9a-fA-F]{6}$/.test(val)) setApp(key, val);
}

function syncColorField(swatchId, pickerId, hexId, val){
  var sw=document.getElementById(swatchId);
  if(sw) sw.style.background=val;
  var pk=document.getElementById(pickerId);
  if(pk) pk.value=val;
  var hx=document.getElementById(hexId);
  if(hx) hx.value=val;
}
function syncAppUI(){
  syncColorField('btnColorSwatch','btnColorPicker','btnColorHex', APP.btnColor||'#6366f1');
  syncColorField('btnTextColorSwatch','btnTextColorPicker','btnTextColorHex', APP.btnTextColor||'#ffffff');
  syncColorField('bgColorSwatch','bgColorPicker','bgColorHex', APP.bgColor||'#ffffff');
  syncColorField('textColorSwatch','textColorPicker','textColorHex', APP.textColor||'#1a1a1a');
  // Button style chips
  document.querySelectorAll('#btnStyleRow .chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.btnStyle);
  });
  // Radius chips
  document.querySelectorAll('#btnRadiusRow .rad-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.btnRadius);
  });
  // Font chips
  document.querySelectorAll('#fontRow .font-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.fontFamily);
  });
  // BG type tabs
  document.querySelectorAll('.bg-tab').forEach(function(t){t.classList.remove('active');});
  var activeTab=document.getElementById('bgTab'+APP.bgType.charAt(0).toUpperCase()+APP.bgType.slice(1));
  if(activeTab) activeTab.classList.add('active');
  document.querySelectorAll('.bg-tab-pane').forEach(function(p){p.classList.remove('active');});
  var activePane=document.getElementById('bgPane'+APP.bgType.charAt(0).toUpperCase()+APP.bgType.slice(1));
  if(activePane) activePane.classList.add('active');
  // Gradient chips
  document.querySelectorAll('#gradGrid .grad-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.bgGradient);
  });
  // BG image
  document.getElementById('bgImageUrl').value=APP.bgImage||'';
  updateBgThumb();
  // SEO
  document.getElementById('seoTitle').value=SEO.title||'';
  document.getElementById('seoDesc').value=SEO.description||'';
  document.getElementById('seoNoindex').checked=!!SEO.noindex;
  // Animation chips
  document.querySelectorAll('#animStyleGrid .anim-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===(APP.animationStyle||'slide-up'));
  });
  document.querySelectorAll('#animSpeedRow .chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===(APP.animationSpeed||'normal'));
  });
  document.querySelectorAll('#animStaggerRow .chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===String(APP.animationStagger||'100'));
  });
}
function setSeo(key,val){
  SEO[key]=val;
  markDirty();
  debouncedPreview();
}
function setBgType(type){
  APP.bgType=type;
  syncAppUI();
  markDirty();
  debouncedPreview();
}
function updateBgThumb(){
  var t=document.getElementById('bgImgThumb');
  if(!t) return;
  var u=APP.bgImage||'';
  if(u){ t.innerHTML='<img src="'+u+'" style="width:100%;height:100%;object-fit:cover;">'; }
  else { t.textContent='🖼️'; }
}

/* ── Apply style preset ──────────────────────── */
function applyPreset(p){
  var skip={name:1,emoji:1};
  Object.keys(p).forEach(function(k){ if(!skip[k]) APP[k]=p[k]; });
  syncAppUI();
  markDirty();
  debouncedPreview();
}

/* ── Build Settings UI ───────────────────────── */
function buildSettingsUI(){
  // Style presets
  var pg=document.getElementById('presetGrid');
  if(pg){
    pg.innerHTML='';
    PRESETS.forEach(function(p){
      var btn=document.createElement('button');
      btn.className='preset-btn';

/* ── Dirty / save state ──────────────────────── */
var isDirty = false;
function markDirty(){
  isDirty = true;
  document.getElementById('saveDot').className='save-dot dirty';
  document.getElementById('saveLabel').textContent='Unsaved';
}

/* ── Auto-remove deprecated block types ──────── */
(function(){
  var DEPRECATED = ['service'];
  var before = BLOCKS.length;
  BLOCKS = BLOCKS.filter(function(b){ return DEPRECATED.indexOf(b.type) === -1; });
  if(BLOCKS.length !== before) markDirty();
})();

/* ── Accordion ───────────────────────────────── */
function toggleAcc(id){
  var el=document.getElementById(id);
  el.classList.toggle('open');
}

/* ── Tabs ────────────────────────────────────── */
function showTab(tab){
  ['blocks','settings','contact'].forEach(function(t){
    var pane=document.getElementById('tab'+t.charAt(0).toUpperCase()+t.slice(1));
    var btn =document.getElementById('tabBtn'+t.charAt(0).toUpperCase()+t.slice(1));
    if(pane) pane.style.display = (t===tab) ? '' : 'none';
    if(pane) pane.classList.toggle('active', t===tab);
    if(btn)  btn.classList.toggle('active', t===tab);
  });
}

/* ── Copy URL ────────────────────────────────── */
function copyUrl(){
  navigator.clipboard.writeText('https://'+SITE_SUB+'.'+BASE_DOMAIN).then(function(){
    var b=document.querySelector('.url-copy-btn, .tb-urlbadge');
    var orig=b?b.textContent:'';
    if(b){b.textContent='Copied!';}
    setTimeout(function(){if(b)b.textContent=orig;},1500);
  });
}

/* ── Appearance helpers ──────────────────────── */
function setApp(key, val){
  APP[key]=val;
  syncAppUI();
  markDirty();
  debouncedPreview();
}
function onHexInput(key, val){
  if(/^#[0-9a-fA-F]{6}$/.test(val)) setApp(key, val);
}

function syncColorField(swatchId, pickerId, hexId, val){
  var sw=document.getElementById(swatchId);
  if(sw) sw.style.background=val;
  var pk=document.getElementById(pickerId);
  if(pk) pk.value=val;
  var hx=document.getElementById(hexId);
  if(hx) hx.value=val;
}
function syncAppUI(){
  syncColorField('btnColorSwatch','btnColorPicker','btnColorHex', APP.btnColor||'#6366f1');
  syncColorField('btnTextColorSwatch','btnTextColorPicker','btnTextColorHex', APP.btnTextColor||'#ffffff');
  syncColorField('bgColorSwatch','bgColorPicker','bgColorHex', APP.bgColor||'#ffffff');
  syncColorField('textColorSwatch','textColorPicker','textColorHex', APP.textColor||'#1a1a1a');
  // Button style chips
  document.querySelectorAll('#btnStyleRow .chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.btnStyle);
  });
  // Radius chips
  document.querySelectorAll('#btnRadiusRow .rad-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.btnRadius);
  });
  // Font chips
  document.querySelectorAll('#fontRow .font-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.fontFamily);
  });
  // BG type tabs
  document.querySelectorAll('.bg-tab').forEach(function(t){t.classList.remove('active');});
  var activeTab=document.getElementById('bgTab'+APP.bgType.charAt(0).toUpperCase()+APP.bgType.slice(1));
  if(activeTab) activeTab.classList.add('active');
  document.querySelectorAll('.bg-tab-pane').forEach(function(p){p.classList.remove('active');});
  var activePane=document.getElementById('bgPane'+APP.bgType.charAt(0).toUpperCase()+APP.bgType.slice(1));
  if(activePane) activePane.classList.add('active');
  // Gradient chips
  document.querySelectorAll('#gradGrid .grad-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===APP.bgGradient);
  });
  // BG image
  document.getElementById('bgImageUrl').value=APP.bgImage||'';
  updateBgThumb();
  // SEO
  document.getElementById('seoTitle').value=SEO.title||'';
  document.getElementById('seoDesc').value=SEO.description||'';
  document.getElementById('seoNoindex').checked=!!SEO.noindex;
  // Animation chips
  document.querySelectorAll('#animStyleGrid .anim-chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===(APP.animationStyle||'slide-up'));
  });
  document.querySelectorAll('#animSpeedRow .chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===(APP.animationSpeed||'normal'));
  });
  document.querySelectorAll('#animStaggerRow .chip').forEach(function(c){
    c.classList.toggle('active', c.dataset.val===String(APP.animationStagger||'100'));
  });
}
function setSeo(key,val){
  SEO[key]=val;
  markDirty();
  debouncedPreview();
}
function setBgType(type){
  APP.bgType=type;
  syncAppUI();
  markDirty();
  debouncedPreview();
}
function updateBgThumb(){
  var t=document.getElementById('bgImgThumb');
  if(!t) return;
  var u=APP.bgImage||'';
  if(u){ t.innerHTML='<img src="'+u+'" style="width:100%;height:100%;object-fit:cover;">'; }
  else { t.textContent='🖼️'; }
}

/* ── Apply style preset ──────────────────────── */
function applyPreset(p){
  var skip={name:1,emoji:1};
  Object.keys(p).forEach(function(k){ if(!skip[k]) APP[k]=p[k]; });
  syncAppUI();
  markDirty();
  debouncedPreview();
}

/* ── Build Settings UI ───────────────────────── */
function buildSettingsUI(){
  // Style presets
  var pg=document.getElementById('presetGrid');
  if(pg){
    pg.innerHTML='';
    PRESETS.forEach(function(p){
      var isGrad = p.bgType==='gradient';
      var cardBg = isGrad ? p.bgGradient : p.bgColor;
      var radius = (parseInt(p.btnRadius)||8)+'px';
      var footBg = p.bgColor; // always solid for footer
      var btn=document.createElement('button');
      btn.className='preset-btn';
      btn.dataset.preset=p.name;
      var isActive = APP.btnColor===p.btnColor && APP.bgColor===p.bgColor;
      if(isActive){ btn.style.outlineColor=p.btnColor; btn.style.boxShadow='0 0 0 1px '+p.btnColor+'55'; }
      btn.innerHTML=
        '<div class="preset-preview" style="background:'+cardBg+';min-height:72px;">'+
          '<div class="preset-top">'+
            '<div class="preset-avatar" style="background:'+p.btnColor+';"></div>'+
            '<div class="preset-line" style="background:'+p.textColor+';"></div>'+
          '</div>'+
          '<div class="preset-strip" style="background:'+p.btnColor+';border-radius:'+radius+';"></div>'+
        '</div>'+
        '<div class="preset-foot" style="background:'+footBg+';">'+
          '<div class="preset-name" style="color:'+p.textColor+';">'+p.name+'</div>'+
          '<div class="preset-meta" style="color:'+p.textColor+';">Aa · '+p.btnStyle+'</div>'+
        '</div>';
      btn.onclick=function(){
        applyPreset(p);
        document.querySelectorAll('.preset-btn').forEach(function(b){b.style.outlineColor='transparent';b.style.boxShadow='none';});
        btn.style.outlineColor=p.btnColor;
        btn.style.boxShadow='0 0 0 1px '+p.btnColor+'55';
      };
      pg.appendChild(btn);
    });
  }

  // Button style chips
  var bsr=document.getElementById('btnStyleRow');
  bsr.innerHTML='';
  [{v:'filled',l:'Filled'},{v:'outline',l:'Outline'},{v:'soft',l:'Soft'},{v:'shadow',l:'Shadow'}].forEach(function(s){
    var c=document.createElement('div');
    c.className='chip'; c.dataset.val=s.v; c.textContent=s.l;
    c.onclick=function(){setApp('btnStyle',s.v);};
    bsr.appendChild(c);
  });

  // Radius chips
  var brr=document.getElementById('btnRadiusRow');
  brr.innerHTML='';
  [{v:'0',l:'□'},{v:'6',l:'▢'},{v:'12',l:'▣'},{v:'20',l:'▤'},{v:'50',l:'●'}].forEach(function(r){
    var c=document.createElement('div');
    c.className='rad-chip'; c.dataset.val=r.v; c.textContent=r.l; c.title=r.v+'px';
    c.onclick=function(){setApp('btnRadius',r.v);};
    brr.appendChild(c);
  });

  // Gradient chips
  var gg=document.getElementById('gradGrid');
  gg.innerHTML='';
  GRADIENTS.forEach(function(g){
    var c=document.createElement('div');
    c.className='grad-chip'; c.dataset.val=g.v;
    c.style.background=g.v; c.title=g.n;
    c.onclick=function(){setApp('bgGradient',g.v); debouncedPreview();};
    gg.appendChild(c);
  });

  // Font chips
  var fr=document.getElementById('fontRow');
  fr.innerHTML='';
  [{v:'Inter',l:'Inter'},{v:'DM Sans',l:'DM Sans'},{v:'Poppins',l:'Poppins'},{v:'Sora',l:'Sora'}].forEach(function(f){
    var c=document.createElement('div');
    c.className='font-chip'; c.dataset.val=f.v; c.textContent=f.l;
    c.style.fontFamily=f.v+',sans-serif';
    c.onclick=function(){setApp('fontFamily',f.v);};
    fr.appendChild(c);
  });

  // Animation style chips
  var animStyles=[
    {v:'none',l:'None',i:'⛔'},{v:'fade',l:'Fade',i:'🌫'},{v:'slide-up',l:'↑ Slide Up',i:'⬆'},
    {v:'slide-down',l:'↓ Slide Dn',i:'⬇'},{v:'slide-left',l:'→ From R',i:'➡'},{v:'slide-right',l:'← From L',i:'⬅'},
    {v:'zoom',l:'Zoom',i:'🔍'},{v:'bounce',l:'Bounce',i:'🏀'},{v:'flip',l:'Flip',i:'🔄'}
  ];
  var asg=document.getElementById('animStyleGrid');
  if(asg){
    asg.innerHTML='';
    animStyles.forEach(function(s){
      var c=document.createElement('button'); c.className='anim-chip'; c.dataset.val=s.v;
      c.innerHTML='<div class="anim-chip-icon">'+s.i+'</div><div class="anim-chip-label">'+s.l+'</div>';
      c.onclick=function(){ setApp('animationStyle',s.v); };
      asg.appendChild(c);
    });
  }
  // Animation speed chips
  var asr=document.getElementById('animSpeedRow');
  if(asr){
    asr.innerHTML='';
    [{v:'fast',l:'Fast'},{v:'normal',l:'Normal'},{v:'slow',l:'Slow'}].forEach(function(s){
      var c=document.createElement('div'); c.className='chip'; c.dataset.val=s.v; c.textContent=s.l;
      c.onclick=function(){ setApp('animationSpeed',s.v); };
      asr.appendChild(c);
    });
  }
  // Stagger chips
  var asts=document.getElementById('animStaggerRow');
  if(asts){
    asts.innerHTML='';
    [{v:'0',l:'None'},{v:'60',l:'60ms'},{v:'100',l:'100ms'},{v:'150',l:'150ms'},{v:'200',l:'200ms'}].forEach(function(s){
      var c=document.createElement('div'); c.className='chip'; c.dataset.val=s.v; c.textContent=s.l;
      c.onclick=function(){ setApp('animationStagger',s.v); };
      asts.appendChild(c);
    });
  }

  // Build Add Modal
  var ms=document.getElementById('modalStandard');
  var ma=document.getElementById('modalAdvanced');
  ms.innerHTML=''; ma.innerHTML='';
  Object.keys(BLOCK_TYPES).forEach(function(type){
    var bt=BLOCK_TYPES[type];
    var btn=document.createElement('button');
    btn.className='modal-block-btn';
    btn.dataset.label=bt.label.toLowerCase();
    btn.dataset.desc=(bt.desc||'').toLowerCase();
    btn.onclick=function(){addBlock(type);closeAddModal();};
    btn.innerHTML='<span class="mbb-icon">'+bt.icon+'</span><span class="mbb-text"><span class="mbb-name">'+bt.label+'</span><span class="mbb-desc">'+bt.desc+'</span></span>';
    (bt.cat==='advanced'?ma:ms).appendChild(btn);
  });

  syncAppUI();
}

/* ── Image upload ────────────────────────────── */
var _imgCb=null;
document.getElementById('hiddenFileInput').addEventListener('change',function(){
  var file=this.files[0];
  if(!file||!_imgCb) return;
  var fd=new FormData(); fd.append('image',file); fd.append('site_id',SITE_ID);
  fetch('/dashboard/media/'+SITE_ID+'/upload',{method:'POST',body:fd})
    .then(function(r){return r.json();})
    .then(function(d){if(d.url)_imgCb(d.url);});
  this.value='';
});
function triggerUpload(cb){_imgCb=cb;document.getElementById('hiddenFileInput').click();}

/* ── Block helpers ───────────────────────────── */
function genId(){return 'b'+(Date.now()).toString(36)+Math.random().toString(36).slice(2,5);}
function getBlockSummary(block){
  switch(block.type){
    case 'avatar': return block.name||'Avatar';
    case 'link': return block.title||'Link';
    case 'heading': return block.text||'Heading';
    case 'paragraph': return (block.text||'').slice(0,28)||'Paragraph';
    case 'image': return 'Image';
    case 'socials': return 'Social icons';
    case 'email_collector': return 'Email collector';
    case 'phone_collector': return 'Phone collector';
    case 'contact_form': return 'Contact form';
    case 'business_hours': return 'Business hours';
    case 'video': return block.url ? block.url.slice(0,36)+'…' : 'Video';
    case 'divider': return 'Divider';
    case 'product': return block.title||'Product';
    case 'banner': return block.text||'Banner';
    case 'testimonial': return block.name||'Testimonial';
    case 'faq': return 'FAQ ('+(block.items?block.items.length:0)+' items)';
    case 'reviews': return 'Reviews ('+(block.items?block.items.length:0)+')';
    case 'map': return 'Map';
    case 'html': return 'Custom HTML';
    default: return block.type;
  }
}

/* ── Add block ───────────────────────────────── */
function addBlock(type){
  var bt=BLOCK_TYPES[type];
  if(!bt) return;
  var block=Object.assign({id:genId(),type:type,enabled:true},bt.defaults);
  BLOCKS.push(block);
  markDirty(); debouncedPreview(); renderBlocks();
  // Auto-open new block
  setTimeout(function(){
    var cards=document.querySelectorAll('.blk-card');
    var last=cards[cards.length-1];
    if(last){last.classList.add('open');last.scrollIntoView({behavior:'smooth',block:'nearest'});}
    showTab('blocks');
  },50);
}

/* ── Toggle block enabled ────────────────────── */
function toggleBlock(id, btn){
  var block=BLOCKS.find(function(b){return b.id===id;});
  if(!block) return;
  block.enabled=!block.enabled;
  var card=btn.closest('.blk-card');
  if(card) card.classList.toggle('disabled',!block.enabled);
  btn.textContent=block.enabled?'👁':'🚫';
  markDirty(); debouncedPreview();
}

/* ── Delete block ────────────────────────────── */
function deleteBlock(id){
  BLOCKS=BLOCKS.filter(function(b){return b.id!==id;});
  markDirty(); debouncedPreview(); renderBlocks();
}

/* ── Apply global animation to all blocks ────── */
function applyAnimToAll(){
  BLOCKS.forEach(function(b){ b.animation=APP.animationStyle; });
  markDirty(); debouncedPreview(); renderBlocks();
}


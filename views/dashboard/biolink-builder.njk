    function _setCC(v){blk.card_color=v;sw.style.background=v;nat.value=v;hex.value=v;markDirty();debouncedPreview();}
    nat.addEventListener('input',function(){_setCC(this.value);});
    hex.addEventListener('input',function(){if(/^#[0-9a-fA-F]{6}$/.test(this.value))_setCC(this.value);});
  })(_ccsw,_ccnat,_cchex,block);
  _ccpair.appendChild(_ccsw); _ccpair.appendChild(_cchex);
  _ccfg.appendChild(_cclbl); _ccfg.appendChild(_ccpair);
  _adv.appendChild(_ccfg);

  // ── Footer: Done button only ────────────────────────
  var done=document.createElement('button'); done.className='blk-done'; done.type='button';
  done.style.width='100%'; done.textContent='Done ✓';
  done.onclick=function(){done.closest('.blk-card').classList.remove('open');};
  container.appendChild(done);
}

/* ── Render block list ───────────────────────── */
var _dragSrcIdx=null;

/* ── Block type accent colors (border + icon bg) ── */
var BLOCK_COLORS={
  avatar:      {border:'#6366f1',bg:'#eef2ff'},
  link:        {border:'#0ea5e9',bg:'#e0f2fe'},
  heading:     {border:'#f59e0b',bg:'#fef3c7'},
  paragraph:   {border:'#f59e0b',bg:'#fef3c7'},
  divider:     {border:'#9ca3af',bg:'#f3f4f6'},
  image:       {border:'#f97316',bg:'#fff7ed'},
  video:       {border:'#f97316',bg:'#fff7ed'},
  socials:     {border:'#ec4899',bg:'#fce7f3'},
  services_grid:{border:'#6366f1',bg:'#eef2ff'},
  jobs_grid:{border:'#f59e0b',bg:'#fef3c7'},
  products_grid:{border:'#10b981',bg:'#d1fae5'},
  product:     {border:'#10b981',bg:'#d1fae5'},
  service:     {border:'#14b8a6',bg:'#ccfbf1'},
  form:        {border:'#7c3aed',bg:'#ede9fe'},
  email_collector:{border:'#7c3aed',bg:'#ede9fe'},
  phone_collector:{border:'#7c3aed',bg:'#ede9fe'},
  contact_form:{border:'#7c3aed',bg:'#ede9fe'},
  booking:     {border:'#3b82f6',bg:'#dbeafe'},
  business_hours:{border:'#64748b',bg:'#f1f5f9'},
  banner:      {border:'#f59e0b',bg:'#fef3c7'},
  testimonial: {border:'#f43f5e',bg:'#fff1f2'},
  faq:         {border:'#f43f5e',bg:'#fff1f2'},
  reviews:     {border:'#f43f5e',bg:'#fff1f2'},
  map:         {border:'#22c55e',bg:'#f0fdf4'},
  html:        {border:'#6b7280',bg:'#f9fafb'},
  announcement:{border:'#f59e0b',bg:'#fef3c7'},
  video:       {border:'#ef4444',bg:'#fee2e2'},
  gallery:     {border:'#f97316',bg:'#fff7ed'},
  countdown:   {border:'#8b5cf6',bg:'#ede9fe'},
  coupon:      {border:'#10b981',bg:'#d1fae5'},
  payment_link:{border:'#0ea5e9',bg:'#e0f2fe'},
  brochure:    {border:'#64748b',bg:'#f1f5f9'},
  poll:        {border:'#ec4899',bg:'#fce7f3'}
};

function renderBlocks(){
  var list=document.getElementById('blockList');
  var empty=document.getElementById('blocksEmpty');
  list.innerHTML='';
  empty.style.display=BLOCKS.length?'none':'block';

  BLOCKS.forEach(function(block,idx){
    var bt=BLOCK_TYPES[block.type]||{label:block.type,icon:'⚙️'};
    var bc=BLOCK_COLORS[block.type]||{border:'#d1d5db',bg:'#f3f4f6'};
    var card=document.createElement('div');
    card.className='blk-card'+(block.enabled===false?' disabled':'');
    card.style.borderLeftColor=bc.border;

    // Head
    var head=document.createElement('div'); head.className='blk-head';

    // Drag handle
    var drag=document.createElement('span'); drag.className='blk-drag'; drag.textContent='⠿';
    drag.title='Drag to reorder';

    // Icon square
    var ico=document.createElement('div');
    ico.className='blk-icon-wrap';
    ico.style.background=bc.bg;
    ico.textContent=bt.icon;

    // Text: type label + block name
    var txt=document.createElement('div'); txt.className='blk-text';
    var typeLbl=document.createElement('div'); typeLbl.className='blk-type-label'; typeLbl.textContent=bt.label;
    var nameLbl=document.createElement('div'); nameLbl.className='blk-name'; nameLbl.textContent=getBlockSummary(block);
    txt.appendChild(typeLbl); txt.appendChild(nameLbl);

    // Actions
    var acts=document.createElement('div'); acts.className='blk-actions';

    var eyeBtn=document.createElement('button');
    var isOn=block.enabled!==false;
    eyeBtn.className='blk-btn'+(isOn?'':' eye-off');
    eyeBtn.innerHTML=isOn?'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>':'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    eyeBtn.title=isOn?'Hide block':'Show block';
    (function(bid,btn){eyeBtn.onclick=function(e){e.stopPropagation();toggleBlock(bid,btn);};})(block.id,eyeBtn);

    var delBtn=document.createElement('button'); delBtn.className='blk-btn del';
    delBtn.innerHTML='<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
    delBtn.title='Delete block';
    (function(bid){delBtn.onclick=function(e){e.stopPropagation();if(confirm('Delete this block?'))deleteBlock(bid);};})(block.id);

    acts.appendChild(eyeBtn); acts.appendChild(delBtn);
    head.appendChild(drag); head.appendChild(ico); head.appendChild(txt); head.appendChild(acts);

    // Body (edit fields)
    var body=document.createElement('div'); body.className='blk-body';
    buildBlockFields(block, body);

    // Toggle open on head click
    head.addEventListener('click',function(e){
      if(e.target.tagName==='BUTTON') return;
      card.classList.toggle('open');
      if(card.classList.contains('open')){
        card.scrollIntoView({behavior:'smooth',block:'nearest'});
      }
    });

    // Drag-and-drop
    (function(i,c){
      drag.addEventListener('mousedown',function(e){e.stopPropagation();c.setAttribute('draggable','true');});
      c.addEventListener('dragstart',function(e){
        _dragSrcIdx=i; e.dataTransfer.effectAllowed='move';
        setTimeout(function(){c.classList.add('dragging');},0);
      });
      c.addEventListener('dragend',function(){
        c.removeAttribute('draggable'); c.classList.remove('dragging');
        list.querySelectorAll('.blk-card').forEach(function(x){x.classList.remove('drag-over');});
      });
      c.addEventListener('dragover',function(e){
        e.preventDefault();
        if(_dragSrcIdx!==null&&_dragSrcIdx!==i){
          list.querySelectorAll('.blk-card').forEach(function(x){x.classList.remove('drag-over');});
          c.classList.add('drag-over');
        }
      });
      c.addEventListener('dragleave',function(e){if(!c.contains(e.relatedTarget))c.classList.remove('drag-over');});
      c.addEventListener('drop',function(e){
        e.preventDefault(); c.classList.remove('drag-over');
        if(_dragSrcIdx===null||_dragSrcIdx===i){_dragSrcIdx=null;return;}
        var moved=BLOCKS.splice(_dragSrcIdx,1)[0];
        BLOCKS.splice(i,0,moved);
        _dragSrcIdx=null;
        markDirty(); debouncedPreview(); renderBlocks();
      });
    })(idx,card);

    card.appendChild(head); card.appendChild(body);
    list.appendChild(card);
  });
}

function escHtml(str){
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ── Add block modal ─────────────────────────── */
function openAddModal(){
  document.getElementById('addModal').classList.add('open');
  var s=document.getElementById('modalSearch');
  s.value='';
  filterModalBlocks('');
  setTimeout(function(){s.focus();},80);
}
function closeAddModal(e){
  if(!e||e.target===document.getElementById('addModal')){
    document.getElementById('addModal').classList.remove('open');
  }
}
function filterModalBlocks(q){
  q=q.toLowerCase();
  var anyVisible=false;
  ['Standard','Advanced'].forEach(function(cat){
    var grid=document.getElementById('modal'+cat);
    var label=document.getElementById('catLabel'+cat);
    if(!grid) return;
    var btns=grid.querySelectorAll('.modal-block-btn');
    var catVisible=false;
    btns.forEach(function(btn){
      var matches=!q||(btn.dataset.label||'').includes(q)||(btn.dataset.desc||'').includes(q);
      btn.style.display=matches?'':'none';
      if(matches) catVisible=true;
    });
    if(label) label.style.display=(catVisible||!q)?'':'none';
    if(catVisible) anyVisible=true;
  });
  document.getElementById('modalNoResults').style.display=(anyVisible||!q)?'none':'block';
}

/* ── Preview (debounced POST → iframe) ──────── */
var _previewTimer=null;
function debouncedPreview(){
  clearTimeout(_previewTimer);
  _previewTimer=setTimeout(doPreview, 400);
}
function doPreview(){
  var frame=document.getElementById('previewFrame');
  var loading=document.getElementById('previewLoading');
  if(!frame) return;
  if(loading) loading.classList.add('show');
  fetch('/dashboard/site/biolink-preview',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({site_id:SITE_ID, settings:{blocks:BLOCKS, appearance:APP, seo:SEO, contact:CONTACT}})
  }).then(function(r){return r.text();}).then(function(html){
    if(loading) loading.classList.remove('show');
    var doc=frame.contentDocument||frame.contentWindow.document;
    doc.open(); doc.write(html); doc.close();
  }).catch(function(){
    if(loading) loading.classList.remove('show');
  });
}

/* ── Save ───────────────────────────────────── */
function saveBlocks(){
  return fetch('/dashboard/site/biolink-save',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({site_id:SITE_ID, settings:{blocks:BLOCKS, appearance:APP, seo:SEO, contact:CONTACT}})
  }).then(function(r){return r.json();}).then(function(d){
    isDirty=false;
    document.getElementById('saveDot').className='save-dot';
    document.getElementById('saveLabel').textContent='Saved';
  }).catch(function(){ alert('Save failed'); });
}

function publishSite(){
  return fetch('/dashboard/site/toggle-publish',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({site_id:SITE_ID, published:true})
  }).then(function(r){return r.json();});
}

/* ── Save All (unified button handler) ───────── */
function saveAll(){
  var btn = document.getElementById('saveBtn');
  btn.disabled = true;
  document.getElementById('saveDot').className='save-dot saving';
  document.getElementById('saveLabel').textContent='Saving…';

  if(IS_PUBLISHED){
    saveBlocks().then(function(){
      btn.disabled=false;
      btn.textContent='Save';
    });
  } else {
    saveBlocks().then(function(){
      return publishSite();
    }).then(function(d){
      if(d && d.ok){
        IS_PUBLISHED = true;
        btn.textContent='Save';
        btn.style.background='#059669';
        setTimeout(function(){ btn.style.background=''; },1800);
      }
      btn.disabled=false;
    }).catch(function(){
      btn.disabled=false;
    });
  }
}

/* ── Keyboard shortcuts ──────────────────────── */
document.addEventListener('keydown',function(e){
  if((e.metaKey||e.ctrlKey)&&e.key==='s'){e.preventDefault();saveAll();}
});

/* ── Refresh button ──────────────────────────── */
function refreshPreview(){ doPreview(); }

/* ── Contact Info ────────────────────────────── */
var CI_FIELDS = ['name','title','company','phone','email','website','address','whatsapp'];
function loadContactInfo(){
  CI_FIELDS.forEach(function(k){
    var el = document.getElementById('ci_'+k);
    if(el) el.value = CONTACT[k] || '';
  });
}
function saveContactInfo(){
  CI_FIELDS.forEach(function(k){
    var el = document.getElementById('ci_'+k);
    if(el) CONTACT[k] = el.value;
  });
  markDirty();
}
function saveContactInfoNow(){
  saveContactInfo();
  var btn = document.getElementById('ciSaveBtn');
  var msg = document.getElementById('ciSaveMsg');
  if(btn) btn.disabled = true;
  saveBlocks().then(function(){
    if(msg){ msg.style.display='inline'; setTimeout(function(){ msg.style.display='none'; },2000); }
    if(btn) btn.disabled = false;
  }).catch(function(){
    if(btn) btn.disabled = false;
  });
}

/* ── Init ────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', function(){
  buildSettingsUI();
  renderBlocks();
  loadContactInfo();
  debouncedPreview();
});
</script>

{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{font-family:"DM Sans",sans-serif;}
.layout{display:flex;min-height:100vh;}
.sidebar{width:220px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;}
.sidebar-logo{font-family:"DM Serif Display",serif;font-size:20px;padding:22px 24px;border-bottom:1px solid var(--border);text-decoration:none;color:var(--ink);display:block;}
.sidebar-logo em{font-style:italic;color:var(--blue);}
.sidebar-nav{padding:16px 12px;flex:1;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius);font-size:14px;color:var(--ink-muted);text-decoration:none;transition:all 0.15s;margin-bottom:2px;}
.nav-item:hover{background:var(--off);color:var(--ink);}
.nav-item.active{background:var(--blue-light);color:var(--blue);font-weight:500;}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border);}
.content{flex:1;padding:36px 40px;min-width:0;overflow:auto;}

.page-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;gap:16px;}
.page-title{font-family:"DM Serif Display",serif;font-size:26px;font-weight:400;letter-spacing:-0.5px;margin-bottom:4px;}
.page-sub{font-size:13px;color:var(--ink-muted);}
.header-actions{display:flex;gap:8px;flex-shrink:0;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:var(--radius);font-size:13px;font-weight:500;cursor:pointer;text-decoration:none;border:none;font-family:inherit;transition:all 0.15s;}
.btn-primary{background:var(--ink);color:#fff;}
.btn-ghost{background:transparent;color:var(--ink-muted);border:1px solid var(--border);}
.btn-ghost:hover{background:var(--off);}
.btn-sm{padding:6px 12px;font-size:12px;}

/* Stats row */
.stats-row{display:flex;gap:14px;margin-bottom:28px;}
.stat-card{background:#fff;border:1px solid var(--border);border-radius:10px;padding:16px 20px;flex:1;}
.stat-num{font-family:"DM Serif Display",serif;font-size:28px;font-weight:400;color:var(--ink);letter-spacing:-1px;}
.stat-label{font-size:12px;color:var(--ink-muted);margin-top:2px;}

/* Table */
.entries-table-wrap{background:#fff;border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.entries-table-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);}
.entries-count{font-size:13px;font-weight:600;color:var(--ink);}
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead th{padding:11px 14px;text-align:left;font-size:11px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;color:var(--ink-faint);background:#f9fafb;border-bottom:1px solid var(--border);white-space:nowrap;}
tbody tr{border-bottom:1px solid #f3f4f6;transition:background 0.12s;}
tbody tr:last-child{border-bottom:none;}
tbody tr:hover{background:#fafafa;}
tbody td{padding:11px 14px;color:var(--ink);vertical-align:top;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
td.td-date{color:var(--ink-muted);font-size:12px;white-space:nowrap;}
td.td-ip{color:var(--ink-faint);font-size:12px;font-family:monospace;}
td.td-actions{width:60px;}

.del-btn{width:26px;height:26px;border-radius:5px;border:none;background:transparent;cursor:pointer;color:#d1d5db;font-size:12px;display:flex;align-items:center;justify-content:center;transition:all 0.12s;}
.del-btn:hover{color:#ef4444;background:#fef2f2;}

.empty-state{text-align:center;padding:56px 24px;}
.empty-icon{font-size:40px;margin-bottom:14px;opacity:0.35;}
.empty-title{font-size:15px;font-weight:600;color:var(--ink);margin-bottom:6px;}
.empty-sub{font-size:13px;color:var(--ink-muted);}

/* Toast */
.toast{position:fixed;bottom:24px;right:24px;background:#111827;color:#fff;padding:10px 18px;border-radius:8px;font-size:13px;font-weight:500;z-index:999;opacity:0;transform:translateY(8px);transition:all 0.25s;pointer-events:none;}
.toast.show{opacity:1;transform:translateY(0);}
</style>
{% endblock %}

{% block body %}
{% set activePage = 'forms' %}
<div class="layout">
  {% include "dashboard/_sidebar.njk" %}

  <div class="content">
    <div class="page-header">
      <div>
        <div style="font-size:13px;color:var(--ink-faint);margin-bottom:6px;">
          <a href="/dashboard/forms" style="color:var(--blue);text-decoration:none;">Forms</a> /
        </div>
        <h1 class="page-title">📥 {{ form.name }}</h1>
        <p class="page-sub">{{ site.title }} · Form ID: <code style="background:#f3f4f6;padding:1px 6px;border-radius:4px;font-size:12px;">{{ form.id }}</code></p>
      </div>
      <div class="header-actions">
        <a class="btn btn-ghost" href="/dashboard/forms/edit/{{ form.id }}">✏️ Edit Form</a>
        <a class="btn btn-ghost" href="/dashboard/forms/entries/{{ form.id }}/export">⬇️ Export CSV</a>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-num">{{ entries | length }}</div>
        <div class="stat-label">Total Entries</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{{ fields | length }}</div>
        <div class="stat-label">Form Fields</div>
      </div>
      {% if entries | length %}
      <div class="stat-card">
        <div class="stat-num" style="font-size:14px;letter-spacing:0;padding-top:4px;">
          {{ entries[0].created_at | string | truncate(16, true, '') }}
        </div>
        <div class="stat-label">Latest submission</div>
      </div>
      {% endif %}
    </div>

    <!-- Entries table -->
    <div class="entries-table-wrap">
      <div class="entries-table-header">
        <span class="entries-count">{{ entries | length }} {{ 'entry' if entries | length == 1 else 'entries' }}</span>
      </div>

      {% if entries | length %}
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Date</th>
              {% for field in fields %}
                {% if field.type !== 'heading' and field.type !== 'divider' %}
                <th>{{ field.label }}</th>
                {% endif %}
              {% endfor %}
              <th>IP</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="entriesBody">
            {% for entry in entries %}
            <tr id="entry-{{ entry.id }}">
              <td style="color:var(--ink-faint);font-size:12px;">{{ loop.index }}</td>
              <td class="td-date">{{ entry.created_at | string | truncate(19, true, '') }}</td>
              {% for field in fields %}
                {% if field.type !== 'heading' and field.type !== 'divider' %}
                  {% if field.type === 'file' and entry.data[field.id] %}
                <td><a href="{{ entry.data[field.id] }}" target="_blank" rel="noopener" style="color:var(--blue);text-decoration:none;font-size:12px;">📎 View file</a></td>
                  {% else %}
                <td title="{{ entry.data[field.id] }}">{{ entry.data[field.id] or '—' }}</td>
                  {% endif %}
                {% endif %}
              {% endfor %}
              <td class="td-ip">{{ entry.ip or '—' }}</td>
              <td class="td-actions">
                <button class="del-btn" onclick="deleteEntry({{ entry.id }}, this)" title="Delete">🗑</button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% else %}
      <div class="empty-state">
        <div class="empty-icon">📭</div>
        <div class="empty-title">No entries yet</div>
        <div class="empty-sub">Submissions will appear here once people fill out your form.</div>
      </div>
      {% endif %}
    </div>

  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const SITE_ID = {{ site.id }};
const FORM_ID = {{ form.id }};

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

async function deleteEntry(entryId, btn) {
  if (!confirm('Delete this entry?')) return;
  btn.disabled = true;
  try {
    const r = await fetch(`/dashboard/forms/${SITE_ID}/entries/${FORM_ID}/delete/${entryId}`, { method: 'DELETE' });
    const d = await r.json();
    if (d.ok) {
      document.getElementById('entry-' + entryId).remove();
      showToast('Entry deleted');
      // Update count
      const rows = document.querySelectorAll('#entriesBody tr');
      document.querySelector('.entries-count').textContent = rows.length + ' ' + (rows.length === 1 ? 'entry' : 'entries');
      if (!rows.length) location.reload();
    }
  } catch(e) { btn.disabled = false; }
}
</script>
{% endblock %}

{% extends "layouts/base.njk" %}
{% block body %}
<div style="max-width:860px;margin:40px auto;padding:0 24px;">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;">
    <div>
      <div style="font-size:12px;color:var(--ink-faint);margin-bottom:4px;">
        <a href="/dashboard" style="color:var(--ink-muted);text-decoration:none;">Dashboard</a> / {{ site.title }}
      </div>
      <h1 style="font-size:22px;font-weight:600;color:var(--ink);">📝 Blog Posts</h1>
    </div>
    <a href="/dashboard/blog/{{ site.id }}/new"
       style="padding:10px 20px;background:var(--ink);color:#fff;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;">
      + New Post
    </a>
  </div>

  {% if needsMigration %}
  <div style="background:#fefce8;border:1px solid #fde047;border-radius:10px;padding:20px 24px;margin-bottom:24px;">
    <div style="font-size:15px;font-weight:600;color:#854d0e;margin-bottom:8px;">⚠️ Blog table not set up</div>
    <p style="font-size:14px;color:#713f12;margin-bottom:12px;">Run <strong>blog_migration.sql</strong> in phpMyAdmin to enable the blog feature.</p>
    <code style="font-size:12px;background:#fff;padding:4px 10px;border-radius:6px;border:1px solid #fde047;">blog_migration.sql — in your project root</code>
  </div>
  {% endif %}

  {% if flash_success and flash_success.length %}
  <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:14px;color:#166534;">
    {{ flash_success[0] }}
  </div>
  {% endif %}

  {% if posts.length %}
  <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
    {% for post in posts %}
    <div style="display:flex;align-items:center;gap:16px;padding:16px 20px;border-bottom:{{ 'none' if loop.last else '1px solid #f3f4f6' }};">
      <div style="flex:1;min-width:0;">
        <div style="font-size:15px;font-weight:600;color:#111827;margin-bottom:3px;">{{ post.title }}</div>
        <div style="font-size:12px;color:#9ca3af;">/blog/{{ post.slug }}</div>
      </div>
      <span style="font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;
        {% if post.status == 'published' %}background:#dcfce7;color:#166534;{% else %}background:#f3f4f6;color:#6b7280;{% endif %}">
        {{ post.status | capitalize }}
      </span>
      <a href="/dashboard/blog/{{ site.id }}/edit/{{ post.id }}"
         style="font-size:13px;color:#6366f1;font-weight:500;text-decoration:none;padding:6px 12px;border:1px solid #ddd6fe;border-radius:6px;">
        Edit
      </a>
      <form method="POST" action="/dashboard/blog/{{ site.id }}/delete/{{ post.id }}" style="margin:0;"
            onsubmit="return confirm('Delete this post?')">
        <button type="submit" style="font-size:13px;color:#ef4444;background:transparent;border:none;cursor:pointer;padding:6px 8px;">✕</button>
      </form>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div style="text-align:center;padding:64px 24px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;">
    <div style="font-size:40px;margin-bottom:16px;">✍️</div>
    <div style="font-size:16px;font-weight:600;color:#374151;margin-bottom:8px;">No posts yet</div>
    <p style="font-size:14px;color:#9ca3af;margin-bottom:20px;">Create your first blog post to start publishing.</p>
    <a href="/dashboard/blog/{{ site.id }}/new"
       style="padding:10px 24px;background:#111827;color:#fff;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;">
      Write your first post
    </a>
  </div>
  {% endif %}

</div>
{% endblock %}

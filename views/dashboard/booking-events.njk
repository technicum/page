{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{font-family:"DM Sans",sans-serif;}
.layout{display:flex;min-height:100vh;}
.sidebar{width:220px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;}
.sidebar-logo{font-family:"DM Serif Display",serif;font-size:20px;padding:22px 24px;border-bottom:1px solid var(--border);text-decoration:none;color:var(--ink);display:block;}
.sidebar-logo em{font-style:italic;color:var(--blue);}
.sidebar-nav{padding:16px 12px;flex:1;}
.nav-label{font-size:11px;font-weight:700;color:var(--ink-faint);text-transform:uppercase;letter-spacing:0.06em;padding:10px 12px 4px;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius);font-size:14px;color:var(--ink-muted);text-decoration:none;margin-bottom:2px;}
.nav-item:hover{background:var(--off);color:var(--ink);}
.nav-item.active{background:var(--blue-light);color:var(--blue);font-weight:500;}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border);}
.user-avatar{width:32px;height:32px;border-radius:50%;background:var(--blue-light);color:var(--blue);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;}
.logout-link{display:block;font-size:13px;color:var(--ink-faint);padding:6px 12px;margin-top:4px;}
.content{flex:1;padding:36px 40px;min-width:0;}
.page-title{font-family:"DM Serif Display",serif;font-size:26px;font-weight:400;margin-bottom:4px;}
.page-sub{font-size:14px;color:var(--ink-muted);margin-bottom:28px;}
.back-btn{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--ink-muted);text-decoration:none;margin-bottom:20px;padding:7px 14px;border-radius:var(--radius);border:1px solid var(--border);background:var(--white);}
.back-btn:hover{background:var(--off);}
.two-col{display:grid;grid-template-columns:1fr 360px;gap:28px;align-items:start;}
.events-list{display:flex;flex-direction:column;gap:12px;}
.event-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px 20px;display:flex;align-items:center;gap:16px;}
.event-swatch{width:44px;height:44px;border-radius:12px;flex-shrink:0;}
.event-info{flex:1;min-width:0;}
.event-name{font-size:15px;font-weight:700;margin-bottom:3px;}
.event-meta{font-size:13px;color:var(--ink-muted);}
.event-actions{display:flex;gap:8px;flex-shrink:0;}
.btn-edit{padding:7px 14px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;font-weight:500;color:var(--ink);text-decoration:none;background:var(--white);transition:all 0.15s;}
.btn-edit:hover{border-color:var(--blue);color:var(--blue);}
.btn-del{padding:7px 14px;border:1px solid #fecaca;border-radius:var(--radius);font-size:13px;font-weight:500;color:#dc2626;background:#fff5f5;cursor:pointer;transition:all 0.15s;}
.btn-del:hover{background:#dc2626;color:#fff;border-color:#dc2626;}
.event-link-row{display:flex;align-items:center;gap:8px;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);}
.event-link-url{flex:1;font-size:12px;color:var(--ink-muted);background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:5px 10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:monospace;}
.btn-copy{padding:5px 12px;background:var(--blue);color:#fff;border:none;border-radius:var(--radius);font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;font-family:inherit;flex-shrink:0;transition:opacity 0.15s;}
.btn-copy:hover{opacity:0.85;}
.inactive-badge{background:var(--off);color:var(--ink-faint);font-size:11px;padding:2px 8px;border-radius:20px;margin-left:8px;}
.form-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;}
.form-title{font-size:16px;font-weight:700;margin-bottom:20px;}
.form-group{margin-bottom:16px;}
.form-label{font-size:13px;font-weight:600;margin-bottom:6px;display:block;color:var(--ink);}
.form-input{width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:var(--radius);font-size:14px;font-family:inherit;background:var(--bg);color:var(--ink);box-sizing:border-box;}
.form-input:focus{outline:none;border-color:var(--blue);}
.form-hint{font-size:12px;color:var(--ink-muted);margin-top:4px;}
.color-row{display:flex;gap:8px;flex-wrap:wrap;}
.color-opt{width:28px;height:28px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:transform 0.15s;}
.color-opt:hover{transform:scale(1.15);}
.color-opt.active{border-color:var(--ink);}
.submit-btn{display:block;width:100%;padding:11px;background:var(--blue);color:#fff;border:none;border-radius:var(--radius);font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:opacity 0.15s;}
.submit-btn:hover{opacity:0.88;}
.toggle-wrap{display:flex;align-items:center;gap:10px;}
.toggle{position:relative;display:inline-block;width:40px;height:22px;}
.toggle input{display:none;}
.toggle-slider{position:absolute;inset:0;background:#d1d5db;border-radius:22px;transition:0.2s;}
.toggle-slider:before{content:'';position:absolute;width:16px;height:16px;background:#fff;border-radius:50%;top:3px;left:3px;transition:0.2s;}
.toggle input:checked+.toggle-slider{background:var(--blue);}
.toggle input:checked+.toggle-slider:before{transform:translateX(18px);}
.alert-ok{background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;padding:10px 14px;border-radius:var(--radius);font-size:13px;margin-bottom:16px;}
.empty{text-align:center;padding:40px 24px;color:var(--ink-muted);background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);}
</style>
{% endblock %}
{% block body %}
<div class="layout">
  <aside class="sidebar">
    <a class="sidebar-logo" href="/">page<em>zapper</em></a>
    <nav class="sidebar-nav">
      <a class="nav-item" href="/dashboard">🏠 Dashboard</a>
      <a class="nav-item" href="/dashboard/wizard">✨ New Site</a>
      <div class="nav-label">Booking</div>
      <a class="nav-item" href="/dashboard/booking/{{ site.id }}">📊 Overview</a>
      <a class="nav-item active" href="/dashboard/booking/{{ site.id }}/events">🎯 Event Types</a>
      <a class="nav-item" href="/dashboard/booking/{{ site.id }}/availability">📅 Availability</a>
      <a class="nav-item" href="/dashboard/booking/{{ site.id }}/list">📋 All Bookings</a>
    </nav>
    <div class="sidebar-bottom">
      <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;">
        <div class="user-avatar">{{ user.name[0] | upper }}</div>
        <div style="font-size:13px;font-weight:500;">{{ user.name }}</div>
      </div>
      <a class="logout-link" href="/logout">← Logout</a>
    </div>
  </aside>
  <main class="content">
    <a class="back-btn" href="/dashboard/booking/{{ site.id }}">← Overview</a>
    <div class="page-title">Event Types</div>
    <div class="page-sub">Define the types of meetings people can book with you.</div>

    <div class="two-col">
      <!-- Left: list -->
      <div>
        {% if saved %}<div class="alert-ok">✅ Event type saved.</div>{% endif %}
        {% if deleted %}<div class="alert-ok">🗑️ Event type deleted.</div>{% endif %}

        {% if not events.length %}
        <div class="empty">
          <div style="font-size:32px;margin-bottom:10px;">🎯</div>
          <div style="font-size:15px;font-weight:500;margin-bottom:4px;">No event types yet</div>
          <div>Create your first meeting type on the right.</div>
        </div>
        {% else %}
        <div class="events-list">
          {% for ev in events %}
          <div class="event-card" style="flex-direction:column;align-items:stretch;">
            <div style="display:flex;align-items:center;gap:16px;">
              <div class="event-swatch" style="background:{{ ev.color }}"></div>
              <div class="event-info">
                <div class="event-name">
                  {{ ev.name }}
                  {% if not ev.is_active %}<span class="inactive-badge">Inactive</span>{% endif %}
                </div>
                <div class="event-meta">{% if ev.event_type == 'appointment' %}📍 In-Person{% else %}🖥️ Meeting{% endif %} · {{ ev.duration }} min{% if ev.location %} · {{ ev.location }}{% endif %}{% if ev.description %} · {{ ev.description | truncate(50) }}{% endif %}</div>
              </div>
              <div class="event-actions">
                <a class="btn-edit" href="/dashboard/booking/{{ site.id }}/events?edit={{ ev.id }}">Edit</a>
                <form method="POST" action="/dashboard/booking/{{ site.id }}/events/delete" onsubmit="return confirm('Delete this event type?')">
                  <input type="hidden" name="id" value="{{ ev.id }}">
                  <button type="submit" class="btn-del">Delete</button>
                </form>
              </div>
            </div>
            <div class="event-link-row">
              <input class="event-link-url" id="evurl-{{ ev.id }}" type="text" value="https://{{ site.subdomain }}.{{ baseDomain }}/book/{{ ev.id }}" readonly>
              <button class="btn-copy" onclick="pzCopyEvLink('evurl-{{ ev.id }}', this)">Copy Link</button>
            </div>
          </div>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- Right: form -->
      <div class="form-card">
        <div class="form-title">{{ 'Edit Event Type' if edit else 'New Event Type' }}</div>
        <form method="POST" action="/dashboard/booking/{{ site.id }}/events/save">
          {% if edit %}<input type="hidden" name="id" value="{{ edit.id }}">{% endif %}

          <div class="form-group">
            <label class="form-label">Type</label>
            <select class="form-input" name="event_type">
              <option value="meeting" {% if not edit or edit.event_type == 'meeting' %}selected{% endif %}>🖥️ Online Meeting (video / phone call)</option>
              <option value="appointment" {% if edit and edit.event_type == 'appointment' %}selected{% endif %}>📍 In-Person Appointment (clinic, salon, etc.)</option>
            </select>
            <div class="form-hint">Determines which booking page shows this event type — /book for meetings, /appointment for in-person.</div>
          </div>

          <div class="form-group">
            <label class="form-label">Name</label>
            <input class="form-input" type="text" name="name" placeholder="e.g. 30-Min Discovery Call" value="{{ edit.name if edit else '' }}" required>
          </div>

          <div class="form-group">
            <label class="form-label">Duration (minutes)</label>
            <select class="form-input" name="duration">
              {% for d in [15, 30, 45, 60, 90, 120] %}
              <option value="{{ d }}" {% if edit and edit.duration == d %}selected{% elif not edit and d == 30 %}selected{% endif %}>{{ d }} min</option>
              {% endfor %}
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Color</label>
            <div class="color-row">
              {% for c in ['#7c3aed','#2563eb','#0f766e','#e11d48','#d97706','#16a34a','#1a1a18','#6b7280'] %}
              <div class="color-opt {% if (edit and edit.color == c) or (not edit and c == '#7c3aed') %}active{% endif %}" style="background:{{ c }};" onclick="pickColor('{{ c }}', this)"></div>
              {% endfor %}
            </div>
            <input type="hidden" name="color" id="colorVal" value="{{ edit.color if edit else '#7c3aed' }}">
          </div>

          <div class="form-group">
            <label class="form-label">Location / Meeting link <span style="font-weight:400;color:var(--ink-muted);">(optional)</span></label>
            <input class="form-input" type="text" name="location" placeholder="Zoom link or office address" value="{{ edit.location if edit else '' }}">
          </div>

          <div class="form-group">
            <label class="form-label">Description <span style="font-weight:400;color:var(--ink-muted);">(optional)</span></label>
            <input class="form-input" type="text" name="description" placeholder="Brief description shown to bookers" value="{{ edit.description if edit else '' }}">
          </div>

          <div class="form-group">
            <label class="form-label">Status</label>
            <div class="toggle-wrap">
              <label class="toggle">
                <input type="checkbox" name="is_active" value="1" {% if not edit or edit.is_active %}checked{% endif %}>
                <span class="toggle-slider"></span>
              </label>
              <span style="font-size:14px;">Active (visible on bio link)</span>
            </div>
          </div>

          <button type="submit" class="submit-btn">{{ 'Save Changes' if edit else 'Create Event Type' }}</button>
          {% if edit %}
          <a href="/dashboard/booking/{{ site.id }}/events" style="display:block;text-align:center;margin-top:10px;font-size:13px;color:var(--ink-muted);">Cancel editing</a>
          {% endif %}
        </form>
      </div>
    </div>
  </main>
</div>
<script>
function pickColor(hex, el) {
  document.getElementById('colorVal').value = hex;
  document.querySelectorAll('.color-opt').forEach(e => e.classList.remove('active'));
  el.classList.add('active');
}
function pzCopyEvLink(inputId, btn) {
  var el = document.getElementById(inputId);
  el.select(); el.setSelectionRange(0, 999);
  try { document.execCommand('copy'); } catch(e) {}
  var orig = btn.textContent;
  btn.textContent = 'Copied!';
  setTimeout(function(){ btn.textContent = orig; }, 2000);
}
</script>
{% endblock %}

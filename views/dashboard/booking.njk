{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{background:var(--off);}
.layout{display:flex;min-height:100vh;}
.main{flex:1;padding:28px 32px;min-width:0;}
.page-card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:22px 24px;}
.page-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px;}
.page-title{font-size:18px;font-weight:700;color:var(--ink);}
.page-sub{font-size:12px;color:var(--ink-muted);margin-top:2px;}
.head-btns{display:flex;gap:8px;}
.hbtn{font-size:13px;padding:7px 14px;border-radius:var(--radius);border:1px solid var(--border);background:var(--white);color:var(--ink-muted);text-decoration:none;cursor:pointer;white-space:nowrap;}
.hbtn:hover{background:var(--off);}
.hbtn.primary{background:var(--blue);color:#fff;border-color:var(--blue);}
.hbtn.primary:hover{opacity:.88;}
.stat-row{display:flex;gap:10px;margin-bottom:16px;}
.stat{flex:1;background:var(--off);border:1px solid var(--border);border-radius:var(--radius);padding:13px 16px;}
.sv{font-size:22px;font-weight:700;color:var(--ink);}
.sv.blue{color:var(--blue);}
.sl{font-size:11px;color:var(--ink-muted);margin-top:3px;}
.section{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:12px;}
.sec-head{padding:10px 14px;border-bottom:1px solid var(--border);font-size:12px;font-weight:600;color:var(--ink-muted);display:flex;align-items:center;justify-content:space-between;}
.sec-head a{font-size:12px;color:var(--blue);font-weight:400;text-decoration:none;}
.sec-body{padding:12px 14px;}
.link-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);}
.link-row:last-child{border-bottom:none;}
.link-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;}
.link-name{font-size:13px;font-weight:500;color:var(--ink);}
.link-url{font-size:11px;color:var(--ink-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.copy-btn{font-size:12px;padding:5px 12px;border-radius:var(--radius);border:1px solid var(--border);background:var(--white);color:var(--ink-muted);cursor:pointer;white-space:nowrap;flex-shrink:0;}
.copy-btn:hover{border-color:var(--blue);color:var(--blue);}
.empty{text-align:center;padding:24px;color:var(--ink-muted);font-size:13px;}
.empty-icon{font-size:24px;margin-bottom:8px;}
.bk-table{width:100%;border-collapse:collapse;}
.bk-table th{font-size:11px;font-weight:600;color:var(--ink-muted);text-transform:uppercase;letter-spacing:.04em;padding:8px 12px;border-bottom:1px solid var(--border);text-align:left;}
.bk-table td{padding:10px 12px;font-size:13px;color:var(--ink);border-bottom:1px solid var(--border);}
.bk-table tr:last-child td{border-bottom:none;}
.bk-table tr:hover td{background:var(--off);}
.badge{background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;}
.back-btn{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--ink-muted);text-decoration:none;margin-bottom:16px;padding:6px 12px;border-radius:var(--radius);border:1px solid var(--border);background:var(--white);}
.back-btn:hover{background:var(--off);}
</style>
{% endblock %}
{% block body %}
{% set activePage = 'booking' %}
{% set bookingSiteId = site.id %}
{% set bookingPage = 'overview' %}
<div class="layout">
  {% include "dashboard/_sidebar.njk" %}
  <main class="main">
    <a class="back-btn" href="/dashboard/site/biolink-builder?id={{ site.id }}">← Back to Editor</a>

    <div class="page-card">
      <div class="page-head">
        <div>
          <div class="page-title">Booking — {{ site.title }}</div>
          <div class="page-sub">Manage appointments and availability</div>
        </div>
        <div class="head-btns">
          <a class="hbtn" href="/dashboard/booking/{{ site.id }}/availability">📅 Availability</a>
          <a class="hbtn" href="/dashboard/booking/{{ site.id }}/events">🎯 Event types</a>
          <a class="hbtn primary" href="/dashboard/booking/{{ site.id }}/list">📋 All bookings</a>
        </div>
      </div>

      <div class="stat-row">
        <div class="stat"><div class="sv">{{ stats.total or 0 }}</div><div class="sl">Total bookings</div></div>
        <div class="stat"><div class="sv blue">{{ stats.week_count or 0 }}</div><div class="sl">This week</div></div>
        <div class="stat"><div class="sv">{{ stats.today_count or 0 }}</div><div class="sl">Today</div></div>
      </div>

      <div class="section">
        <div class="sec-head">Booking links</div>
        <div class="sec-body">
          <div class="link-row">
            <div class="link-icon" style="background:#eff6ff;">🖥️</div>
            <div style="flex:1;min-width:0;">
              <div class="link-name">Online meetings</div>
              <div class="link-url">{{ bookUrl }}</div>
            </div>
            <button class="copy-btn" onclick="pzCopy('{{ bookUrl }}', this)">Copy</button>
          </div>
          <div class="link-row">
            <div class="link-icon" style="background:#f0fdf4;">📍</div>
            <div style="flex:1;min-width:0;">
              <div class="link-name">In-person appointments</div>
              <div class="link-url">{{ appointmentUrl }}</div>
            </div>
            <button class="copy-btn" onclick="pzCopy('{{ appointmentUrl }}', this)">Copy</button>
          </div>
        </div>
      </div>

      <div class="section">
        <div class="sec-head">
          Upcoming bookings
          <a href="/dashboard/booking/{{ site.id }}/list">View all →</a>
        </div>
        <div class="sec-body" style="padding:0;">
          {% if not upcoming or not upcoming.length %}
          <div class="empty">
            <div class="empty-icon">📅</div>
            No upcoming bookings
          </div>
          {% else %}
          <table class="bk-table">
            <thead>
              <tr><th>Date</th><th>Time</th><th>Event</th><th>Name</th><th>Email</th><th>Status</th></tr>
            </thead>
            <tbody>
              {% for b in upcoming %}
              <tr>
                <td style="font-weight:600;">{{ b.booking_date | string | truncate(10, true, '') }}</td>
                <td>{{ b.start_time | string | truncate(5, true, '') }}</td>
                <td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:{{ b.color }};margin-right:6px;"></span>{{ b.event_name }}</td>
                <td>{{ b.booker_name }}</td>
                <td style="color:var(--ink-muted);">{{ b.booker_email }}</td>
                <td><span class="badge">Confirmed</span></td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
          {% endif %}
        </div>
      </div>
    </div>
  </main>
</div>

<script>
function pzCopy(text, btn) {
  navigator.clipboard.writeText(text).catch(function(){
    var ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
  });
  btn.textContent = 'Copied!';
  setTimeout(function(){ btn.textContent = 'Copy'; }, 2000);
}
</script>
{% endblock %}

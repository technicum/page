<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ current.seo_title or (current.title + ' — ' + website.title) }}</title>
{% if current.seo_desc %}<meta name="description" content="{{ current.seo_desc }}">{% endif %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family={{ (website.settings.font or 'Inter') | urlencode }}:wght@400;500;600;700;800&display=swap" rel="stylesheet">
{% set activeTheme = website.settings.theme or 'default' %}
<style>
:root{
  --primary: {{ website.settings.primary or '#6366f1' }};
  --primary-dark: {{ website.settings.primary or '#4f46e5' }};
  --text: {{ website.settings.text or '#111827' }};
  --bg: {{ website.settings.bg or '#ffffff' }};
  --font: '{{ website.settings.font or 'Inter' }}', system-ui, sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.6;}
img{max-width:100%;height:auto;display:block;}
a{color:var(--primary);text-decoration:none;}
.container{max-width:1100px;margin:0 auto;padding:0 24px;}

/* ── Navigation ─── */
nav{background:#fff;border-bottom:1px solid rgba(0,0,0,.07);position:sticky;top:0;z-index:100;box-shadow:0 1px 4px rgba(0,0,0,.04);}
.nav-inner{display:flex;align-items:center;height:64px;gap:32px;}
.nav-logo{font-size:20px;font-weight:800;color:var(--text);text-decoration:none;flex-shrink:0;}
.nav-logo img{height:36px;object-fit:contain;}
.nav-links{display:flex;gap:4px;flex:1;}
.nav-links a{padding:7px 14px;border-radius:8px;font-size:14px;font-weight:500;color:#6b7280;transition:all .15s;}
.nav-links a:hover,.nav-links a.active{color:var(--primary);background:rgba(99,102,241,.07);}

/* ── Sections general ─── */
.section{padding:80px 0;}
.section-alt{background:#f9fafb;}
.section-heading{text-align:center;margin-bottom:48px;}
.section-heading h2{font-size:clamp(26px,4vw,38px);font-weight:800;color:var(--text);margin-bottom:10px;}
.section-heading p{font-size:16px;color:#6b7280;max-width:560px;margin:0 auto;}

/* ── Hero base ─── */
.hero{position:relative;overflow:hidden;}
.hero h1{font-size:clamp(30px,5.5vw,62px);font-weight:800;line-height:1.08;letter-spacing:-1.5px;}
.hero p{font-size:clamp(15px,1.8vw,19px);opacity:.75;line-height:1.7;}
.hero-badge{display:inline-block;padding:6px 16px;border-radius:20px;font-size:13px;font-weight:600;margin-bottom:20px;letter-spacing:.3px;background:rgba(255,255,255,.15);}
.hero-badge.badge-light{background:rgba(0,0,0,.07);color:var(--primary);}
/* Buttons */
.btn-primary{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;background:var(--primary);color:#fff;border-radius:12px;font-size:16px;font-weight:700;text-decoration:none;transition:all .2s;border:none;cursor:pointer;font-family:inherit;box-shadow:0 4px 18px rgba(0,0,0,.18);}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.25);}
.btn-outline-hero{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border:2px solid rgba(255,255,255,.35);color:currentColor;border-radius:12px;font-size:16px;font-weight:600;text-decoration:none;transition:all .2s;}
.btn-outline-hero.dark-outline{border-color:rgba(0,0,0,.18);}
.btn-outline-hero:hover{background:rgba(255,255,255,.12);}
.hero-btns{display:flex;gap:12px;align-items:center;flex-wrap:wrap;}
/* ── Hero centered ── */
.hero-centered{padding:72px 0 0;text-align:center;}
.hero-centered h1{margin-bottom:18px;}
.hero-centered>div>p,.hero-centered>div>.hero-badge+h1+p{max-width:540px;margin-left:auto;margin-right:auto;margin-bottom:36px;}
.hero-centered .hero-btns{justify-content:center;margin-bottom:52px;}
/* Browser/dashboard mockup */
.hero-visual{max-width:860px;margin:0 auto;}
.hero-browser{background:#1e293b;border-radius:16px 16px 0 0;padding:14px 20px 0;box-shadow:0 30px 80px rgba(0,0,0,.32);}
.hero-browser-chrome{display:flex;align-items:center;gap:7px;margin-bottom:14px;}
.hero-browser-chrome span{width:12px;height:12px;border-radius:50%;}
.hero-browser-chrome span:nth-child(1){background:#ef4444;}
.hero-browser-chrome span:nth-child(2){background:#f59e0b;}
.hero-browser-chrome span:nth-child(3){background:#22c55e;}
.hero-browser-url{flex:1;height:22px;background:rgba(255,255,255,.07);border-radius:5px;margin-left:10px;}
.hero-browser-body{display:flex;gap:16px;padding:24px 20px 0;background:linear-gradient(155deg,rgba(99,102,241,.18),rgba(139,92,246,.1));border-radius:10px 10px 0 0;align-items:flex-end;}
.hero-person{width:170px;flex-shrink:0;border-radius:12px 12px 0 0;overflow:hidden;position:relative;min-height:180px;}
.hero-person-l{background:linear-gradient(145deg,var(--primary),#8b5cf6);}
.hero-person-r{background:linear-gradient(145deg,#f59e0b,#f97316);}
.hero-chart-area{flex:1;display:flex;flex-direction:column;padding-bottom:0;}
.hero-chart-label{font-size:12px;color:rgba(255,255,255,.4);font-weight:500;margin-bottom:12px;}
.hero-chart-bars{display:flex;gap:7px;align-items:flex-end;height:120px;}
.hero-chart-bars span{flex:1;border-radius:4px 4px 0 0;background:linear-gradient(to top,var(--primary),#8b5cf6);opacity:.85;}
/* ── Hero split ── */
.hero-split{padding:64px 0;}
.hero-split-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;}
.hero-split h1{margin-bottom:18px;}
.hero-split .hero-p{margin-bottom:32px;}
.hero-split .hero-btns{justify-content:flex-start;}
/* Split visual */
.hero-split-img{position:relative;height:440px;}
.hero-split-card{position:absolute;inset:0;left:40px;background:linear-gradient(140deg,rgba(99,102,241,.14),rgba(99,102,241,.06));border-radius:24px;overflow:hidden;}
.hero-split-inner{position:absolute;bottom:0;right:0;width:60%;height:88%;background:linear-gradient(145deg,var(--primary),#8b5cf6);border-radius:20px 0 0 0;overflow:hidden;}
.hero-split-inner2{position:absolute;bottom:0;left:0;width:52%;height:80%;background:linear-gradient(145deg,#f59e0b,#f97316);border-radius:0 20px 0 24px;overflow:hidden;}
.hero-float-card{position:absolute;background:#fff;border-radius:16px;box-shadow:0 16px 48px rgba(0,0,0,.14);}
.hfc-stat{bottom:36px;left:0;padding:16px 20px;min-width:180px;}
.hfc-stat .s-lbl{font-size:11px;color:#9ca3af;font-weight:500;margin-bottom:5px;}
.hfc-stat .s-num{font-size:26px;font-weight:800;color:#111827;line-height:1.1;}
.hfc-stat .s-pct{font-size:11px;color:#10b981;font-weight:700;margin-top:5px;}
.hfc-chart{top:24px;left:0;padding:14px 16px;}
.hfc-chart-head{display:flex;gap:10px;align-items:center;margin-bottom:10px;}
.hfc-icon{width:36px;height:36px;border-radius:10px;background:rgba(99,102,241,.12);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.hfc-chart-lbl{font-size:11px;color:#9ca3af;}
.hfc-chart-val{font-size:16px;font-weight:700;color:#111827;}
.hfc-bars{display:flex;gap:3px;align-items:flex-end;height:24px;}
.hfc-bars span{flex:1;border-radius:2px;background:var(--primary);opacity:.75;}
@media(max-width:768px){
  .hero-split-grid{grid-template-columns:1fr;}
  .hero-split-img{height:300px;margin-top:32px;}
  .hero-split-card{left:0;}
  .hfc-stat,.hfc-chart{display:none;}
}

/* ── About ─── */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
.about-grid.img-left{direction:rtl;}.about-grid.img-left>*{direction:ltr;}
.about-img{border-radius:20px;overflow:hidden;aspect-ratio:4/3;background:#f3f4f6;display:flex;align-items:center;justify-content:center;font-size:48px;}
.about-img img{width:100%;height:100%;object-fit:cover;}
.about-text h2{font-size:32px;font-weight:800;margin-bottom:16px;}
.about-text p{font-size:16px;color:#6b7280;line-height:1.75;}

/* ── Services ─── */
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;}
.service-card{background:#fff;border:1.5px solid #e5e7eb;border-radius:16px;padding:28px;transition:all .2s;}
.service-card:hover{border-color:var(--primary);box-shadow:0 8px 24px rgba(0,0,0,.08);transform:translateY(-3px);}
.service-icon{font-size:36px;margin-bottom:16px;}
.service-title{font-size:18px;font-weight:700;margin-bottom:8px;color:var(--text);}
.service-desc{font-size:14px;color:#6b7280;line-height:1.6;}

/* ── Gallery ─── */
.gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;}
.gallery-item{border-radius:14px;overflow:hidden;background:#f3f4f6;cursor:zoom-in;}
.gallery-item img{width:100%;height:100%;object-fit:cover;transition:transform .35s;}
.gallery-item:hover img{transform:scale(1.06);}
/* Lightbox */
#pzLb{position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:9998;display:none;align-items:center;justify-content:center;cursor:zoom-out;}
#pzLb img{max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px;box-shadow:0 8px 60px rgba(0,0,0,.5);}
#pzLbClose{position:absolute;top:18px;right:22px;color:#fff;font-size:32px;cursor:pointer;line-height:1;background:rgba(255,255,255,.1);border-radius:50%;width:42px;height:42px;display:flex;align-items:center;justify-content:center;border:none;transition:background .15s;}
#pzLbClose:hover{background:rgba(255,255,255,.2);}
#pzLbPrev,#pzLbNext{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.12);border:none;color:#fff;font-size:26px;width:48px;height:48px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s;}
#pzLbPrev{left:18px;}#pzLbNext{right:18px;}
#pzLbPrev:hover,#pzLbNext:hover{background:rgba(255,255,255,.22);}

/* ── Testimonials ─── */
.testimonials-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;}
.testi-card{background:#fff;border:1.5px solid #e5e7eb;border-radius:16px;padding:28px;position:relative;}
.testi-quote{font-size:15px;color:#374151;line-height:1.75;margin-bottom:20px;font-style:italic;}
.testi-author{display:flex;align-items:center;gap:12px;}
.testi-avatar{width:40px;height:40px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;flex-shrink:0;}
.testi-name{font-size:14px;font-weight:700;color:var(--text);}
.testi-role{font-size:12px;color:#9ca3af;}

/* ── Team ─── */
.team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:24px;}
.team-card{text-align:center;}
.team-photo{width:100%;aspect-ratio:1;border-radius:16px;overflow:hidden;background:#f3f4f6;display:flex;align-items:center;justify-content:center;font-size:48px;margin-bottom:14px;}
.team-photo img{width:100%;height:100%;object-fit:cover;}
.team-name{font-size:16px;font-weight:700;color:var(--text);}
.team-role{font-size:13px;color:#9ca3af;margin-top:4px;}

/* ── FAQ ─── */
.faq-list{max-width:720px;margin:0 auto;display:flex;flex-direction:column;gap:12px;}
.faq-item{background:#fff;border:1.5px solid #e5e7eb;border-radius:14px;overflow:hidden;}
.faq-q{padding:18px 20px;font-size:15px;font-weight:600;color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;transition:background .15s;}
.faq-q:hover{background:#f9fafb;}
.faq-q::after{content:'';width:10px;height:10px;border-right:2px solid #9ca3af;border-bottom:2px solid #9ca3af;transform:rotate(45deg);flex-shrink:0;transition:transform .2s;margin-top:-4px;}
.faq-item.open .faq-q::after{transform:rotate(-135deg);margin-top:4px;}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s ease;}
.faq-item.open .faq-a{max-height:500px;}
.faq-a-inner{padding:0 20px 18px;font-size:14px;color:#6b7280;line-height:1.75;border-top:1px solid #f3f4f6;}

/* ── CTA Banner ─── */
.cta-banner{padding:80px 0;text-align:center;}
.cta-banner h2{font-size:clamp(26px,4vw,42px);font-weight:800;margin-bottom:12px;}
.cta-banner p{font-size:17px;opacity:.8;margin-bottom:32px;max-width:500px;margin-left:auto;margin-right:auto;}

/* ── Contact ─── */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;}
.contact-info{display:flex;flex-direction:column;gap:20px;}
.contact-item{display:flex;align-items:flex-start;gap:14px;}
.contact-item-icon{width:40px;height:40px;border-radius:10px;background:rgba(99,102,241,.1);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.contact-item-text{font-size:14px;color:#6b7280;line-height:1.6;}
.contact-item-label{font-weight:600;color:var(--text);margin-bottom:2px;font-size:13px;}
.contact-form{background:#fff;border:1.5px solid #e5e7eb;border-radius:20px;padding:28px;display:flex;flex-direction:column;gap:14px;}
.cf-input{padding:11px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:var(--font);outline:none;transition:border-color .15s;width:100%;}
.cf-input:focus{border-color:var(--primary);}
.cf-textarea{resize:vertical;min-height:100px;}
.cf-submit{padding:12px;background:var(--primary);color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;font-family:var(--font);transition:opacity .15s;width:100%;}
.cf-submit:hover{opacity:.9;}

/* ── Footer ─── */
footer{background:#111827;color:#9ca3af;padding:32px 0;text-align:center;font-size:13px;}
footer a{color:#9ca3af;text-decoration:none;}footer a:hover{color:#fff;}

/* ── Pricing ── */
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;}
.pricing-card{background:#fff;border:1.5px solid #e5e7eb;border-radius:20px;padding:32px 24px;text-align:center;transition:all .2s;display:flex;flex-direction:column;}
.pricing-card.featured{border-color:var(--primary);box-shadow:0 8px 32px rgba(0,0,0,.12);transform:scale(1.03);}
.pricing-name{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:#6b7280;margin-bottom:12px;}
.pricing-price{font-size:clamp(26px,4vw,40px);font-weight:800;color:var(--text);margin-bottom:20px;line-height:1.1;}
.pricing-features{list-style:none;display:flex;flex-direction:column;gap:9px;margin-bottom:28px;text-align:left;flex:1;}
.pricing-features li{font-size:14px;color:#6b7280;padding-left:22px;position:relative;}
.pricing-features li::before{content:'✓';color:var(--primary);font-weight:700;position:absolute;left:0;}
.pricing-cta{display:block;padding:12px 24px;background:var(--primary);color:#fff;border-radius:10px;font-size:14px;font-weight:700;text-decoration:none;transition:opacity .15s;}
.pricing-cta:hover{opacity:.9;}
.pricing-card.featured .pricing-name{color:var(--primary);}
/* ── Stats ── */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));}
.stat-item{text-align:center;padding:32px 16px;}
.stat-emoji{font-size:36px;margin-bottom:12px;}
.stat-number{font-size:clamp(32px,5vw,52px);font-weight:800;color:var(--primary);line-height:1;margin-bottom:8px;}
.stat-label{font-size:14px;color:#6b7280;font-weight:500;}
/* ── Rich Text ── */
.rich-text-block{max-width:780px;margin:0 auto;}
.rich-text-block h2{font-size:clamp(22px,3.5vw,34px);font-weight:800;margin-bottom:16px;}
.rich-text-block .rtb-content{font-size:16px;color:#374151;line-height:1.8;white-space:pre-wrap;}
.rich-text-block.center{text-align:center;}
/* ── Columns ── */
.columns-grid{display:grid;gap:28px;}
.columns-grid.cols-2{grid-template-columns:repeat(2,1fr);}
.columns-grid.cols-3{grid-template-columns:repeat(3,1fr);}
.col-item{padding:4px;}
.col-item-icon{font-size:32px;margin-bottom:14px;}
.col-item-heading{font-size:18px;font-weight:700;margin-bottom:10px;color:var(--text);}
.col-item-text{font-size:15px;color:#6b7280;line-height:1.7;}
.col-item-btn{display:inline-block;margin-top:14px;padding:9px 20px;background:var(--primary);color:#fff;border-radius:8px;font-size:14px;font-weight:600;text-decoration:none;}
@media(max-width:768px){.columns-grid.cols-2,.columns-grid.cols-3{grid-template-columns:1fr;}}
/* ── Video ── */
.video-wrap{max-width:820px;margin:0 auto;}
.video-embed{position:relative;padding-bottom:56.25%;border-radius:16px;overflow:hidden;background:#111;}
.video-embed iframe{position:absolute;inset:0;width:100%;height:100%;border:none;}
.video-caption{text-align:center;font-size:14px;color:#9ca3af;margin-top:14px;}
/* ── Logo Bar ── */
.logo-bar{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:32px 48px;padding:8px 0;}
.logo-item{opacity:.55;filter:grayscale(1);transition:all .2s;}
.logo-item:hover{opacity:1;filter:none;}
.logo-item img{height:36px;object-fit:contain;display:block;}
.logo-item-text{font-size:16px;font-weight:700;color:#374151;}
/* ── Timeline ── */
.timeline{max-width:680px;margin:0 auto;display:flex;flex-direction:column;}
.tl-item{display:flex;gap:20px;align-items:flex-start;}
.tl-line{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:36px;}
.tl-dot{width:36px;height:36px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0;}
.tl-connector{flex:1;width:2px;background:#e5e7eb;min-height:28px;margin:4px 0;}
.tl-item:last-child .tl-connector{display:none;}
.tl-content{padding-bottom:36px;padding-top:6px;}
.tl-title{font-size:17px;font-weight:700;color:var(--text);margin-bottom:6px;}
.tl-desc{font-size:14px;color:#6b7280;line-height:1.65;}
/* ── Newsletter ── */
.newsletter-wrap{max-width:560px;margin:0 auto;text-align:center;}
.newsletter-wrap h2{font-size:clamp(22px,3.5vw,36px);font-weight:800;margin-bottom:10px;}
.newsletter-wrap p{font-size:16px;color:#6b7280;margin-bottom:28px;}
.newsletter-form{display:flex;gap:10px;max-width:440px;margin:0 auto;}
.nl-input{flex:1;padding:12px 16px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:var(--font);outline:none;transition:border-color .15s;}
.nl-input:focus{border-color:var(--primary);}
.nl-btn{padding:12px 20px;background:var(--primary);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:var(--font);white-space:nowrap;}
@media(max-width:480px){.newsletter-form{flex-direction:column;}}

/* ── Responsive ─── */
@media(max-width:768px){
  .about-grid,.contact-grid{grid-template-columns:1fr;}
  .about-grid.img-left{direction:ltr;}
  .nav-links{gap:2px;overflow-x:auto;padding-bottom:2px;}
  .nav-links a{white-space:nowrap;padding:6px 10px;font-size:13px;}
  .section{padding:56px 0;}
  .hero-centered{padding:52px 0 0;}
  .hero-split{padding:48px 0;}
  .hero-visual{display:none;}
  .hero-centered .hero-btns{margin-bottom:32px;}
}
</style>
<link rel="stylesheet" href="/themes/website/{{ activeTheme }}/theme.css">
</head>
<body>

<!-- Navigation -->
<nav>
  <div class="container">
    <div class="nav-inner">
      {% if website.settings.logo %}
      <a class="nav-logo" href="/w/{{ website.subdomain }}"><img src="{{ website.settings.logo }}" alt="{{ website.title }}"></a>
      {% else %}
      <a class="nav-logo" href="/w/{{ website.subdomain }}">{{ website.title }}</a>
      {% endif %}
      <div class="nav-links">
        {% for p in pages %}
        <a href="/w/{{ website.subdomain }}/{{ p.slug }}" class="{{ 'active' if p.id == current.id }}">{{ p.title }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</nav>

<!-- Sections -->
{% for sec in current.sections %}

  {# ── HERO ── #}
  {% if sec.type == 'hero' %}
  {% set hLayout = sec.data.layout or 'centered' %}
  {% set hLight = sec.data.text_color and sec.data.text_color != '#ffffff' %}
  <section class="hero hero-{{ hLayout }}" style="background:{{ sec.data.bg_color or '#6366f1' }};color:{{ sec.data.text_color or '#ffffff' }};" id="hero">
    <div class="container">

      {% if hLayout == 'split' %}
      {# ────── SPLIT LAYOUT ────── #}
      <div class="hero-split-grid">
        <div class="hero-split-text">
          <div class="hero-badge {% if hLight %}badge-light{% endif %}">✦ New — See what's possible</div>
          <h1>{{ sec.data.headline or 'Your Vision, Delivered' }}</h1>
          <p class="hero-p">{{ sec.data.subheadline or '' }}</p>
          <div class="hero-btns">
            {% if sec.data.cta_label %}
            <a href="{{ sec.data.cta_url or '#' }}" class="btn-primary" style="background:{{ sec.data.text_color or '#111827' }};color:{{ sec.data.bg_color or '#fff' }};">{{ sec.data.cta_label }}</a>
            {% endif %}
            {% if sec.data.cta2_label %}
            <a href="{{ sec.data.cta2_url or '#' }}" class="btn-outline-hero {% if hLight %}dark-outline{% endif %}">{{ sec.data.cta2_label }}</a>
            {% endif %}
          </div>
        </div>
        <div class="hero-split-img">
          <div class="hero-split-card">
            {# Person right – purple gradient #}
            <div class="hero-split-inner">
              <svg viewBox="0 0 200 340" xmlns="http://www.w3.org/2000/svg" style="position:absolute;bottom:0;width:100%;height:100%;">
                <ellipse cx="100" cy="90" rx="50" ry="54" fill="rgba(255,255,255,.38)"/>
                <path d="M0 340 Q100 190 200 340 Z" fill="rgba(255,255,255,.24)"/>
              </svg>
            </div>
            {# Person left – orange gradient #}
            <div class="hero-split-inner2">
              <svg viewBox="0 0 180 300" xmlns="http://www.w3.org/2000/svg" style="position:absolute;bottom:0;width:100%;height:100%;">
                <ellipse cx="90" cy="82" rx="46" ry="50" fill="rgba(255,255,255,.38)"/>
                <path d="M0 300 Q90 165 180 300 Z" fill="rgba(255,255,255,.24)"/>
              </svg>
            </div>
          </div>
          {# Floating stat card #}
          <div class="hero-float-card hfc-stat">
            <div class="s-lbl">Monthly Users</div>
            <div class="s-num">100M+</div>
            <div class="s-pct">↑ 24% this month</div>
          </div>
          {# Floating chart card #}
          <div class="hero-float-card hfc-chart">
            <div class="hfc-chart-head">
              <div class="hfc-icon">📈</div>
              <div>
                <div class="hfc-chart-lbl">Revenue</div>
                <div class="hfc-chart-val">$48,294</div>
              </div>
            </div>
            <div class="hfc-bars">
              <span style="height:35%;"></span>
              <span style="height:55%;"></span>
              <span style="height:42%;"></span>
              <span style="height:68%;"></span>
              <span style="height:58%;"></span>
              <span style="height:84%;"></span>
              <span style="height:72%;"></span>
              <span style="height:96%;"></span>
            </div>
          </div>
        </div>
      </div>

      {% else %}
      {# ────── CENTERED LAYOUT ────── #}
      <div class="hero-badge {% if hLight %}badge-light{% endif %}">✦ Introducing Our Platform</div>
      <h1>{{ sec.data.headline or 'Welcome' }}</h1>
      {% if sec.data.subheadline %}<p>{{ sec.data.subheadline }}</p>{% endif %}
      <div class="hero-btns">
        {% if sec.data.cta_label %}
        <a href="{{ sec.data.cta_url or '#' }}" class="btn-primary" style="background:{{ sec.data.text_color or '#fff' }};color:{{ sec.data.bg_color or '#6366f1' }};">{{ sec.data.cta_label }}</a>
        {% endif %}
        {% if sec.data.cta2_label %}
        <a href="{{ sec.data.cta2_url or '#' }}" class="btn-outline-hero {% if hLight %}dark-outline{% endif %}">{{ sec.data.cta2_label }}</a>
        {% endif %}
      </div>
      {# Browser / dashboard mockup visual #}
      <div class="hero-visual">
        <div class="hero-browser">
          <div class="hero-browser-chrome">
            <span></span><span></span><span></span>
            <div class="hero-browser-url"></div>
          </div>
          <div class="hero-browser-body">
            {# Person left – purple #}
            <div class="hero-person hero-person-l">
              <svg viewBox="0 0 170 200" xmlns="http://www.w3.org/2000/svg" style="position:absolute;bottom:0;width:100%;height:100%;">
                <ellipse cx="85" cy="64" rx="42" ry="46" fill="rgba(255,255,255,.4)"/>
                <path d="M0 200 Q85 112 170 200 Z" fill="rgba(255,255,255,.26)"/>
              </svg>
            </div>
            {# Chart area #}
            <div class="hero-chart-area">
              <div class="hero-chart-label">Performance Overview</div>
              <div class="hero-chart-bars">
                <span style="height:42%;"></span>
                <span style="height:62%;"></span>
                <span style="height:50%;"></span>
                <span style="height:80%;"></span>
                <span style="height:60%;"></span>
                <span style="height:90%;"></span>
                <span style="height:74%;"></span>
                <span style="height:96%;"></span>
                <span style="height:68%;"></span>
                <span style="height:100%;"></span>
              </div>
            </div>
            {# Person right – orange #}
            <div class="hero-person hero-person-r">
              <svg viewBox="0 0 170 200" xmlns="http://www.w3.org/2000/svg" style="position:absolute;bottom:0;width:100%;height:100%;">
                <ellipse cx="85" cy="64" rx="42" ry="46" fill="rgba(255,255,255,.4)"/>
                <path d="M0 200 Q85 112 170 200 Z" fill="rgba(255,255,255,.26)"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
      {% endif %}

    </div>
  </section>

  {# ── ABOUT ── #}
  {% elif sec.type == 'about' %}
  <section class="section">
    <div class="container">
      <div class="about-grid {{ 'img-left' if sec.data.layout == 'image_left' }}">
        {% if sec.data.image %}
        <div class="about-img"><img src="{{ sec.data.image }}" alt="{{ sec.data.heading or 'About' }}"></div>
        {% elif sec.data.layout != 'full_text' %}
        <div class="about-img">🏢</div>
        {% endif %}
        <div class="about-text">
          <h2>{{ sec.data.heading or 'About Us' }}</h2>
          <p>{{ sec.data.text }}</p>
        </div>
      </div>
    </div>
  </section>

  {# ── SERVICES ── #}
  {% elif sec.type == 'services' %}
  <section class="section section-alt">
    <div class="container">
      <div class="section-heading"><h2>{{ sec.data.heading or 'Our Services' }}</h2></div>
      <div class="services-grid">
        {% for item in sec.data.items %}
        <div class="service-card">
          <div class="service-icon">{{ item.icon or '⚡' }}</div>
          <div class="service-title">{{ item.title }}</div>
          <div class="service-desc">{{ item.desc }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── GALLERY ── #}
  {% elif sec.type == 'gallery' %}
  <section class="section">
    <div class="container">
      {% if sec.data.heading %}<div class="section-heading"><h2>{{ sec.data.heading }}</h2></div>{% endif %}
      {% set gCols = sec.data.columns or 'auto' %}
      {% set gAspect = sec.data.aspect or '4/3' %}
      {% set gColStyle = 'repeat(auto-fill,minmax(240px,1fr))' if gCols == 'auto' else ('repeat(' + gCols + ',1fr)') %}
      <div class="gallery-grid" style="grid-template-columns:{{ gColStyle }};">
        {% for img in sec.data.images %}
        {% if img %}
        <div class="gallery-item" style="aspect-ratio:{{ gAspect }};" onclick="pzOpenLb(this)">
          <img src="{{ img }}" alt="Gallery image" loading="lazy" data-src="{{ img }}">
        </div>
        {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── TESTIMONIALS ── #}
  {% elif sec.type == 'testimonials' %}
  <section class="section section-alt">
    <div class="container">
      <div class="section-heading"><h2>{{ sec.data.heading or 'What Clients Say' }}</h2></div>
      <div class="testimonials-grid">
        {% for item in sec.data.items %}
        <div class="testi-card">
          <div class="testi-quote">"{{ item.quote }}"</div>
          <div class="testi-author">
            <div class="testi-avatar">{{ item.name[0] | upper if item.name else '?' }}</div>
            <div><div class="testi-name">{{ item.name }}</div><div class="testi-role">{{ item.role }}</div></div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── TEAM ── #}
  {% elif sec.type == 'team' %}
  <section class="section">
    <div class="container">
      <div class="section-heading"><h2>{{ sec.data.heading or 'Meet the Team' }}</h2></div>
      <div class="team-grid">
        {% for item in sec.data.items %}
        <div class="team-card">
          <div class="team-photo">
            {% if item.image %}<img src="{{ item.image }}" alt="{{ item.name }}">{% else %}👤{% endif %}
          </div>
          <div class="team-name">{{ item.name }}</div>
          <div class="team-role">{{ item.role }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── FAQ ── #}
  {% elif sec.type == 'faq' %}
  <section class="section section-alt">
    <div class="container">
      <div class="section-heading"><h2>{{ sec.data.heading or 'FAQ' }}</h2></div>
      <div class="faq-list">
        {% for item in sec.data.items %}
        <div class="faq-item" onclick="this.classList.toggle('open')">
          <div class="faq-q">{{ item.q }}</div>
          <div class="faq-a"><div class="faq-a-inner">{{ item.a }}</div></div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── CTA BANNER ── #}
  {% elif sec.type == 'cta' %}
  <section class="cta-banner" style="background:{{ sec.data.bg_color or '#111827' }};color:{{ sec.data.text_color or '#ffffff' }};">
    <div class="container">
      <h2>{{ sec.data.heading }}</h2>
      {% if sec.data.subheading %}<p>{{ sec.data.subheading }}</p>{% endif %}
      {% if sec.data.cta_label %}
      <a href="{{ sec.data.cta_url or '#' }}" class="btn-primary" style="background:{{ sec.data.text_color or '#fff' }};color:{{ sec.data.bg_color or '#111' }};">{{ sec.data.cta_label }}</a>
      {% endif %}
    </div>
  </section>

  {# ── CONTACT ── #}
  {% elif sec.type == 'contact' %}
  <section class="section">
    <div class="container">
      <div class="section-heading"><h2>{{ sec.data.heading or 'Get in Touch' }}</h2></div>
      <div class="contact-grid">
        <div class="contact-info">
          {% if sec.data.email %}
          <div class="contact-item">
            <div class="contact-item-icon">✉️</div>
            <div><div class="contact-item-label">Email</div><div class="contact-item-text">{{ sec.data.email }}</div></div>
          </div>
          {% endif %}
          {% if sec.data.phone %}
          <div class="contact-item">
            <div class="contact-item-icon">📞</div>
            <div><div class="contact-item-label">Phone</div><div class="contact-item-text">{{ sec.data.phone }}</div></div>
          </div>
          {% endif %}
          {% if sec.data.address %}
          <div class="contact-item">
            <div class="contact-item-icon">📍</div>
            <div><div class="contact-item-label">Address</div><div class="contact-item-text">{{ sec.data.address }}</div></div>
          </div>
          {% endif %}
        </div>
        <form class="contact-form" onsubmit="submitContact(event,this)">
          <input class="cf-input" name="name" placeholder="Your Name" required>
          <input class="cf-input" name="email" type="email" placeholder="Email Address" required>
          <input class="cf-input" name="phone" placeholder="Phone Number">
          <textarea class="cf-input cf-textarea" name="message" placeholder="Your message…"></textarea>
          <button type="submit" class="cf-submit">Send Message →</button>
          <p id="cf-success" style="display:none;text-align:center;color:green;font-size:14px;font-weight:600;">✓ Message sent! We'll be in touch soon.</p>
        </form>
      </div>
    </div>
  </section>

  {# ── PRICING ── #}
  {% elif sec.type == 'pricing' %}
  <section class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <h2>{{ sec.data.heading or 'Our Pricing' }}</h2>
        {% if sec.data.subtitle %}<p>{{ sec.data.subtitle }}</p>{% endif %}
      </div>
      <div class="pricing-grid">
        {% for plan in sec.data.plans %}
        <div class="pricing-card {{ 'featured' if plan.featured == 'yes' }}">
          <div class="pricing-name">{{ plan.name }}</div>
          <div class="pricing-price">{{ plan.price }}</div>
          <ul class="pricing-features">
            {% for feat in plan.features.split('\n') %}{% if feat %}<li>{{ feat }}</li>{% endif %}{% endfor %}
          </ul>
          {% if plan.cta %}<a href="{{ plan.link or '#' }}" class="pricing-cta">{{ plan.cta }}</a>{% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── STATS ── #}
  {% elif sec.type == 'stats' %}
  <section class="section">
    <div class="container">
      {% if sec.data.heading %}<div class="section-heading"><h2>{{ sec.data.heading }}</h2></div>{% endif %}
      <div class="stats-grid">
        {% for item in sec.data.items %}
        <div class="stat-item">
          {% if item.emoji %}<div class="stat-emoji">{{ item.emoji }}</div>{% endif %}
          <div class="stat-number">{{ item.number }}</div>
          <div class="stat-label">{{ item.label }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── RICH TEXT ── #}
  {% elif sec.type == 'rich_text' %}
  <section class="section">
    <div class="container">
      <div class="rich-text-block {{ 'center' if sec.data.align == 'center' }}">
        {% if sec.data.title %}<h2>{{ sec.data.title }}</h2>{% endif %}
        <div class="rtb-content">{{ sec.data.content }}</div>
      </div>
    </div>
  </section>

  {# ── COLUMNS ── #}
  {% elif sec.type == 'columns' %}
  {% set colBgClass = 'section-alt' if sec.data.bg == 'light' else '' %}
  <section class="section {{ colBgClass }}"{% if sec.data.bg == 'accent' %} style="background:var(--primary);color:#fff;"{% endif %}>
    <div class="container">
      {% if sec.data.heading %}<div class="section-heading"><h2>{{ sec.data.heading }}</h2></div>{% endif %}
      <div class="columns-grid cols-{{ sec.data.cols or '3' }}">
        {% for item in sec.data.items %}
        <div class="col-item">
          {% if item.emoji %}<div class="col-item-icon">{{ item.emoji }}</div>{% endif %}
          {% if item.heading %}<div class="col-item-heading">{{ item.heading }}</div>{% endif %}
          {% if item.text %}<div class="col-item-text">{{ item.text }}</div>{% endif %}
          {% if item.btn_text %}<a href="{{ item.btn_link or '#' }}" class="col-item-btn">{{ item.btn_text }}</a>{% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── VIDEO ── #}
  {% elif sec.type == 'video' %}
  <section class="section">
    <div class="container">
      {% if sec.data.heading %}<div class="section-heading"><h2>{{ sec.data.heading }}</h2></div>{% endif %}
      <div class="video-wrap">
        {% if sec.data.embed_url %}
        <div class="video-embed">
          <iframe src="{{ sec.data.embed_url }}" allowfullscreen loading="lazy"></iframe>
        </div>
        {% endif %}
        {% if sec.data.caption %}<div class="video-caption">{{ sec.data.caption }}</div>{% endif %}
      </div>
    </div>
  </section>

  {# ── LOGO BAR ── #}
  {% elif sec.type == 'logobar' %}
  <section class="section section-alt">
    <div class="container">
      {% if sec.data.heading %}<div class="section-heading"><h2>{{ sec.data.heading }}</h2></div>{% endif %}
      <div class="logo-bar">
        {% for logo in sec.data.logos %}
        <div class="logo-item">
          {% if logo.url %}<img src="{{ logo.url }}" alt="{{ logo.alt or '' }}">
          {% else %}<span class="logo-item-text">{{ logo.alt or 'Company' }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── TIMELINE ── #}
  {% elif sec.type == 'timeline' %}
  <section class="section">
    <div class="container">
      <div class="section-heading"><h2>{{ sec.data.heading or 'How It Works' }}</h2></div>
      <div class="timeline">
        {% for item in sec.data.items %}
        <div class="tl-item">
          <div class="tl-line">
            <div class="tl-dot">{{ item.step or loop.index }}</div>
            <div class="tl-connector"></div>
          </div>
          <div class="tl-content">
            <div class="tl-title">{{ item.title }}</div>
            {% if item.desc %}<div class="tl-desc">{{ item.desc }}</div>{% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ── NEWSLETTER ── #}
  {% elif sec.type == 'newsletter' %}
  <section class="section section-alt">
    <div class="container">
      <div class="newsletter-wrap">
        <h2>{{ sec.data.heading or 'Stay in the Loop' }}</h2>
        {% if sec.data.subtext %}<p>{{ sec.data.subtext }}</p>{% endif %}
        <form class="newsletter-form" onsubmit="return false;">
          <input class="nl-input" type="email" placeholder="{{ sec.data.placeholder or 'Enter your email' }}" required>
          <button type="submit" class="nl-btn">{{ sec.data.cta or 'Subscribe' }}</button>
        </form>
      </div>
    </div>
  </section>

  {% endif %}
{% endfor %}

<!-- Footer -->
<footer>
  <div class="container">
    <p>© {{ website.title }} {% if website.settings.tagline %}— {{ website.settings.tagline }}{% endif %}</p>
    <p style="margin-top:8px;font-size:11px;">Powered by <a href="/">PageZaper</a></p>
  </div>
</footer>

<!-- Gallery lightbox -->
<div id="pzLb" onclick="if(event.target===this)pzCloseLb()">
  <img id="pzLbImg" src="" alt="">
  <button id="pzLbClose" onclick="pzCloseLb()">×</button>
  <button id="pzLbPrev" onclick="pzLbNav(-1)">‹</button>
  <button id="pzLbNext" onclick="pzLbNav(1)">›</button>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="/themes/website/{{ activeTheme }}/theme.js"></script>
<script>
function submitContact(e, form){
  e.preventDefault();
  document.getElementById('cf-success').style.display = 'block';
  form.reset();
}

// ── Gallery lightbox ──────────────────────────────────────────────────────────
var _lbItems = [], _lbIdx = 0;
function pzOpenLb(el) {
  var items = Array.from(el.closest('.gallery-grid').querySelectorAll('.gallery-item img'));
  _lbItems = items.map(function(i){ return i.getAttribute('data-src') || i.src; });
  _lbIdx   = items.indexOf(el.querySelector('img'));
  if (_lbIdx < 0) _lbIdx = 0;
  _lbShow();
}
function _lbShow() {
  var lb = document.getElementById('pzLb');
  var img = document.getElementById('pzLbImg');
  var prev = document.getElementById('pzLbPrev');
  var next = document.getElementById('pzLbNext');
  if (!lb || !img) return;
  img.src = _lbItems[_lbIdx] || '';
  lb.style.display = 'flex';
  if (prev) prev.style.display = _lbItems.length > 1 ? '' : 'none';
  if (next) next.style.display = _lbItems.length > 1 ? '' : 'none';
}
function pzCloseLb() {
  var lb = document.getElementById('pzLb');
  if (lb) lb.style.display = 'none';
}
function pzLbNav(dir) {
  _lbIdx = (_lbIdx + dir + _lbItems.length) % _lbItems.length;
  _lbShow();
}
document.addEventListener('keydown', function(e) {
  var lb = document.getElementById('pzLb');
  if (!lb || lb.style.display === 'none') return;
  if (e.key === 'Escape') pzCloseLb();
  if (e.key === 'ArrowLeft')  pzLbNav(-1);
  if (e.key === 'ArrowRight') pzLbNav(1);
});
</script>
</body>
</html>

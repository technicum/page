{% extends "layouts/auth.njk" %}
{% block content %}
<div class="card">
  <h1>Create account</h1>
  <p>Build your mini site in minutes.</p>
  {% if errors and errors.length %}
  <ul class="errors">{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
  {% endif %}
  <form method="POST" action="/register">
    <div class="field"><label>Full name</label><input type="text" name="name" value="{{ old.name if old else "" }}" placeholder="Abhi Singh" required></div>
    <div class="field"><label>Email address</label><input type="email" name="email" value="{{ old.email if old else "" }}" placeholder="you@example.com" required></div>
    <div class="field"><label>Password</label><input type="password" name="password" placeholder="Min. 6 characters" required></div>
    <button class="btn" type="submit">Create account</button>
  </form>
</div>
<div class="footer-link">Already have an account? <a href="/login">Sign in</a></div>
{% endblock %}
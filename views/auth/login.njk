{% extends "layouts/auth.njk" %}
{% block content %}
<div class="card">
  <h1>Welcome back</h1>
  <p>Sign in to manage your sites.</p>
  {% if errors and errors.length %}
  <ul class="errors">{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
  {% endif %}
  <form method="POST" action="/login">
    <div class="field"><label>Email address</label><input type="email" name="email" value="{{ old.email if old else "" }}" placeholder="you@example.com" required></div>
    <div class="field"><label>Password</label><input type="password" name="password" placeholder="Your password" required></div>
    <button class="btn" type="submit">Sign in</button>
  </form>
</div>
<div class="footer-link">Don't have an account? <a href="/register">Create one free</a></div>
{% endblock %}
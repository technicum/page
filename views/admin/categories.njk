var EP_ALL = (function(){ var a=[]; EP_CATS.forEach(function(c){a=a.concat(c.list);}); return a; })();
var _epInput=null,_epBtn=null,_epCatIdx=-1,_epCurList=EP_ALL;

function epOpen(inputId, btnId, triggerEl) {
  var pk = document.getElementById('emojiPicker');
  if (_epInput === inputId && pk.classList.contains('open')) { epClose(); return; }
  _epInput = inputId; _epBtn = btnId; _epCatIdx = -1;
  document.getElementById('epSearch').value = '';
  epBuildCats();
  epRender(EP_ALL);
  var rect = triggerEl.getBoundingClientRect();
  pk.style.position = 'fixed';
  pk.style.top  = (rect.bottom + 6) + 'px';
  pk.style.left = Math.min(rect.left, window.innerWidth - 316) + 'px';
  pk.classList.add('open');
}
function epClose() {
  document.getElementById('emojiPicker').classList.remove('open');
  _epInput = null; _epBtn = null;
}
function epPick(idx) {
  if (!_epInput) return;
  var e = _epCurList[idx][0];
  document.getElementById(_epInput).value = e;
  document.getElementById(_epBtn).textContent = e;
  epClose();
}
function epFilter(q) {
  _epCatIdx = -1;
  epBuildCats();
  var src = q ? EP_ALL.filter(function(item){ return item[1].indexOf(q.toLowerCase()) !== -1 || item[0] === q; }) : EP_ALL;
  epRender(src);
}
function epCat(i) {
  _epCatIdx = i;
  document.getElementById('epSearch').value = '';
  epBuildCats();
  epRender(i === -1 ? EP_ALL : EP_CATS[i].list);
}
function epBuildCats() {
  var html = '<button class="ep-cat'+(_epCatIdx===-1?' active':'')+'" onclick="epCat(-1)">All</button>';
  EP_CATS.forEach(function(c, i){
    html += '<button class="ep-cat'+(_epCatIdx===i?' active':'')+'" onclick="epCat('+i+')">'+c.icon+'</button>';
  });
  document.getElementById('epCats').innerHTML = html;
}
function epRender(list) {
  _epCurList = list;
  if (!list || !list.length) {
    document.getElementById('epGrid').innerHTML = '<div class="ep-none">No emoji found</div>';
    return;
  }
  document.getElementById('epGrid').innerHTML = list.map(function(item, i){
    return '<button type="button" class="ep-btn" title="'+item[1]+'" onclick="epPick('+i+')">'+item[0]+'</button>';
  }).join('');
}
document.addEventListener('click', function(e){
  var pk = document.getElementById('emojiPicker');
  if (!pk.classList.contains('open')) return;
  if (e.target.closest('#emojiPicker') || e.target.closest('.ep-trigger')) return;
  epClose();
});
/* ── End Emoji Picker ─────────────────────────────────── */

function openEdit(id, icon, name, desc, order, status) {
  document.getElementById('editId').value     = id;
  document.getElementById('editIcon').value   = icon;
  document.getElementById('editIconBtn').textContent = icon || '🏢';
  document.getElementById('editName').value   = name;
  document.getElementById('editDesc').value   = desc || '';
  document.getElementById('editOrder').value  = order;
  document.getElementById('editStatus').value = status ? '1' : '0';
  document.getElementById('editModal').classList.add('open');
}
function closeEdit() {
  document.getElementById('editModal').classList.remove('open');
}
document.getElementById('editModal').addEventListener('click', function(e) {
  if (e.target === this) closeEdit();
});
</script>
{% endblock %}

{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{background:var(--off);}
.layout{display:flex;min-height:100vh;}
.sidebar{width:220px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh;}
.sidebar-logo{font-family:"DM Serif Display",serif;font-size:18px;padding:24px 20px;border-bottom:1px solid var(--border);text-decoration:none;color:var(--ink);display:block;}
.sidebar-logo em{font-style:italic;color:var(--red);}
.sidebar-nav{padding:16px 12px;flex:1;}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:var(--radius);font-size:14px;color:var(--ink-muted);text-decoration:none;transition:all 0.15s;margin-bottom:2px;font-weight:500;}
.nav-item:hover{background:var(--off);color:var(--ink);}
.nav-item.active{background:var(--red-light);color:var(--red);font-weight:600;}
.sidebar-bottom{padding:16px 12px;border-top:1px solid var(--border);}
.main{flex:1;overflow-y:auto;padding:40px;}
.page-header{margin-bottom:32px;}
.page-header h1{font-size:26px;font-weight:700;color:var(--ink);}
.page-header p{color:var(--ink-muted);font-size:14px;margin-top:4px;}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px;margin-bottom:40px;}
.stat-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;text-align:center;}
.stat-num{font-size:40px;font-weight:700;color:var(--ink);line-height:1;}
.stat-label{font-size:13px;color:var(--ink-muted);margin-top:6px;}
.quick-links{display:flex;gap:12px;flex-wrap:wrap;}
.ql-btn{display:inline-flex;align-items:center;gap:8px;padding:12px 20px;border-radius:var(--radius);background:var(--white);border:1px solid var(--border);font-size:14px;color:var(--ink);text-decoration:none;font-weight:500;transition:all 0.15s;}
.ql-btn:hover{background:var(--off);border-color:var(--border-md);}
</style>
{% endblock %}
{% block body %}
<div class="layout">
  <aside class="sidebar">
    <a class="sidebar-logo" href="/admin">⚙️ <em>Admin</em></a>
    <nav class="sidebar-nav">
      <a class="nav-item active" href="/admin">🏠 Dashboard</a>
      <a class="nav-item" href="/admin/themes">🎨 Themes</a>
      <a class="nav-item" href="/admin/users">👤 Users</a>
      <a class="nav-item" href="/dashboard">← Back to App</a>
    </nav>
    <div class="sidebar-bottom">
      <span style="font-size:12px;color:var(--ink-faint);">{{ user.name }}</span>
    </div>
  </aside>
  <main class="main">
    <div class="page-header">
      <h1>Admin Dashboard</h1>
      <p>Overview of your PageZapper instance.</p>
    </div>
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-num">{{ userCount }}</div>
        <div class="stat-label">Total Users</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{{ siteCount }}</div>
        <div class="stat-label">Total Sites</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{{ themeCount }}</div>
        <div class="stat-label">Themes Installed</div>
      </div>
    </div>
    <div class="quick-links">
      <a class="ql-btn" href="/admin/themes">🎨 Manage Themes</a>
      <a class="ql-btn" href="/admin/users">👤 Manage Users</a>
      <a class="ql-btn" href="/debug">🔧 Debug Info</a>
    </div>
  </main>
</div>
{% endblock %}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Review {{ site.title }} | PageZaper</title>
<meta name="robots" content="noindex">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1a18;--ink-muted:#6b6b66;--ink-faint:#b0afa8;
  --white:#fff;--off:#f8f7f4;--paper:#f2f0eb;
  --border:rgba(26,26,24,0.1);--border-md:rgba(26,26,24,0.18);
  --blue:#2563eb;--blue-light:#eff4ff;
  --green:#16a34a;--green-light:#f0fdf4;
  --red:#dc2626;--red-light:#fef2f2;
  --amber:#f59e0b;
  --radius-sm:8px;--radius-md:12px;--radius-lg:18px;
}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);min-height:100vh;}
nav{background:var(--white);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-family:'DM Serif Display',serif;font-size:19px;color:var(--ink);text-decoration:none;}
.logo em{font-style:italic;color:var(--blue);}

.page{max-width:560px;margin:40px auto;padding:0 16px 60px;}

/* ── Business card ── */
.biz-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;display:flex;align-items:center;gap:16px;margin-bottom:24px;}
.biz-icon{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;background:var(--off);flex-shrink:0;}
.biz-logo{width:56px;height:56px;border-radius:50%;object-fit:cover;flex-shrink:0;}
.biz-name{font-size:17px;font-weight:600;color:var(--ink);margin-bottom:2px;}
.biz-cat{font-size:13px;color:var(--ink-muted);}
.biz-rating-row{display:flex;align-items:center;gap:8px;margin-top:6px;}
.biz-stars{color:var(--amber);font-size:14px;letter-spacing:1px;}
.biz-rating-text{font-size:12px;color:var(--ink-muted);}

/* ── Success banner ── */
.success-banner{background:var(--green-light);border:1px solid #bbf7d0;border-radius:var(--radius-md);padding:20px 24px;text-align:center;margin-bottom:24px;}
.success-banner .icon{font-size:36px;margin-bottom:8px;}
.success-banner h3{font-size:17px;font-weight:600;color:var(--green);margin-bottom:4px;}
.success-banner p{font-size:14px;color:#166534;}

/* ── Error banner ── */
.error-banner{background:var(--red-light);border:1px solid #fecaca;border-radius:var(--radius-md);padding:14px 18px;font-size:14px;color:var(--red);margin-bottom:20px;}

/* ── Form card ── */
.form-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:28px;}
.form-title{font-family:'DM Serif Display',serif;font-size:22px;font-weight:400;color:var(--ink);margin-bottom:4px;}
.form-sub{font-size:14px;color:var(--ink-muted);margin-bottom:24px;}

/* ── Star picker ── */
.star-label{font-size:13px;font-weight:500;color:var(--ink);margin-bottom:10px;display:block;}
.star-picker{display:flex;flex-direction:row-reverse;gap:4px;justify-content:flex-end;margin-bottom:24px;}
.star-picker input{display:none;}
.star-picker label{font-size:36px;color:#e5e7eb;cursor:pointer;transition:color 0.1s;line-height:1;}
.star-picker label:hover,
.star-picker label:hover ~ label,
.star-picker input:checked ~ label{color:var(--amber);}

/* ── Fields ── */
.field{margin-bottom:18px;}
.field label{display:block;font-size:13px;font-weight:500;color:var(--ink);margin-bottom:6px;}
.field label .opt{font-weight:400;color:var(--ink-faint);font-size:12px;}
.field input,.field textarea{width:100%;border:1.5px solid var(--border-md);border-radius:var(--radius-sm);padding:11px 14px;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--ink);outline:none;transition:border-color 0.2s;background:var(--white);}
.field input:focus,.field textarea:focus{border-color:var(--blue);}
.field textarea{resize:vertical;min-height:100px;line-height:1.6;}
.btn-submit{width:100%;background:var(--blue);color:#fff;border:none;padding:14px;border-radius:var(--radius-md);font-size:15px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background 0.2s;margin-top:4px;}
.btn-submit:hover{background:#1d4ed8;}

/* ── Existing reviews ── */
.reviews-section{margin-top:32px;}
.reviews-title{font-size:15px;font-weight:600;color:var(--ink);margin-bottom:16px;}
.review-item{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-md);padding:16px 18px;margin-bottom:12px;}
.review-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.review-author{font-size:14px;font-weight:500;color:var(--ink);}
.review-stars{color:var(--amber);font-size:13px;}
.review-date{font-size:11px;color:var(--ink-faint);margin-bottom:8px;}
.review-comment{font-size:13px;color:var(--ink-muted);line-height:1.6;}
.no-reviews{font-size:13px;color:var(--ink-faint);text-align:center;padding:24px;background:var(--white);border:1px solid var(--border);border-radius:var(--radius-md);}

/* ── Back link ── */
.back-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--ink-muted);text-decoration:none;margin-bottom:20px;}
.back-link:hover{color:var(--ink);}
</style>
</head>
<body>

<nav>
  <a class="logo" href="/">page<em>zaper</em></a>
</nav>

<div class="page">

  <a class="back-link" href="https://{{ site.subdomain }}.{{ base_domain }}" target="_blank">
    ← Back to {{ site.title }}
  </a>

  <!-- Business card -->
  <div class="biz-card">
    {% set logo = site.settings.logo or (site.settings.profile and site.settings.profile.avatar) %}
    {% if logo %}
      <img class="biz-logo" src="{{ logo }}" alt="{{ site.title }}">
    {% else %}
      <div class="biz-icon">{{ site.cat_icon or '🏪' }}</div>
    {% endif %}
    <div>
      <div class="biz-name">{{ site.title }}</div>
      <div class="biz-cat">{{ site.cat_name or 'Business' }}</div>
      {% if stats and stats.total %}
      <div class="biz-rating-row">
        <span class="biz-stars">
          {% for i in range(0, 5) %}{% if i < stats.avg_rating | round %}★{% else %}☆{% endif %}{% endfor %}
        </span>
        <span class="biz-rating-text">{{ stats.avg_rating }} · {{ stats.total }} review{{ 's' if stats.total != 1 }}</span>
      </div>
      {% endif %}
    </div>
  </div>

  <!-- Success state -->
  {% if submitted %}
  <div class="success-banner">
    <div class="icon">🎉</div>
    <h3>Thank you for your review!</h3>
    <p>Your feedback helps others find great businesses.</p>
  </div>
  {% endif %}

  <!-- Error banner -->
  {% if error == 'name' %}
  <div class="error-banner">⚠️ Please enter your name.</div>
  {% elif error == 'rating' %}
  <div class="error-banner">⚠️ Please select a star rating.</div>
  {% endif %}

  <!-- Review form (always shown so they can leave another) -->
  <div class="form-card">
    <div class="form-title">Leave a review</div>
    <div class="form-sub">Share your experience with {{ site.title }}</div>

    <form method="POST" action="/review/{{ site.subdomain }}">
      <span class="star-label">Your rating *</span>
      <div class="star-picker">
        <input type="radio" id="s5" name="rating" value="5"><label for="s5" title="Excellent">★</label>
        <input type="radio" id="s4" name="rating" value="4"><label for="s4" title="Good">★</label>
        <input type="radio" id="s3" name="rating" value="3"><label for="s3" title="Average">★</label>
        <input type="radio" id="s2" name="rating" value="2"><label for="s2" title="Poor">★</label>
        <input type="radio" id="s1" name="rating" value="1"><label for="s1" title="Terrible">★</label>
      </div>

      <div class="field">
        <label for="reviewer_name">Your name *</label>
        <input type="text" id="reviewer_name" name="reviewer_name" placeholder="e.g. Rahul S." required maxlength="100">
      </div>

      <div class="field">
        <label for="reviewer_email">Email <span class="opt">(optional, not shown publicly)</span></label>
        <input type="email" id="reviewer_email" name="reviewer_email" placeholder="your@email.com" maxlength="255">
      </div>

      <div class="field">
        <label for="comment">Your review <span class="opt">(optional)</span></label>
        <textarea id="comment" name="comment" placeholder="Tell others about your experience…" maxlength="1000"></textarea>
      </div>

      <button class="btn-submit" type="submit">Submit review →</button>
    </form>
  </div>

  <!-- Existing reviews -->
  {% if reviews.length %}
  <div class="reviews-section">
    <div class="reviews-title">{{ reviews.length }} review{{ 's' if reviews.length != 1 }} for {{ site.title }}</div>
    {% for r in reviews %}
    <div class="review-item">
      <div class="review-header">
        <span class="review-author">{{ r.reviewer_name }}</span>
        <span class="review-stars">
          {% for i in range(0, 5) %}{% if i < r.rating %}★{% else %}☆{% endif %}{% endfor %}
        </span>
      </div>
      <div class="review-date">{{ r.created_at | date('d MMM yyyy') }}</div>
      {% if r.comment %}<div class="review-comment">{{ r.comment }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

</div>
</body>
</html>

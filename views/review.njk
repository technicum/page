<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Review {{ site.title }} | PageZaper</title>
<meta name="robots" content="noindex">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1a18;--ink-muted:#6b6b66;--ink-faint:#b0afa8;
  --white:#fff;--off:#f8f7f4;--paper:#f2f0eb;
  --border:rgba(26,26,24,0.1);--border-md:rgba(26,26,24,0.18);
  --blue:#2563eb;--blue-light:#eff4ff;
  --green:#16a34a;--green-light:#f0fdf4;
  --red:#dc2626;--red-light:#fef2f2;
  --amber:#f59e0b;
  --radius-sm:8px;--radius-md:12px;--radius-lg:18px;
}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);min-height:100vh;}

/* ── Nav ── */
nav{background:var(--white);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
.logo{font-family:'DM Serif Display',serif;font-size:19px;color:var(--ink);text-decoration:none;}
.logo em{font-style:italic;color:var(--blue);}

/* ── Page ── */
.page{max-width:940px;margin:0 auto;padding:28px 20px 80px;}
.back-link{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--ink-muted);text-decoration:none;margin-bottom:18px;}
.back-link:hover{color:var(--ink);}

/* ── Business hero ── */
.biz-hero{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:24px;}
.biz-band{height:80px;background:linear-gradient(135deg,#1e3a8a 0%,#2563eb 100%);position:relative;}
.biz-avatar{width:62px;height:62px;border-radius:50%;background:var(--off);border:3px solid var(--white);display:flex;align-items:center;justify-content:center;font-size:28px;position:absolute;bottom:-26px;left:24px;overflow:hidden;}
.biz-logo-img{width:62px;height:62px;border-radius:50%;object-fit:cover;}
.biz-body{padding:34px 24px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;}
.biz-name{font-size:18px;font-weight:600;color:var(--ink);margin-bottom:2px;}
.biz-cat{font-size:13px;color:var(--ink-muted);}
.biz-stats{display:flex;gap:10px;}
.biz-stat{text-align:center;background:var(--off);border-radius:var(--radius-sm);padding:8px 16px;min-width:70px;}
.biz-stat-val{font-size:17px;font-weight:600;color:var(--ink);line-height:1.2;}
.biz-stat-lbl{font-size:10px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.04em;margin-top:1px;}

/* ── Flash banners ── */
.success-banner{background:var(--green-light);border:1px solid #bbf7d0;border-radius:var(--radius-md);padding:16px 20px;display:flex;align-items:center;gap:12px;margin-bottom:20px;font-size:14px;color:#166534;}
.success-banner .ico{font-size:22px;flex-shrink:0;}
.error-banner{background:var(--red-light);border:1px solid #fecaca;border-radius:var(--radius-sm);padding:12px 16px;font-size:13px;color:var(--red);margin-bottom:14px;}

/* ── Two-column layout ── */
.cols{display:grid;grid-template-columns:1fr 360px;gap:24px;align-items:start;}

/* ── Reviews column ── */
.reviews-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.reviews-hd-title{font-size:15px;font-weight:600;color:var(--ink);}
.rev-count-badge{font-size:12px;background:var(--blue-light);color:var(--blue);padding:3px 12px;border-radius:20px;font-weight:500;}
.no-reviews{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-md);padding:32px;text-align:center;}
.no-reviews p{font-size:13px;color:var(--ink-faint);}
.review-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-md);padding:16px 18px;margin-bottom:12px;}
.rc-head{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.rc-avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;flex-shrink:0;}
.rc-name{font-size:14px;font-weight:600;color:var(--ink);line-height:1.3;}
.rc-date{font-size:11px;color:var(--ink-faint);}
.rc-stars{margin-left:auto;color:var(--amber);font-size:14px;letter-spacing:1px;}
.rc-comment{font-size:13px;color:var(--ink-muted);line-height:1.65;padding-top:10px;border-top:1px solid var(--border);}

/* ── Form column (sticky) ── */
.form-col{position:sticky;top:72px;}
.form-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;}
.form-title{font-family:'DM Serif Display',serif;font-size:20px;font-weight:400;color:var(--ink);margin-bottom:3px;}
.form-sub{font-size:13px;color:var(--ink-muted);margin-bottom:20px;}

/* ── Star picker ── */
.star-section{text-align:center;margin-bottom:18px;}
.star-section-lbl{font-size:12px;font-weight:500;color:var(--ink-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;}
.star-row{display:flex;gap:4px;justify-content:center;margin-bottom:6px;}
.star-row input{display:none;}
.star-row label{font-size:34px;color:#e5e7eb;cursor:pointer;transition:color 0.1s;line-height:1;user-select:none;}
.star-row input:checked ~ label,
.star-row label:hover,
.star-row label:hover ~ label{color:var(--amber);}
.star-hint{font-size:12px;color:var(--ink-faint);min-height:18px;}

/* ── Form fields ── */
.field{margin-bottom:14px;}
.field label{display:block;font-size:12px;font-weight:500;color:var(--ink-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px;}
.field label .req{color:var(--red);font-size:12px;}
.field label .opt{font-weight:400;color:var(--ink-faint);text-transform:none;letter-spacing:0;font-size:11px;}
.field input,.field textarea{width:100%;border:1.5px solid var(--border-md);border-radius:var(--radius-sm);padding:10px 13px;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--ink);outline:none;transition:border-color 0.2s;background:var(--white);}
.field input:focus,.field textarea:focus{border-color:var(--blue);}
.field textarea{resize:vertical;min-height:88px;line-height:1.6;}
.btn-submit{width:100%;background:var(--blue);color:#fff;border:none;padding:13px;border-radius:var(--radius-md);font-size:14px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background 0.2s;margin-top:2px;}
.btn-submit:hover{background:#1d4ed8;}
.form-note{font-size:11px;color:var(--ink-faint);text-align:center;margin-top:10px;}

/* ── Mobile ── */
@media(max-width:700px){
  .cols{grid-template-columns:1fr;}
  .form-col{position:static;}
  .biz-body{flex-direction:column;align-items:flex-start;}
  .page{padding:20px 16px 60px;}
}
</style>
</head>
<body>

<nav>
  <a class="logo" href="/">page<em>zaper</em></a>
</nav>

<div class="page">

  <a class="back-link" href="https://{{ site.subdomain }}.{{ base_domain }}">
    ← Back to {{ site.title }}
  </a>

  <!-- Business hero -->
  <div class="biz-hero">
    <div class="biz-band"></div>
    {% set logo = site.settings.logo or (site.settings.profile and site.settings.profile.avatar) %}
    <div class="biz-avatar">
      {% if logo %}
        <img class="biz-logo-img" src="{{ logo }}" alt="{{ site.title }}"
          onerror="this.style.display='none';this.parentElement.textContent='{{ site.cat_icon or "🏪" }}'">
      {% else %}
        {{ site.cat_icon or '🏪' }}
      {% endif %}
    </div>
    <div class="biz-body">
      <div>
        <div class="biz-name">{{ site.title }}</div>
        <div class="biz-cat">{{ site.cat_name or 'Business' }}{% if site.settings.city %} · {{ site.settings.city }}{% endif %}</div>
      </div>
      {% if stats and stats.total %}
      <div class="biz-stats">
        <div class="biz-stat">
          <div class="biz-stat-val"><span style="color:var(--amber)">★</span> {{ stats.avg_rating }}</div>
          <div class="biz-stat-lbl">Avg rating</div>
        </div>
        <div class="biz-stat">
          <div class="biz-stat-val">{{ stats.total }}</div>
          <div class="biz-stat-lbl">Review{{ 's' if stats.total != 1 }}</div>
        </div>
      </div>
      {% endif %}
    </div>
  </div>

  <!-- Success banner -->
  {% if submitted %}
  <div class="success-banner">
    <span class="ico">🎉</span>
    <div>
      <strong>Thank you for your review!</strong><br>
      <span style="font-size:13px;">Your feedback helps others find great businesses.</span>
    </div>
  </div>
  {% endif %}

  <!-- Two-column layout -->
  <div class="cols">

    <!-- ── Left: reviews ── -->
    <div class="reviews-col">
      <div class="reviews-hd">
        <span class="reviews-hd-title">Reviews</span>
        {% if reviews.length %}
        <span class="rev-count-badge">{{ reviews.length }} review{{ 's' if reviews.length != 1 }}</span>
        {% endif %}
      </div>

      {% if reviews.length %}
        {% set avatarColors = [
          'background:#dbeafe;color:#1e40af',
          'background:#d1fae5;color:#065f46',
          'background:#fef3c7;color:#92400e',
          'background:#fce7f3;color:#9d174d',
          'background:#ede9fe;color:#4c1d95',
          'background:#ccfbf1;color:#134e4a'
        ] %}
        {% for r in reviews %}
        {% set ci = loop.index0 % 6 %}
        <div class="review-card">
          <div class="rc-head">
            <div class="rc-avatar" style="{{ avatarColors[ci] }}">{{ r.reviewer_name[0] | upper }}</div>
            <div>
              <div class="rc-name">{{ r.reviewer_name }}</div>
              <div class="rc-date">{{ r.created_at | date('d MMM yyyy') }}</div>
            </div>
            <div class="rc-stars">
              {% for i in range(0, 5) %}{% if i < r.rating %}★{% else %}☆{% endif %}{% endfor %}
            </div>
          </div>
          {% if r.comment %}<div class="rc-comment">{{ r.comment }}</div>{% endif %}
        </div>
        {% endfor %}
      {% else %}
      <div class="no-reviews">
        <p style="font-size:28px;margin-bottom:8px;">💬</p>
        <p>No reviews yet. Be the first to share your experience!</p>
      </div>
      {% endif %}
    </div>

    <!-- ── Right: form (sticky) ── -->
    <div class="form-col">

      <!-- Error banners -->
      {% if error == 'name' %}
      <div class="error-banner">⚠️ Please enter your name.</div>
      {% elif error == 'rating' %}
      <div class="error-banner">⚠️ Please select a star rating.</div>
      {% endif %}

      <div class="form-card">
        <div class="form-title">Write a review</div>
        <div class="form-sub">Share your experience with {{ site.title }}</div>

        <form method="POST" action="/review/{{ site.subdomain }}">

          <div class="star-section">
            <div class="star-section-lbl">Your rating <span style="color:var(--red)">*</span></div>
            <div class="star-row" id="starRow">
              <input type="radio" id="s5" name="rating" value="5"><label for="s5" title="Excellent">★</label>
              <input type="radio" id="s4" name="rating" value="4"><label for="s4" title="Good">★</label>
              <input type="radio" id="s3" name="rating" value="3"><label for="s3" title="Average">★</label>
              <input type="radio" id="s2" name="rating" value="2"><label for="s2" title="Poor">★</label>
              <input type="radio" id="s1" name="rating" value="1"><label for="s1" title="Terrible">★</label>
            </div>
            <div class="star-hint" id="starHint">Tap a star to rate</div>
          </div>

          <div class="field">
            <label>Your name <span class="req">*</span></label>
            <input type="text" name="reviewer_name" placeholder="e.g. Rahul S." required maxlength="100">
          </div>

          <div class="field">
            <label>Email <span class="opt">(optional, not shown publicly)</span></label>
            <input type="email" name="reviewer_email" placeholder="your@email.com" maxlength="255">
          </div>

          <div class="field">
            <label>Your review <span class="opt">(optional)</span></label>
            <textarea name="comment" placeholder="Tell others about your experience…" maxlength="1000"></textarea>
          </div>

          <button class="btn-submit" type="submit">Submit review →</button>
          <div class="form-note">Reviews are moderated before publishing.</div>
        </form>
      </div>
    </div>

  </div>
</div>

<script>
(function(){
  var hints = ['','Terrible','Poor','Okay','Good','Excellent'];
  var labels = document.querySelectorAll('#starRow label');
  var inputs = document.querySelectorAll('#starRow input');
  var hint   = document.getElementById('starHint');

  labels.forEach(function(lbl){
    lbl.addEventListener('mouseenter', function(){
      hint.textContent = lbl.title;
    });
    lbl.addEventListener('mouseleave', function(){
      var checked = document.querySelector('#starRow input:checked');
      hint.textContent = checked ? checked.title : 'Tap a star to rate';
    });
  });
  inputs.forEach(function(inp){
    inp.addEventListener('change', function(){
      hint.textContent = inp.nextElementSibling.title;
    });
  });
})();
</script>

</body>
</html>

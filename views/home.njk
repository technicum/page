<script>
(function() {
  var BASE       = '{{ base_domain }}'
  var nearLabel  = document.getElementById('near-city-label')
  var grid       = document.getElementById('nearby-grid')
  var seeAllLink = document.getElementById('see-all-link')

  // Location picker
  var hfCity    = document.getElementById('hf-city')
  var hfState   = document.getElementById('hf-state')
  var hfLat     = document.getElementById('hf-lat')
  var hfLng     = document.getElementById('hf-lng')
  var hlocWrap  = document.getElementById('hloc-wrap')
  var hlocDrop  = document.getElementById('hloc-drop')
  var hlocDisp  = document.getElementById('hloc-display')
  var hlocClear = document.getElementById('hloc-clear')
  var hlocGps   = document.getElementById('hloc-gps')
  var hlocInp   = document.getElementById('hloc-inp')
  var hlocRes   = document.getElementById('hloc-results')

  // ── Render nearby cards ───────────────────────────────────────────────────────
  function renderCards(results) {
    if (!results || !results.length) {
      grid.innerHTML = '<p style="color:var(--ink-faint);font-size:14px;padding:20px 0;">No businesses found near this location yet.</p>'
      return
    }
    var colors = ['var(--blue-light)','var(--green-light)','var(--amber-light)','var(--pink-light)']
    var badges = ['badge-blue','badge-green','badge-amber','badge-pink']
    grid.innerHTML = results.map(function(s, i) {
      var ci   = i % 4
      var icon = s.cat_icon     || '🏪'
      var cat  = s.cat_name     || 'Business'
      var loc  = s.city         || 'India'
      var desc = s.description  || (s.subdomain + '.' + BASE)
      var dist = s.distance_km  ? '<span style="font-size:11px;color:var(--blue);margin-left:4px;">· ' + s.distance_km + ' km</span>' : ''
      return '<a class="provider-card" href="https://' + s.subdomain + '.' + BASE + '" target="_blank">' +
        '<div class="card-icon-wrap" style="background:' + colors[ci] + ';">' + icon + '</div>' +
        '<span class="card-badge ' + badges[ci] + '">' + cat + '</span>' +
        '<div class="card-name">' + s.title + '</div>' +
        '<div class="card-desc">' + desc + '</div>' +
        '<div class="card-location"><svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>' + loc + dist + '</div>' +
        '</a>'
    }).join('')
  }

  function loadNearby(city, lat, lng) {
    var url = '/api/nearby?city=' + encodeURIComponent(city || '')
    if (lat && lng) url += '&lat=' + lat + '&lng=' + lng + '&radius=25'
    fetch(url).then(function(r){return r.json()}).then(function(d){renderCards(d.results)}).catch(function(){renderCards([])})
  }

  // ── Set location (updates display, hidden fields, nearby cards, quick-tags) ──
  function setLocation(opts) {
    hfCity.value  = opts.city  || ''
    hfState.value = opts.state || ''
    hfLat.value   = opts.lat  != null ? opts.lat  : ''
    hfLng.value   = opts.lng  != null ? opts.lng  : ''

    var label = opts.label || opts.city || opts.state || 'All India'
    hlocDisp.textContent = label
    hlocDisp.classList.toggle('has-val', !!(opts.city || opts.state || opts.lat))
    hlocClear.classList.toggle('show',   !!(opts.city || opts.state || opts.lat))

    nearLabel.textContent = opts.city || opts.state || 'you'
    var seeUrl = '/search?city=' + encodeURIComponent(opts.city||'') + '&state=' + encodeURIComponent(opts.state||'')
    if (opts.lat) seeUrl += '&lat=' + opts.lat + '&lng=' + opts.lng + '&radius=25'
    if (seeAllLink) seeAllLink.href = seeUrl

    document.querySelectorAll('#quick-tags .qtag').forEach(function(a) {
      var u = new URL(a.href, location.href)
      if (opts.city)  u.searchParams.set('city',  opts.city)
      if (opts.state) u.searchParams.set('state', opts.state)
      a.href = u.toString()
    })

    loadNearby(opts.city || '', opts.lat, opts.lng)
    closeDrop()
  }

  // ── Dropdown open/close ────────────────────────────────────────────────────
  function openDrop() {
    hlocDrop.classList.add('open')
    showPopular()
    hlocInp.value = ''
    setTimeout(function(){ hlocInp.focus() }, 60)
  }
  function closeDrop() { hlocDrop.classList.remove('open') }

  hlocWrap.addEventListener('click', function(e) {
    if (hlocClear.contains(e.target)) return
    if (hlocDrop.classList.contains('open')) { closeDrop(); return }
    openDrop()
  })
  hlocDrop.addEventListener('click', function(e){ e.stopPropagation() })
  document.addEventListener('click', function(e){ if (!hlocWrap.contains(e.target)) closeDrop() })

  // ── Clear button ───────────────────────────────────────────────────────────
  hlocClear.addEventListener('click', function(e) {
    e.stopPropagation()
    setLocation({ city:'', state:'', lat:null, lng:null, label:'All India' })
    hlocDisp.textContent = 'All India'
  })

  // ── Popular city chips ─────────────────────────────────────────────────────
  function showPopular() {
    hlocRes.innerHTML = document.getElementById('hloc-pop-tpl').innerHTML
    hlocRes.querySelectorAll('.pop-city-chip').forEach(function(c) {
      c.addEventListener('click', function() {
        setLocation({ label:c.dataset.city, city:c.dataset.city, state:c.dataset.state })
      })
    })
  }

  // Store popular HTML as template
  var popTpl = document.createElement('div')
  popTpl.id  = 'hloc-pop-tpl'
  popTpl.style.display = 'none'
  popTpl.innerHTML = hlocRes.innerHTML
  document.body.appendChild(popTpl)

  // Attach clicks to initial popular chips
  hlocRes.querySelectorAll('.pop-city-chip').forEach(function(c) {
    c.addEventListener('click', function() {
      setLocation({ label:c.dataset.city, city:c.dataset.city, state:c.dataset.state })
    })
  })

  // ── Autocomplete ────────────────────────────────────────────────────────────
  var sugTimer
  hlocInp.addEventListener('input', function() {
    clearTimeout(sugTimer)
    var q = this.value.trim()
    if (!q) { showPopular(); return }
    hlocRes.innerHTML = '<div class="loc-result-msg">Searching…</div>'
    sugTimer = setTimeout(function() {
      fetch('/api/location-suggest?q=' + encodeURIComponent(q))
        .then(function(r){ return r.json() })
        .then(function(list) {
          if (!list.length) { hlocRes.innerHTML = '<div class="loc-result-msg">No results for "' + q + '"</div>'; return }
          var seen = {}
          hlocRes.innerHTML = list.filter(function(r){
            if (seen[r.label]) return false; seen[r.label]=true; return true
          }).map(function(r) {
            var sub = (r.city && r.state) ? r.state : (r.type==='state' ? 'State' : '')
            return '<div class="loc-result-item" data-city="'+(r.city||'')+'" data-state="'+(r.state||'')+'" data-lat="'+r.lat+'" data-lng="'+r.lng+'">' +
              '<span style="font-size:16px">'+(r.type==='state'?'🗺️':'📍')+'</span>' +
              '<div><div class="loc-result-name">'+r.label+'</div>'+(sub?'<div class="loc-result-sub">'+sub+'</div>':'')+'</div></div>'
          }).join('')
          hlocRes.querySelectorAll('.loc-result-item').forEach(function(el) {
            el.addEventListener('click', function() {
              setLocation({
                label: el.querySelector('.loc-result-name').textContent,
                city:  el.dataset.city, state: el.dataset.state,
                lat:   parseFloat(el.dataset.lat)||null, lng: parseFloat(el.dataset.lng)||null
              })
            })
          })
        })
        .catch(function(){ hlocRes.innerHTML = '<div class="loc-result-msg">Could not load suggestions.</div>' })
    }, 300)
  })

  // ── GPS ─────────────────────────────────────────────────────────────────────
  hlocGps.addEventListener('click', function() {
    if (!navigator.geolocation) { alert('Geolocation not supported.'); return }
    hlocGps.querySelector('div').innerHTML = 'Detecting…<span class="loc-gps-sub">Allow location access</span>'
    navigator.geolocation.getCurrentPosition(
      function(pos) {
        var lat = pos.coords.latitude, lng = pos.coords.longitude
        fetch('/api/reverse-geocode?lat=' + lat + '&lng=' + lng)
          .then(function(r){ return r.json() })
          .then(function(d) {
            setLocation({ label: d.city||'Current location', city:d.city||'', state:d.state||'', lat:lat, lng:lng })
          })
          .catch(function(){ setLocation({ label:'Current location', city:'', state:'', lat:lat, lng:lng }) })
      },
      function() {
        hlocGps.querySelector('div').innerHTML = 'Use my current location<span class="loc-gps-sub">Precise results near you</span>'
        alert('Could not get location. Please allow access and try again.')
      },
      { timeout:10000 }
    )
  })

  // ── Auto-detect on load (IP-based, silent) ───────────────────────────────────
  fetch('/api/detect-city')
    .then(function(r){ return r.json() })
    .then(function(d) {
      if (d.city) setLocation({ label:d.city, city:d.city, state:d.region||'' })
      else { hlocDisp.textContent='All India'; loadNearby('') }
    })
    .catch(function(){ hlocDisp.textContent='All India'; loadNearby('') })
})()
</script>

{% endblock %}

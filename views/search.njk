{% extends "layouts/base.njk" %}
{% block head %}
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--ink:#1a1a18;--ink-muted:#6b6b66;--ink-faint:#b0afa8;--white:#fff;--off:#f8f7f4;--paper:#f2f0eb;--border:rgba(26,26,24,0.1);--border-md:rgba(26,26,24,0.18);--blue:#2563eb;--blue-light:#eff4ff;--blue-mid:#c7d9fd;--green-light:#ecfdf5;--green-dark:#065f46;--amber-light:#fffbeb;--amber-dark:#92400e;--pink-light:#fdf2f8;--pink-dark:#701a75;--radius-sm:8px;--radius-md:12px;--radius-lg:18px;}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);min-height:100vh;}
nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 40px;height:60px;display:flex;align-items:center;justify-content:space-between;gap:16px;}
.logo{font-family:'DM Serif Display',serif;font-size:20px;color:var(--ink);text-decoration:none;flex-shrink:0;}
.logo em{font-style:italic;color:var(--blue);}
.nav-search{flex:1;max-width:540px;display:flex;align-items:center;background:var(--off);border:1.5px solid var(--border-md);border-radius:40px;padding:7px 7px 7px 16px;gap:8px;transition:border-color 0.2s,box-shadow 0.2s;}
.nav-search:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);background:var(--white);}
.nav-search svg{color:var(--ink-faint);flex-shrink:0;}
.nav-q{flex:1;border:none;outline:none;font-size:14px;font-family:'DM Sans',sans-serif;color:var(--ink);background:transparent;min-width:0;}
.nav-sep{width:1px;height:22px;background:var(--border);flex-shrink:0;}
.nav-city{border:none;outline:none;font-size:13px;font-family:'DM Sans',sans-serif;color:var(--ink-muted);background:transparent;width:100px;min-width:0;}
.nav-city::placeholder{color:var(--ink-faint);}
.nav-btn{background:var(--blue);color:#fff;border:none;padding:8px 18px;border-radius:30px;font-size:13px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;white-space:nowrap;flex-shrink:0;}
.nav-btn:hover{background:#1d4ed8;}
.nav-user a{font-size:13px;color:var(--ink-muted);text-decoration:none;white-space:nowrap;}

.page-wrap{max-width:1100px;margin:0 auto;padding:32px 40px 80px;}
.results-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;}
.results-title{font-size:15px;color:var(--ink-muted);}
.results-title strong{color:var(--ink);}

/* Category filter pills */
.filter-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px;}
.filter-pill{font-size:13px;padding:6px 14px;border-radius:20px;border:1px solid var(--border-md);background:var(--white);color:var(--ink-muted);cursor:pointer;text-decoration:none;transition:all 0.18s;white-space:nowrap;}
.filter-pill:hover{border-color:var(--blue);color:var(--blue);}
.filter-pill.active{background:var(--blue);color:#fff;border-color:var(--blue);}

/* Cards */
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:16px;}
.provider-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 18px;cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;text-decoration:none;display:block;}
.provider-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,0.08);}
.card-icon-wrap{width:48px;height:48px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:14px;}
.card-badge{font-size:11px;font-weight:500;padding:3px 10px;border-radius:20px;display:inline-block;margin-bottom:10px;}
.badge-blue{background:var(--blue-light);color:#1d4ed8;}
.badge-green{background:var(--green-light);color:var(--green-dark);}
.badge-amber{background:var(--amber-light);color:var(--amber-dark);}
.badge-pink{background:var(--pink-light);color:var(--pink-dark);}
.card-name{font-size:15px;font-weight:500;color:var(--ink);margin-bottom:3px;}
.card-desc{font-size:12px;color:var(--ink-muted);margin-bottom:12px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;}
.card-location{font-size:12px;color:var(--ink-faint);display:flex;align-items:center;gap:4px;}

/* Empty state */
.empty{text-align:center;padding:80px 20px;}
.empty-icon{font-size:48px;margin-bottom:16px;}
.empty h2{font-family:'DM Serif Display',serif;font-size:24px;font-weight:400;color:var(--ink);margin-bottom:8px;}
.empty p{font-size:15px;color:var(--ink-muted);margin-bottom:24px;}
.btn-primary{background:var(--ink);color:#fff;border:none;padding:11px 24px;border-radius:var(--radius-md);font-size:14px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;display:inline-block;transition:opacity 0.2s;}
.btn-primary:hover{opacity:0.85;}

@media(max-width:768px){
  nav{padding:0 16px;gap:10px;}
  .page-wrap{padding:20px 16px 60px;}
  .cards-grid{grid-template-columns:repeat(2,1fr);}
  .nav-sep,.nav-city{display:none;}
}
</style>
{% endblock %}
{% block body %}

<nav>
  <a class="logo" href="/">page<em>zaper</em></a>
  <form class="nav-search" action="/search" method="GET">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input class="nav-q" type="text" name="q" value="{{ q }}" placeholder="Search businesses…" autocomplete="off">
    <div class="nav-sep"></div>
    <input class="nav-city" type="text" name="city" id="nav-city" value="{{ city }}" placeholder="City…" autocomplete="off">
    {% if category_id %}<input type="hidden" name="category_id" value="{{ category_id }}">{% endif %}
    <button class="nav-btn" type="submit">Search</button>
  </form>
  <div class="nav-user">
    {% if user %}<a href="/dashboard">Dashboard</a>{% else %}<a href="/register">Create site →</a>{% endif %}
  </div>
</nav>

<div class="page-wrap">

  <!-- Category filter pills -->
  <div class="filter-row">
    <a class="filter-pill {% if not category_id %}active{% endif %}"
       href="/search?q={{ q | urlencode }}&city={{ city | urlencode }}">All</a>
    {% for cat in categories %}
    <a class="filter-pill {% if category_id == cat.id | string %}active{% endif %}"
       href="/search?q={{ q | urlencode }}&city={{ city | urlencode }}&category_id={{ cat.id }}">
      {{ cat.icon }} {{ cat.name }}
    </a>
    {% endfor %}
  </div>

  <div class="results-header">
    <div class="results-title">
      {% if results.length %}
        <strong>{{ results.length }}</strong> result{{ 's' if results.length != 1 }}
        {% if q %} for <strong>"{{ q }}"</strong>{% endif %}
        {% if city %} near <strong>{{ city }}</strong>{% endif %}
      {% else %}
        No results
        {% if q %} for <strong>"{{ q }}"</strong>{% endif %}
        {% if city %} near <strong>{{ city }}</strong>{% endif %}
      {% endif %}
    </div>
    {% if city %}
    <a class="filter-pill" href="/search?q={{ q | urlencode }}">✕ Clear location</a>
    {% endif %}
  </div>

  {% if results.length %}
  <div class="cards-grid">
    {% for site in results %}
    {% set ci = loop.index0 % 4 %}
    {% set colors = ['var(--blue-light)','var(--green-light)','var(--amber-light)','var(--pink-light)'] %}
    {% set badges = ['badge-blue','badge-green','badge-amber','badge-pink'] %}
    <a class="provider-card" href="https://{{ site.subdomain }}.{{ base_domain }}" target="_blank">
      <div class="card-icon-wrap" style="background:{{ colors[ci] }};">{{ site.cat_icon or '🏪' }}</div>
      <span class="card-badge {{ badges[ci] }}">{{ site.cat_name or site.category or 'Business' }}</span>
      <div class="card-name">{{ site.title }}</div>
      <div class="card-desc">{{ site.settings.description or (site.subdomain + '.' + base_domain) }}</div>
      <div class="card-location">
        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {{ site.settings.city or 'India' }}
      </div>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <div class="empty">
    <div class="empty-icon">🔍</div>
    <h2>Nothing found yet</h2>
    <p>Try a different keyword or broaden your location.</p>
    <a class="btn-primary" href="/search">Clear filters</a>
  </div>
  {% endif %}

</div>

<script>
// Auto-detect city if field is empty on search page
(function() {
  var cityEl = document.getElementById('nav-city')
  if (!cityEl || cityEl.value.trim()) return
  fetch('/api/detect-city')
    .then(function(r) { return r.json() })
    .then(function(d) { if (d.city) cityEl.value = d.city })
    .catch(function() {})
})()
</script>

{% endblock %}

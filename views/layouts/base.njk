<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — {{ app_name }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--ink:#1a1a18;--ink-muted:#6b6b66;--ink-faint:#b0afa8;--white:#fff;--off:#f8f7f4;--paper:#f2f0eb;--border:rgba(26,26,24,0.1);--border-md:rgba(26,26,24,0.18);--blue:#2563eb;--blue-light:#eff4ff;--green:#16a34a;--green-light:#f0fdf4;--red:#dc2626;--red-light:#fef2f2;--radius:10px;--radius-lg:16px;}
body{font-family:"DM Sans",sans-serif;background:var(--off);color:var(--ink);min-height:100vh;}
a{color:inherit;text-decoration:none;}
</style>
{% block head %}{% endblock %}
</head>
<body>
{% block body %}{% endblock %}
</body>
</html>
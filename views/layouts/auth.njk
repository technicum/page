{% extends "layouts/base.njk" %}
{% block head %}
<style>
body{display:flex;align-items:center;justify-content:center;padding:24px;}
.wrap{width:100%;max-width:420px;}
.logo{font-family:"DM Serif Display",serif;font-size:22px;text-align:center;margin-bottom:32px;display:block;color:var(--ink);}
.logo em{font-style:italic;color:var(--blue);}
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:36px 32px;}
.card h1{font-family:"DM Serif Display",serif;font-size:26px;font-weight:400;letter-spacing:-0.5px;margin-bottom:6px;}
.card p{font-size:14px;color:var(--ink-muted);margin-bottom:28px;}
.errors{background:var(--red-light);border:1px solid rgba(220,38,38,0.2);border-radius:var(--radius);padding:12px 16px;margin-bottom:20px;}
.errors li{font-size:13px;color:var(--red);list-style:none;padding:2px 0;}
.field{margin-bottom:18px;}
.field label{display:block;font-size:13px;font-weight:500;color:var(--ink-muted);margin-bottom:6px;}
.field input{width:100%;padding:11px 14px;border:1px solid var(--border-md);border-radius:var(--radius);font-size:15px;font-family:"DM Sans",sans-serif;color:var(--ink);background:var(--white);outline:none;transition:border-color 0.2s;}
.field input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,0.08);}
.btn{width:100%;padding:13px;background:var(--ink);color:var(--white);border:none;border-radius:var(--radius);font-size:15px;font-weight:500;font-family:"DM Sans",sans-serif;cursor:pointer;transition:opacity 0.2s;margin-top:4px;}
.btn:hover{opacity:0.85;}
.footer-link{text-align:center;margin-top:20px;font-size:14px;color:var(--ink-muted);}
.footer-link a{color:var(--blue);font-weight:500;}
</style>
{% endblock %}
{% block body %}
<div class="wrap">
  <a class="logo" href="/">page<em>zaper</em></a>
  {% block content %}{% endblock %}
</div>
{% endblock %}
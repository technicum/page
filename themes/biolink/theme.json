{
  "name": "BioLink",
  "slug": "biolink",
  "author": "PageZapper",
  "version": "1.0",
  "description": "Narrow, mobile-first link-in-bio page. Perfect for creators, influencers, and personal brands.",
  "tags": ["biolink", "linktree", "narrow", "mobile", "creator"],
  "for": ["linktree", "other"],
  "order": 4,

  "settings": {
    "colors": [
      { "id": "violet",  "label": "Violet",  "hex": "#7c3aed" },
      { "id": "rose",    "label": "Rose",    "hex": "#e11d48" },
      { "id": "sky",     "label": "Sky",     "hex": "#0284c7" },
      { "id": "emerald", "label": "Emerald", "hex": "#059669" },
      { "id": "amber",   "label": "Amber",   "hex": "#d97706" },
      { "id": "ink",     "label": "Ink",     "hex": "#1a1a18" },
      { "id": "slate",   "label": "Slate",   "hex": "#475569" },
      { "id": "pink",    "label": "Pink",    "hex": "#db2777" }
    ],
    "fonts": [
      { "id": "sans",  "label": "DM Sans" },
      { "id": "serif", "label": "DM Serif" }
    ]
  },

  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "emoji": "👤",
      "description": "Your avatar, name, and bio at the top.",
      "fields": [
        { "id": "avatar_emoji", "label": "Avatar (emoji or letter)", "type": "text",     "default": "✨" },
        { "id": "name",         "label": "Display Name",             "type": "text",     "default": "Your Name" },
        { "id": "tagline",      "label": "Tagline / Username",       "type": "text",     "default": "@yourhandle" },
        { "id": "bio",          "label": "Bio",                      "type": "textarea", "default": "Creator · Photographer · Based in India" }
      ]
    },
    {
      "id": "links",
      "label": "Links",
      "emoji": "🔗",
      "description": "Your main link buttons.",
      "fields": [
        {
          "id": "items",
          "label": "Links",
          "type": "list",
          "item_fields": [
            { "id": "emoji", "label": "Icon (emoji)", "type": "text", "default": "🌐" },
            { "id": "label", "label": "Label",        "type": "text", "default": "My Website" },
            { "id": "url",   "label": "URL",          "type": "url",  "default": "https://" },
            { "id": "style", "label": "Style (solid/outline)", "type": "text", "default": "solid" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Social Icons",
      "emoji": "📱",
      "description": "Small icon row for social platforms.",
      "fields": [
        { "id": "instagram", "label": "Instagram URL", "type": "url", "default": "" },
        { "id": "youtube",   "label": "YouTube URL",   "type": "url", "default": "" },
        { "id": "twitter",   "label": "Twitter/X URL", "type": "url", "default": "" },
        { "id": "tiktok",    "label": "TikTok URL",    "type": "url", "default": "" },
        { "id": "linkedin",  "label": "LinkedIn URL",  "type": "url", "default": "" },
        { "id": "github",    "label": "GitHub URL",    "type": "url", "default": "" }
      ]
    },
    {
      "id": "products",
      "label": "Products & Services",
      "emoji": "🛍️",
      "description": "Showcase products/services. Customers order via WhatsApp cart.",
      "fields": [
        { "id": "heading",  "label": "Section Heading",       "type": "text", "default": "Products & Services" },
        { "id": "wa_phone", "label": "WhatsApp Order Number", "type": "tel",  "default": "" },
        {
          "id": "items", "label": "Products", "type": "list",
          "item_fields": [
            { "id": "emoji", "label": "Emoji",       "type": "text", "default": "📦" },
            { "id": "name",  "label": "Name",        "type": "text", "default": "My Product" },
            { "id": "price", "label": "Price",       "type": "text", "default": "₹999" },
            { "id": "desc",  "label": "Description", "type": "text", "default": "" },
            { "id": "image", "label": "Image URL",   "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "upi_pay",
      "label": "UPI Payment",
      "emoji": "💳",
      "description": "Accept payments via UPI with QR code and deep link button.",
      "fields": [
        { "id": "upi_id",       "label": "UPI ID (VPA)",     "type": "text", "default": "" },
        { "id": "display_name", "label": "Display Name",     "type": "text", "default": "" },
        { "id": "amount",       "label": "Amount (optional)","type": "text", "default": "" },
        { "id": "btn_label",    "label": "Button Text",      "type": "text", "default": "💳 Pay with UPI" }
      ]
    },
    {
      "id": "lead_form",
      "label": "Lead Capture Form",
      "emoji": "📝",
      "description": "Collect visitor name, phone and email leads.",
      "fields": [
        { "id": "heading",      "label": "Form Heading",    "type": "text", "default": "Get in Touch" },
        { "id": "show_name",    "label": "Show Name",       "type": "text", "default": "yes" },
        { "id": "show_phone",   "label": "Show Phone",      "type": "text", "default": "yes" },
        { "id": "show_email",   "label": "Show Email",      "type": "text", "default": "yes" },
        { "id": "show_message", "label": "Show Message",    "type": "text", "default": "no" },
        { "id": "btn_label",    "label": "Button Text",     "type": "text", "default": "Send" },
        { "id": "success_msg",  "label": "Success Message", "type": "text", "default": "Thanks! We'll be in touch soon." }
      ]
    },
    {
      "id": "video_embed",
      "label": "Video Embed",
      "emoji": "🎬",
      "description": "Embed a YouTube video on your page.",
      "fields": [
        { "id": "url",     "label": "YouTube URL", "type": "text", "default": "" },
        { "id": "caption", "label": "Caption",     "type": "text", "default": "" }
      ]
    },
    {
      "id": "featured",
      "label": "Featured Card",
      "emoji": "⭐",
      "description": "A highlighted card — great for a product, book, or offer.",
      "fields": [
        { "id": "emoji",    "label": "Icon",        "type": "text",     "default": "🚀" },
        { "id": "title",    "label": "Title",       "type": "text",     "default": "My Latest Project" },
        { "id": "subtitle", "label": "Subtitle",    "type": "text",     "default": "Check it out →" },
        { "id": "url",      "label": "Link URL",    "type": "url",      "default": "https://" },
        { "id": "desc",     "label": "Description", "type": "textarea", "default": "A short description of what this is." }
      ]
    },
    {
      "id": "contact_card",
      "label": "Contact Card",
      "emoji": "📇",
      "description": "Phone, email, address and a save-to-phone button for visitors.",
      "fields": [
        { "id": "phone",      "label": "Phone Number",              "type": "tel",  "default": "" },
        { "id": "email",      "label": "Email Address",             "type": "text", "default": "" },
        { "id": "website",    "label": "Website URL",               "type": "text", "default": "" },
        { "id": "address",    "label": "Address",                   "type": "text", "default": "" },
        { "id": "maps_url",   "label": "Directions URL (optional)", "type": "text", "default": "" },
        { "id": "save_label", "label": "Save Button Text",          "type": "text", "default": "💾 Save Contact" }
      ]
    },
    {
      "id": "whatsapp_widget",
      "label": "WhatsApp Widget",
      "emoji": "💬",
      "description": "Floating WhatsApp button.",
      "fields": [
        { "id": "phone",   "label": "WhatsApp Number",     "type": "tel",  "default": "" },
        { "id": "message", "label": "Pre-filled Message",  "type": "text", "default": "Hi! I'd like to know more." },
        { "id": "label",   "label": "Bubble Label",        "type": "text", "default": "Chat" }
      ]
    }
  ]
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.title }}</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --c:{{ settings.accent_color }};
  --c15:{{ settings.accent_color }}26;
  --c30:{{ settings.accent_color }}4d;
}
html,body{min-height:100%;}
body{
  font-family:'DM Sans',sans-serif;
  background:linear-gradient(160deg,var(--c15) 0%,#ffffff 60%);
  background-attachment:fixed;
  color:#1a1a18;
  display:flex;
  flex-direction:column;
  align-items:center;
  padding:40px 16px 80px;
  min-height:100vh;
}

/* ── Page wrapper — narrow centered column ── */
.page{width:100%;max-width:480px;display:flex;flex-direction:column;gap:0;}

/* ── Profile ── */
.profile{text-align:center;padding:0 0 28px;}
.avatar{
  width:88px;height:88px;border-radius:50%;
  background:var(--c);color:#fff;
  font-size:36px;display:flex;align-items:center;justify-content:center;
  margin:0 auto 16px;
  box-shadow:0 8px 24px var(--c30);
  border:3px solid #fff;
}
.profile-name{font-family:'DM Serif Display',serif;font-size:26px;font-weight:400;letter-spacing:-0.5px;margin-bottom:4px;}
.profile-handle{font-size:14px;color:#6b6b66;margin-bottom:12px;font-weight:500;}
.profile-bio{font-size:14px;color:#6b6b66;line-height:1.7;max-width:340px;margin:0 auto;}

/* ── Section labels ── */
.section-divider{text-align:center;margin:24px 0 14px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(26,26,24,0.35);}

/* ── Link buttons ── */
.links-list{display:flex;flex-direction:column;gap:10px;}
.link-btn{
  display:flex;align-items:center;gap:12px;
  padding:14px 20px;border-radius:14px;
  font-size:15px;font-weight:500;
  text-decoration:none;
  transition:transform 0.15s,box-shadow 0.15s;
  cursor:pointer;
}
.link-btn:hover{transform:translateY(-2px);}
.link-btn.solid{
  background:var(--c);color:#fff;
  box-shadow:0 4px 14px var(--c30);
}
.link-btn.solid:hover{box-shadow:0 8px 22px var(--c30);}
.link-btn.outline{
  background:#fff;color:#1a1a18;
  border:1.5px solid rgba(26,26,24,0.12);
  box-shadow:0 2px 8px rgba(0,0,0,0.05);
}
.link-btn.outline:hover{border-color:var(--c);color:var(--c);}
.link-btn.ghost{
  background:var(--c15);color:var(--c);
  border:1.5px solid var(--c30);
}
.link-btn.ghost:hover{background:var(--c30);}
.link-emoji{font-size:20px;flex-shrink:0;line-height:1;}
.link-label{flex:1;}
.link-arrow{font-size:14px;opacity:0.5;}

/* ── Socials row ── */
.socials-row{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-top:4px;}
.social-btn{
  width:44px;height:44px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  background:#fff;border:1.5px solid rgba(26,26,24,0.1);
  font-size:20px;text-decoration:none;
  transition:transform 0.15s,border-color 0.15s,box-shadow 0.15s;
  box-shadow:0 2px 6px rgba(0,0,0,0.04);
}
.social-btn:hover{transform:translateY(-2px);border-color:var(--c);box-shadow:0 4px 12px var(--c30);}

/* ── Featured card ── */
.featured-card{
  background:#fff;border-radius:16px;padding:20px;
  border:1.5px solid rgba(26,26,24,0.08);
  box-shadow:0 4px 18px rgba(0,0,0,0.06);
  text-decoration:none;color:#1a1a18;
  display:block;
  transition:transform 0.15s,box-shadow 0.15s;
}
.featured-card:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,0.1);}
.featured-top{display:flex;align-items:flex-start;gap:14px;}
.featured-icon{font-size:36px;flex-shrink:0;line-height:1;}
.featured-title{font-size:16px;font-weight:600;margin-bottom:3px;}
.featured-sub{font-size:13px;color:var(--c);font-weight:500;}
.featured-desc{font-size:13px;color:#6b6b66;margin-top:12px;line-height:1.6;}

/* ── WhatsApp widget ── */
.wa-widget{position:fixed;bottom:20px;right:20px;z-index:999;}
.wa-bubble{
  display:flex;align-items:center;gap:8px;
  background:#25d366;color:#fff;
  padding:10px 18px;border-radius:50px;
  text-decoration:none;font-size:14px;font-weight:600;
  box-shadow:0 4px 18px rgba(37,211,102,0.4);
  transition:transform 0.2s,box-shadow 0.2s;
}
.wa-bubble:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(37,211,102,0.5);}

/* ── Footer ── */
.bio-footer{
  margin-top:32px;text-align:center;
  font-size:12px;color:rgba(26,26,24,0.35);
}
.bio-footer a{color:var(--c);text-decoration:none;font-weight:500;}
</style>
</head>
<body>
<div class="page">

{% for section in sections %}
  {% assign f = section.fields %}

  {% if section.id == 'profile' %}
  <div class="profile">
    <div class="avatar">{{ f.avatar_emoji | default: '✨' }}</div>
    <div class="profile-name">{{ f.name | default: site.title }}</div>
    {% if f.tagline != '' and f.tagline != nil %}
    <div class="profile-handle">{{ f.tagline }}</div>
    {% endif %}
    {% if f.bio != '' and f.bio != nil %}
    <p class="profile-bio">{{ f.bio }}</p>
    {% endif %}
  </div>

  {% elsif section.id == 'links' %}
  {% if f.items.size > 0 %}
  <div class="section-divider">Links</div>
  <div class="links-list">
    {% for item in f.items %}
    {% assign btn_style = item.style | default: 'solid' %}
    <a class="link-btn {{ btn_style }}" href="{{ item.url | default: '#' }}" target="_blank" rel="noopener">
      {% if item.emoji != '' and item.emoji != nil %}<span class="link-emoji">{{ item.emoji }}</span>{% endif %}
      <span class="link-label">{{ item.label }}</span>
      <span class="link-arrow">›</span>
    </a>
    {% endfor %}
  </div>
  {% endif %}

  {% elsif section.id == 'socials' %}
  {% assign has_social = false %}
  {% if f.instagram != '' and f.instagram != nil %}{% assign has_social = true %}{% endif %}
  {% if f.youtube != '' and f.youtube != nil %}{% assign has_social = true %}{% endif %}
  {% if f.twitter != '' and f.twitter != nil %}{% assign has_social = true %}{% endif %}
  {% if f.tiktok != '' and f.tiktok != nil %}{% assign has_social = true %}{% endif %}
  {% if f.linkedin != '' and f.linkedin != nil %}{% assign has_social = true %}{% endif %}
  {% if f.github != '' and f.github != nil %}{% assign has_social = true %}{% endif %}
  {% if has_social %}
  <div class="section-divider">Find me on</div>
  <div class="socials-row">
    {% if f.instagram != '' and f.instagram != nil %}
      <a class="social-btn" href="{{ f.instagram }}" target="_blank" title="Instagram">📸</a>
    {% endif %}
    {% if f.youtube != '' and f.youtube != nil %}
      <a class="social-btn" href="{{ f.youtube }}" target="_blank" title="YouTube">▶️</a>
    {% endif %}
    {% if f.twitter != '' and f.twitter != nil %}
      <a class="social-btn" href="{{ f.twitter }}" target="_blank" title="Twitter/X">𝕏</a>
    {% endif %}
    {% if f.tiktok != '' and f.tiktok != nil %}
      <a class="social-btn" href="{{ f.tiktok }}" target="_blank" title="TikTok">🎵</a>
    {% endif %}
    {% if f.linkedin != '' and f.linkedin != nil %}
      <a class="social-btn" href="{{ f.linkedin }}" target="_blank" title="LinkedIn">💼</a>
    {% endif %}
    {% if f.github != '' and f.github != nil %}
      <a class="social-btn" href="{{ f.github }}" target="_blank" title="GitHub">🐙</a>
    {% endif %}
  </div>
  {% endif %}

  {% elsif section.id == 'featured' %}
  {% if f.title != '' and f.title != nil %}
  <div class="section-divider">Featured</div>
  <a class="featured-card" href="{{ f.url | default: '#' }}" target="_blank">
    <div class="featured-top">
      <div class="featured-icon">{{ f.emoji | default: '🚀' }}</div>
      <div>
        <div class="featured-title">{{ f.title }}</div>
        {% if f.subtitle != '' and f.subtitle != nil %}
        <div class="featured-sub">{{ f.subtitle }}</div>
        {% endif %}
      </div>
    </div>
    {% if f.desc != '' and f.desc != nil %}
    <p class="featured-desc">{{ f.desc }}</p>
    {% endif %}
  </a>
  {% endif %}

  {% elsif section.id == 'whatsapp_widget' %}
  {% if f.phone != '' and f.phone != nil %}
  {% assign wa_msg = f.message | default: 'Hi!' | url_encode %}
  <div class="wa-widget">
    <a class="wa-bubble" href="https://wa.me/{{ f.phone | wa }}?text={{ wa_msg }}" target="_blank">
      💬 {{ f.label | default: 'Chat' }}
    </a>
  </div>
  {% endif %}

  {% endif %}
{% endfor %}

<div class="bio-footer">
  Powered by <a href="{{ app_url }}">{{ app_name }}</a>
</div>
</div>
</body>
</html>

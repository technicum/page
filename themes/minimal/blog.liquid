<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blog — {{ site.title }}</title>
<meta name="description" content="Read the latest articles from {{ site.title }}.">
<meta property="og:title" content="Blog — {{ site.title }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ site.url }}/blog">
<link rel="canonical" href="{{ site.url }}/blog">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/themes/minimal/style.css">
<style>:root{--c:{{ settings.accent_color }};--c15:{{ settings.accent_color }}26;}</style>
</head>
<body>
<nav>
  <a class="nav-logo" href="/">{{ site.title }}</a>
  <div class="nav-links">
    {% for item in nav_items %}
      <a href="{{ item.url }}" {% if item.id == 'blog' %}style="color:var(--c);font-weight:500;"{% endif %}>{{ item.label }}</a>
    {% endfor %}
    <a href="/blog" style="color:var(--c);font-weight:500;">Blog</a>
  </div>
</nav>

<div class="section" style="max-width:740px;">
  <div class="section-label">Blog</div>
  <div class="section-title">Latest Articles</div>

  {% if posts.size == 0 %}
  <p class="section-text" style="margin-top:16px;">No posts published yet. Check back soon!</p>
  {% else %}
  <div style="margin-top:32px;display:flex;flex-direction:column;gap:28px;">
    {% for post in posts %}
    <a href="{{ post.url }}" style="text-decoration:none;color:inherit;display:block;padding:24px;border:1px solid rgba(0,0,0,0.08);border-radius:12px;transition:box-shadow 0.2s,transform 0.2s;">
      <div style="font-size:12px;color:#b0afa8;margin-bottom:8px;">{{ post.date }}</div>
      <h2 style="font-family:'DM Serif Display',serif;font-size:clamp(18px,2.5vw,24px);font-weight:400;letter-spacing:-0.5px;color:#1a1a18;margin-bottom:10px;">{{ post.title }}</h2>
      {% if post.excerpt != '' and post.excerpt != nil %}
      <p style="font-size:15px;color:#6b6b66;line-height:1.7;">{{ post.excerpt }}</p>
      {% endif %}
      <span style="display:inline-block;margin-top:12px;font-size:13px;font-weight:500;color:var(--c);">Read more →</span>
    </a>
    {% endfor %}
  </div>
  {% endif %}
</div>

<footer>Powered by <a href="{{ app_url }}">{{ app_name }}</a></footer>
</body>
</html>

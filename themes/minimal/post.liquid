<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ post.meta_title | default: post.title }} — {{ site.title }}</title>
<meta name="description" content="{{ post.meta_desc | default: post.excerpt }}">
<meta property="og:title" content="{{ post.meta_title | default: post.title }}">
<meta property="og:description" content="{{ post.meta_desc | default: post.excerpt }}">
{% if post.og_image != '' and post.og_image != nil %}
<meta property="og:image" content="{{ post.og_image }}">
<meta name="twitter:image" content="{{ post.og_image }}">
{% endif %}
<meta property="og:type" content="article">
<meta property="og:url" content="{{ site.url }}{{ post.url }}">
<meta name="twitter:card" content="summary_large_image">
<link rel="canonical" href="{{ site.url }}{{ post.url }}">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Article","headline":"{{ post.title }}","datePublished":"{{ post.date }}","author":{"@type":"Organization","name":"{{ site.title }}"},"publisher":{"@type":"Organization","name":"{{ site.title }}"},"url":"{{ site.url }}{{ post.url }}"}
</script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/themes/minimal/style.css">
<style>
:root{--c:{{ settings.accent_color }};--c15:{{ settings.accent_color }}26;}
.post-body{font-size:17px;line-height:1.85;color:#374151;max-width:680px;}
.post-body h2{font-family:'DM Serif Display',serif;font-size:1.6em;font-weight:400;color:#1a1a18;margin:1.4em 0 0.5em;letter-spacing:-0.5px;}
.post-body h3{font-size:1.2em;font-weight:600;color:#1a1a18;margin:1.2em 0 0.4em;}
.post-body p{margin-bottom:1.2em;}
.post-body ul,.post-body ol{padding-left:1.6em;margin-bottom:1.2em;}
.post-body li{margin-bottom:0.4em;}
.post-body blockquote{border-left:3px solid var(--c);padding:8px 20px;margin:1.5em 0;background:var(--c15);border-radius:0 8px 8px 0;font-style:italic;color:#6b6b66;}
.post-body strong{font-weight:700;color:#1a1a18;}
.post-body a{color:var(--c);text-decoration:underline;}
.post-body img{max-width:100%;border-radius:8px;margin:1em 0;}
.post-body hr{border:none;border-top:1px solid rgba(0,0,0,0.08);margin:2em 0;}
.post-body code{background:#f8f7f4;padding:2px 6px;border-radius:4px;font-size:0.9em;}
.post-body pre{background:#f8f7f4;padding:16px;border-radius:8px;overflow-x:auto;font-size:14px;margin-bottom:1.2em;}
</style>
</head>
<body>
<nav>
  <a class="nav-logo" href="/">{{ site.title }}</a>
  <div class="nav-links">
    {% for item in nav_items %}
      <a href="{{ item.url }}">{{ item.label }}</a>
    {% endfor %}
    <a href="/blog" style="color:var(--c);font-weight:500;">Blog</a>
  </div>
</nav>

<article style="max-width:740px;margin:0 auto;padding:56px 40px 80px;">
  <div style="margin-bottom:32px;">
    <a href="/blog" style="font-size:13px;color:#b0afa8;text-decoration:none;">← Back to Blog</a>
  </div>

  {% if post.og_image != '' and post.og_image != nil %}
  <img src="{{ post.og_image }}" alt="{{ post.title }}"
       style="width:100%;height:320px;object-fit:cover;border-radius:14px;margin-bottom:32px;">
  {% endif %}

  <div style="font-size:13px;color:#b0afa8;margin-bottom:12px;">{{ post.date }}</div>
  <h1 style="font-family:'DM Serif Display',serif;font-size:clamp(28px,4vw,44px);font-weight:400;letter-spacing:-1px;line-height:1.15;color:#1a1a18;margin-bottom:24px;">{{ post.title }}</h1>

  <div class="post-body">{{ post.content }}</div>

  <div style="margin-top:48px;padding-top:24px;border-top:1px solid rgba(0,0,0,0.06);">
    <a href="/blog" style="font-size:14px;color:var(--c);font-weight:500;text-decoration:none;">← All posts</a>
  </div>
</article>

<footer>Powered by <a href="{{ app_url }}">{{ app_name }}</a></footer>
</body>
</html>

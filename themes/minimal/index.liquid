<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.title }}</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/themes/minimal/style.css">
<style>:root{--c:{{ settings.accent_color }};--c15:{{ settings.accent_color }}26;}</style>
</head>
<body>
<nav>
  <a class="nav-logo" href="#">{{ site.title }}</a>
  <div class="nav-links">
    {% if nav_items.size > 0 %}
      {% for item in nav_items %}
        <a href="{{ item.url }}" {% if item.id == page_id %}style="color:var(--c);font-weight:500;"{% endif %}
           {% if item.external %}target="_blank" rel="noopener"{% endif %}>{{ item.label }}</a>
      {% endfor %}
    {% else %}
      {% for section in sections %}
        {% unless section.id == 'hero' or section.id == 'links' or section.id == 'hero_slider' or section.id == 'whatsapp_widget' %}
          <a href="#{{ section.id }}">{{ section.fields.title | default: section.id }}</a>
        {% endunless %}
      {% endfor %}
    {% endif %}
  </div>
</nav>

{% for section in sections %}
  {% unless section._hidden %}
  {% assign f = section.fields %}
  <div class="pz-sec" data-pz="{{ section.id }}">

  {% if rendered_sections[section.id] %}
  {{ rendered_sections[section.id] }}
  {% elsif section.id == 'hero_slider' %}
  {% assign interval = f.interval | default: 4000 %}
  <div class="hslider" id="hslider-{{ forloop.index }}">
    <div class="hslider-track" id="htrack-{{ forloop.index }}">
      {% for slide in f.slides %}
      <div class="hslide">
        {% if slide.emoji != '' and slide.emoji != nil %}<div class="hslide-icon">{{ slide.emoji }}</div>{% endif %}
        <h2 class="hslide-title">{{ slide.headline }}</h2>
        <p class="hslide-sub">{{ slide.subheading }}</p>
        {% if slide.btn_text != '' and slide.btn_text != nil %}
          <a class="btn-p" href="{{ slide.btn_link | default: '#' }}">{{ slide.btn_text }}</a>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% if f.slides.size > 1 %}
    <div class="hslider-arrow prev" onclick="hSlide('{{ forloop.index }}',-1)">‹</div>
    <div class="hslider-arrow next" onclick="hSlide('{{ forloop.index }}',1)">›</div>
    <div class="hslider-dots" id="hdots-{{ forloop.index }}">
      {% for slide in f.slides %}
      <div class="hslider-dot {% if forloop.first %}active{% endif %}" onclick="hGoTo('{{ forloop.parentloop.index }}',{{ forloop.index0 }})"></div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  <script>
  (function(){
    var id="{{ forloop.index }}",cur=0,total={{ f.slides.size }},iv={{ interval }};
    function go(n){cur=(n+total)%total;document.getElementById('htrack-'+id).style.transform='translateX(-'+cur*100+'%)';var dots=document.getElementById('hdots-'+id);if(dots){dots.querySelectorAll('.hslider-dot').forEach(function(d,i){d.classList.toggle('active',i===cur);});}}
    window.hSlide=window.hSlide||function(i,d){if(i===id)go(cur+d);};
    window.hGoTo=window.hGoTo||function(i,n){if(i===id)go(n);};
    if(total>1)setInterval(function(){go(cur+1);},iv);
  })();
  </script>

  {% elsif section.id == 'testimonials_slider' %}
  {% assign tid = forloop.index %}
  <div style="background:#f8f7f4;">
    <div class="tslider-wrap" id="tslider-{{ tid }}">
      <div class="section-label">Testimonials</div>
      <div class="tslider-title">{{ f.title }}</div>
      <div style="overflow:hidden;">
        <div class="tslider-track" id="ttrack-{{ tid }}">
          {% for item in f.items %}
          <div class="tslide-card">
            <div class="tslide-avatar">{{ item.emoji | default: '😊' }}</div>
            <p class="tslide-text">"{{ item.text }}"</p>
            <div class="tslide-name">{{ item.name }}</div>
            <div class="tslide-role">{{ item.role }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% if f.items.size > 1 %}
      <div class="tslider-nav">
        <button class="tslider-btn" onclick="tSlide('{{ tid }}',-1)">← Prev</button>
        <button class="tslider-btn" onclick="tSlide('{{ tid }}',1)">Next →</button>
      </div>
      {% endif %}
    </div>
  </div>
  <script>
  (function(){
    var id="{{ tid }}",cur=0,total={{ f.items.size }},cardW=340;
    window.tSlide=window.tSlide||{};
    window.tSlide['{{ tid }}']=function(d){cur=Math.max(0,Math.min(cur+d,total-1));document.getElementById('ttrack-'+id).style.transform='translateX(-'+(cur*cardW)+'px)';};
    window.tSlide=function(i,d){if(window.tSlide[i])window.tSlide[i](d);};
  })();
  </script>

  {% elsif section.id == 'whatsapp_widget' %}
  {% if f.phone != '' and f.phone != nil %}
  {% assign wa_pos = f.position | default: 'right' %}
  {% assign wa_msg = f.message | default: 'Hi! I would like to know more.' | url_encode %}
  <div class="wa-widget {{ wa_pos }}">
    <a class="wa-bubble" href="https://wa.me/{{ f.phone | wa }}?text={{ wa_msg }}" target="_blank" rel="noopener">
      <span class="wa-icon">💬</span>
      <span>{{ f.label | default: 'Chat with us' }}</span>
    </a>
  </div>
  {% endif %}

  {% elsif section.id == 'hero' %}
  <div class="hero">
    <div class="hero-tag">{{ site_type }}{% if city %} · {{ city }}{% endif %}</div>
    <h1 class="hero-title">{{ f.headline | default: site.title }}</h1>
    <p class="hero-sub">{{ f.subheading }}</p>
    <div class="hero-btns">
      {% if f.btn_text != '' and f.btn_text != nil %}
        <a class="btn-p" href="#contact">{{ f.btn_text }}</a>
      {% endif %}
      {% if f.btn2_text != '' and f.btn2_text != nil %}
        <a class="btn-o" href="#about">{{ f.btn2_text }}</a>
      {% endif %}
    </div>
  </div>

  {% elsif section.id == 'about' %}
  <div class="section" id="about">
    <div class="section-label">About</div>
    <div class="section-title">{{ f.title }}</div>
    <p class="section-text">{{ f.text }}</p>
  </div>

  {% elsif section.id == 'services' or section.id == 'skills' %}
  <div class="section-alt" id="{{ section.id }}">
    <div class="section">
      <div class="section-label">{{ section.label }}</div>
      <div class="section-title">{{ f.title }}</div>
      <div class="cards-grid">
        {% for item in f.items %}
        <div class="card">
          <div class="card-emoji">{{ item.emoji }}</div>
          <div class="card-name">{{ item.name }}</div>
          <div class="card-desc">{{ item.desc }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% elsif section.id == 'contact' %}
  <div class="contact-wrap" id="contact">
    <div class="section-label">Contact</div>
    <div class="section-title">{{ f.title | default: 'Get in Touch' }}</div>
    <div class="contact-items">
      {% if f.phone != '' and f.phone != nil %}
        <a class="contact-item" href="tel:{{ f.phone }}">📞 {{ f.phone }}</a>
      {% endif %}
      {% if f.whatsapp != '' and f.whatsapp != nil %}
        <a class="contact-item" href="https://wa.me/{{ f.whatsapp | wa }}">💬 WhatsApp</a>
      {% endif %}
      {% if f.address != '' and f.address != nil %}
        <span class="contact-item">📍 {{ f.address }}</span>
      {% endif %}
    </div>
  </div>

  {% elsif section.id == 'links' %}
  <div class="links-wrap">
    {% for link in f.items %}
      <a class="link-item" href="{{ link.url | default: '#' }}" target="_blank">
        {{ link.emoji }} {{ link.name }}
      </a>
    {% endfor %}
  </div>

  {% endif %}
  </div><!-- /pz-sec -->
  {% endunless %}
{% endfor %}

<footer>Powered by <a href="{{ app_url }}">{{ app_name }}</a></footer>
</body>
</html>

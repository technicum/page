{
  "name": "Service Link",
  "description": "Biolink for service providers — services list, booking CTA, contact.",
  "for": ["minisite"],
  "categories": ["beauty", "healthcare", "fitness", "restaurant", "retail", "events", "travel", "education", "finance", "freelancer", "other"],
  "preview": "preview.jpg",
  "default_appearance": {
    "bgColor": "#f0f9ff", "btnColor": "#2563eb", "btnTextColor": "#ffffff",
    "textColor": "#1a1a1a", "btnStyle": "filled", "btnRadius": "8",
    "bgType": "color", "fontFamily": "inter"
  },
  "default_blocks": [
    { "id":"b1", "type":"avatar",  "enabled":true, "photo":"", "name":"Your Name", "bio":"Professional Hair Stylist · 5+ years experience · Book today!" },
    { "id":"b2", "type":"link",    "enabled":true, "title":"📅 Book Appointment", "url":"#" },
    { "id":"b3", "type":"heading", "enabled":true, "text":"What I Offer", "size":"h3", "align":"center" },
    { "id":"b4", "type":"service", "enabled":true, "title":"Hair Cut & Style", "description":"Wash, cut and blow-dry", "price":"Starting ₹500", "duration":"45 min", "btn_text":"Book now", "btn_url":"#" },
    { "id":"b5", "type":"service", "enabled":true, "title":"Hair Colouring", "description":"Global or highlight colouring", "price":"Starting ₹1,500", "duration":"90 min", "btn_text":"Book now", "btn_url":"#" },
    { "id":"b6", "type":"socials", "enabled":true, "instagram":"https://instagram.com" }
  ],
  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "fields": [
        { "id": "avatar", "label": "Avatar URL",   "type": "image",    "default": "" },
        { "id": "name",   "label": "Your Name",    "type": "text",     "default": "Your Name" },
        { "id": "title",  "label": "Title / Role", "type": "text",     "default": "Professional Hair Stylist" },
        { "id": "bio",    "label": "Short Bio",    "type": "textarea", "default": "5+ years experience · 500+ happy clients · Book your appointment today!" },
        { "id": "accent", "label": "Accent Color", "type": "color",    "default": "#2563eb" }
      ]
    },
    {
      "id": "services",
      "label": "Services",
      "fields": [
        { "id": "heading",           "label": "Section Heading",                          "type": "text", "default": "What I Offer" },
        { "id": "order_on_whatsapp", "label": "Order on WhatsApp (yes / no)",            "type": "text", "default": "no" },
        { "id": "items", "label": "Services", "type": "repeater",
          "default": [
            { "emoji": "✂️", "name": "Hair Cut & Style",   "description": "Wash, cut and blow-dry",        "price": "Starting ₹500", "url": "" },
            { "emoji": "💆", "name": "Head Massage",        "description": "Relaxing 30-min session",       "price": "Starting ₹300", "url": "" },
            { "emoji": "🎨", "name": "Hair Colouring",      "description": "Global or highlight colouring", "price": "Starting ₹1500","url": "" }
          ],
          "item_fields": [
            { "id": "emoji",       "label": "Emoji / Icon",                                    "type": "text", "default": "✅" },
            { "id": "name",        "label": "Service Name",                                    "type": "text", "default": "Service" },
            { "id": "description", "label": "Description",                                     "type": "text", "default": "" },
            { "id": "price",       "label": "Price / Starting From",                           "type": "text", "default": "" },
            { "id": "url",         "label": "Book / Buy Link URL (if set, redirects instead of cart)", "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Booking & Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "label": "Book Appointment", "url": "", "emoji": "📅", "primary": "yes" },
            { "label": "View My Work",     "url": "", "emoji": "📸", "primary": "no"  }
          ],
          "item_fields": [
            { "id": "label",   "label": "Label",                   "type": "text", "default": "Book a Call" },
            { "id": "url",     "label": "URL",                     "type": "text", "default": "" },
            { "id": "emoji",   "label": "Emoji",                   "type": "text", "default": "📅" },
            { "id": "primary", "label": "Primary Button (yes/no)", "type": "text", "default": "no" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Socials",
      "fields": [
        { "id": "heading",    "label": "Section Heading",          "type": "text",  "default": "Follow me" },
        { "id": "sub",        "label": "Sub Heading (leave blank to hide)", "type": "text", "default": "" },
        { "id": "icon_color", "label": "Icon Color",                "type": "color", "default": "" },
        { "id": "icon_size",  "label": "Icon Size (sm / md / lg / xl)", "type": "text", "default": "md" },
        { "id": "instagram", "label": "Instagram URL",   "type": "text", "default": "" },
        { "id": "linkedin",  "label": "LinkedIn URL",    "type": "text", "default": "" },
        { "id": "facebook",  "label": "Facebook URL",    "type": "text", "default": "" },
        { "id": "twitter",   "label": "Twitter / X URL", "type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube URL",     "type": "text", "default": "" }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "whatsapp",     "label": "WhatsApp Number (for cart orders)", "type": "text", "default": "" },
        { "id": "phone",        "label": "Phone Number",                      "type": "text", "default": "" },
        { "id": "email",     "label": "Email",           "type": "text", "default": "" },
        { "id": "website",   "label": "Website URL",     "type": "text", "default": "" },
        { "id": "address",   "label": "Address",         "type": "text", "default": "" },
        { "id": "save_label","label": "Save Contact Button Label", "type": "text", "default": "💾 Save Contact" }
      ]
    },
    {
      "id": "booking",
      "label": "Booking",
      "fields": [
        { "id": "show",    "label": "Show Booking Widget (yes / no)", "type": "text", "default": "yes" },
        { "id": "heading", "label": "Section Heading",                "type": "text", "default": "Book a Meeting" }
      ]
    }
  ]
}

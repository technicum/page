<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ settings.profile.name }}</title>
<link rel="stylesheet" href="/themes/biolink-service/assets/css/style.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --accent: {{ settings.profile.accent | default: '#2563eb' }};
  --ink: #1a1a18; --muted: #6b6b66; --border: #e5e5e2;
  --bg: #fafaf8; --white: #fff; --radius: 14px;
}
</style>
</head>
<body>
<div class="page">

  <!-- Profile -->
  {% assign pr = settings.profile %}
  <div class="profile">
    {% if pr.avatar != blank %}
      <img class="avatar" src="{{ pr.avatar }}" alt="{{ pr.name }}">
    {% else %}
      <div class="avatar-ph">{{ pr.name | slice: 0, 1 | upcase }}</div>
    {% endif %}
    <div class="name">{{ pr.name }}</div>
    {% if pr.title %}<div class="title">{{ pr.title }}</div>{% endif %}
    {% if pr.bio %}<div class="bio">{{ pr.bio }}</div>{% endif %}
  </div>

  <!-- Links (always visible) -->
  {% assign lk = settings.links %}
  {% if lk.items and lk.items.size > 0 %}
  <div class="links" style="margin-bottom:20px;">
    {% for item in lk.items %}
    <a class="link-btn {% if item.primary == 'yes' %}primary{% else %}secondary{% endif %}" href="{{ item.url }}" target="_blank">
      {% if item.emoji and item.primary != 'yes' %}<span class="link-emoji">{{ item.emoji }}</span>{% endif %}
      {{ item.label }}
    </a>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Accordion: Services -->
  {% assign sv = settings.services %}
  {% if sv.items and sv.items.size > 0 %}
  <div class="pz-sections">
    <div class="pz-sec" id="sec-services">
      <div class="pz-sec-head" onclick="pzToggle('sec-services')">
        <div class="pz-sec-icon">✅</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ sv.heading | default: 'What I Offer' }}</div>
          <div class="pz-sec-sub">{{ sv.items.size }} service{% if sv.items.size != 1 %}s{% endif %}</div>
        </div>
        <div class="pz-sec-right">
          <span class="pz-count">{{ sv.items.size }}</span>
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner">
          <div class="services">
            {% for item in sv.items %}
            <div class="service-card">
              <div class="svc-emoji">{{ item.emoji | default: '✅' }}</div>
              <div class="svc-body">
                <div class="svc-name">{{ item.name }}</div>
                {% if item.description %}<div class="svc-desc">{{ item.description }}</div>{% endif %}
                {% if item.price %}<div class="svc-price">{{ item.price }}</div>{% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Socials accordion -->
  {% assign s = settings.socials %}
  {% if s.instagram != blank or s.linkedin != blank or s.facebook != blank or s.twitter != blank or s.youtube != blank %}
  <div class="pz-sections">
    <div class="pz-sec" id="sec-socials">
      <div class="pz-sec-head" onclick="pzToggle('sec-socials')">
        <div class="pz-sec-icon">📱</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ s.heading | default: 'Follow me' }}</div>
          {% if s.sub != blank %}<div class="pz-sec-sub">{{ s.sub }}</div>{% endif %}
        </div>
        <div class="pz-sec-right">
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        {% assign _sz = 58 %}{% assign _fz = 24 %}
        {% if s.icon_size == 'sm' %}{% assign _sz = 44 %}{% assign _fz = 18 %}{% endif %}
        {% if s.icon_size == 'lg' %}{% assign _sz = 70 %}{% assign _fz = 30 %}{% endif %}
        {% if s.icon_size == 'xl' %}{% assign _sz = 86 %}{% assign _fz = 38 %}{% endif %}
        <style>#sec-socials .soc-icon{width:{{ _sz }}px;height:{{ _sz }}px;font-size:{{ _fz }}px;{% if s.icon_color != blank %}color:{{ s.icon_color }};border-color:{{ s.icon_color }};background:{{ s.icon_color }}1a;{% endif %}}{% if s.icon_color != blank %}#sec-socials .soc-icon:hover{background:{{ s.icon_color }};color:#fff;}{% endif %}</style>
        <div class="pz-sec-inner" style="padding:20px 16px;text-align:center;">
          <div class="social-row">
            {% if s.instagram != blank %}<a class="soc-icon" href="{{ s.instagram }}" target="_blank" title="Instagram"><i class="fa-brands fa-instagram"></i></a>{% endif %}
            {% if s.linkedin != blank %}<a class="soc-icon" href="{{ s.linkedin }}" target="_blank" title="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>{% endif %}
            {% if s.facebook != blank %}<a class="soc-icon" href="{{ s.facebook }}" target="_blank" title="Facebook"><i class="fa-brands fa-facebook"></i></a>{% endif %}
            {% if s.twitter != blank %}<a class="soc-icon" href="{{ s.twitter }}" target="_blank" title="Twitter"><i class="fa-brands fa-x-twitter"></i></a>{% endif %}
            {% if s.youtube != blank %}<a class="soc-icon" href="{{ s.youtube }}" target="_blank" title="YouTube"><i class="fa-brands fa-youtube"></i></a>{% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Contact accordion -->
  {% assign c = settings.contact %}
  {% if c.whatsapp != blank or c.phone != blank or c.email != blank %}
  <div class="pz-sections">
    <div class="pz-sec" id="sec-contact">
      <div class="pz-sec-head" onclick="pzToggle('sec-contact')">
        <div class="pz-sec-icon">📞</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">Get in Touch</div>
        </div>
        <div class="pz-sec-right">
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner" style="padding:12px 16px 16px;">
          <div class="contact-actions">
            {% if c.whatsapp != blank %}<a class="contact-btn" href="https://wa.me/{{ c.whatsapp | remove: '+' | remove: ' ' }}" target="_blank"><span class="contact-btn-icon"><i class="fa-brands fa-whatsapp"></i></span><span class="contact-btn-label">WhatsApp</span></a>{% endif %}
            {% if c.phone != blank %}<a class="contact-btn" href="tel:{{ c.phone }}"><span class="contact-btn-icon"><i class="fa-solid fa-phone"></i></span><span class="contact-btn-label">Call</span><span class="contact-btn-val">{{ c.phone }}</span></a>{% endif %}
            {% if c.email != blank %}<a class="contact-btn" href="mailto:{{ c.email }}"><span class="contact-btn-icon"><i class="fa-solid fa-envelope"></i></span><span class="contact-btn-label">Email</span><span class="contact-btn-val">{{ c.email }}</span></a>{% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Booking accordion -->
  {% if settings.booking.show != 'no' %}
  <div class="pz-sections">
    <div class="pz-sec" id="sec-booking">
      <div class="pz-sec-head" onclick="pzToggle('sec-booking')">
        <div class="pz-sec-icon">📅</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ settings.booking.heading | default: 'Book a Meeting' }}</div>
        </div>
        <div class="pz-sec-right">
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner" id="pzBookWrap" style="min-height:60px;padding:16px;">
          <div class="bk-loading">Tap to schedule a meeting</div>
        </div>
      </div>
    </div>
  </div>
  <script>
  (function(){var sub='{{ site.subdomain }}',w=document.getElementById('pzBookWrap'),s={event:null,date:null,slot:null,yr:0,mo:0},MN=['January','February','March','April','May','June','July','August','September','October','November','December'],opened=false;var head=document.querySelector('#sec-booking .pz-sec-head');if(head)head.addEventListener('click',function(){if(!document.getElementById('sec-booking').classList.contains('open')&&!opened){opened=true;setTimeout(bkLoad,80);}});function bkLoad(){bkR('<div class="bk-loading">Loading...</div>');fetch('/api/booking/'+sub+'/events').then(function(r){return r.json();}).then(function(d){if(!d||!d.length){bkR('<div class="bk-loading">No meeting types available.</div>');return;}var h='';d.forEach(function(e){h+='<div class="bk-event" onclick="bkEv(this)" data-ev="'+esc(JSON.stringify(e))+'"><span class="bk-event-dot" style="background:'+e.color+'"></span><span class="bk-event-name">'+e.name+'</span><span class="bk-event-dur">'+e.duration+' min</span></div>';});bkR(h);}).catch(function(){bkR('<div class="bk-err">Could not load. Try again.</div>');});}window.bkEv=function(el){s.event=JSON.parse(el.getAttribute('data-ev').replace(/&quot;/g,'"'));var n=new Date();s.yr=n.getFullYear();s.mo=n.getMonth();s.date=null;s.slot=null;bkCal();};function bkCal(){var DY=['Su','Mo','Tu','We','Th','Fr','Sa'],h='<button class="bk-back" onclick="bkLoad()">← Back</button><div style="font-size:14px;font-weight:600;margin-bottom:14px;">'+s.event.name+'</div><div class="bk-cal-nav"><button onclick="bkMo(-1)">‹</button><span>'+MN[s.mo]+' '+s.yr+'</span><button onclick="bkMo(1)">›</button></div><div class="bk-cal-grid">';DY.forEach(function(d){h+='<div class="bk-cal-dh">'+d+'</div>';});var fd=new Date(s.yr,s.mo,1).getDay(),td=new Date(s.yr,s.mo+1,0).getDate(),now=new Date();now.setHours(0,0,0,0);for(var i=0;i<fd;i++)h+='<div></div>';for(var d=1;d<=td;d++){var dt=new Date(s.yr,s.mo,d),ds=s.yr+'-'+pad(s.mo+1)+'-'+pad(d),past=dt<now,sel=s.date===ds;h+='<div class="bk-cal-day'+(past?'':' selectable')+(sel?' selected':'')+'"'+(past?'':' onclick="bkDay(\''+ds+'\')"')+'>'+d+'</div>';}h+='</div><div id="bkSlots"></div>';bkR(h);if(s.date)bkSl(s.date);}window.bkMo=function(d){s.mo+=d;if(s.mo<0){s.mo=11;s.yr--;}if(s.mo>11){s.mo=0;s.yr++;}bkCal();};window.bkDay=function(ds){s.date=ds;bkCal();};function bkSl(ds){var el=document.getElementById('bkSlots');if(el)el.innerHTML='<div class="bk-loading" style="padding:16px 0">Loading slots...</div>';fetch('/api/booking/'+sub+'/slots/'+s.event.id+'/'+ds).then(function(r){return r.json();}).then(function(d){var el2=document.getElementById('bkSlots');if(!el2)return;if(!d||!d.length){el2.innerHTML='<div class="bk-err" style="margin-top:12px;">No available slots on this date.</div>';return;}var h='<div style="font-size:12px;font-weight:700;color:var(--muted);margin:14px 0 8px;">AVAILABLE TIMES</div><div class="bk-slots">';d.forEach(function(sl){var sel=s.slot&&s.slot.time===sl.time;h+='<div class="bk-slot'+(sel?' selected':'')+'" onclick="bkSlot(\''+sl.time+'\',\''+sl.label+'\')">'+sl.label+'</div>';});h+='</div>';el2.innerHTML=h;}).catch(function(){var el2=document.getElementById('bkSlots');if(el2)el2.innerHTML='<div class="bk-err" style="margin-top:12px;">Failed to load slots.</div>';});}window.bkSlot=function(time,label){s.slot={time:time,label:label};var h='<button class="bk-back" onclick="bkCal()">← Back</button><div style="font-size:13px;color:var(--muted);margin-bottom:16px;padding:10px 12px;background:color-mix(in srgb,var(--accent) 8%,#fff);border-radius:10px;">📅 '+s.date+' at '+label+' · '+s.event.name+' ('+s.event.duration+' min)</div><div class="bk-form"><input type="text" id="bkN" placeholder="Your name *"><input type="email" id="bkE" placeholder="Email address *"><input type="tel" id="bkP" placeholder="Phone (optional)"><textarea id="bkT" placeholder="Notes (optional)"></textarea><div id="bkErr" class="bk-err" style="display:none"></div><button class="bk-submit" onclick="bkGo()">Confirm Booking</button></div>';bkR(h);};window.bkGo=function(){var name=v('bkN'),email=v('bkE'),phone=v('bkP'),notes=v('bkT'),err=document.getElementById('bkErr');if(!name||!email){show(err,'Please fill in name and email.');return;}hide(err);var btn=document.querySelector('.bk-submit');btn.disabled=true;btn.textContent='Confirming...';fetch('/api/booking/'+sub+'/create',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({event_id:s.event.id,booking_date:s.date,start_time:s.slot.time,booker_name:name,booker_email:email,booker_phone:phone,notes:notes})}).then(function(r){return r.json();}).then(function(d){if(d.ok){bkR('<div class="bk-success"><div class="bk-success-icon">✅</div><div class="bk-success-title">You\'re booked!</div><div class="bk-success-sub">'+s.event.name+'<br>'+s.date+' at '+s.slot.label+'</div></div>');}else{btn.disabled=false;btn.textContent='Confirm Booking';show(err,d.error||'Booking failed. Try again.');}}).catch(function(){btn.disabled=false;btn.textContent='Confirm Booking';show(err,'Network error.');});};function bkR(html){if(w)w.innerHTML=html;}function v(id){var el=document.getElementById(id);return el?el.value.trim():'';}function show(el,t){el.textContent=t;el.style.display='block';}function hide(el){el.style.display='none';}function pad(n){return String(n).padStart(2,'0');}function esc(s){return s.replace(/"/g,'&quot;');}})();
  </script>
  {% endif %}

  <!-- Save Contact -->
  {% if settings.contact.email != blank or settings.contact.phone != blank or settings.contact.whatsapp != blank %}
  <div class="save-contact-bar">
    <button class="save-contact-btn" onclick="pzSaveContact()"><i class="fa-solid fa-user-plus"></i> {{ settings.contact.save_label | default: 'Save Contact' }}</button>
  </div>
  {% endif %}

  <!-- Share -->
  <div class="share-bar">
    <button class="share-btn" onclick="pzShare()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share this page
    </button>
    <div class="share-toast" id="pzToast">✓ Link copied!</div>
  </div>

</div>
<script>
function pzToggle(id){var el=document.getElementById(id);el.classList.toggle('open');}
function pzSaveContact(){var n='{{ settings.profile.name | escape }}';var t='{{ settings.profile.title | default: "" | escape }}';var p='{{ settings.contact.phone | default: "" | escape }}';if(!p)p='{{ settings.contact.whatsapp | default: "" | escape }}';var e='{{ settings.contact.email | default: "" | escape }}';var w='{{ settings.contact.website | default: "" | escape }}';var vcf='BEGIN:VCARD\nVERSION:3.0\nFN:'+n+'\n'+(t?'TITLE:'+t+'\n':'')+(p?'TEL;TYPE=CELL:'+p+'\n':'')+(e?'EMAIL:'+e+'\n':'')+(w?'URL:'+w+'\n':'')+'URL:'+location.href+'\nEND:VCARD';var b=new Blob([vcf],{type:'text/vcard'});var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=(n||'contact').replace(/\s+/g,'-')+'.vcf';a.click();}
function pzShare(){var u=location.href,t=document.title;if(navigator.share){navigator.share({title:t,url:u});}else{var ta=document.createElement('textarea');ta.value=u;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);var el=document.getElementById('pzToast');el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2200);}}
</script>
</body>
</html>

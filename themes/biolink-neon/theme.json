{
  "name": "BioLink Neon",
  "slug": "biolink-neon",
  "author": "PageZapper",
  "version": "1.0",
  "description": "Dark neon aesthetic for creators who want to stand out. Glowing accents on a deep dark canvas.",
  "tags": ["biolink", "dark", "neon", "creator", "glow"],
  "for": ["linktree", "other"],
  "order": 5,

  "settings": {
    "colors": [
      { "id": "cyan",    "label": "Cyan",    "hex": "#06b6d4" },
      { "id": "violet",  "label": "Violet",  "hex": "#7c3aed" },
      { "id": "lime",    "label": "Lime",    "hex": "#84cc16" },
      { "id": "pink",    "label": "Pink",    "hex": "#ec4899" },
      { "id": "amber",   "label": "Amber",   "hex": "#f59e0b" },
      { "id": "sky",     "label": "Sky",     "hex": "#38bdf8" },
      { "id": "rose",    "label": "Rose",    "hex": "#f43f5e" },
      { "id": "teal",    "label": "Teal",    "hex": "#14b8a6" }
    ]
  },

  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "emoji": "👤",
      "description": "Your avatar, name, and bio.",
      "fields": [
        { "id": "avatar_emoji", "label": "Avatar Emoji", "type": "text",     "default": "✨" },
        { "id": "name",         "label": "Display Name", "type": "text",     "default": "Your Name" },
        { "id": "tagline",      "label": "Tagline",      "type": "text",     "default": "@yourhandle" },
        { "id": "bio",          "label": "Bio",          "type": "textarea", "default": "Creator · Based in India" }
      ]
    },
    {
      "id": "links",
      "label": "Links",
      "emoji": "🔗",
      "description": "Your main link buttons.",
      "fields": [
        {
          "id": "items", "label": "Links", "type": "list",
          "item_fields": [
            { "id": "emoji", "label": "Icon",  "type": "text", "default": "🌐" },
            { "id": "label", "label": "Label", "type": "text", "default": "My Website" },
            { "id": "url",   "label": "URL",   "type": "text", "default": "https://" },
            { "id": "style", "label": "Style", "type": "text", "default": "solid" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Social Icons",
      "emoji": "📱",
      "description": "Social platform links.",
      "fields": [
        { "id": "instagram", "label": "Instagram", "type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube",   "type": "text", "default": "" },
        { "id": "twitter",   "label": "Twitter/X", "type": "text", "default": "" },
        { "id": "tiktok",    "label": "TikTok",    "type": "text", "default": "" },
        { "id": "linkedin",  "label": "LinkedIn",  "type": "text", "default": "" },
        { "id": "github",    "label": "GitHub",    "type": "text", "default": "" }
      ]
    },
    {
      "id": "contact_card",
      "label": "Contact Card",
      "emoji": "📇",
      "description": "Phone, email, address and save-to-phone button.",
      "fields": [
        { "id": "phone",      "label": "Phone Number",    "type": "tel",  "default": "" },
        { "id": "email",      "label": "Email Address",   "type": "text", "default": "" },
        { "id": "website",    "label": "Website URL",     "type": "text", "default": "" },
        { "id": "address",    "label": "Address",         "type": "text", "default": "" },
        { "id": "maps_url",   "label": "Directions URL",  "type": "text", "default": "" },
        { "id": "save_label", "label": "Save Button Text","type": "text", "default": "💾 Save Contact" }
      ]
    },
    {
      "id": "whatsapp_widget",
      "label": "WhatsApp Widget",
      "emoji": "💬",
      "description": "Floating WhatsApp button.",
      "fields": [
        { "id": "phone",   "label": "WhatsApp Number",    "type": "tel",  "default": "" },
        { "id": "message", "label": "Pre-filled Message", "type": "text", "default": "Hi!" },
        { "id": "label",   "label": "Bubble Label",       "type": "text", "default": "Chat" }
      ]
    }
  ]
}

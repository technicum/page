{
  "name": "BioLink Card",
  "slug": "biolink-card",
  "author": "PageZapper",
  "version": "1.0",
  "description": "Bold card-based layout. Large visuals, strong typography — great for businesses and influencers.",
  "tags": ["biolink", "card", "bold", "business", "creator"],
  "for": ["linktree", "other"],
  "order": 6,

  "settings": {
    "colors": [
      { "id": "indigo",  "label": "Indigo",  "hex": "#4f46e5" },
      { "id": "rose",    "label": "Rose",    "hex": "#e11d48" },
      { "id": "emerald", "label": "Emerald", "hex": "#059669" },
      { "id": "amber",   "label": "Amber",   "hex": "#d97706" },
      { "id": "sky",     "label": "Sky",     "hex": "#0284c7" },
      { "id": "violet",  "label": "Violet",  "hex": "#7c3aed" },
      { "id": "ink",     "label": "Ink",     "hex": "#1a1a18" },
      { "id": "pink",    "label": "Pink",    "hex": "#db2777" }
    ]
  },

  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "emoji": "👤",
      "description": "Your avatar, name, and bio.",
      "fields": [
        { "id": "avatar_emoji", "label": "Avatar Emoji", "type": "text",     "default": "✨" },
        { "id": "name",         "label": "Display Name", "type": "text",     "default": "Your Name" },
        { "id": "tagline",      "label": "Tagline",      "type": "text",     "default": "@yourhandle" },
        { "id": "bio",          "label": "Bio",          "type": "textarea", "default": "Creator · Based in India" }
      ]
    },
    {
      "id": "links",
      "label": "Links",
      "emoji": "🔗",
      "description": "Your main link buttons.",
      "fields": [
        {
          "id": "items", "label": "Links", "type": "list",
          "item_fields": [
            { "id": "emoji", "label": "Icon",  "type": "text", "default": "🌐" },
            { "id": "label", "label": "Label", "type": "text", "default": "My Website" },
            { "id": "url",   "label": "URL",   "type": "text", "default": "https://" },
            { "id": "style", "label": "Style", "type": "text", "default": "solid" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Social Icons",
      "emoji": "📱",
      "description": "Social platform links.",
      "fields": [
        { "id": "instagram", "label": "Instagram", "type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube",   "type": "text", "default": "" },
        { "id": "twitter",   "label": "Twitter/X", "type": "text", "default": "" },
        { "id": "tiktok",    "label": "TikTok",    "type": "text", "default": "" },
        { "id": "linkedin",  "label": "LinkedIn",  "type": "text", "default": "" },
        { "id": "github",    "label": "GitHub",    "type": "text", "default": "" }
      ]
    },
    {
      "id": "contact_card",
      "label": "Contact Card",
      "emoji": "📇",
      "description": "Phone, email, address and save-to-phone button.",
      "fields": [
        { "id": "phone",      "label": "Phone Number",    "type": "tel",  "default": "" },
        { "id": "email",      "label": "Email Address",   "type": "text", "default": "" },
        { "id": "website",    "label": "Website URL",     "type": "text", "default": "" },
        { "id": "address",    "label": "Address",         "type": "text", "default": "" },
        { "id": "maps_url",   "label": "Directions URL",  "type": "text", "default": "" },
        { "id": "save_label", "label": "Save Button Text","type": "text", "default": "💾 Save Contact" }
      ]
    },
    {
      "id": "products",
      "label": "Products & Services",
      "emoji": "🛍️",
      "fields": [
        { "id": "heading",      "label": "Section Heading",            "type": "text", "default": "Products & Services" },
        { "id": "display_mode", "label": "Display Mode (grid/slider)", "type": "text", "default": "grid" },
        { "id": "wa_phone",     "label": "WhatsApp Order Number",      "type": "tel",  "default": "" },
        {
          "id": "items", "label": "Products", "type": "list",
          "item_fields": [
            { "id": "emoji", "label": "Emoji",       "type": "text", "default": "📦" },
            { "id": "name",  "label": "Name",        "type": "text", "default": "My Product" },
            { "id": "price", "label": "Price",       "type": "text", "default": "₹999" },
            { "id": "desc",  "label": "Description", "type": "text", "default": "" },
            { "id": "image", "label": "Image URL",   "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "upi_pay",
      "label": "UPI Payment",
      "emoji": "💳",
      "fields": [
        { "id": "upi_id", "label": "UPI ID", "type": "text", "default": "" },
        { "id": "display_name", "label": "Display Name", "type": "text", "default": "" },
        { "id": "amount", "label": "Amount (optional)", "type": "text", "default": "" },
        { "id": "btn_label", "label": "Button Text", "type": "text", "default": "💳 Pay with UPI" }
      ]
    },
    {
      "id": "form_embed",
      "label": "Embed Form",
      "emoji": "📋",
      "description": "Embed any form from your Forms module using its Form ID.",
      "fields": [
        { "id": "form_id",    "label": "Form ID",              "type": "text", "default": "" },
        { "id": "heading",    "label": "Heading (optional)",    "type": "text", "default": "" },
        { "id": "subheading", "label": "Subheading (optional)", "type": "text", "default": "" }
      ]
    },
    {
      "id": "video_embed",
      "label": "Video Embed",
      "emoji": "🎬",
      "fields": [
        { "id": "url", "label": "YouTube URL", "type": "text", "default": "" },
        { "id": "caption", "label": "Caption", "type": "text", "default": "" }
      ]
    },
    {
      "id": "whatsapp_widget",
      "label": "WhatsApp Widget",
      "emoji": "💬",
      "description": "Floating WhatsApp button.",
      "fields": [
        { "id": "phone",   "label": "WhatsApp Number",    "type": "tel",  "default": "" },
        { "id": "message", "label": "Pre-filled Message", "type": "text", "default": "Hi!" },
        { "id": "label",   "label": "Bubble Label",       "type": "text", "default": "Chat" }
      ]
    }
  ]
}

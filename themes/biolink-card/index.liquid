<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.title }}</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/themes/biolink-card/style.css">
<style>:root{--c:{{ settings.accent_color }};--c15:{{ settings.accent_color }}26;--c30:{{ settings.accent_color }}4d;}</style>
</head>
<body>
<div class="page">

{% for section in sections %}
  {% unless section._hidden %}
  {% assign f = section.fields %}
  {% if section._isRow %}
  {{ rendered_sections[section.id] }}
  {% else %}
  {% if section.id == 'profile' %}
  <div class="pz-sec" data-pz="{{ section.id }}">
  <div class="profile">
    {% if f.avatar_url != '' and f.avatar_url != nil %}
    <img class="avatar-img" src="{{ f.avatar_url }}" alt="{{ f.name }}">
    {% else %}
    <div class="avatar">{{ f.avatar_emoji | default: '✨' }}</div>
    {% endif %}
    <div class="profile-name">{{ f.name | default: site.title }}</div>
    {% if f.tagline != '' and f.tagline != nil %}<div class="profile-handle">{{ f.tagline }}</div>{% endif %}
    {% if f.bio != '' and f.bio != nil %}<p class="profile-bio">{{ f.bio }}</p>{% endif %}
  </div>
  </div>
  <div class="page-body">
  {% else %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>

  {% if rendered_sections[section.id] %}
  {{ rendered_sections[section.id] }}

  {% elsif section.id == 'links' %}
  {% if f.items.size > 0 %}
  <div class="section-divider">Links</div>
  <div class="links-list">
    {% for item in f.items %}
    <a class="link-btn {{ item.style | default: 'solid' }}" href="{{ item.url | default: '#' }}" target="_blank" rel="noopener">
      {% if item.emoji != '' and item.emoji != nil %}<span class="link-emoji">{{ item.emoji }}</span>{% endif %}
      <span class="link-label">{{ item.label }}</span>
      <span class="link-arrow">›</span>
    </a>
    {% endfor %}
  </div>
  {% endif %}

  {% elsif section.id == 'socials' %}
  {% assign has_s = false %}
  {% if f.instagram != '' and f.instagram != nil %}{% assign has_s = true %}{% endif %}
  {% if f.youtube   != '' and f.youtube   != nil %}{% assign has_s = true %}{% endif %}
  {% if f.twitter   != '' and f.twitter   != nil %}{% assign has_s = true %}{% endif %}
  {% if f.tiktok    != '' and f.tiktok    != nil %}{% assign has_s = true %}{% endif %}
  {% if f.linkedin  != '' and f.linkedin  != nil %}{% assign has_s = true %}{% endif %}
  {% if f.github    != '' and f.github    != nil %}{% assign has_s = true %}{% endif %}
  {% if has_s %}
  <div class="section-divider">Find me on</div>
  <div class="socials-row">
    {% if f.instagram != '' and f.instagram != nil %}<a class="social-btn" href="{{ f.instagram }}" target="_blank">📸</a>{% endif %}
    {% if f.youtube   != '' and f.youtube   != nil %}<a class="social-btn" href="{{ f.youtube }}"   target="_blank">▶️</a>{% endif %}
    {% if f.twitter   != '' and f.twitter   != nil %}<a class="social-btn" href="{{ f.twitter }}"   target="_blank">𝕏</a>{% endif %}
    {% if f.tiktok    != '' and f.tiktok    != nil %}<a class="social-btn" href="{{ f.tiktok }}"    target="_blank">🎵</a>{% endif %}
    {% if f.linkedin  != '' and f.linkedin  != nil %}<a class="social-btn" href="{{ f.linkedin }}"  target="_blank">💼</a>{% endif %}
    {% if f.github    != '' and f.github    != nil %}<a class="social-btn" href="{{ f.github }}"    target="_blank">🐙</a>{% endif %}
  </div>
  {% endif %}

  {% elsif section.id == 'contact_card' %}
  {% assign has_c = false %}
  {% if f.phone   != '' and f.phone   != nil %}{% assign has_c = true %}{% endif %}
  {% if f.email   != '' and f.email   != nil %}{% assign has_c = true %}{% endif %}
  {% if f.address != '' and f.address != nil %}{% assign has_c = true %}{% endif %}
  {% if f.website != '' and f.website != nil %}{% assign has_c = true %}{% endif %}
  {% if has_c %}
  <div class="section-divider">Contact</div>
  <div class="contact-card">
    {% if f.phone   != '' and f.phone   != nil %}<a class="contact-row" href="tel:{{ f.phone }}"><span class="contact-icon">📞</span><span class="contact-text">{{ f.phone }}</span><span class="contact-arr">›</span></a>{% endif %}
    {% if f.email   != '' and f.email   != nil %}<a class="contact-row" href="mailto:{{ f.email }}"><span class="contact-icon">✉️</span><span class="contact-text">{{ f.email }}</span><span class="contact-arr">›</span></a>{% endif %}
    {% if f.website != '' and f.website != nil %}<a class="contact-row" href="{{ f.website }}" target="_blank"><span class="contact-icon">🌐</span><span class="contact-text">{{ f.website }}</span><span class="contact-arr">›</span></a>{% endif %}
    {% if f.address != '' and f.address != nil %}
    {% assign ml = f.maps_url %}{% if ml == '' or ml == nil %}{% assign ml = 'https://maps.google.com/?q=' | append: f.address %}{% endif %}
    <a class="contact-row" href="{{ ml }}" target="_blank"><span class="contact-icon">📍</span><span class="contact-text">{{ f.address }}</span><span class="contact-arr">›</span></a>
    {% endif %}
    <button class="save-contact-btn" data-name="{{ site.title }}" data-phone="{{ f.phone }}" data-email="{{ f.email }}" data-address="{{ f.address }}" data-website="{{ f.website }}" onclick="pzSaveContact(this)">{{ f.save_label | default: '💾 Save Contact' }}</button>
  </div>
  <script>if(!window.pzSaveContact){window.pzSaveContact=function(b){var v=['BEGIN:VCARD','VERSION:3.0'];if(b.dataset.name)v.push('FN:'+b.dataset.name);if(b.dataset.phone)v.push('TEL:'+b.dataset.phone);if(b.dataset.email)v.push('EMAIL:'+b.dataset.email);if(b.dataset.address)v.push('ADR:;;'+b.dataset.address+';;;;');if(b.dataset.website)v.push('URL:'+b.dataset.website);v.push('END:VCARD');var blob=new Blob([v.join('\r\n')],{type:'text/vcard;charset=utf-8'});var url=URL.createObjectURL(blob);var a=document.createElement('a');a.href=url;a.download=(b.dataset.name||'contact').replace(/[^a-z0-9]/gi,'-')+'.vcf';document.body.appendChild(a);a.click();setTimeout(function(){document.body.removeChild(a);URL.revokeObjectURL(url);},200);};}
  </script>
  {% endif %}

  {% elsif section.id == 'products' %}
  {% if f.items.size > 0 %}
  <div class="section-divider">{{ f.heading | default: 'Products & Services' }}</div>
  <div class="{% if f.display_mode == 'slider' %}products-slider{% else %}products-grid{% endif %}">
    {% for item in f.items %}
    <div class="product-card">
      {% if item.image != '' and item.image != nil %}<img class="product-img" src="{{ item.image }}" alt="{{ item.name }}">
      {% else %}<div class="product-emoji-box">{{ item.emoji | default: '📦' }}</div>{% endif %}
      <div class="product-info"><div class="product-name">{{ item.name }}</div>{% if item.desc != '' and item.desc != nil %}<div class="product-desc">{{ item.desc }}</div>{% endif %}<div class="product-price">{{ item.price }}</div></div>
      <button class="product-btn" onclick="pzAddToCart('{{ item.name }}','{{ item.price }}','{{ item.emoji | default: '📦' }}','{{ f.wa_phone }}')">Add to Cart</button>
    </div>
    {% endfor %}
  </div>
  <div class="pz-cart" id="pzCart"><div class="pz-cart-hdr"><span>🛒 Your Order</span><button class="pz-cart-close" onclick="pzCloseCart()">✕</button></div><div id="pzCartItems" class="pz-cart-items"></div><div class="pz-cart-footer"><div id="pzCartTotal" class="pz-cart-total"></div><button class="pz-cart-order" onclick="pzOrderWA()">📲 Order on WhatsApp</button></div></div>
  <button class="pz-cart-fab" id="pzCartFab" onclick="pzOpenCart()">🛒<span class="pz-cart-fab-badge" id="pzCartBadge">0</span></button>
  <div class="pz-overlay" id="pzOverlay" onclick="pzCloseCart()"></div>
  <script>if(!window._pzCartInit){window._pzCartInit=true;window._pzCart=[];window._pzWaPhone='';window.pzUpdateFab=function(){var total=window._pzCart.reduce(function(a,i){return a+i.qty;},0);var fab=document.getElementById('pzCartFab');var badge=document.getElementById('pzCartBadge');if(fab)fab.classList.toggle('visible',total>0);if(badge)badge.textContent=total;};window.pzAddToCart=function(n,p,e,wa){window._pzWaPhone=wa;var ex=window._pzCart.find(function(i){return i.name===n;});if(ex)ex.qty++;else window._pzCart.push({name:n,price:p,emoji:e,qty:1});pzRenderCart();pzUpdateFab();document.getElementById('pzCart').classList.add('open');document.getElementById('pzOverlay').classList.add('show');};window.pzOpenCart=function(){document.getElementById('pzCart').classList.add('open');document.getElementById('pzOverlay').classList.add('show');};window.pzCloseCart=function(){document.getElementById('pzCart').classList.remove('open');document.getElementById('pzOverlay').classList.remove('show');};window.pzQty=function(i,d){window._pzCart[i].qty+=d;if(window._pzCart[i].qty<=0)window._pzCart.splice(i,1);pzRenderCart();pzUpdateFab();if(!window._pzCart.length)pzCloseCart();};window.pzRenderCart=function(){var el=document.getElementById('pzCartItems');var tot=document.getElementById('pzCartTotal');if(!el)return;el.innerHTML=window._pzCart.map(function(item,i){return'<div class="pz-ci"><span class="pz-ci-n">'+item.emoji+' '+item.name+'</span><div class="pz-ci-r"><button onclick="pzQty('+i+',-1)">−</button><span>'+item.qty+'</span><button onclick="pzQty('+i+',1)">+</button><span class="pz-ci-p">'+item.price+'</span></div></div>';}).join('');var total=window._pzCart.reduce(function(a,i){return a+i.qty;},0);if(tot)tot.innerHTML='<strong>'+total+'</strong> item'+(total!==1?'s':'')+' in cart';};window.pzOrderWA=function(){if(!window._pzCart.length)return;var lines=['Hello! I want to order:'];window._pzCart.forEach(function(i){lines.push('• '+i.qty+'x '+i.name+' — '+i.price);});var ph=window._pzWaPhone.replace(/\D/g,'');window.open('https://wa.me/'+ph+'?text='+encodeURIComponent(lines.join('\n')),'_blank');};}</script>
  {% endif %}

  {% elsif section.id == 'upi_pay' %}
  {% if f.upi_id != '' and f.upi_id != nil %}
  <div class="section-divider">Pay</div>
  <div class="upi-card" data-upi="{{ f.upi_id }}" data-name="{{ f.display_name }}" data-amount="{{ f.amount }}">
    <div class="upi-top-bar"></div>
    <div class="upi-body">
      <div class="upi-badge">💳 UPI Payment</div>
      <div class="upi-qr-wrap"><img class="upi-qr" src="" alt="UPI QR"></div>
      <div class="upi-id">{{ f.upi_id }}</div>
      {% if f.amount != '' and f.amount != nil %}<div class="upi-amount">₹{{ f.amount }}</div>{% endif %}
      <a class="upi-btn" href="#">{{ f.btn_label | default: '💳 Pay with UPI' }}</a>
      <div class="upi-apps"><span class="upi-app">GPay</span><span class="upi-app">PhonePe</span><span class="upi-app">Paytm</span><span class="upi-app">BHIM</span></div>
      <div class="upi-hint">📷 Scan QR or tap button to pay</div>
    </div>
  </div>
  <script>(function(){var c=document.querySelector('.upi-card[data-upi]');if(!c)return;var link='upi://pay?pa='+encodeURIComponent(c.dataset.upi)+'&pn='+encodeURIComponent(c.dataset.name||'')+'&cu=INR';if(c.dataset.amount)link+='&am='+encodeURIComponent(c.dataset.amount);var qr=c.querySelector('.upi-qr');if(qr)qr.src='https://chart.googleapis.com/chart?chs=180x180&cht=qr&chco=000000&chf=bg,s,FFFFFF00&chl='+encodeURIComponent(link);var btn=c.querySelector('.upi-btn');if(btn)btn.href=link;})();</script>
  {% endif %}

  {% elsif section.id == 'video_embed' %}
  {% if f.url != '' and f.url != nil %}
  <div class="video-wrap" data-url="{{ f.url }}"><div class="video-container"><iframe class="video-iframe" src="" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe></div>{% if f.caption != '' and f.caption != nil %}<div class="video-caption">{{ f.caption }}</div>{% endif %}</div>
  <script>(function(){var w=document.querySelector('.video-wrap[data-url]');if(!w)return;var url=w.dataset.url||'';var yt=url.match(/(?:youtube\.com\/(?:watch\?v=|shorts\/|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);if(yt){var f=w.querySelector('iframe');if(f)f.src='https://www.youtube.com/embed/'+yt[1]+'?rel=0';}})();</script>
  {% endif %}

  {% elsif section.id == 'whatsapp_widget' %}
  {% if f.phone != '' and f.phone != nil %}
  {% assign wa_msg = f.message | default: 'Hi!' | url_encode %}
  <div class="wa-widget"><a class="wa-bubble" href="https://wa.me/{{ f.phone | wa }}?text={{ wa_msg }}" target="_blank">💬 {{ f.label | default: 'Chat' }}</a></div>
  {% endif %}

  {% endif %}
  </div>
  {% endif %}
  {% endif %}
  {% endunless %}
{% endfor %}
</div>

<div class="bio-footer">Powered by <a href="{{ app_url }}">{{ app_name }}</a></div>
</div>
</body>
</html>

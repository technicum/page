{
  "name": "Shop Link",
  "description": "Biolink for ecommerce & product sellers — product grid, order links, contact.",
  "for": ["linktree"],
  "categories": ["retail", "restaurant", "technology"],
  "preview": "preview.jpg",
  "sections": [
    {
      "id": "profile",
      "label": "Shop Profile",
      "fields": [
        { "id": "logo",    "label": "Shop Logo URL",  "type": "image",    "default": "" },
        { "id": "name",    "label": "Shop Name",      "type": "text",     "default": "My Online Store" },
        { "id": "tagline", "label": "Tagline",        "type": "text",     "default": "Quality products, fast delivery" },
        { "id": "accent",  "label": "Accent Color",   "type": "color",    "default": "#f97316" }
      ]
    },
    {
      "id": "products",
      "label": "Products",
      "fields": [
        { "id": "heading",           "label": "Section Heading",                       "type": "text", "default": "Our Products" },
        { "id": "display_mode",      "label": "Display (grid / slider)",               "type": "text", "default": "grid" },
        { "id": "order_on_whatsapp", "label": "Order on WhatsApp (yes / no)",          "type": "text", "default": "no" },
        { "id": "items", "label": "Products", "type": "repeater",
          "default": [
            { "image": "", "name": "Product One",   "price": "₹499",  "link": "" },
            { "image": "", "name": "Product Two",   "price": "₹799",  "link": "" },
            { "image": "", "name": "Product Three", "price": "₹1299", "link": "" }
          ],
          "item_fields": [
            { "id": "image", "label": "Product Image URL",                          "type": "image", "default": "" },
            { "id": "name",  "label": "Product Name",                               "type": "text",  "default": "New Product" },
            { "id": "price", "label": "Price",                                      "type": "text",  "default": "₹499" },
            { "id": "link",  "label": "Buy Link URL (if set, redirects instead of cart)", "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Quick Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "emoji": "🛍️", "label": "Shop All Products", "url": "", "primary": "yes" },
            { "emoji": "⭐", "label": "Read Our Reviews",  "url": "", "primary": "no" }
          ],
          "item_fields": [
            { "id": "emoji",   "label": "Emoji",            "type": "text", "default": "🛍️" },
            { "id": "label",   "label": "Label",            "type": "text", "default": "Visit Store" },
            { "id": "url",     "label": "URL",              "type": "text", "default": "" },
            { "id": "primary", "label": "Primary (yes/no)", "type": "text", "default": "no" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Socials",
      "fields": [
        { "id": "heading",    "label": "Section Heading",          "type": "text",  "default": "Follow us" },
        { "id": "sub",        "label": "Sub Heading (leave blank to hide)", "type": "text", "default": "" },
        { "id": "icon_color", "label": "Icon Color",                "type": "color", "default": "" },
        { "id": "icon_size",  "label": "Icon Size (sm / md / lg / xl)", "type": "text", "default": "md" },
        { "id": "instagram", "label": "Instagram URL",   "type": "text", "default": "" },
        { "id": "facebook",  "label": "Facebook URL",    "type": "text", "default": "" },
        { "id": "twitter",   "label": "Twitter / X URL", "type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube URL",     "type": "text", "default": "" },
        { "id": "tiktok",    "label": "TikTok URL",      "type": "text", "default": "" },
        { "id": "pinterest", "label": "Pinterest URL",   "type": "text", "default": "" }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "whatsapp",     "label": "WhatsApp Number (for cart orders)", "type": "text", "default": "" },
        { "id": "checkout_url", "label": "Checkout / Order URL (for cart)",  "type": "text", "default": "" },
        { "id": "phone",        "label": "Phone Number",                      "type": "text", "default": "" },
        { "id": "email",        "label": "Email",                             "type": "text", "default": "" },
        { "id": "website",      "label": "Website URL",                       "type": "text", "default": "" },
        { "id": "address",      "label": "Address",                           "type": "text", "default": "" },
        { "id": "save_label",   "label": "Save Contact Button Label",         "type": "text", "default": "💾 Save Contact" }
      ]
    },
    {
      "id": "booking",
      "label": "Booking",
      "fields": [
        { "id": "show",    "label": "Show Booking Widget (yes / no)", "type": "text", "default": "yes" },
        { "id": "heading", "label": "Section Heading",                "type": "text", "default": "Book a Meeting" }
      ]
    }
  ]
}

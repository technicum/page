<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ settings.profile.name }}</title>
<link rel="stylesheet" href="/themes/biolink-shop/assets/css/style.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --accent: {{ settings.profile.accent | default: '#f97316' }};
  --ink: #1a1a18; --muted: #6b6b66; --border: #e5e5e2;
  --bg: #fafaf8; --white: #fff; --radius: 14px;
}
</style>
</head>
<body>
<div class="page">

  <!-- Profile -->
  <div class="profile">
    {% if settings.profile.logo != blank %}
      <img class="avatar" src="{{ settings.profile.logo }}" alt="{{ settings.profile.name }}">
    {% else %}
      <div class="avatar-ph">{{ settings.profile.name | slice: 0, 1 | upcase }}</div>
    {% endif %}
    <div class="shop-name">{{ settings.profile.name }}</div>
    {% if settings.profile.tagline %}<div class="tagline">{{ settings.profile.tagline }}</div>{% endif %}
  </div>

  <!-- Links (always visible) -->
  {% assign l = settings.links %}
  {% if l.items and l.items.size > 0 %}
  <div class="links" style="margin-bottom:20px;">
    {% for item in l.items %}
    <a class="link-btn" href="{{ item.url }}" target="_blank">
      {% if item.emoji %}<span class="link-emoji">{{ item.emoji }}</span>{% endif %}
      {{ item.label }}
    </a>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Accordion: Products -->
  {% assign p = settings.products %}
  {% if p.items and p.items.size > 0 %}
  <div class="pz-sections">
    <div class="pz-sec" id="sec-products">
      <div class="pz-sec-head" onclick="pzToggle('sec-products')">
        <div class="pz-sec-icon">🛍</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ p.heading | default: 'Our Products' }}</div>
          <div class="pz-sec-sub">{{ p.items.size }} item{% if p.items.size != 1 %}s{% endif %}</div>
        </div>
        <div class="pz-sec-right">
          <span class="pz-count">{{ p.items.size }}</span>
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner">
          {% if p.display_mode == 'slider' %}
            <div class="pz-slider-wrap" id="pzWrap">
              <div class="pz-slider-track" id="pzTrack">
                {% for item in p.items %}
                <div class="product-card">
                  {% if item.image != blank %}<img class="product-img" src="{{ item.image }}" alt="{{ item.name }}" data-thumb="{{ item.image }}">
                  {% else %}<div class="product-img-ph" data-thumb="">🛍</div>{% endif %}
                  <div class="product-info">
                    <div class="product-name">{{ item.name }}</div>
                    <div class="product-price">{{ item.price }}</div>
                    <button class="product-btn" onclick="pzAddToCart(this,'{{ item.name | escape }}','{{ item.price | escape }}','{{ item.image | escape }}')">🛒 Add to Cart</button>
                  </div>
                </div>
                {% endfor %}
              </div>
              <div class="pz-slider-arrows">
                <button class="pz-slider-arrow" onclick="pzSlide(-1)">‹</button>
                <button class="pz-slider-arrow" onclick="pzSlide(1)">›</button>
              </div>
            </div>
            <div class="pz-slider-dots" id="pzDots"></div>
          {% else %}
            <div class="products-grid">
              {% for item in p.items %}
              <div class="product-card">
                {% if item.image != blank %}<img class="product-img" src="{{ item.image }}" alt="{{ item.name }}">
                {% else %}<div class="product-img-ph">🛍</div>{% endif %}
                <div class="product-info">
                  <div class="product-name">{{ item.name }}</div>
                  <div class="product-price">{{ item.price }}</div>
                  <button class="product-btn" onclick="pzAddToCart(this,'{{ item.name | escape }}','{{ item.price | escape }}','{{ item.image | escape }}')">🛒 Add to Cart</button>
                </div>
              </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Socials accordion -->
  {% assign s = settings.socials %}
  {% if s.instagram != blank or s.facebook != blank or s.twitter != blank or s.youtube != blank or s.tiktok != blank or s.pinterest != blank %}
  <div class="pz-sections">
    <div class="pz-sec" id="sec-socials">
      <div class="pz-sec-head" onclick="pzToggle('sec-socials')">
        <div class="pz-sec-icon">📱</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ s.heading | default: 'Follow us' }}</div>
          {% if s.sub != blank %}<div class="pz-sec-sub">{{ s.sub }}</div>{% endif %}
        </div>
        <div class="pz-sec-right">
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        {% assign _sz = 58 %}{% assign _fz = 24 %}
        {% if s.icon_size == 'sm' %}{% assign _sz = 44 %}{% assign _fz = 18 %}{% endif %}
        {% if s.icon_size == 'lg' %}{% assign _sz = 70 %}{% assign _fz = 30 %}{% endif %}
        {% if s.icon_size == 'xl' %}{% assign _sz = 86 %}{% assign _fz = 38 %}{% endif %}
        <style>#sec-socials .soc-icon{width:{{ _sz }}px;height:{{ _sz }}px;font-size:{{ _fz }}px;{% if s.icon_color != blank %}color:{{ s.icon_color }};border-color:{{ s.icon_color }};background:{{ s.icon_color }}1a;{% endif %}}{% if s.icon_color != blank %}#sec-socials .soc-icon:hover{background:{{ s.icon_color }};color:#fff;}{% endif %}</style>
        <div class="pz-sec-inner" style="padding:20px 16px;text-align:center;">
          <div class="social-row">
            {% if s.instagram != blank %}<a class="soc-icon" href="{{ s.instagram }}" target="_blank" title="Instagram"><i class="fa-brands fa-instagram"></i></a>{% endif %}
            {% if s.facebook != blank %}<a class="soc-icon" href="{{ s.facebook }}" target="_blank" title="Facebook"><i class="fa-brands fa-facebook"></i></a>{% endif %}
            {% if s.twitter != blank %}<a class="soc-icon" href="{{ s.twitter }}" target="_blank" title="Twitter"><i class="fa-brands fa-x-twitter"></i></a>{% endif %}
            {% if s.youtube != blank %}<a class="soc-icon" href="{{ s.youtube }}" target="_blank" title="YouTube"><i class="fa-brands fa-youtube"></i></a>{% endif %}
            {% if s.tiktok != blank %}<a class="soc-icon" href="{{ s.tiktok }}" target="_blank" title="TikTok"><i class="fa-brands fa-tiktok"></i></a>{% endif %}
            {% if s.pinterest != blank %}<a class="soc-icon" href="{{ s.pinterest }}" target="_blank" title="Pinterest"><i class="fa-brands fa-pinterest"></i></a>{% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Contact actions -->
  {% assign c = settings.contact %}
  {% if c.whatsapp != blank or c.phone != blank or c.email != blank %}
  <div class="socials" style="margin-top:16px;margin-bottom:8px;">
    {% if c.whatsapp != blank %}<a class="soc-btn" href="https://wa.me/{{ c.whatsapp | remove: '+' | remove: ' ' }}" target="_blank"><i class="fa-brands fa-whatsapp"></i> WhatsApp</a>{% endif %}
    {% if c.phone != blank %}<a class="soc-btn" href="tel:{{ c.phone }}"><i class="fa-solid fa-phone"></i> Call</a>{% endif %}
    {% if c.email != blank %}<a class="soc-btn" href="mailto:{{ c.email }}"><i class="fa-solid fa-envelope"></i> Email</a>{% endif %}
  </div>
  {% endif %}

  <!-- Save Contact -->
  {% if c.email != blank or c.phone != blank or c.whatsapp != blank %}
  <div class="save-contact-bar">
    <button class="save-contact-btn" onclick="pzSaveContact()"><i class="fa-solid fa-user-plus"></i> {{ c.save_label | default: 'Save Contact' }}</button>
  </div>
  {% endif %}

  <!-- Floating Cart Button -->
  <button class="pz-cart-fab hidden" id="pzCartFab" onclick="pzOpenCart()">
    🛒 <span id="pzCartLabel">Cart</span>
    <span class="pz-cart-badge" id="pzCartBadge">0</span>
  </button>

  <!-- Cart Overlay -->
  <div class="pz-cart-overlay" id="pzCartOverlay" onclick="pzCloseCart()"></div>

  <!-- Cart Drawer -->
  <div class="pz-cart-drawer closed" id="pzCartDrawer">
    <div class="pz-cart-header">
      <span class="pz-cart-title">🛒 Your Cart</span>
      <button class="pz-cart-close" onclick="pzCloseCart()">×</button>
    </div>
    <div class="pz-cart-items" id="pzCartItems">
      <div class="pz-cart-empty">Your cart is empty</div>
    </div>
    <div class="pz-cart-footer">
      <div class="pz-cart-total">
        <span>Total</span>
        <span id="pzCartTotal">₹0</span>
      </div>
      <button class="pz-cart-wa-btn" onclick="pzWhatsAppOrder()">
        <svg style="vertical-align:middle;margin-right:6px;" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Order via WhatsApp
      </button>
    </div>
  </div>

  <!-- Share -->
  <div class="share-bar">
    <button class="share-btn" onclick="pzShare()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share this page
    </button>
    <div class="share-toast" id="pzToast">✓ Link copied!</div>
  </div>

</div>
<script src="/themes/biolink-shop/assets/js/slider.js"></script>
<script>
// ── Accordion ────────────────────────────────────────────────────────────────
function pzToggle(id){var el=document.getElementById(id);el.classList.toggle('open');}

// ── Save Contact ──────────────────────────────────────────────────────────────
function pzSaveContact(){var n='{{ settings.profile.name | escape }}';var p='{{ settings.contact.phone | default: "" | escape }}';if(!p)p='{{ settings.contact.whatsapp | default: "" | escape }}';var e='{{ settings.contact.email | default: "" | escape }}';var w='{{ settings.contact.website | default: "" | escape }}';var vcf='BEGIN:VCARD\nVERSION:3.0\nFN:'+n+'\n'+(p?'TEL;TYPE=CELL:'+p+'\n':'')+(e?'EMAIL:'+e+'\n':'')+(w?'URL:'+w+'\n':'')+'URL:'+location.href+'\nEND:VCARD';var b=new Blob([vcf],{type:'text/vcard'});var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=(n||'contact').replace(/\s+/g,'-')+'.vcf';a.click();}

// ── Cart ──────────────────────────────────────────────────────────────────────
var pzCart = [];

function pzAddToCart(btn, name, price, image) {
  var existing = pzCart.find(function(i){ return i.name === name; });
  if (existing) {
    existing.qty++;
  } else {
    pzCart.push({ name: name, price: price, image: image, qty: 1 });
  }
  btn.textContent = '✓ Added';
  btn.classList.add('added');
  setTimeout(function(){ btn.textContent = '🛒 Add to Cart'; btn.classList.remove('added'); }, 1200);
  pzUpdateCartUI();
}

function pzUpdateCartUI() {
  var total = pzCart.reduce(function(s,i){ return s + i.qty; }, 0);
  document.getElementById('pzCartBadge').textContent = total;
  document.getElementById('pzCartLabel').textContent = 'Cart (' + total + ')';
  var fab = document.getElementById('pzCartFab');
  if (total > 0) fab.classList.remove('hidden'); else fab.classList.add('hidden');

  var container = document.getElementById('pzCartItems');
  if (pzCart.length === 0) {
    container.innerHTML = '<div class="pz-cart-empty">Your cart is empty</div>';
    document.getElementById('pzCartTotal').textContent = '';
    return;
  }

  var html = '';
  pzCart.forEach(function(item, idx) {
    var thumb = item.image
      ? '<img class="pz-cart-item-thumb" src="' + item.image + '" alt="">'
      : '<div class="pz-cart-item-thumb-ph">🛍</div>';
    html += '<div class="pz-cart-item">' +
      thumb +
      '<div class="pz-cart-item-info">' +
        '<div class="pz-cart-item-name">' + item.name + '</div>' +
        '<div class="pz-cart-item-price">' + item.price + '</div>' +
      '</div>' +
      '<div class="pz-cart-item-qty">' +
        '<button class="pz-cart-qty-btn" onclick="pzQty(' + idx + ',-1)">−</button>' +
        '<span class="pz-cart-qty-num">' + item.qty + '</span>' +
        '<button class="pz-cart-qty-btn" onclick="pzQty(' + idx + ',1)">+</button>' +
      '</div>' +
    '</div>';
  });
  container.innerHTML = html;

  // Compute total if prices are numeric (strip non-numeric except . , )
  var sum = 0;
  var allNumeric = true;
  var prefix = '';
  pzCart.forEach(function(item) {
    var p = item.price || '';
    // Extract prefix (currency symbol)
    var match = p.match(/^([^\d]*)(\d[\d,.]*)$/);
    if (match) {
      prefix = prefix || match[1];
      var num = parseFloat(match[2].replace(/,/g, ''));
      if (!isNaN(num)) { sum += num * item.qty; } else { allNumeric = false; }
    } else { allNumeric = false; }
  });
  document.getElementById('pzCartTotal').textContent = allNumeric
    ? prefix + sum.toLocaleString('en-IN')
    : '';
}

function pzQty(idx, delta) {
  pzCart[idx].qty += delta;
  if (pzCart[idx].qty <= 0) pzCart.splice(idx, 1);
  pzUpdateCartUI();
}

function pzOpenCart() {
  document.getElementById('pzCartDrawer').classList.remove('closed');
  document.getElementById('pzCartOverlay').classList.add('show');
}

function pzCloseCart() {
  document.getElementById('pzCartDrawer').classList.add('closed');
  document.getElementById('pzCartOverlay').classList.remove('show');
}

function pzWhatsAppOrder() {
  var shopName = document.title || 'your shop';
  var waNum = '{{ settings.contact.whatsapp | remove: "+" | remove: " " | remove: "-" }}';
  if (!waNum) { alert('WhatsApp number not configured.'); return; }

  var lines = ['Hello! I want to order from ' + shopName + ':'];
  pzCart.forEach(function(item, i) {
    lines.push((i+1) + '. ' + item.name + ' × ' + item.qty + ' — ' + item.price);
  });
  var totalEl = document.getElementById('pzCartTotal').textContent;
  if (totalEl) lines.push('Total: ' + totalEl);
  lines.push('\nPlease confirm my order. Thank you!');

  var msg = lines.join('\n');
  var url = 'https://wa.me/' + waNum + '?text=' + encodeURIComponent(msg);
  window.open(url, '_blank');
}

function pzShare(){var u=location.href,t=document.title;if(navigator.share){navigator.share({title:t,url:u});}else{var ta=document.createElement('textarea');ta.value=u;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);var el=document.getElementById('pzToast');el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2200);}}
</script>
</body>
</html>

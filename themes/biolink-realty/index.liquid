  if(!wrap)return;
  wrap.querySelectorAll('button').forEach(function(b){b.disabled=true;b.style.opacity=b===btn?'1':'.4';});
  btn.style.borderColor='currentColor';btn.style.fontWeight='700';
  if(res)res.style.display='block';
  fetch('/track',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({event:'poll_vote',poll_id:pollId,option:idx,url:location.href})}).catch(function(){});
}

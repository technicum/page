  <div style="display:flex;justify-content:center;gap:12px;" id="cd-display-{{ block.id }}">
    <div style="text-align:center;"><span style="font-size:32px;font-weight:800;line-height:1;" id="cd-d-{{ block.id }}">--</span><div style="font-size:10px;opacity:.5;margin-top:2px;font-weight:600;letter-spacing:.5px;">DAYS</div></div>
    <div style="font-size:28px;font-weight:300;opacity:.3;line-height:1.2;">:</div>
    <div style="text-align:center;"><span style="font-size:32px;font-weight:800;line-height:1;" id="cd-h-{{ block.id }}">--</span><div style="font-size:10px;opacity:.5;margin-top:2px;font-weight:600;letter-spacing:.5px;">HRS</div></div>
    <div style="font-size:28px;font-weight:300;opacity:.3;line-height:1.2;">:</div>
    <div style="text-align:center;"><span style="font-size:32px;font-weight:800;line-height:1;" id="cd-m-{{ block.id }}">--</span><div style="font-size:10px;opacity:.5;margin-top:2px;font-weight:600;letter-spacing:.5px;">MINS</div></div>
    <div style="font-size:28px;font-weight:300;opacity:.3;line-height:1.2;">:</div>
    <div style="text-align:center;"><span style="font-size:32px;font-weight:800;line-height:1;" id="cd-s-{{ block.id }}">--</span><div style="font-size:10px;opacity:.5;margin-top:2px;font-weight:600;letter-spacing:.5px;">SECS</div></div>
  </div>
  {% if block.btn_text != blank and block.btn_url != blank %}

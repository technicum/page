<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
{% assign _app = settings.appearance %}
{% assign _bg_color = _app.bgColor | default: '#ffffff' %}
{% assign _btn_color = _app.btnColor | default: '#6366f1' %}
{% assign _btn_text_color = _app.btnTextColor | default: '#ffffff' %}
{% assign _btn_radius = _app.btnRadius | default: '8' %}
{% assign _btn_style = _app.btnStyle | default: 'filled' %}
{% assign _font = _app.fontFamily | default: 'Inter' %}
{% assign _text_color = _app.textColor | default: '#1a1a1a' %}
{% assign _bg_type = _app.bgType | default: 'color' %}
{% assign _bg_gradient = _app.bgGradient | default: 'linear-gradient(135deg,#667eea 0%,#764ba2 100%)' %}
{% assign _bg_image = _app.bgImage | default: '' %}
{% assign _avatar_block = nil %}
{% for b in settings.blocks %}{% if b.type == 'avatar' %}{% assign _avatar_block = b %}{% break %}{% endif %}{% endfor %}
{% assign _seo = settings.seo %}
{% assign _pg_title = _seo.title | default: _avatar_block.name | default: site.title %}
{% assign _pg_desc = _seo.description | default: _avatar_block.bio | default: '' %}
<title>{{ _pg_title }}</title>
<meta name="description" content="{{ _pg_desc }}">
{% if _seo.noindex %}<meta name="robots" content="noindex">{% endif %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family={{ _font }}:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{
  font-family:'{{ _font }}',system-ui,sans-serif;
  color:{{ _text_color }};
  min-height:100vh;
  {% if _bg_type == 'gradient' %}
  background:{{ _bg_gradient }};
  {% elsif _bg_type == 'image' %}
  {% if _bg_image != '' %}
  background:url('{{ _bg_image }}') center/cover no-repeat fixed;
  {% else %}
  background:{{ _bg_color }};
  {% endif %}
  {% else %}
  background:{{ _bg_color }};
  {% endif %}
}
.page-wrap{max-width:480px;margin:0 auto;padding:32px 16px 60px;}
.block{margin-bottom:12px;}
.b-avatar{text-align:center;padding:24px 0 8px;}
.b-avatar .av-wrap{position:relative;width:88px;height:88px;margin:0 auto 14px;animation:av-pop .65s cubic-bezier(.34,1.56,.64,1) both,av-float 4s 1.2s ease-in-out infinite;}
.b-avatar .av-ring{position:absolute;inset:-7px;border-radius:50%;border:2.5px solid transparent;border-top-color:{{ _btn_color }};border-right-color:{{ _btn_color }}88;animation:av-spin 2.4s linear infinite;}
.b-avatar .av-ring-2{position:absolute;inset:-14px;border-radius:50%;border:1.5px solid transparent;border-bottom-color:{{ _btn_color }}44;border-left-color:{{ _btn_color }}44;animation:av-spin 4.5s linear infinite reverse;}
.b-avatar .av-img,.b-avatar .av-ph{position:absolute;inset:0;width:100%;height:100%;border-radius:50%;display:flex;object-fit:cover;}
.b-avatar .av-ph{align-items:center;justify-content:center;font-size:34px;font-weight:700;background:{{ _btn_color }};color:{{ _btn_text_color }};}
.b-avatar h1{font-size:21px;font-weight:700;margin-bottom:5px;}
.b-avatar .av-bio{font-size:14px;line-height:1.55;opacity:0.72;}
@keyframes av-spin{to{transform:rotate(360deg)}}
@keyframes av-pop{from{opacity:0;transform:scale(.65)}to{opacity:1;transform:scale(1)}}
@keyframes av-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.b-link a{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px 20px;border-radius:{{ _btn_radius }}px;font-size:15px;font-weight:600;text-decoration:none;transition:transform .15s,opacity .15s;{% if _btn_style == 'outline' %}border:2px solid {{ _btn_color }};color:{{ _btn_color }};background:transparent;{% elsif _btn_style == 'soft' %}background:{{ _btn_color }}22;color:{{ _btn_color }};border:none;{% elsif _btn_style == 'shadow' %}background:{{ _btn_color }};color:{{ _btn_text_color }};border:none;box-shadow:0 4px 14px {{ _btn_color }}55;{% else %}background:{{ _btn_color }};color:{{ _btn_text_color }};border:none;{% endif %}}
.b-link a:hover{transform:translateY(-2px);opacity:.9;}
.b-link .lk-icon{font-size:18px;flex-shrink:0;}
.b-link .lk-thumb{width:34px;height:34px;border-radius:6px;object-fit:cover;flex-shrink:0;}
.b-heading{padding:6px 0;}.b-heading h1{font-size:28px;font-weight:700;}.b-heading h2{font-size:21px;font-weight:600;}.b-heading h3{font-size:16px;font-weight:500;opacity:.75;}
.b-paragraph p{font-size:14px;line-height:1.65;opacity:.8;}
.b-image img{width:100%;border-radius:12px;display:block;}.b-image .img-caption{font-size:12px;text-align:center;opacity:.6;margin-top:6px;}
.b-socials .soc-row{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;padding:4px 0;}
.b-socials a{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;text-decoration:none;background:rgba(0,0,0,0.07);color:{{ _text_color }};transition:background .15s,color .15s;}
.b-socials a:hover{background:{{ _btn_color }};color:{{ _btn_text_color }};}
.b-collector{background:rgba(0,0,0,0.05);border-radius:12px;padding:20px;text-align:center;}
.b-collector h3{font-size:15px;font-weight:600;margin-bottom:12px;}
.b-collector form{display:flex;gap:8px;}
.b-collector input{flex:1;padding:10px 14px;border:1.5px solid rgba(0,0,0,0.12);border-radius:8px;font-size:14px;font-family:inherit;background:rgba(255,255,255,0.85);outline:none;}
.b-collector button{padding:10px 16px;background:{{ _btn_color }};color:{{ _btn_text_color }};border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;font-family:inherit;}
.b-collector .col-msg{font-size:13px;margin-top:8px;display:none;}
.b-contact{background:rgba(0,0,0,0.05);border-radius:12px;padding:20px;}
.b-contact h3{font-size:15px;font-weight:600;margin-bottom:12px;text-align:center;}
.b-contact input,.b-contact textarea{width:100%;padding:10px 14px;margin-bottom:8px;border:1.5px solid rgba(0,0,0,0.12);border-radius:8px;font-size:14px;font-family:inherit;background:rgba(255,255,255,0.85);outline:none;}
.b-contact textarea{min-height:80px;resize:vertical;}
.b-contact button{width:100%;padding:12px;background:{{ _btn_color }};color:{{ _btn_text_color }};border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;}
.b-contact .con-msg{font-size:13px;margin-top:8px;text-align:center;display:none;}
.b-hours{border-radius:{{ _btn_radius | default: '12' }}px;overflow:hidden;
  {% if _btn_style == 'outline' %}background:transparent;border:2px solid {{ _btn_color }};
  {% elsif _btn_style == 'soft' %}background:{{ _btn_color }}18;border:none;
  {% else %}background:{{ _btn_color }}18;border:none;{% endif %}}
.b-hours-body{display:none;border-top:1px solid rgba(0,0,0,0.07);}
.b-hours-body.open{display:block;}
.b-hours-rows{padding:4px 0 6px;background:#f8fcff1c;}
.b-hours .day-row{display:flex;align-items:center;justify-content:space-between;padding:7px 18px;gap:8px;}
.b-hours .day-row.bh-today{background:rgba(0,0,0,0.06);}
.b-hours .day-row.bh-today .day-name{font-weight:700;}
.b-hours .day-name{font-size:13px;font-weight:500;}
.b-hours .day-time{font-size:12px;opacity:.75;}
.b-hours .day-closed{font-size:12px;opacity:.38;font-style:italic;}
.b-video .vid-wrap{position:relative;padding-bottom:56.25%;height:0;border-radius:12px;overflow:hidden;}
.b-video .vid-wrap iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none;}
.b-video .vid-caption{font-size:12px;text-align:center;opacity:.6;margin-top:6px;}
.b-divider{padding:4px 0;}.b-divider .d-line{border:none;border-top:1.5px solid rgba(0,0,0,0.15);}
.b-divider .d-dots{text-align:center;font-size:16px;opacity:.4;letter-spacing:4px;}
.b-divider .d-gradient{height:3px;border-radius:99px;background:linear-gradient(90deg,transparent,{{ _btn_color }},transparent);}
.b-product{background:rgba(0,0,0,0.05);border-radius:12px;overflow:hidden;}
.b-product img{width:100%;height:180px;object-fit:cover;display:block;}
.b-product .prod-body{padding:14px 16px;}.b-product .prod-title{font-size:16px;font-weight:700;margin-bottom:4px;}
.b-product .prod-desc{font-size:13px;opacity:.7;line-height:1.5;margin-bottom:10px;}
.b-product .prod-foot{display:flex;align-items:center;justify-content:space-between;gap:10px;}
.b-product .prod-price{font-size:18px;font-weight:700;color:{{ _btn_color }};}
.b-product .prod-btn{padding:10px 18px;border-radius:{{ _btn_radius }}px;background:{{ _btn_color }};color:{{ _btn_text_color }};font-size:13px;font-weight:600;text-decoration:none;display:inline-block;white-space:nowrap;}
.b-banner{border-radius:12px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;}
.b-banner .ban-text{font-size:14px;font-weight:600;flex:1;}
.b-banner .ban-btn{padding:8px 16px;border-radius:{{ _btn_radius }}px;background:rgba(0,0,0,0.15);color:inherit;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;flex-shrink:0;}
.b-testimonial{background:rgba(0,0,0,0.05);border-radius:12px;padding:18px;}
.b-testimonial .test-stars{color:#f59e0b;font-size:15px;margin-bottom:8px;}
.b-testimonial .test-quote{font-size:14px;line-height:1.65;font-style:italic;opacity:.85;margin-bottom:12px;}
.b-testimonial .test-author{display:flex;align-items:center;gap:10px;}
.b-testimonial .test-photo{width:38px;height:38px;border-radius:50%;object-fit:cover;flex-shrink:0;}
.b-testimonial .test-ph{width:38px;height:38px;border-radius:50%;background:{{ _btn_color }};color:{{ _btn_text_color }};display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;flex-shrink:0;}
.b-testimonial .test-name{font-size:14px;font-weight:600;}.b-testimonial .test-role{font-size:12px;opacity:.6;}
.b-faq .faq-heading{font-size:17px;font-weight:700;margin-bottom:12px;text-align:center;}
.b-faq .faq-list{border:1px solid rgba(0,0,0,0.09);border-radius:12px;overflow:hidden;}
.b-faq .faq-item{border-bottom:1px solid rgba(0,0,0,0.07);}
.b-faq .faq-item:last-child{border-bottom:none;}
.b-faq .faq-q{width:100%;text-align:left;background:none;border:none;padding:14px 16px;font-size:14px;font-weight:600;color:{{ _text_color }};cursor:pointer;font-family:inherit;display:flex;justify-content:space-between;align-items:center;gap:12px;transition:background .15s;}
.b-faq .faq-q:hover{background:rgba(0,0,0,0.03);}
.b-faq .faq-q.open{background:rgba(0,0,0,0.025);}
.b-faq .faq-icon{width:22px;height:22px;border-radius:50%;border:1.5px solid {{ _text_color }};display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;font-weight:400;opacity:0.4;transition:transform .25s,opacity .2s;}
.b-faq .faq-q.open .faq-icon{transform:rotate(45deg);opacity:0.7;}
.b-faq .faq-body{max-height:0;overflow:hidden;transition:max-height .32s cubic-bezier(.4,0,.2,1);}
.b-faq .faq-body.open{max-height:800px;}
.b-faq .faq-a{font-size:13px;line-height:1.7;padding:2px 16px 14px;opacity:0.72;}
.b-map .map-wrap{border-radius:12px;overflow:hidden;}
.b-map iframe{width:100%;height:280px;border:none;display:block;}
.b-map .map-caption{font-size:12px;text-align:center;opacity:.6;margin-top:6px;}
.b-html{border-radius:12px;overflow:hidden;}

/* ── Products grid ─────────────────────────── */
.b-products-grid{border-radius:{{ _btn_radius }}px;overflow:hidden;
  {% if _btn_style == 'outline' %}background:transparent;border:2px solid {{ _btn_color }};
  {% elsif _btn_style == 'soft' %}background:{{ _btn_color }}18;border:none;
  {% else %}background:{{ _btn_color }}18;border:none;{% endif %}}
.pg-acc-head{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;cursor:pointer;user-select:none;-webkit-user-select:none;
  {% if _btn_style == 'outline' %}background:transparent;color:{{ _btn_color }};
  {% elsif _btn_style == 'soft' %}background:{{ _btn_color }}22;color:{{ _btn_color }};
  {% elsif _btn_style == 'shadow' %}background:{{ _btn_color }};color:{{ _btn_text_color }};box-shadow:0 4px 14px {{ _btn_color }}44;
  {% else %}background:{{ _btn_color }};color:{{ _btn_text_color }};{% endif %}}
.pg-acc-head:active{opacity:.85;}
.pg-acc-title{font-size:15px;font-weight:600;
  {% if _btn_style == 'outline' or _btn_style == 'soft' %}color:{{ _btn_color }};{% else %}color:{{ _btn_text_color }};{% endif %}}
.pg-acc-meta{display:flex;align-items:center;gap:8px;}
.pg-acc-count{font-size:11px;font-weight:500;opacity:.75;
  {% if _btn_style == 'outline' or _btn_style == 'soft' %}color:{{ _btn_color }};{% else %}color:{{ _btn_text_color }};{% endif %}}
.pg-acc-chevron{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:transform .25s ease;flex-shrink:0;}
.pg-acc-chevron::after{content:'';display:block;width:7px;height:7px;border-right:1.5px solid;border-bottom:1.5px solid;transform:rotate(45deg);margin-top:-3px;
  {% if _btn_style == 'soft' %}color:{{ _btn_color }};{% else %}color:{{ _btn_text_color }};{% endif %}}
.pg-acc-body{display:none;padding:8px 8px 10px;}
.pg-acc-body.open{display:block;}
.pg-acc-chevron.open{transform:rotate(180deg);}
.pg-list{display:flex;flex-direction:column;gap:6px;}
.pg-row{display:flex;align-items:center;gap:12px;background:rgba(128,128,128,0.12);border-radius:10px;padding:14px 12px;}
.pg-thumb{width:58px;height:58px;border-radius:9px;overflow:hidden;flex-shrink:0;background:rgba(128,128,128,0.15);display:flex;align-items:center;justify-content:center;font-size:24px;}
.pg-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.pg-info{flex:1;min-width:0;}
.pg-name{font-size:16px;font-weight:600;line-height:1.3;margin-bottom:3px;}
.pg-desc{font-size:13px;opacity:.6;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;}
.pg-right{flex-shrink:0;text-align:right;}
.pg-price{font-size:15px;font-weight:700;display:block;color:{{ _btn_color }};}
.pg-compare{font-size:12px;opacity:.45;text-decoration:line-through;display:block;}
.pg-dur{font-size:12px;opacity:.55;display:block;}
.pg-buy{margin-top:6px;display:block;padding:7px 13px;background:{{ _btn_color }};color:{{ _btn_text_color }};border-radius:{{ _btn_radius }}px;font-size:13px;font-weight:600;text-decoration:none;text-align:center;border:none;cursor:pointer;font-family:inherit;}
.pg-oos{margin-top:6px;display:block;padding:7px 13px;border-radius:6px;font-size:13px;font-weight:600;text-align:center;opacity:.45;background:rgba(128,128,128,0.15);}
/* Layout: grid (2-col) */
.pg-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
.pg-gc{background:rgba(128,128,128,0.12);border-radius:10px;overflow:hidden;}
.pg-gi{width:100%;aspect-ratio:1;background:rgba(128,128,128,0.15);display:flex;align-items:center;justify-content:center;font-size:28px;overflow:hidden;}
.pg-gi img{width:100%;height:100%;object-fit:cover;display:block;}
.pg-gb{padding:8px 10px 10px;}
.pg-gn{font-size:13px;font-weight:600;line-height:1.3;margin-bottom:4px;}
.pg-gp{font-size:14px;font-weight:700;color:{{ _btn_color }};display:block;}
.pg-gcp{font-size:10px;opacity:.45;text-decoration:line-through;display:block;}
.pg-gbtn{display:block;width:100%;margin-top:6px;padding:6px 0;background:{{ _btn_color }};color:{{ _btn_text_color }};border-radius:6px;font-size:12px;font-weight:600;text-align:center;border:none;cursor:pointer;font-family:inherit;}
.pg-goos{display:block;width:100%;margin-top:6px;padding:6px 0;border-radius:6px;font-size:12px;font-weight:600;text-align:center;opacity:.45;background:rgba(128,128,128,0.15);}
/* Layout: cards (full-width) */
.pg-cards{display:flex;flex-direction:column;gap:8px;}
.pg-card{background:rgba(128,128,128,0.12);border-radius:10px;overflow:hidden;}
.pg-ci{width:100%;height:130px;background:rgba(128,128,128,0.15);display:flex;align-items:center;justify-content:center;font-size:36px;overflow:hidden;}
.pg-ci img{width:100%;height:100%;object-fit:cover;display:block;}
.pg-cb{padding:10px 12px 12px;}
.pg-cn{font-size:16px;font-weight:700;margin-bottom:4px;}
.pg-cd{font-size:13px;opacity:.65;line-height:1.4;margin-bottom:8px;}
.pg-cf{display:flex;align-items:center;justify-content:space-between;gap:10px;}
.pg-cp{font-size:16px;font-weight:700;color:{{ _btn_color }};}
.pg-ccp{font-size:11px;opacity:.45;text-decoration:line-through;display:block;}
.pg-cbtn{padding:8px 16px;background:{{ _btn_color }};color:{{ _btn_text_color }};border-radius:6px;font-size:13px;font-weight:600;border:none;cursor:pointer;font-family:inherit;white-space:nowrap;}
.pg-coos{padding:8px 16px;border-radius:6px;font-size:13px;font-weight:600;text-align:center;opacity:.45;background:rgba(128,128,128,0.15);white-space:nowrap;}
/* ── Services grid ──────────────────────────────────────────── */
.b-services-grid{border-radius:14px;overflow:hidden;background:{{ _btn_color }}18;}
.sv-acc-head{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;cursor:pointer;user-select:none;-webkit-user-select:none;background:{{ _btn_color }};}
.sv-acc-head:active{opacity:.85;}
.sv-acc-title{font-size:16px;font-weight:700;color:{{ _btn_text_color }};}
.sv-acc-meta{display:flex;align-items:center;gap:8px;}
.sv-acc-count{font-size:11px;font-weight:500;color:{{ _btn_text_color }};opacity:.75;}
.sv-acc-chevron{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:{{ _btn_text_color }};transition:transform .25s ease;flex-shrink:0;}
.sv-acc-body{display:none;padding:8px 8px 10px;}
.sv-acc-body.open{display:block;}
.sv-acc-chevron.open{transform:rotate(180deg);}
.sv-list{display:flex;flex-direction:column;gap:6px;}
.sv-row{display:flex;align-items:center;gap:12px;background:rgba(128,128,128,0.12);border-radius:10px;padding:14px 12px;}
.sv-thumb{width:58px;height:58px;border-radius:9px;overflow:hidden;flex-shrink:0;background:rgba(128,128,128,0.15);display:flex;align-items:center;justify-content:center;font-size:24px;}
.sv-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.sv-info{flex:1;min-width:0;}
.sv-name{font-size:16px;font-weight:600;line-height:1.3;margin-bottom:3px;}
.sv-desc{font-size:13px;opacity:.6;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;}
.sv-dur{font-size:12px;opacity:.55;display:block;margin-top:2px;}
.sv-right{flex-shrink:0;text-align:right;}
.sv-price{font-size:15px;font-weight:700;display:block;color:{{ _btn_color }};}
.sv-book{margin-top:6px;display:block;padding:7px 13px;background:{{ _btn_color }};color:{{ _btn_text_color }};border-radius:6px;font-size:13px;font-weight:600;text-decoration:none;text-align:center;border:none;cursor:pointer;font-family:inherit;}
/* ── Jobs grid ───────────────────────────────────────────────── */
.b-jobs-grid{border-radius:14px;overflow:hidden;background:{{ _btn_color }}18;}
.jb-acc-head{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;cursor:pointer;user-select:none;-webkit-user-select:none;background:{{ _btn_color }};}
.jb-acc-head:active{opacity:.85;}
.jb-acc-title{font-size:16px;font-weight:700;color:{{ _btn_text_color }};}
.jb-acc-meta{display:flex;align-items:center;gap:8px;}
.jb-acc-count{font-size:11px;font-weight:500;color:{{ _btn_text_color }};opacity:.75;}
.jb-acc-chevron{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:{{ _btn_text_color }};transition:transform .25s ease;flex-shrink:0;}
.jb-acc-body{display:none;padding:8px 8px 10px;}
.jb-acc-body.open{display:block;}
.jb-acc-chevron.open{transform:rotate(180deg);}
.jb-list{display:flex;flex-direction:column;gap:8px;}
.jb-card{background:rgba(128,128,128,0.12);border-radius:10px;padding:14px 12px;}
.jb-top{display:flex;align-items:flex-start;gap:12px;margin-bottom:8px;}
.jb-logo{width:44px;height:44px;border-radius:8px;overflow:hidden;flex-shrink:0;background:rgba(128,128,128,0.15);display:flex;align-items:center;justify-content:center;font-size:20px;}
.jb-logo img{width:100%;height:100%;object-fit:cover;display:block;}
.jb-head{flex:1;min-width:0;}
.jb-title{font-size:16px;font-weight:700;line-height:1.3;margin-bottom:2px;}
.jb-sub{font-size:13px;opacity:.6;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;}
.jb-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px;}
.jb-tag{font-size:11px;font-weight:500;padding:3px 9px;border-radius:20px;background:rgba(128,128,128,0.15);}
.jb-salary{font-size:14px;font-weight:700;color:{{ _btn_color }};display:block;margin-bottom:8px;}
.jb-apply{display:block;width:100%;padding:8px 0;background:{{ _btn_color }};color:{{ _btn_text_color }};border-radius:6px;font-size:13px;font-weight:600;text-align:center;border:none;cursor:pointer;font-family:inherit;}
/* ── Form link block ───────────────────────────────────────────────── */
.b-form-link{margin-bottom:8px;}
.fl-heading{font-size:15px;font-weight:600;margin-bottom:8px;}
.fl-btn{display:block;text-align:center;padding:12px 20px;border-radius:10px;border:1px solid rgba(128,128,128,0.35);color:inherit;text-decoration:none;font-weight:600;font-size:14px;border:none;cursor:pointer;font-family:inherit;box-sizing:border-box;background:{{ _btn_color }};color:{{ _btn_text_color }};border-radius:{{ _btn_radius }}px;}

/* ── Form popup modal (bottom-sheet) ─────────── */
.form-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:flex-end;justify-content:center;box-sizing:border-box;}
.form-modal-overlay.open{display:flex;animation:fmo-in .2s ease;}
@keyframes fmo-in{from{opacity:0}to{opacity:1}}
.form-modal-box{background:{{ _bg_color | default: '#ffffff' }};border-radius:{{ _btn_radius }}px {{ _btn_radius }}px 0 0;width:100%;max-width:560px;height:90vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 -8px 40px rgba(0,0,0,0.18);animation:fmb-in .25s cubic-bezier(.32,1,.25,1);}
@keyframes fmb-in{from{transform:translateY(100%)}to{transform:translateY(0)}}
.form-modal-drag{width:36px;height:4px;background:{{ _btn_color }}44;border-radius:99px;margin:10px auto 0;flex-shrink:0;}
.form-modal-body{flex:1;overflow:hidden;}
.form-modal-body iframe{width:100%;height:100%;border:none;display:block;}
.form-modal-actions{display:flex;align-items:center;justify-content:space-between;padding:10px 16px 16px;flex-shrink:0;background:{{ _bg_color | default: '#ffffff' }};}
.form-modal-fab{width:42px;height:42px;border-radius:50%;background:{{ _btn_color }};border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:{{ _btn_text_color }};transition:opacity .15s;}
.form-modal-fab:hover{opacity:.85;}
</style>
</head>
<body>
<div class="page-wrap">

{% if settings.blocks %}
{% for block in settings.blocks %}
{% if block.enabled != false %}
<div class="block" id="blk-{{ block.id }}">
{% case block.type %}

{% when 'avatar' %}
<div class="b-avatar">
  <div class="av-wrap">
    <div class="av-ring"></div>
    <div class="av-ring-2"></div>
    {% if block.photo != blank and block.photo != nil %}
      <img class="av-img" src="{{ block.photo }}" alt="{{ block.name }}">
    {% else %}
      <div class="av-ph">{{ block.name | slice: 0, 1 | upcase | default: '?' }}</div>
    {% endif %}
  </div>
  {% if block.name != blank and block.name != nil %}<h1>{{ block.name }}</h1>{% endif %}
  {% if block.bio != blank and block.bio != nil %}<p class="av-bio">{{ block.bio }}</p>{% endif %}
</div>

{% when 'link' %}
<div class="b-link">
  <a href="{{ block.url | default: '#' }}" target="_blank" rel="noopener">
    {% if block.thumbnail != blank and block.thumbnail != nil %}<img class="lk-thumb" src="{{ block.thumbnail }}" alt="">
    {% elsif block.icon != blank and block.icon != nil %}<span class="lk-icon">{{ block.icon }}</span>{% endif %}
    {{ block.title | default: 'Link' }}
  </a>
</div>

{% when 'heading' %}
{% assign _ha = block.align | default: 'center' %}{% assign _hs = block.size | default: 'h2' %}
<div class="b-heading" style="text-align:{{ _ha }}">
  {% if _hs == 'h1' %}<h1>{{ block.text }}</h1>{% elsif _hs == 'h3' %}<h3>{{ block.text }}</h3>{% else %}<h2>{{ block.text }}</h2>{% endif %}
</div>

{% when 'paragraph' %}
<div class="b-paragraph"><p style="text-align:{{ block.align | default: 'center' }}">{{ block.text }}</p></div>

{% when 'image' %}
<div class="b-image">
  {% if block.url != blank and block.url != nil %}
    {% if block.link_url != blank and block.link_url != nil %}<a href="{{ block.link_url }}" target="_blank">{% endif %}
    <img src="{{ block.url }}" alt="{{ block.caption | default: '' }}">
    {% if block.link_url != blank and block.link_url != nil %}</a>{% endif %}
    {% if block.caption != blank and block.caption != nil %}<div class="img-caption">{{ block.caption }}</div>{% endif %}
  {% endif %}
</div>

{% when 'socials' %}
<div class="b-socials"><div class="soc-row">
  {% if block.instagram != blank and block.instagram != nil %}<a href="{{ block.instagram }}" target="_blank" title="Instagram"><i class="fab fa-instagram"></i></a>{% endif %}
  {% if block.twitter != blank and block.twitter != nil %}<a href="{{ block.twitter }}" target="_blank" title="X / Twitter"><i class="fab fa-x-twitter"></i></a>{% endif %}
  {% if block.youtube != blank and block.youtube != nil %}<a href="{{ block.youtube }}" target="_blank" title="YouTube"><i class="fab fa-youtube"></i></a>{% endif %}
  {% if block.tiktok != blank and block.tiktok != nil %}<a href="{{ block.tiktok }}" target="_blank" title="TikTok"><i class="fab fa-tiktok"></i></a>{% endif %}
  {% if block.linkedin != blank and block.linkedin != nil %}<a href="{{ block.linkedin }}" target="_blank" title="LinkedIn"><i class="fab fa-linkedin-in"></i></a>{% endif %}
  {% if block.facebook != blank and block.facebook != nil %}<a href="{{ block.facebook }}" target="_blank" title="Facebook"><i class="fab fa-facebook-f"></i></a>{% endif %}
  {% if block.github != blank and block.github != nil %}<a href="{{ block.github }}" target="_blank" title="GitHub"><i class="fab fa-github"></i></a>{% endif %}
  {% if block.whatsapp != blank and block.whatsapp != nil %}<a href="https://wa.me/{{ block.whatsapp | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" title="WhatsApp"><i class="fab fa-whatsapp"></i></a>{% endif %}
  {% if block.telegram != blank and block.telegram != nil %}<a href="{{ block.telegram }}" target="_blank" title="Telegram"><i class="fab fa-telegram"></i></a>{% endif %}
  {% if block.snapchat != blank and block.snapchat != nil %}<a href="{{ block.snapchat }}" target="_blank" title="Snapchat"><i class="fab fa-snapchat"></i></a>{% endif %}
  {% if block.pinterest != blank and block.pinterest != nil %}<a href="{{ block.pinterest }}" target="_blank" title="Pinterest"><i class="fab fa-pinterest"></i></a>{% endif %}
  {% if block.spotify != blank and block.spotify != nil %}<a href="{{ block.spotify }}" target="_blank" title="Spotify"><i class="fab fa-spotify"></i></a>{% endif %}
</div></div>

{% when 'email_collector' %}
<div class="b-collector">
  {% if block.heading != blank and block.heading != nil %}<h3>{{ block.heading }}</h3>{% endif %}
  <form onsubmit="return pzCollect(event,'email','{{ block.id }}','{{ site.id }}')">
    <input type="email" placeholder="{{ block.placeholder | default: 'Enter your email' }}" required>
    <button type="submit">{{ block.btn_text | default: 'Subscribe' }}</button>
  </form>
  <div class="col-msg" id="col-{{ block.id }}"></div>
</div>

{% when 'phone_collector' %}
<div class="b-collector">
  {% if block.heading != blank and block.heading != nil %}<h3>{{ block.heading }}</h3>{% endif %}
  <form onsubmit="return pzCollect(event,'phone','{{ block.id }}','{{ site.id }}')">
    <input type="tel" placeholder="{{ block.placeholder | default: 'Enter your phone number' }}" required>
    <button type="submit">{{ block.btn_text | default: 'Submit' }}</button>
  </form>
  <div class="col-msg" id="col-{{ block.id }}"></div>
</div>

{% when 'contact_form' %}
<div class="b-contact">
  {% if block.heading != blank and block.heading != nil %}<h3>{{ block.heading }}</h3>{% endif %}
  <form onsubmit="return pzContact(event,'{{ site.id }}','{{ block.id }}')">
    {% if block.show_name %}<input type="text" name="name" placeholder="Your name">{% endif %}
    {% if block.show_email %}<input type="email" name="email" placeholder="Your email">{% endif %}
    {% if block.show_phone %}<input type="tel" name="phone" placeholder="Your phone">{% endif %}
    {% if block.show_message %}<textarea name="message" placeholder="Your message"></textarea>{% endif %}
    <button type="submit">{{ block.btn_text | default: 'Send message' }}</button>
  </form>
  <div class="con-msg" id="con-{{ block.id }}"></div>
</div>

{% when 'business_hours' %}
{% assign _bh_days = 'Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday' | split: ',' %}
{% assign _bh_keys = 'mon,tue,wed,thu,fri,sat,sun' | split: ',' %}
<div class="b-hours" id="bh-{{ block.id }}">
  <div class="pg-acc-head" onclick="bhToggle('{{ block.id }}')">
    <span class="pg-acc-title">{% if block.heading != blank and block.heading != nil %}{{ block.heading }}{% else %}Business Hours{% endif %}</span>
    <span class="pg-acc-meta">
      <span class="pg-acc-count" id="bh-badge-{{ block.id }}">Closed</span>
      <span class="pg-acc-chevron" id="bh-chv-{{ block.id }}"></span>
    </span>
  </div>
  <div class="b-hours-body" id="bh-body-{{ block.id }}">
    <div class="b-hours-rows">
    {% for _bk in _bh_keys %}
      {% assign _bopen_key = _bk | append: '_open' %}
      {% assign _bclose_key = _bk | append: '_close' %}
      {% assign _bopen = block[_bopen_key] %}
      {% assign _bclose = block[_bclose_key] %}
      <div class="day-row" data-bhday="{{ forloop.index0 }}">
        <span class="day-name">{{ _bh_days[forloop.index0] }}</span>
        {% if _bopen != blank and _bopen != nil %}
        <span class="day-time">{{ _bopen }}{% if _bclose != blank and _bclose != nil %} – {{ _bclose }}{% endif %}</span>
        {% else %}
        <span class="day-closed">Closed</span>
        {% endif %}
      </div>
    {% endfor %}
    </div>
  </div>
</div>
<script>(function(){
  var jd=new Date().getDay(),map=[6,0,1,2,3,4,5];
  var rows=document.querySelectorAll('#bh-{{ block.id }} .day-row');
  var badge=document.getElementById('bh-badge-{{ block.id }}');
  if(rows[map[jd]]) rows[map[jd]].classList.add('bh-today');
  var tr=rows[map[jd]];
  if(tr&&badge&&!tr.querySelector('.day-closed')){
    var tel=tr.querySelector('.day-time');
    if(tel){var now=new Date(),cur=now.getHours()*60+now.getMinutes();
      function pt(t){var m=t.match(/(\d+):(\d+)\s*(AM|PM)/i);if(!m)return -1;var h=+m[1],mn=+m[2],ap=m[3].toUpperCase();if(ap==='PM'&&h!==12)h+=12;if(ap==='AM'&&h===12)h=0;return h*60+mn;}
      var p=tel.textContent.split('–').map(function(s){return s.trim();});
      if(pt(p[0])>=0&&pt(p[1]||'')>0&&cur>=pt(p[0])&&cur<pt(p[1])){badge.textContent='Open now';}
    }
  }
})();</script>
{% when 'video' %}
<div class="b-video">
  {% if block.url != blank and block.url != nil %}
  <div class="vid-wrap" id="vw-{{ block.id }}">
    <iframe src="{{ block.url }}" allowfullscreen allow="autoplay; encrypted-media" loading="lazy"></iframe>
  </div>
  {% endif %}
  {% if block.caption != blank and block.caption != nil %}<div class="vid-caption">{{ block.caption }}</div>{% endif %}
</div>

{% when 'divider' %}
<div class="b-divider" style="padding:{{ block.spacing | default: '16' }}px 0;">
  {% if block.style == 'dots' %}<div class="d-dots">· · ·</div>
  {% elsif block.style == 'gradient' %}<div class="d-gradient"></div>
  {% elsif block.style == 'space' %}{%- comment -%}space{%- endcomment -%}
  {% else %}<hr class="d-line">{% endif %}
</div>

{% when 'product' %}
<div class="b-product">
  {% if block.image != blank and block.image != nil %}<img src="{{ block.image }}" alt="{{ block.title | default: '' }}">{% endif %}
  <div class="prod-body">
    {% if block.title != blank and block.title != nil %}<div class="prod-title">{{ block.title }}</div>{% endif %}
    {% if block.description != blank and block.description != nil %}<div class="prod-desc">{{ block.description }}</div>{% endif %}
    <div class="prod-foot">
      {% if block.price != blank and block.price != nil %}<div class="prod-price">{{ block.price }}</div>{% endif %}
      {% if block.btn_url != blank and block.btn_url != nil %}<a class="prod-btn" href="{{ block.btn_url }}" target="_blank" rel="noopener">{{ block.btn_text | default: 'Buy now' }}</a>{% endif %}
    </div>
  </div>
</div>

{% when 'banner' %}
{% assign _ban_bg = block.bg_color | default: '#fef3c7' %}{% assign _ban_tc = block.text_color | default: '#92400e' %}
<div class="b-banner" style="background:{{ _ban_bg }};color:{{ _ban_tc }};">
  <div class="ban-text">{{ block.text | default: '' }}</div>
  {% if block.btn_url != blank and block.btn_url != nil %}<a class="ban-btn" href="{{ block.btn_url }}" target="_blank" rel="noopener" style="color:{{ _ban_tc }};">{{ block.btn_text | default: 'Learn more' }}</a>{% endif %}
</div>

{% when 'testimonial' %}
{% assign _tr = block.rating | default: '5' | times: 1 %}
<div class="b-testimonial">
  {% if block.quote != blank and block.quote != nil %}
    <div class="test-stars">{% for i in (1.._tr) %}★{% endfor %}</div>
    <div class="test-quote">"{{ block.quote }}"</div>
  {% endif %}
  <div class="test-author">
    {% if block.photo != blank and block.photo != nil %}<img class="test-photo" src="{{ block.photo }}" alt="{{ block.name | default: '' }}">
    {% else %}<div class="test-ph">{{ block.name | slice: 0, 1 | upcase | default: '?' }}</div>{% endif %}
    <div>
      {% if block.name != blank and block.name != nil %}<div class="test-name">{{ block.name }}</div>{% endif %}
      {% if block.role != blank and block.role != nil %}<div class="test-role">{{ block.role }}</div>{% endif %}
    </div>
  </div>
</div>

{% when 'faq' %}
<div class="b-faq">
  {% if block.heading != blank and block.heading != nil %}<div class="faq-heading">{{ block.heading }}</div>{% endif %}
  <div class="faq-list">
    {% for item in block.items %}
    <div class="faq-item">
      <button class="faq-q" onclick="faqToggle(this)" type="button">
        <span>{{ item.question }}</span><span class="faq-icon">+</span>
      </button>
      <div class="faq-body">
        <div class="faq-a">{{ item.answer }}</div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>

{% when 'map' %}
<div class="b-map">
  {% if block.embed_url != blank and block.embed_url != nil %}
  <div class="map-wrap"><iframe src="{{ block.embed_url }}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe></div>
  {% endif %}
  {% if block.caption != blank and block.caption != nil %}<div class="map-caption">{{ block.caption }}</div>{% endif %}
</div>

{% when 'html' %}
<div class="b-html">{{ block.code }}</div>


{% when 'products_grid' %}
{% if block.collection != blank and block.collection != nil %}
  {% assign _pg_items = settings._products | where_includes: "_clist", block.collection %}
{% else %}
  {% assign _pg_items = settings._products %}
{% endif %}
{% assign _pg_layout = block.layout | default: 'list' %}
<div class="b-products-grid" id="pg-{{ block.id }}">
  <div class="pg-acc-head" onclick="pgToggle('{{ block.id }}')">
    <span class="pg-acc-title">{{ block.heading | default: 'Products' }}</span>
    <span class="pg-acc-meta">
      {% if _pg_items and _pg_items.size > 0 %}<span class="pg-acc-count">{{ _pg_items.size }} items</span>{% endif %}
      <span class="pg-acc-chevron" id="pg-chv-{{ block.id }}"></span>
    </span>
  </div>
  <div class="pg-acc-body" id="pg-body-{{ block.id }}">
    {% if _pg_items and _pg_items.size > 0 %}
    {% if _pg_layout == 'grid' %}
    <div class="pg-grid">
      {% for p in _pg_items %}
      <div class="pg-gc">
        <div class="pg-gi">{% if p.image_url != blank and p.image_url != nil %}<img src="{{ p.image_url }}" alt="{{ p.name }}">{% elsif p.type == 'digital' %}&#128190;{% elsif p.type == 'service' %}&#128296;{% else %}&#128230;{% endif %}</div>
        <div class="pg-gb">
          <div class="pg-gn">{{ p.name }}</div>
          {% if p.price != blank and p.price != nil %}<span class="pg-gp">&#8377;{{ p.price | floor }}</span>{% endif %}
          {% if p.compare_price != blank and p.compare_price > p.price %}<span class="pg-gcp">&#8377;{{ p.compare_price | floor }}</span>{% endif %}
          {% if p.in_stock == false or p.in_stock == 0 %}<span class="pg-goos">Sold out</span>{% else %}<button class="pg-gbtn">Buy</button>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% elsif _pg_layout == 'cards' %}
    <div class="pg-cards">
      {% for p in _pg_items %}
      <div class="pg-card">
        <div class="pg-ci">{% if p.image_url != blank and p.image_url != nil %}<img src="{{ p.image_url }}" alt="{{ p.name }}">{% elsif p.type == 'digital' %}&#128190;{% elsif p.type == 'service' %}&#128296;{% else %}&#128230;{% endif %}</div>
        <div class="pg-cb">
          <div class="pg-cn">{{ p.name }}</div>
          {% if p.description != blank %}<div class="pg-cd">{{ p.description | truncate: 100 }}</div>{% endif %}
          <div class="pg-cf">
            <div>{% if p.price != blank and p.price != nil %}<span class="pg-cp">&#8377;{{ p.price | floor }}</span>{% endif %}{% if p.compare_price != blank and p.compare_price > p.price %}<span class="pg-ccp">&#8377;{{ p.compare_price | floor }}</span>{% endif %}</div>
            {% if p.in_stock == false or p.in_stock == 0 %}<span class="pg-coos">Sold out</span>{% else %}<button class="pg-cbtn">Buy</button>{% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="pg-list">
      {% for p in _pg_items %}
      <div class="pg-row">
        <div class="pg-thumb">{% if p.image_url != blank and p.image_url != nil %}<img src="{{ p.image_url }}" alt="{{ p.name }}">{% elsif p.type == 'digital' %}&#128190;{% elsif p.type == 'service' %}&#128296;{% else %}&#128230;{% endif %}</div>
        <div class="pg-info">
          <div class="pg-name">{{ p.name }}</div>
          {% if p.description != blank %}<div class="pg-desc">{{ p.description | truncate: 60 }}</div>{% endif %}
          {% if p.type == 'service' and p.duration != blank %}<div class="pg-dur">&#9201; {{ p.duration }}</div>{% endif %}
        </div>
        <div class="pg-right">
          {% if p.price != blank and p.price != nil %}<span class="pg-price">&#8377;{{ p.price | floor }}</span>{% endif %}
          {% if p.compare_price != blank and p.compare_price > p.price %}<span class="pg-compare">&#8377;{{ p.compare_price | floor }}</span>{% endif %}
          {% if p.in_stock == false or p.in_stock == 0 %}<span class="pg-oos">Sold out</span>{% else %}<button class="pg-buy">Buy</button>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
    {% else %}
    <div style="text-align:center;padding:24px 16px;opacity:.45;font-size:13px;">
      {% if block.collection != blank %}No products in "{{ block.collection }}"{% else %}No products added yet{% endif %}
    </div>
    {% endif %}
  </div>
</div>

{% when 'services_grid' %}
{% assign _sv_items = settings._products | where: "type", "service" %}
{% if block.collection and block.collection != '' %}{% assign _sv_items = _sv_items | where: "collection", block.collection %}{% endif %}
{% assign _sv_layout = block.layout | default: 'list' %}
<div class="b-products-grid" id="sv-{{ block.id }}">
  <div class="pg-acc-head" onclick="svToggle('{{ block.id }}')">
    <span class="pg-acc-title">{{ block.heading | default: 'Our Services' }}</span>
    <span class="pg-acc-meta">
      {% if _sv_items and _sv_items.size > 0 %}<span class="pg-acc-count">{{ _sv_items.size }} services</span>{% endif %}
      <span class="pg-acc-chevron" id="sv-chv-{{ block.id }}"></span>
    </span>
  </div>
  <div class="pg-acc-body" id="sv-body-{{ block.id }}">
    {% if _sv_items and _sv_items.size > 0 %}
    {% if _sv_layout == 'grid' %}
    <div class="pg-grid">
      {% for p in _sv_items %}
      <div class="pg-gc">
        <div class="pg-gi">{% if p.image_url != blank and p.image_url != nil %}<img src="{{ p.image_url }}" alt="{{ p.name }}">{% else %}&#128296;{% endif %}</div>
        <div class="pg-gb">
          <div class="pg-gn">{{ p.name }}</div>
          {% if p.price != blank and p.price != nil %}<span class="pg-gp">&#8377;{{ p.price | floor }}</span>{% endif %}
          {% if p.duration != blank %}<span class="pg-gcp">{{ p.duration }}</span>{% endif %}
          <button class="pg-gbtn">{{ block.btn_text | default: 'Book' }}</button>
        </div>
      </div>
      {% endfor %}
    </div>
    {% elsif _sv_layout == 'cards' %}
    <div class="pg-cards">
      {% for p in _sv_items %}
      <div class="pg-card">
        <div class="pg-ci">{% if p.image_url != blank and p.image_url != nil %}<img src="{{ p.image_url }}" alt="{{ p.name }}">{% else %}&#128296;{% endif %}</div>
        <div class="pg-cb">
          <div class="pg-cn">{{ p.name }}</div>
          {% if p.description != blank %}<div class="pg-cd">{{ p.description | truncate: 100 }}</div>{% endif %}
          <div class="pg-cf">
            <div>{% if p.price != blank and p.price != nil %}<span class="pg-cp">&#8377;{{ p.price | floor }}</span>{% endif %}{% if p.duration != blank %}<span class="pg-ccp">{{ p.duration }}</span>{% endif %}</div>
            <button class="pg-cbtn">{{ block.btn_text | default: 'Book' }}</button>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="pg-list">
      {% for p in _sv_items %}
      <div class="pg-row">
        <div class="pg-thumb">{% if p.image_url != blank and p.image_url != nil %}<img src="{{ p.image_url }}" alt="{{ p.name }}">{% else %}&#128296;{% endif %}</div>
        <div class="pg-info">
          <div class="pg-name">{{ p.name }}</div>
          {% if p.description != blank %}<div class="pg-desc">{{ p.description | truncate: 60 }}</div>{% endif %}
          {% if p.duration != blank %}<div class="pg-dur">&#9201; {{ p.duration }}</div>{% endif %}
        </div>
        <div class="pg-right">
          {% if p.price != blank and p.price != nil %}<span class="pg-price">&#8377;{{ p.price | floor }}</span>{% endif %}

  {% endif %}
</div>
<script>(function(){
  var t=new Date('{{ block.target_date }}').getTime();
  function tick(){var n=new Date().getTime(),d=t-n;
    if(isNaN(t)||d<0){document.getElementById('cd-display-{{ block.id }}').innerHTML='<span style="font-size:18px;opacity:.5;">Event has passed</span>';return;}
    document.getElementById('cd-d-{{ block.id }}').textContent=String(Math.floor(d/86400000)).padStart(2,'0');
    document.getElementById('cd-h-{{ block.id }}').textContent=String(Math.floor((d%86400000)/3600000)).padStart(2,'0');
    document.getElementById('cd-m-{{ block.id }}').textContent=String(Math.floor((d%3600000)/60000)).padStart(2,'0');
    document.getElementById('cd-s-{{ block.id }}').textContent=String(Math.floor((d%60000)/1000)).padStart(2,'0');
  }tick();setInterval(tick,1000);
})();</script>


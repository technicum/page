<div class="form-modal-overlay" id="formModalOverlay" onclick="if(event.target===this)closeFormPopup()">
  <div class="form-modal-box">
    <div class="form-modal-drag"></div>
    <div class="form-modal-body">
      <iframe id="formModalIframe" src="about:blank" title="Form"></iframe>
    </div>
    <div class="form-modal-actions">

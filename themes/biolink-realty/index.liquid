<script>
// ── FAQ accordion ─────────────────────────────────────────────────────────────
function bhToggle(id){
  var b=document.getElementById('bh-body-'+id),c=document.getElementById('bh-chv-'+id);
  if(!b)return;var o=b.classList.contains('open');
  b.classList.toggle('open',!o);if(c)c.classList.toggle('open',!o);
}
function pgToggle(blockId) {
  var body = document.getElementById('pg-body-' + blockId);
  var chv  = document.getElementById('pg-chv-' + blockId);
  if (!body) return;
  var open = body.classList.contains('open');
  body.classList.toggle('open', !open);
  if (chv) chv.classList.toggle('open', !open);
}

function svToggle(blockId) {
  var body=document.getElementById('sv-body-'+blockId);
  var chv=document.getElementById('sv-chv-'+blockId);
  if(!body)return;
  var open=body.classList.contains('open');
  body.classList.toggle('open',!open);
  if(chv)chv.classList.toggle('open',!open);
}
function jbToggle(blockId) {
  var body=document.getElementById('jb-body-'+blockId);
  var chv=document.getElementById('jb-chv-'+blockId);
  if(!body)return;
  var open=body.classList.contains('open');
  body.classList.toggle('open',!open);
  if(chv)chv.classList.toggle('open',!open);
}
function faqToggle(btn) {
  var list  = btn.closest('.faq-list');
  var body  = btn.nextElementSibling;
  var isOpen = body.classList.contains('open');
  list.querySelectorAll('.faq-body').forEach(function(b){ b.classList.remove('open'); });
  list.querySelectorAll('.faq-q').forEach(function(b){ b.classList.remove('open'); });
  if (!isOpen) { body.classList.add('open'); btn.classList.add('open'); }
}

(function(){
  document.querySelectorAll('.vid-wrap iframe').forEach(function(iframe){
    var src=iframe.src||'';
    src=src.replace(/youtube\.com\/watch\?v=([^&]+)/,'youtube.com/embed/$1');
    src=src.replace(/youtu\.be\/([^?]+)/,'youtube.com/embed/$1');
    src=src.replace(/(?:www\.)?vimeo\.com\/(\d+)/,'player.vimeo.com/video/$1');
    iframe.src=src;
  });
})();
function pzCollect(e,type,blockId,siteId){e.preventDefault();var input=e.target.querySelector('input');var msgEl=document.getElementById('col-'+blockId);var payload={};if(type==='email')payload.email=input.value.trim();else payload.phone=input.value.trim();fetch('/api/biolink-lead/'+siteId,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).then(function(r){return r.json();}).then(function(d){if(msgEl){msgEl.style.display='block';msgEl.textContent=d.message||'Thank you!';}e.target.reset();}).catch(function(){if(msgEl){msgEl.style.display='block';msgEl.textContent='Something went wrong.';}});return false;}
function pzContact(e,siteId,blockId){e.preventDefault();var fd=new FormData(e.target);var data={};fd.forEach(function(v,k){if(v.trim())data[k]=v.trim();});var form=e.target;var btn=form.querySelector('button');var msgEl=document.getElementById('con-'+blockId);if(btn)btn.disabled=true;fetch('/api/biolink-lead/'+siteId,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)}).then(function(r){return r.json();}).then(function(d){if(msgEl){msgEl.style.display='block';msgEl.textContent=d.message||'Message sent!';}form.reset();if(btn)btn.disabled=false;}).catch(function(){if(msgEl){msgEl.style.display='block';msgEl.textContent='Something went wrong.';}if(btn)btn.disabled=false;});return false;}

/* ── Form popup ───────────────────────────────── */
function openFormPopup(formId){
  var overlay=document.getElementById('formModalOverlay');
  var iframe=document.getElementById('formModalIframe');
  if(!overlay||!iframe) return;
  // Minisite runs on subdomain — build absolute URL to main app domain
  var parts=window.location.hostname.split('.');
  var appHost=parts.length>2 ? parts.slice(1).join('.') : window.location.hostname;
  var base=window.location.protocol+'//'+appHost;
  if(isNaN(formId)||formId===''){iframe.src=formId; overlay.classList.add('open'); document.body.style.overflow='hidden'; return;}
  // Pass theme colors so the form matches the preset
  var params=new URLSearchParams({
    btnColor:'{{ _btn_color | default: "#6366f1" }}',
    btnTextColor:'{{ _btn_text_color | default: "#ffffff" }}',
    btnRadius:'{{ _btn_radius | default: "8" }}',
    bgColor:'{{ _bg_color | default: "#ffffff" }}',
    textColor:'{{ _text_color | default: "#1a1a1a" }}'
  });
  iframe.src=base+'/f/'+formId+'?'+params.toString();
  overlay.classList.add('open');
  document.body.style.overflow='hidden';
}
function closeFormPopup(){
  var overlay=document.getElementById('formModalOverlay');
  var iframe=document.getElementById('formModalIframe');
  if(overlay) overlay.classList.remove('open');
  if(iframe) iframe.src='about:blank';
  document.body.style.overflow='';
}
function shareFormUrl(){
  var iframe=document.getElementById('formModalIframe');
  var url=iframe?iframe.src:'';
  if(url&&url!=='about:blank'&&navigator.share){navigator.share({url:url});}
  else if(url&&url!=='about:blank'){navigator.clipboard&&navigator.clipboard.writeText(url);}
}


// ── Save to Contact (vCard) ────────────────────────────────────────────────
function pzSaveContact(){
  var c = {% if settings.contact %}{{ settings.contact | tojson }}{% else %}{}{% endif %};
  var lines = ['BEGIN:VCARD','VERSION:3.0'];
  if(c.name) lines.push('FN:'+c.name);
  if(c.company) lines.push('ORG:'+c.company);
  if(c.title) lines.push('TITLE:'+c.title);
  if(c.phone) lines.push('TEL;TYPE=CELL:'+c.phone);
  if(c.whatsapp && c.whatsapp !== c.phone) lines.push('TEL;TYPE=WORK:'+c.whatsapp);
  if(c.email) lines.push('EMAIL:'+c.email);
  if(c.website) lines.push('URL:'+c.website);
  if(c.address) lines.push('ADR:;;'+c.address.replace(/\n/g,', ')+';;;;');
  lines.push('END:VCARD');
  var blob = new Blob([lines.join('\r\n')], {type:'text/vcard'});
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = (c.name || 'contact').replace(/[^a-z0-9]/gi,'_')+'.vcf';
  a.click();
}

/* ── Analytics tracking ──────────────────────────────────────────────────────── */
(function(){
  var SITE_ID = '{{ site.id }}';
  var parts = window.location.hostname.split('.');
  var appHost = parts.length > 2 ? parts.slice(1).join('.') : window.location.hostname;
  var BASE = window.location.protocol + '//' + appHost;

  function pzTrack(data){
    data.site_id = SITE_ID;
    data.referrer = document.referrer || '';
    try { navigator.sendBeacon(BASE+'/api/track', JSON.stringify(Object.assign({}, data, {_ct:'application/json'}))); } catch(e){}
    fetch(BASE+'/api/track',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data),keepalive:true}).catch(function(){});
  }

  // Page view — fire once per session using sessionStorage dedup
  var vkey = 'pzv_'+SITE_ID;
  if(!sessionStorage.getItem(vkey)){
    sessionStorage.setItem(vkey,'1');
    pzTrack({event_type:'view'});
  }

  // Click tracking — delegate on all .pg-buy, .fl-btn, .bk-btn, .pg-gbtn, .pg-cbtn, a[href], button
  document.addEventListener('click', function(e){
    var el = e.target.closest('a[href], button, .pg-buy, .fl-btn, .bk-btn, .pg-gbtn, .pg-cbtn, .svc-btn');
    if(!el) return;
    var block = el.closest('[id]');
    var blockId = block ? block.id : '';
    var blockType = (block && block.className) ? block.className.split(' ')[0] : '';
    var label = (el.textContent || '').trim().slice(0,80);
    pzTrack({event_type:'click', block_id:blockId, block_type:blockType, label:label});
  }, true);
})();
</script>

{% if settings.contact and settings.contact.phone and settings.contact.phone != blank %}
<div style="text-align:center;margin:4px 0 8px;">

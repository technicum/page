<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ settings.profile.name }}</title>
<link rel="stylesheet" href="/themes/biolink-realty/assets/css/style.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --accent: {{ settings.profile.accent | default: '#0f766e' }};
  --ink: #1a1a18; --muted: #6b6b66; --border: #e5e5e2;
  --bg: #fafaf8; --white: #fff; --radius: 14px;
}
</style>
</head>
<body>
<div class="page">

  <!-- Hero -->
  {% assign pr = settings.profile %}
  <div class="hero">
    {% if pr.avatar != blank %}
      <img class="avatar" src="{{ pr.avatar }}" alt="{{ pr.name }}">
    {% else %}
      <div class="avatar-ph">{{ pr.name | slice: 0, 1 | upcase }}</div>
    {% endif %}
    <div class="agent-name">{{ pr.name }}</div>
    {% if pr.title %}<div class="agent-title">{{ pr.title }}</div>{% endif %}
    {% if pr.agency %}<div class="agent-agency">{{ pr.agency }}</div>{% endif %}
  </div>

  <div class="body">
    {% if pr.bio %}<div class="bio" style="margin-bottom:20px;">{{ pr.bio }}</div>{% endif %}

    <!-- Links (always visible) -->
    {% assign lk = settings.links %}
    {% if lk.items and lk.items.size > 0 %}
    <div class="links" style="margin-bottom:20px;">
      {% for item in lk.items %}
      <a class="link-btn {% if item.primary == 'yes' %}primary{% else %}secondary{% endif %}" href="{{ item.url }}" target="_blank">
        {% if item.emoji and item.primary != 'yes' %}<span class="link-emoji">{{ item.emoji }}</span>{% endif %}
        {{ item.label }}
      </a>
      {% endfor %}
    </div>
    {% endif %}

    <!-- Accordion: Properties -->
    {% assign ls = settings.listings %}
    {% if ls.items and ls.items.size > 0 %}
    <div class="pz-sections">
      <div class="pz-sec" id="sec-listings">
        <div class="pz-sec-head" onclick="pzToggle('sec-listings')">
          <div class="pz-sec-icon">🏠</div>
          <div class="pz-sec-meta">
            <div class="pz-sec-title">{{ ls.heading | default: 'Featured Properties' }}</div>
            <div class="pz-sec-sub">{{ ls.items.size }} propert{% if ls.items.size != 1 %}ies{% else %}y{% endif %}</div>
          </div>
          <div class="pz-sec-right">
            <span class="pz-count">{{ ls.items.size }}</span>
            <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
        <div class="pz-sec-body">
          <div class="pz-sec-inner">
            <div class="properties">
              {% for item in ls.items %}
              <div class="prop-card">
                {% if item.image != blank %}<img class="prop-img" src="{{ item.image }}" alt="{{ item.title }}">
                {% else %}<div class="prop-img-ph">🏠</div>{% endif %}
                <div class="prop-body">
                  <div class="prop-badges">
                    {% if item.type %}<span class="badge badge-type">{{ item.type }}</span>{% endif %}
                    {% if item.price %}<span class="badge badge-price">{{ item.price }}</span>{% endif %}
                  </div>
                  <div class="prop-title">{{ item.title }}</div>
                  {% if item.location %}<div class="prop-location">📍 {{ item.location }}</div>{% endif %}
                  {% if item.link != blank %}<a class="prop-btn" href="{{ item.link }}" target="_blank">View Details →</a>{% endif %}
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Socials row -->
    {% assign s = settings.socials %}
    {% if s.instagram != blank or s.linkedin != blank or s.facebook != blank or s.twitter != blank or s.youtube != blank %}
    <div class="social-row">
      {% if s.instagram != blank %}<a class="soc-pill" href="{{ s.instagram }}" target="_blank"><i class="fa-brands fa-instagram"></i> Instagram</a>{% endif %}
      {% if s.linkedin != blank %}<a class="soc-pill" href="{{ s.linkedin }}" target="_blank"><i class="fa-brands fa-linkedin"></i> LinkedIn</a>{% endif %}
      {% if s.facebook != blank %}<a class="soc-pill" href="{{ s.facebook }}" target="_blank"><i class="fa-brands fa-facebook"></i> Facebook</a>{% endif %}
      {% if s.twitter != blank %}<a class="soc-pill" href="{{ s.twitter }}" target="_blank"><i class="fa-brands fa-x-twitter"></i> Twitter</a>{% endif %}
      {% if s.youtube != blank %}<a class="soc-pill" href="{{ s.youtube }}" target="_blank"><i class="fa-brands fa-youtube"></i> YouTube</a>{% endif %}
    </div>
    {% endif %}

    <!-- Contact actions -->
    {% assign c = settings.contact %}
    {% if c.whatsapp != blank or c.phone != blank or c.email != blank %}
    <div class="socials" style="margin-top:16px;margin-bottom:8px;">
      {% if c.whatsapp != blank %}<a class="soc-btn" href="https://wa.me/{{ c.whatsapp | remove: '+' | remove: ' ' }}" target="_blank"><i class="fa-brands fa-whatsapp"></i> WhatsApp</a>{% endif %}
      {% if c.phone != blank %}<a class="soc-btn" href="tel:{{ c.phone }}"><i class="fa-solid fa-phone"></i> Call</a>{% endif %}
      {% if c.email != blank %}<a class="soc-btn" href="mailto:{{ c.email }}"><i class="fa-solid fa-envelope"></i> Email</a>{% endif %}
    </div>
    {% endif %}

    <!-- Save Contact -->
    {% if c.email != blank or c.phone != blank or c.whatsapp != blank %}
    <div class="save-contact-bar">
      <button class="save-contact-btn" onclick="pzSaveContact()"><i class="fa-solid fa-user-plus"></i> {{ c.save_label | default: 'Save Contact' }}</button>
    </div>
    {% endif %}
  </div>

  <!-- Share -->
  <div class="share-bar">
    <button class="share-btn" onclick="pzShare()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share this page
    </button>
    <div class="share-toast" id="pzToast">✓ Link copied!</div>
  </div>

</div>
<script>
function pzToggle(id){var el=document.getElementById(id);el.classList.toggle('open');}
function pzSaveContact(){var n='{{ settings.profile.name | escape }}';var t='{{ settings.profile.title | default: "" | escape }}';var p='{{ settings.contact.phone | default: "" | escape }}';if(!p)p='{{ settings.contact.whatsapp | default: "" | escape }}';var e='{{ settings.contact.email | default: "" | escape }}';var w='{{ settings.contact.website | default: "" | escape }}';var vcf='BEGIN:VCARD\nVERSION:3.0\nFN:'+n+'\n'+(t?'TITLE:'+t+'\n':'')+(p?'TEL;TYPE=CELL:'+p+'\n':'')+(e?'EMAIL:'+e+'\n':'')+(w?'URL:'+w+'\n':'')+'URL:'+location.href+'\nEND:VCARD';var b=new Blob([vcf],{type:'text/vcard'});var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=(n||'contact').replace(/\s+/g,'-')+'.vcf';a.click();}
function pzShare(){var u=location.href,t=document.title;if(navigator.share){navigator.share({title:t,url:u});}else{var ta=document.createElement('textarea');ta.value=u;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);var el=document.getElementById('pzToast');el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2200);}}
</script>
</body>
</html>

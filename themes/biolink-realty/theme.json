{
  "name": "Realty Link",
  "description": "Biolink for real estate brokers — property listings, agent profile, inquiry CTA.",
  "for": ["minisite"],
  "categories": ["real-estate"],
  "preview": "preview.jpg",
  "default_appearance": {
    "bgColor": "#f0fdf9", "btnColor": "#0f766e", "btnTextColor": "#ffffff",
    "textColor": "#1a1a1a", "btnStyle": "filled", "btnRadius": "8",
    "bgType": "color", "fontFamily": "inter",
    "animationStyle": "fade", "animationStagger": "80"
  },
  "default_blocks": [
    { "id":"b1", "type":"avatar",  "enabled":true, "photo":"", "name":"Your Name", "bio":"Real Estate Broker · 10+ years experience · Finding your perfect home 🏠" },
    { "id":"b2", "type":"link",    "enabled":true, "title":"🏠 Schedule a Site Visit", "url":"#" },
    { "id":"b3", "type":"link",    "enabled":true, "title":"💬 WhatsApp Me Now", "url":"#" },
    { "id":"b4", "type":"heading", "enabled":true, "text":"Featured Properties", "size":"h3", "align":"center" },
    { "id":"b5", "type":"banner",  "enabled":true, "text":"3BHK Premium Apartment · Gurgaon · ₹1.2 Cr", "btn_text":"View Details", "btn_url":"#" },
    { "id":"b6", "type":"banner",  "enabled":true, "text":"2BHK Ready to Move · Powai, Mumbai · ₹85 Lac", "btn_text":"View Details", "btn_url":"#" },
    { "id":"b7", "type":"socials", "enabled":true, "instagram":"https://instagram.com", "linkedin":"https://linkedin.com" }
  ],
  "sections": [
    {
      "id": "profile",
      "label": "Agent Profile",
      "fields": [
        { "id": "avatar", "label": "Agent Photo URL", "type": "image",    "default": "" },
        { "id": "name",   "label": "Agent Name",      "type": "text",     "default": "Your Name" },
        { "id": "title",  "label": "Title",           "type": "text",     "default": "Real Estate Broker" },
        { "id": "agency", "label": "Agency Name",     "type": "text",     "default": "Your Agency" },
        { "id": "bio",    "label": "Short Bio",       "type": "textarea", "default": "10+ years experience in residential & commercial properties. I'll find you the perfect home." },
        { "id": "accent", "label": "Accent Color",   "type": "color",    "default": "#0f766e" }
      ]
    },
    {
      "id": "listings",
      "label": "Property Listings",
      "fields": [
        { "id": "heading", "label": "Section Heading", "type": "text", "default": "Featured Properties" },
        { "id": "items", "label": "Properties", "type": "repeater",
          "default": [
            { "image": "", "title": "3BHK Premium Apartment",  "location": "Sector 15, Gurgaon",  "price": "₹1.2 Cr",  "type": "Sale", "link": "" },
            { "image": "", "title": "2BHK Ready to Move",      "location": "Powai, Mumbai",        "price": "₹85 Lac",  "type": "Sale", "link": "" },
            { "image": "", "title": "Commercial Office Space",  "location": "Koramangala, Bengaluru", "price": "₹45K/mo", "type": "Rent", "link": "" }
          ],
          "item_fields": [
            { "id": "image",    "label": "Property Image URL",     "type": "image", "default": "" },
            { "id": "title",    "label": "Property Title",         "type": "text",  "default": "3BHK Apartment" },
            { "id": "location", "label": "Location",               "type": "text",  "default": "" },
            { "id": "price",    "label": "Price",                  "type": "text",  "default": "₹45 Lac" },
            { "id": "type",     "label": "Type (Sale / Rent)",     "type": "text",  "default": "Sale" },
            { "id": "link",     "label": "Details / Inquiry Link", "type": "text",  "default": "" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "label": "Schedule a Site Visit", "url": "", "emoji": "🏠", "primary": "yes" },
            { "label": "WhatsApp Me Now",       "url": "", "emoji": "💬", "primary": "no"  }
          ],
          "item_fields": [
            { "id": "label",   "label": "Label",            "type": "text", "default": "Schedule a Visit" },
            { "id": "url",     "label": "URL",              "type": "text", "default": "" },
            { "id": "emoji",   "label": "Emoji",            "type": "text", "default": "🏠" },
            { "id": "primary", "label": "Primary (yes/no)", "type": "text", "default": "no" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Socials",
      "fields": [
        { "id": "heading",    "label": "Section Heading",          "type": "text",  "default": "Follow me" },
        { "id": "sub",        "label": "Sub Heading (leave blank to hide)", "type": "text", "default": "" },
        { "id": "icon_color", "label": "Icon Color",                "type": "color", "default": "" },
        { "id": "icon_size",  "label": "Icon Size (sm / md / lg / xl)", "type": "text", "default": "md" },
        { "id": "instagram", "label": "Instagram URL",   "type": "text", "default": "" },
        { "id": "linkedin",  "label": "LinkedIn URL",    "type": "text", "default": "" },
        { "id": "facebook",  "label": "Facebook URL",    "type": "text", "default": "" },
        { "id": "twitter",   "label": "Twitter / X URL", "type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube URL",     "type": "text", "default": "" }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "whatsapp",  "label": "WhatsApp Number", "type": "text", "default": "" },
        { "id": "phone",     "label": "Phone Number",    "type": "text", "default": "" },
        { "id": "email",     "label": "Email",           "type": "text", "default": "" },
        { "id": "website",   "label": "Website URL",     "type": "text", "default": "" },
        { "id": "address",   "label": "Office Address",  "type": "text", "default": "" },
        { "id": "save_label","label": "Save Contact Button Label", "type": "text", "default": "💾 Save Contact" }
      ]
    },
    {
      "id": "booking",
      "label": "Booking",
      "fields": [
        { "id": "show",    "label": "Show Booking Widget (yes / no)", "type": "text", "default": "yes" },
        { "id": "heading", "label": "Section Heading",                "type": "text", "default": "Book a Meeting" }
      ]
    }
  ]
}

{
  "name": "TradeVault Academy",
  "description": "Dark market-terminal biolink for SEBI-registered traders and course creators — live stats, course cards, Telegram/YouTube CTAs.",
  "for": ["linktree"],
  "categories": ["finance", "education"],
  "tags": ["trading", "courses", "dark", "education", "finance"],
  "order": 11,
  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "fields": [
        { "id": "avatar",   "label": "Photo / Logo URL",       "type": "image", "default": "" },
        { "id": "name",     "label": "Your Name",              "type": "text",  "default": "Arjun Verma" },
        { "id": "title",    "label": "Title / Credentials",    "type": "text",  "default": "SEBI Reg. Analyst · Options Trader · 9 yrs" },
        { "id": "sebi_reg", "label": "SEBI Registration No.",  "type": "text",  "default": "INH000012345" },
        { "id": "accent",   "label": "Accent Color",           "type": "color", "default": "#00D964" }
      ]
    },
    {
      "id": "ticker",
      "label": "Market Ticker",
      "fields": [
        { "id": "show",    "label": "Show ticker (yes/no)",  "type": "text", "default": "yes" },
        { "id": "items",   "label": "Ticker Items", "type": "repeater",
          "default": [
            { "label": "NIFTY",     "value": "23,450", "change": "+1.2%",  "up": "yes" },
            { "label": "BANKNIFTY", "value": "49,820", "change": "-0.4%",  "up": "no" },
            { "label": "SENSEX",    "value": "77,210", "change": "+0.9%",  "up": "yes" }
          ],
          "item_fields": [
            { "id": "label",  "label": "Index Name",       "type": "text", "default": "NIFTY" },
            { "id": "value",  "label": "Value",             "type": "text", "default": "23,000" },
            { "id": "change", "label": "Change %",          "type": "text", "default": "+1.0%" },
            { "id": "up",     "label": "Up? (yes/no)",      "type": "text", "default": "yes" }
          ]
        }
      ]
    },
    {
      "id": "stats",
      "label": "Performance Stats",
      "fields": [
        { "id": "monthly_pnl",   "label": "Monthly P&L",      "type": "text", "default": "+₹2.3L" },
        { "id": "win_rate",      "label": "Win Rate",          "type": "text", "default": "78%" },
        { "id": "students",      "label": "Total Students",    "type": "text", "default": "4,200+" },
        { "id": "experience",    "label": "Years Experience",  "type": "text", "default": "9 yrs" }
      ]
    },
    {
      "id": "cta",
      "label": "Primary CTA",
      "fields": [
        { "id": "label", "label": "Button Text", "type": "text", "default": "Join the academy →" },
        { "id": "url",   "label": "Button URL",  "type": "text", "default": "" }
      ]
    },
    {
      "id": "courses",
      "label": "Courses",
      "fields": [
        { "id": "items", "label": "Course List", "type": "repeater",
          "default": [
            { "emoji": "📈", "name": "Options Mastery Pro",   "sub": "12 weeks · Live sessions", "price": "₹9,999", "url": "" },
            { "emoji": "🎯", "name": "Intraday Scalping",     "sub": "6 weeks · Recorded",       "price": "₹4,999", "url": "" },
            { "emoji": "📊", "name": "F&O Fundamentals",      "sub": "4 weeks · Beginner",       "price": "₹2,499", "url": "" }
          ],
          "item_fields": [
            { "id": "emoji", "label": "Emoji",        "type": "text", "default": "📚" },
            { "id": "name",  "label": "Course Name",  "type": "text", "default": "Course" },
            { "id": "sub",   "label": "Subtitle",     "type": "text", "default": "" },
            { "id": "price", "label": "Price",        "type": "text", "default": "" },
            { "id": "url",   "label": "Enroll URL",   "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Community Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "emoji": "📺", "label": "YouTube channel",   "url": "", "sub": "Free trading videos" },
            { "emoji": "💬", "label": "Telegram community","url": "", "sub": "Daily market calls" },
            { "emoji": "📊", "label": "Free market call",  "url": "", "sub": "Book a 30-min session" }
          ],
          "item_fields": [
            { "id": "emoji", "label": "Emoji",    "type": "text", "default": "🔗" },
            { "id": "label", "label": "Label",    "type": "text", "default": "Link" },
            { "id": "url",   "label": "URL",      "type": "text", "default": "" },
            { "id": "sub",   "label": "Subtitle", "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "whatsapp", "label": "WhatsApp Number", "type": "text", "default": "" },
        { "id": "email",    "label": "Email",           "type": "text", "default": "" },
        { "id": "disclaimer", "label": "SEBI Disclaimer (shown at bottom)", "type": "textarea",
          "default": "SEBI Registration No. INH000012345. Trading in securities is subject to market risk. Past performance is not indicative of future results." }
      ]
    }
  ]
}

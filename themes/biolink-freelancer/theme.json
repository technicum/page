{
  "name": "Freelancer Link",
  "description": "Biolink for freelancers — skills, portfolio work, hire me CTA.",
  "for": ["minisite"],
  "categories": ["freelancer", "creative", "technology", "education"],
  "preview": "preview.jpg",
  "default_appearance": {
    "bgColor": "#faf5ff", "btnColor": "#7c3aed", "btnTextColor": "#ffffff",
    "textColor": "#1a1a1a", "btnStyle": "filled", "btnRadius": "8",
    "bgType": "color", "fontFamily": "inter"
  },
  "default_blocks": [
    { "id":"b1", "type":"avatar",    "enabled":true, "photo":"", "name":"Your Name", "bio":"UI Designer & Developer · 5+ years experience · Available for projects ✅" },
    { "id":"b2", "type":"link",      "enabled":true, "title":"🤝 Hire Me", "url":"#" },
    { "id":"b3", "type":"link",      "enabled":true, "title":"🎨 View Portfolio", "url":"#" },
    { "id":"b4", "type":"heading",   "enabled":true, "text":"What I Do", "size":"h3", "align":"center" },
    { "id":"b5", "type":"paragraph", "enabled":true, "text":"Specializing in Web Design · UI/UX · React · Node.js · Mobile Apps. I help brands look great online.", "align":"center" },
    { "id":"b6", "type":"socials",   "enabled":true, "linkedin":"https://linkedin.com", "github":"https://github.com" }
  ],
  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "fields": [
        { "id": "avatar",       "label": "Avatar URL",               "type": "image",    "default": "" },
        { "id": "name",         "label": "Your Name",                "type": "text",     "default": "Your Name" },
        { "id": "title",        "label": "What You Do",              "type": "text",     "default": "UI Designer & Developer" },
        { "id": "bio",          "label": "Short Bio",                "type": "textarea", "default": "I help brands look great online. 5+ years experience in design & development." },
        { "id": "availability", "label": "Available for Work (yes/no)", "type": "text", "default": "yes" },
        { "id": "accent",       "label": "Accent Color",             "type": "color",    "default": "#7c3aed" }
      ]
    },
    {
      "id": "skills",
      "label": "Skills",
      "fields": [
        { "id": "heading", "label": "Heading", "type": "text", "default": "What I Do" },
        { "id": "items", "label": "Skills", "type": "repeater",
          "default": [
            { "emoji": "💻", "name": "Web Design" },
            { "emoji": "⚡", "name": "React / Node" },
            { "emoji": "🎨", "name": "UI/UX Design" },
            { "emoji": "📱", "name": "Mobile Apps" }
          ],
          "item_fields": [
            { "id": "emoji", "label": "Emoji",      "type": "text", "default": "💻" },
            { "id": "name",  "label": "Skill Name", "type": "text", "default": "Skill" }
          ]
        }
      ]
    },
    {
      "id": "portfolio",
      "label": "Portfolio",
      "fields": [
        { "id": "heading", "label": "Heading", "type": "text", "default": "Recent Work" },
        { "id": "items", "label": "Projects", "type": "repeater",
          "default": [
            { "image": "", "title": "Brand Redesign",      "description": "Full identity refresh for a fintech startup", "link": "" },
            { "image": "", "title": "E-commerce App",      "description": "Mobile-first shopping experience",           "link": "" }
          ],
          "item_fields": [
            { "id": "image",       "label": "Image URL",              "type": "image", "default": "" },
            { "id": "title",       "label": "Project Name",           "type": "text",  "default": "My Project" },
            { "id": "description", "label": "Brief Description",      "type": "text",  "default": "" },
            { "id": "link",        "label": "Live / Case Study Link", "type": "text",  "default": "" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "label": "Hire Me",          "url": "", "emoji": "🤝", "primary": "yes" },
            { "label": "View Full Portfolio", "url": "", "emoji": "🎨", "primary": "no"  }
          ],
          "item_fields": [
            { "id": "label",   "label": "Label",            "type": "text", "default": "My Link" },
            { "id": "url",     "label": "URL",              "type": "text", "default": "" },
            { "id": "emoji",   "label": "Emoji",            "type": "text", "default": "🤝" },
            { "id": "primary", "label": "Primary (yes/no)", "type": "text", "default": "no" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Socials",
      "fields": [
        { "id": "heading",    "label": "Section Heading",          "type": "text",  "default": "Follow me" },
        { "id": "sub",        "label": "Sub Heading (leave blank to hide)", "type": "text", "default": "" },
        { "id": "icon_color", "label": "Icon Color",                "type": "color", "default": "" },
        { "id": "icon_size",  "label": "Icon Size (sm / md / lg / xl)", "type": "text", "default": "md" },
        { "id": "instagram", "label": "Instagram URL",  "type": "text", "default": "" },
        { "id": "linkedin",  "label": "LinkedIn URL",   "type": "text", "default": "" },
        { "id": "github",    "label": "GitHub URL",     "type": "text", "default": "" },
        { "id": "twitter",   "label": "Twitter / X URL","type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube URL",    "type": "text", "default": "" },
        { "id": "tiktok",    "label": "TikTok URL",     "type": "text", "default": "" }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "email",     "label": "Email",         "type": "text", "default": "" },
        { "id": "whatsapp",  "label": "WhatsApp Number","type": "text", "default": "" },
        { "id": "phone",     "label": "Phone Number",  "type": "text", "default": "" },
        { "id": "website",   "label": "Website URL",   "type": "text", "default": "" },
        { "id": "address",   "label": "Address",       "type": "text", "default": "" },
        { "id": "save_label","label": "Save Contact Button Label", "type": "text", "default": "💾 Save Contact" }
      ]
    },
    {
      "id": "booking",
      "label": "Booking",
      "fields": [
        { "id": "show",    "label": "Show Booking Widget (yes / no)", "type": "text", "default": "yes" },
        { "id": "heading", "label": "Section Heading",                "type": "text", "default": "Book a Meeting" }
      ]
    }
  ]
}

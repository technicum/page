<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
{% comment %}── SEO ──{% endcomment %}
{% assign _pr  = settings.profile %}
{% assign _seo = settings.seo %}
{% assign _t   = _seo.title | default: _pr.name %}
{% assign _d   = _seo.description | default: _pr.bio | default: _pr.tagline %}
{% assign _img = _seo.og_image | default: _pr.avatar %}
<title>{{ _t }}</title>
<meta name="description" content="{{ _d }}">
<meta name="robots" content="{% if _seo.noindex %}noindex,nofollow{% else %}index,follow{% endif %}">
<link rel="canonical" href="{{ site.url }}">
<link rel="manifest" href="/manifest.json">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="{{ settings.profile.name | default: site.title }}">
<meta property="og:type" content="profile">
<meta property="og:title" content="{{ _t }}">
<meta property="og:description" content="{{ _d }}">
<meta property="og:url" content="{{ site.url }}">
{% if _img != blank %}<meta property="og:image" content="{{ _img }}"><meta name="twitter:image" content="{{ _img }}">{% endif %}
<meta name="twitter:card" content="{% if _img != blank %}summary_large_image{% else %}summary{% endif %}">
<meta name="twitter:title" content="{{ _t }}">
<meta name="twitter:description" content="{{ _d }}">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Person","name":{{ _pr.name | json }},"url":{{ site.url | json }}{% if _d != blank %},"description":{{ _d | json }}{% endif %}{% if _img != blank %},"image":{{ _img | json }}{% endif %}}</script>
<link rel="stylesheet" href="/themes/biolink-freelancer/assets/css/style.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --accent: {{ settings.profile.accent | default: '#7c3aed' }};
  --ink: #1a1a18; --muted: #6b6b66; --border: #e5e5e2;
  --bg: #fafaf8; --white: #fff; --radius: 14px;
}
.pz-company{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;color:var(--muted);background:rgba(0,0,0,0.05);padding:3px 10px;border-radius:20px;margin-top:6px;text-decoration:none;cursor:pointer;}
.pz-company:hover{background:rgba(0,0,0,0.1);color:var(--ink);}
</style>
</head>
<body>
<div class="page">

  <!-- Profile -->
  {% assign pr = settings.profile %}
  <div class="profile" data-sec="profile">
    {% if pr.avatar != blank %}
      <img class="avatar" src="{{ pr.avatar }}" alt="{{ pr.name }}">
    {% else %}
      <div class="avatar-ph">{{ pr.name | slice: 0, 1 | upcase }}</div>
    {% endif %}
    {% if pr.availability == 'yes' %}<div class="avail-dot">Available for work</div>{% endif %}
    <div class="name">{{ pr.name }}</div>
    {% if pr.title %}<div class="title">{{ pr.title }}</div>{% endif %}
    {% if pr.company %}<a class="pz-company" href="{{ pr.company_url | default: '#' }}" target="_blank">🏢 {{ pr.company }}</a>{% endif %}
    {% if pr.bio %}<div class="bio">{{ pr.bio }}</div>{% endif %}
  </div>

  <!-- Links (always visible) -->
  {% assign lk = settings.links %}
  {% if lk.items and lk.items.size > 0 %}
  <div class="links" data-sec="links" style="margin-bottom:20px;">
    {% for item in lk.items %}
    <a class="link-btn {% if item.primary == 'yes' %}primary{% else %}secondary{% endif %}" href="{{ item.url }}" target="_blank">
      {% if item.emoji and item.primary != 'yes' %}<span class="link-emoji">{{ item.emoji }}</span>{% endif %}
      {{ item.label }}
    </a>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Accordion sections -->
  {% assign sk = settings.skills %}
  {% if sk.items and sk.items.size > 0 %}
  <div class="pz-sections" data-sec="skills">
    <div class="pz-sec" id="sec-skills">
      <div class="pz-sec-head" onclick="pzToggle('sec-skills')">
        <div class="pz-sec-icon">⚡</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ sk.heading | default: 'What I Do' }}</div>
          <div class="pz-sec-sub">{{ sk.items.size }} skill{% if sk.items.size != 1 %}s{% endif %}</div>
        </div>
        <div class="pz-sec-right">
          <span class="pz-count">{{ sk.items.size }}</span>
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner">
          <div class="skills-wrap">
            {% for item in sk.items %}
            <div class="skill-chip"><span class="skill-emoji">{{ item.emoji }}</span>{{ item.name }}</div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  {% assign pf = settings.portfolio %}
  {% if pf.items and pf.items.size > 0 %}
  <div class="pz-sections" data-sec="portfolio">
    <div class="pz-sec" id="sec-portfolio">
      <div class="pz-sec-head" onclick="pzToggle('sec-portfolio')">
        <div class="pz-sec-icon">🎨</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ pf.heading | default: 'Recent Work' }}</div>
          <div class="pz-sec-sub">{{ pf.items.size }} project{% if pf.items.size != 1 %}s{% endif %}</div>
        </div>
        <div class="pz-sec-right">
          <span class="pz-count">{{ pf.items.size }}</span>
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner">
          <div class="portfolio">
            {% for item in pf.items %}
            <div class="proj-card">
              {% if item.image != blank %}<img class="proj-img" src="{{ item.image }}" alt="{{ item.title }}">
              {% else %}<div class="proj-img-ph">🎨</div>{% endif %}
              <div class="proj-body">
                <div class="proj-title">{{ item.title }}</div>
                {% if item.description %}<div class="proj-desc">{{ item.description }}</div>{% endif %}
                {% if item.link != blank %}<a class="proj-link" href="{{ item.link }}" target="_blank">View Project →</a>{% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Socials accordion -->
  {% assign s = settings.socials %}
  {% if s.instagram != blank or s.linkedin != blank or s.github != blank or s.twitter != blank or s.youtube != blank or s.tiktok != blank %}
  <div class="pz-sections" data-sec="socials">
    <div class="pz-sec" id="sec-socials">
      <div class="pz-sec-head" onclick="pzToggle('sec-socials')">
        <div class="pz-sec-icon">📱</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ s.heading | default: 'Follow me' }}</div>
          {% if s.sub != blank %}<div class="pz-sec-sub">{{ s.sub }}</div>{% endif %}
        </div>
        <div class="pz-sec-right">
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        {% assign _sz = 58 %}{% assign _fz = 24 %}
        {% if s.icon_size == 'sm' %}{% assign _sz = 44 %}{% assign _fz = 18 %}{% endif %}
        {% if s.icon_size == 'lg' %}{% assign _sz = 70 %}{% assign _fz = 30 %}{% endif %}
        {% if s.icon_size == 'xl' %}{% assign _sz = 86 %}{% assign _fz = 38 %}{% endif %}
        <style>#sec-socials .soc-icon{width:{{ _sz }}px;height:{{ _sz }}px;font-size:{{ _fz }}px;{% if s.icon_color != blank %}color:{{ s.icon_color }};border-color:{{ s.icon_color }};background:{{ s.icon_color }}1a;{% endif %}}{% if s.icon_color != blank %}#sec-socials .soc-icon:hover{background:{{ s.icon_color }};color:#fff;}{% endif %}</style>
        <div class="pz-sec-inner" style="padding:20px 16px;text-align:center;">
          <div class="social-row">
            {% if s.instagram != blank %}<a class="soc-icon" href="{{ s.instagram }}" target="_blank" title="Instagram"><i class="fa-brands fa-instagram"></i></a>{% endif %}
            {% if s.linkedin != blank %}<a class="soc-icon" href="{{ s.linkedin }}" target="_blank" title="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>{% endif %}
            {% if s.github != blank %}<a class="soc-icon" href="{{ s.github }}" target="_blank" title="GitHub"><i class="fa-brands fa-github"></i></a>{% endif %}
            {% if s.twitter != blank %}<a class="soc-icon" href="{{ s.twitter }}" target="_blank" title="Twitter"><i class="fa-brands fa-x-twitter"></i></a>{% endif %}
            {% if s.youtube != blank %}<a class="soc-icon" href="{{ s.youtube }}" target="_blank" title="YouTube"><i class="fa-brands fa-youtube"></i></a>{% endif %}
            {% if s.tiktok != blank %}<a class="soc-icon" href="{{ s.tiktok }}" target="_blank" title="TikTok"><i class="fa-brands fa-tiktok"></i></a>{% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Contact accordion -->
  {% assign c = settings.contact %}
  {% if c.email != blank or c.whatsapp != blank or c.phone != blank %}
  <div class="pz-sections" data-sec="contact">
    <div class="pz-sec" id="sec-contact">
      <div class="pz-sec-head" onclick="pzToggle('sec-contact')">
        <div class="pz-sec-icon">📞</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">Get in Touch</div>
        </div>
        <div class="pz-sec-right">
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner" style="padding:12px 16px 16px;">
          <div class="contact-actions">
            {% if c.email != blank %}<a class="contact-btn" href="mailto:{{ c.email }}"><span class="contact-btn-icon"><i class="fa-solid fa-envelope"></i></span><span class="contact-btn-label">Email</span><span class="contact-btn-val">{{ c.email }}</span></a>{% endif %}
            {% if c.whatsapp != blank %}<a class="contact-btn" href="https://wa.me/{{ c.whatsapp | remove: '+' | remove: ' ' }}" target="_blank"><span class="contact-btn-icon"><i class="fa-brands fa-whatsapp"></i></span><span class="contact-btn-label">WhatsApp</span></a>{% endif %}
            {% if c.phone != blank %}<a class="contact-btn" href="tel:{{ c.phone }}"><span class="contact-btn-icon"><i class="fa-solid fa-phone"></i></span><span class="contact-btn-label">Call</span><span class="contact-btn-val">{{ c.phone }}</span></a>{% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- Reviews -->
  <div class="pz-sections" data-sec="reviews">
    <div class="pz-sec" id="sec-reviews">
      <div class="pz-sec-head" onclick="pzToggle('sec-reviews')">
        <div class="pz-sec-icon">⭐</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">Reviews</div>
          <div class="pz-sec-sub" id="pz-rev-sub">Loading…</div>
        </div>
        <div class="pz-sec-right">
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner" style="padding:16px;">
          <a href="/review/{{ site.subdomain }}" style="display:block;text-align:center;background:var(--accent);color:#fff;padding:12px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;">📝 View / Write a Review</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Save Contact -->
  {% if settings.contact.email != blank or settings.contact.phone != blank or settings.contact.whatsapp != blank %}
  <div class="save-contact-bar">
    <button class="save-contact-btn" onclick="pzSaveContact()"><i class="fa-solid fa-user-plus"></i> {{ settings.contact.save_label | default: 'Save Contact' }}</button>
  </div>
  {% endif %}

  <!-- Share -->
  <div class="share-bar">
    <button class="share-btn" onclick="pzShare()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share this page
    </button>
    <div class="share-toast" id="pzToast">✓ Link copied!</div>
  </div>

  <div id="pzInstallBar" style="display:none;text-align:center;padding:6px 16px 0;">
    <button id="pzInstallBtn" onclick="pzInstall()" style="display:inline-flex;align-items:center;gap:7px;padding:11px 22px;background:transparent;border:1.5px solid var(--accent);border-radius:24px;color:var(--accent);font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:opacity 0.15s;">
      📲 Save to Home Screen
    </button>
  </div>
  <div id="pzIOSHint" style="display:none;text-align:center;padding:8px 20px 2px;">
    <div style="display:inline-flex;align-items:flex-start;gap:10px;background:rgba(0,0,0,0.06);border-radius:12px;padding:11px 15px;font-size:12px;color:#6b6b66;max-width:280px;text-align:left;line-height:1.5;">
      <span style="font-size:18px;flex-shrink:0;margin-top:1px;">📲</span>
      <span>Tap the <strong style="color:#1a1a18;">Share</strong> button <svg style="display:inline;vertical-align:middle;" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1a1a18" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg> in Safari, then tap <strong style="color:#1a1a18;">"Add to Home Screen"</strong></span>
    </div>
  </div>

</div>
<script>
function pzToggle(id){var el=document.getElementById(id);el.classList.toggle('open');}
(function(){fetch('/api/reviews/{{ site.subdomain }}').then(function(r){return r.json()}).then(function(d){document.getElementById('pz-rev-sub').textContent=d.avg_rating?('⭐ '+d.avg_rating+' · '+d.total+' review'+(d.total!==1?'s':'')):('No reviews yet');}).catch(function(){document.getElementById('pz-rev-sub').textContent='Reviews';});})();
function pzSaveContact(){var n='{{ settings.profile.name | escape }}';var t='{{ settings.profile.title | default: "" | escape }}';var p='{{ settings.contact.phone | default: "" | escape }}';if(!p)p='{{ settings.contact.whatsapp | default: "" | escape }}';var e='{{ settings.contact.email | default: "" | escape }}';var w='{{ settings.contact.website | default: "" | escape }}';var vcf='BEGIN:VCARD\nVERSION:3.0\nFN:'+n+'\n'+(t?'TITLE:'+t+'\n':'')+(p?'TEL;TYPE=CELL:'+p+'\n':'')+(e?'EMAIL:'+e+'\n':'')+(w?'URL:'+w+'\n':'')+'URL:'+location.href+'\nEND:VCARD';var b=new Blob([vcf],{type:'text/vcard'});var a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=(n||'contact').replace(/\s+/g,'-')+'.vcf';a.click();}
function pzShare(){var u=location.href,t=document.title;if(navigator.share){navigator.share({title:t,url:u});}else{var ta=document.createElement('textarea');ta.value=u;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);var el=document.getElementById('pzToast');el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2200);}}
(function(){var _dp=null;var isIOS=/iPad|iPhone|iPod/.test(navigator.userAgent)&&!window.MSStream;var isAndroid=/Android/.test(navigator.userAgent);if(window.navigator.standalone===true)return;if(navigator.serviceWorker){navigator.serviceWorker.register('/sw.js').catch(function(){});}window.addEventListener('beforeinstallprompt',function(e){e.preventDefault();_dp=e;});window.addEventListener('appinstalled',function(){var b=document.getElementById('pzInstallBar');if(b)b.style.display='none';_dp=null;});fetch('{{ app_url }}/api/check-owner/{{ site.subdomain }}',{credentials:'include'}).then(function(r){return r.json()}).then(function(d){if(!d.is_owner)return;if(isIOS){var h=document.getElementById('pzIOSHint');if(h)h.style.display='';}else if(isAndroid){var b=document.getElementById('pzInstallBar');if(b)b.style.display='';}}).catch(function(){});window.pzInstall=function(){if(_dp){_dp.prompt();_dp.userChoice.then(function(){_dp=null;});}else{var o=document.createElement('div');o.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99999;display:flex;align-items:flex-end;justify-content:center;';o.innerHTML='<div style="background:#fff;border-radius:16px 16px 0 0;padding:24px;max-width:480px;width:100%;text-align:center;"><div style="font-size:15px;font-weight:600;margin-bottom:12px;">Install this app</div><div style="font-size:14px;color:#6b6b66;line-height:1.6;">Tap the <strong>⋮ menu</strong> at the top right, then tap <strong>"Install app"</strong> or <strong>"Add to Home screen"</strong></div><button onclick="this.parentElement.parentElement.remove()" style="margin-top:16px;padding:10px 24px;background:var(--accent,#2563eb);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">Got it</button></div>';document.body.appendChild(o);o.addEventListener('click',function(e){if(e.target===o)o.remove();});}};})();
</script>
</body>
</html>

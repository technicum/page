<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ settings.profile.name }}</title>
<link rel="stylesheet" href="/themes/biolink-freelancer/assets/css/style.css">
<style>
:root{
  --accent: {{ settings.profile.accent | default: '#7c3aed' }};
  --ink: #1a1a18; --muted: #6b6b66; --border: #e5e5e2;
  --bg: #fafaf8; --white: #fff; --radius: 14px;
}
</style>
</head>
<body>
<div class="page">

  <!-- Profile -->
  {% assign pr = settings.profile %}
  <div class="profile">
    {% if pr.avatar != blank %}
      <img class="avatar" src="{{ pr.avatar }}" alt="{{ pr.name }}">
    {% else %}
      <div class="avatar-ph">{{ pr.name | slice: 0, 1 | upcase }}</div>
    {% endif %}
    {% if pr.availability == 'yes' %}<div class="avail-dot">Available for work</div>{% endif %}
    <div class="name">{{ pr.name }}</div>
    {% if pr.title %}<div class="title">{{ pr.title }}</div>{% endif %}
    {% if pr.bio %}<div class="bio">{{ pr.bio }}</div>{% endif %}
  </div>

  <!-- Links (always visible) -->
  {% assign lk = settings.links %}
  {% if lk.items and lk.items.size > 0 %}
  <div class="links" style="margin-bottom:20px;">
    {% for item in lk.items %}
    <a class="link-btn {% if item.primary == 'yes' %}primary{% else %}secondary{% endif %}" href="{{ item.url }}" target="_blank">
      {% if item.emoji and item.primary != 'yes' %}<span class="link-emoji">{{ item.emoji }}</span>{% endif %}
      {{ item.label }}
    </a>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Accordion sections -->
  <div class="pz-sections">

    {% assign sk = settings.skills %}
    {% if sk.items and sk.items.size > 0 %}
    <div class="pz-sec" id="sec-skills">
      <div class="pz-sec-head" onclick="pzToggle('sec-skills')">
        <div class="pz-sec-icon">⚡</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ sk.heading | default: 'What I Do' }}</div>
          <div class="pz-sec-sub">{{ sk.items.size }} skill{% if sk.items.size != 1 %}s{% endif %}</div>
        </div>
        <div class="pz-sec-right">
          <span class="pz-count">{{ sk.items.size }}</span>
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner">
          <div class="skills-wrap">
            {% for item in sk.items %}
            <div class="skill-chip"><span class="skill-emoji">{{ item.emoji }}</span>{{ item.name }}</div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    {% assign pf = settings.portfolio %}
    {% if pf.items and pf.items.size > 0 %}
    <div class="pz-sec" id="sec-portfolio">
      <div class="pz-sec-head" onclick="pzToggle('sec-portfolio')">
        <div class="pz-sec-icon">🎨</div>
        <div class="pz-sec-meta">
          <div class="pz-sec-title">{{ pf.heading | default: 'Recent Work' }}</div>
          <div class="pz-sec-sub">{{ pf.items.size }} project{% if pf.items.size != 1 %}s{% endif %}</div>
        </div>
        <div class="pz-sec-right">
          <span class="pz-count">{{ pf.items.size }}</span>
          <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
      <div class="pz-sec-body">
        <div class="pz-sec-inner">
          <div class="portfolio">
            {% for item in pf.items %}
            <div class="proj-card">
              {% if item.image != blank %}<img class="proj-img" src="{{ item.image }}" alt="{{ item.title }}">
              {% else %}<div class="proj-img-ph">🎨</div>{% endif %}
              <div class="proj-body">
                <div class="proj-title">{{ item.title }}</div>
                {% if item.description %}<div class="proj-desc">{{ item.description }}</div>{% endif %}
                {% if item.link != blank %}<a class="proj-link" href="{{ item.link }}" target="_blank">View Project →</a>{% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    {% endif %}

  </div>

  <!-- Contact / Social -->
  {% assign c = settings.contact %}
  {% if c.email != blank or c.whatsapp != blank or c.linkedin != blank or c.github != blank or c.instagram != blank %}
  <div class="socials">
    {% if c.email != blank %}<a class="soc-btn" href="mailto:{{ c.email }}">✉️ Email</a>{% endif %}
    {% if c.whatsapp != blank %}<a class="soc-btn" href="https://wa.me/{{ c.whatsapp | remove: '+' | remove: ' ' }}" target="_blank">💬 WhatsApp</a>{% endif %}
    {% if c.linkedin != blank %}<a class="soc-btn" href="{{ c.linkedin }}" target="_blank">💼 LinkedIn</a>{% endif %}
    {% if c.github != blank %}<a class="soc-btn" href="{{ c.github }}" target="_blank">🐙 GitHub</a>{% endif %}
    {% if c.instagram != blank %}<a class="soc-btn" href="{{ c.instagram }}" target="_blank">📸 Instagram</a>{% endif %}
  </div>
  {% endif %}

  <!-- Share -->
  <div class="share-bar">
    <button class="share-btn" onclick="pzShare()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share this page
    </button>
    <div class="share-toast" id="pzToast">✓ Link copied!</div>
  </div>

</div>
<script>
function pzToggle(id){var el=document.getElementById(id);el.classList.toggle('open');}
function pzShare(){var u=location.href,t=document.title;if(navigator.share){navigator.share({title:t,url:u});}else{var ta=document.createElement('textarea');ta.value=u;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);var el=document.getElementById('pzToast');el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2200);}}
</script>
</body>
</html>

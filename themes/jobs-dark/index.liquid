<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ settings.profile.name | default: site.title }}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ac:{{ settings.profile.accent | default:'#3B82F6' }};
  --bg:#0D1320;
  --card:#141C2E;
  --border:rgba(255,255,255,0.08);
  --ink:#F1F5F9;
  --muted:#64748B;
  --sub:#94A3B8;
  --faint:#1E293B;
  --ac-faint:rgba(59,130,246,0.1);
  --ac-border:rgba(59,130,246,0.22);
}
body{background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;display:flex;justify-content:center;min-height:100vh;}
.page{width:100%;max-width:420px;padding:40px 16px 64px;display:flex;flex-direction:column;align-items:center;}

/* Avatar */
.av-wrap{width:76px;height:76px;border-radius:50%;background:var(--faint);border:2px solid var(--ac);display:flex;align-items:center;justify-content:center;font-size:26px;overflow:hidden;flex-shrink:0;animation:popIn .6s cubic-bezier(.34,1.56,.64,1) both;}
.av-wrap img{width:100%;height:100%;object-fit:cover;}
.name{margin-top:14px;font-size:20px;font-weight:600;color:var(--ink);text-align:center;animation:fadeUp .4s .25s both;}
.tagline{font-size:12px;color:var(--muted);text-align:center;margin-top:4px;animation:fadeUp .4s .35s both;}
.badges{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-top:10px;animation:fadeUp .4s .45s both;}
.badge-hiring{background:rgba(34,197,94,0.12);color:#22C55E;font-size:10px;padding:3px 10px;border-radius:10px;border:1px solid rgba(34,197,94,0.22);}
.badge-exp{background:var(--ac-faint);color:var(--ac);font-size:10px;padding:3px 10px;border-radius:10px;border:1px solid var(--ac-border);}

/* Stats */
.stats{display:grid;grid-template-columns:1fr 1fr 1fr;width:100%;margin-top:18px;border:1px solid var(--border);border-radius:12px;overflow:hidden;animation:fadeUp .4s .5s both;}
.stat{padding:12px 8px;text-align:center;background:var(--bg);}
.stat+.stat{border-left:1px solid var(--border);}
.stat-val{color:var(--ac);font-size:18px;font-weight:600;}
.stat-label{color:var(--muted);font-size:9px;margin-top:2px;text-transform:uppercase;letter-spacing:.04em;}

/* CTA */
.cta{display:block;width:100%;margin-top:16px;padding:13px;border-radius:12px;background:var(--ac);color:#fff;font-size:14px;font-weight:600;text-align:center;text-decoration:none;animation:slideUp .4s .55s both;transition:opacity .2s;}
.cta:hover{opacity:.88;}

/* Section heading */
.sec-title{width:100%;font-size:10px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin:20px 0 10px;}

/* ── Accordion (shop style) ── */
.pz-sections{width:100%;display:flex;flex-direction:column;gap:10px;margin:16px 0 4px;}
.pz-sec{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;transition:border-color .2s;}
.pz-sec.open{border-color:var(--ac);}
.pz-sec-head{display:flex;align-items:center;gap:12px;padding:14px 16px;cursor:pointer;user-select:none;}
.pz-sec-icon{width:40px;height:40px;border-radius:12px;background:var(--ac-faint);border:1px solid var(--ac-border);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.pz-sec-meta{flex:1;min-width:0;}
.pz-sec-title{font-size:14px;font-weight:600;color:var(--ink);line-height:1.2;}
.pz-sec-sub{font-size:12px;color:var(--muted);margin-top:2px;}
.pz-sec-right{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.pz-count{font-size:11px;font-weight:700;background:var(--faint);border:1px solid var(--border);color:var(--muted);padding:3px 9px;border-radius:20px;}
.pz-sec.open .pz-count{background:var(--ac);border-color:var(--ac);color:#fff;}
.pz-chevron{color:var(--muted);transition:transform .3s;}
.pz-sec.open .pz-chevron{transform:rotate(180deg);color:var(--ac);}
.pz-sec-body{max-height:0;overflow:hidden;transition:max-height .4s ease;}
.pz-sec.open .pz-sec-body{max-height:4000px;}
.pz-sec-inner{padding:4px 14px 14px;}

/* ── Job grid (2-col like product grid) ── */
.jobs-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.job-card{background:var(--bg);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color .2s,transform .15s;}
.job-card:hover{border-color:var(--ac);transform:translateY(-2px);}
.job-icon{width:100%;aspect-ratio:1;background:var(--faint);display:flex;align-items:center;justify-content:center;font-size:32px;}
.job-info{padding:10px 10px 12px;}
.job-role{font-size:12px;font-weight:600;color:var(--ink);line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.job-company{font-size:10px;color:var(--muted);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.job-salary{font-size:13px;font-weight:700;color:var(--ac);margin:6px 0 8px;}
.job-btn{display:block;width:100%;text-align:center;background:var(--ac);color:#fff;font-size:11px;font-weight:600;padding:7px 8px;border-radius:8px;text-decoration:none;border:none;cursor:pointer;font-family:inherit;transition:opacity .15s;}
.job-btn:hover{opacity:.88;}
.job-btn.wa{background:rgba(37,211,102,0.1);border:1px solid rgba(37,211,102,0.25);color:#22C55E;margin-top:5px;}
.job-btn.wa:hover{background:rgba(37,211,102,0.18);}
.job-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px;}
.job-tag{background:rgba(255,255,255,0.05);color:var(--muted);font-size:9px;padding:1px 6px;border-radius:4px;}

/* Partners */
.partners{display:flex;flex-wrap:wrap;gap:6px;width:100%;animation:fadeUp .4s .85s both;}
.partner-pill{background:var(--faint);color:#CBD5E1;font-size:11px;padding:4px 10px;border-radius:6px;border:1px solid var(--border);}

/* Quick links */
.q-link{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:12px 14px;margin-bottom:7px;text-decoration:none;transition:border-color .2s;}
.q-link:hover{border-color:rgba(255,255,255,0.18);}
.q-emoji{font-size:17px;width:28px;text-align:center;flex-shrink:0;}
.q-body{flex:1;}
.q-label{font-size:13px;font-weight:500;color:var(--ink);}
.q-sub{font-size:11px;color:var(--muted);margin-top:1px;}
.q-arr{color:var(--muted);}

/* WhatsApp */
.wa-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:13px;border-radius:12px;background:rgba(37,211,102,0.09);border:1.5px solid rgba(37,211,102,0.25);color:#22C55E;font-size:14px;font-weight:600;text-decoration:none;margin-top:8px;transition:background .2s;animation:fadeUp .4s 1s both;}
.wa-btn:hover{background:rgba(37,211,102,0.16);}

/* Contact */
.contact-row{display:flex;align-items:center;gap:10px;color:var(--muted);font-size:12px;margin-top:8px;}
.contact-row i{font-size:15px;color:var(--ac);flex-shrink:0;}

/* Socials */
.socials{display:flex;gap:10px;margin-top:20px;justify-content:center;animation:fadeUp .4s 1.1s both;}
.soc-ic{width:40px;height:40px;border-radius:50%;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;text-decoration:none;transition:border-color .2s,transform .15s;}
.soc-ic:hover{border-color:var(--ac);transform:scale(1.08);}
.soc-ic i{font-size:17px;color:var(--muted);}

/* Share */
.share-wrap{margin-top:24px;display:flex;flex-direction:column;align-items:center;gap:6px;animation:fadeUp .4s 1.2s both;}
.share-btn{background:transparent;border:1px solid var(--border);color:var(--muted);padding:7px 16px;border-radius:20px;font-size:12px;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:6px;transition:border-color .2s;}
.share-btn:hover{border-color:rgba(255,255,255,0.2);}
.share-toast{font-size:12px;color:var(--ac);opacity:0;transition:opacity .3s;}
.share-toast.show{opacity:1;}

@keyframes popIn{0%{transform:scale(.2);opacity:0;}65%{transform:scale(1.1);}100%{transform:scale(1);opacity:1;}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
@keyframes slideUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
</style>
</head>
<body>
<div class="page">

{% assign pr = settings.profile %}
{% assign st = settings.stats %}
{% assign ct = settings.cta %}
{% assign jb = settings.jobs %}
{% assign pt = settings.partners %}
{% assign lk = settings.links %}
{% assign co = settings.contact %}
{% assign sc = settings.socials %}

<!-- Avatar / Logo -->
<div class="av-wrap">
  {% if pr.avatar != blank %}<img src="{{ pr.avatar }}" alt="{{ pr.name }}">
  {% else %}{{ pr.emoji | default: '🏢' }}{% endif %}
</div>

<h1 class="name">{{ pr.name | default: 'HireEdge Placements' }}</h1>
<p class="tagline">{{ pr.tagline | default: 'Connecting talent with opportunity' }}{% if pr.city != blank %} · {{ pr.city }}{% endif %}</p>

<div class="badges">
  {% if pr.hiring != 'no' %}<span class="badge-hiring">● Actively hiring</span>{% endif %}
  {% if pr.exp_tag != blank %}<span class="badge-exp">{{ pr.exp_tag }}</span>{% endif %}
</div>

<!-- Stats -->
{% if st %}
<div class="stats">
  <div class="stat"><div class="stat-val">{{ st.stat1_val | default: '2,400+' }}</div><div class="stat-label">{{ st.stat1_label | default: 'Placed' }}</div></div>
  <div class="stat"><div class="stat-val">{{ st.stat2_val | default: '180+' }}</div><div class="stat-label">{{ st.stat2_label | default: 'Companies' }}</div></div>
  <div class="stat"><div class="stat-val">{{ st.stat3_val | default: '94%' }}</div><div class="stat-label">{{ st.stat3_label | default: 'Success rate' }}</div></div>
</div>
{% endif %}

<!-- CTA -->
{% if ct.label != blank %}
<a class="cta" href="{{ ct.url }}" target="_blank">{{ ct.label }}</a>
{% endif %}

<!-- ── Job Listings — accordion + 2-col grid ── -->
{% if jb.items and jb.items.size > 0 %}
{% assign wa_num = co.whatsapp | remove:'+' | remove:' ' %}
<div class="pz-sections">
  <div class="pz-sec open" id="sec-jobs">
    <div class="pz-sec-head" onclick="pzToggle('sec-jobs')">
      <div class="pz-sec-icon">💼</div>
      <div class="pz-sec-meta">
        <div class="pz-sec-title">{{ jb.heading | default: 'Active openings' }}</div>
        <div class="pz-sec-sub">{{ jb.items.size }} position{% if jb.items.size != 1 %}s{% endif %}</div>
      </div>
      <div class="pz-sec-right">
        <span class="pz-count">{{ jb.items.size }}</span>
        <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
    <div class="pz-sec-body">
      <div class="pz-sec-inner">
        <div class="jobs-grid">
          {% for job in jb.items %}
          <div class="job-card">
            <div class="job-icon">💼</div>
            <div class="job-info">
              <div class="job-role">{{ job.role }}</div>
              <div class="job-company">{{ job.company }}{% if job.location != blank %} · {{ job.location }}{% endif %}</div>
              {% if job.salary != blank %}<div class="job-salary">{{ job.salary }}</div>{% endif %}
              <div class="job-tags">
                {% if job.type != blank %}<span class="job-tag">{{ job.type }}</span>{% endif %}
                {% if job.exp != blank %}<span class="job-tag">{{ job.exp }}</span>{% endif %}
              </div>
              {% if job.url != blank %}
                <a class="job-btn" href="{{ job.url }}" target="_blank">Apply now →</a>
              {% endif %}
              {% if wa_num != blank %}
                {% assign wa_msg = 'Hi! I am interested in the ' | append: job.role | append: ' role' %}
                {% if job.company != blank %}{% assign wa_msg = wa_msg | append: ' at ' | append: job.company %}{% endif %}
                {% assign wa_msg = wa_msg | append: '. Please share details.' %}
                <a class="job-btn wa" href="https://wa.me/{{ wa_num }}?text={{ wa_msg | url_encode }}" target="_blank">💬 Send CV</a>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
{% endif %}

<!-- Hiring Partners -->
{% if pt.items and pt.items.size > 0 %}
<div class="sec-title">{{ pt.heading | default: 'Hiring partners' }}</div>
<div class="partners">
  {% for p in pt.items %}<span class="partner-pill">{{ p.name }}</span>{% endfor %}
</div>
{% endif %}

<!-- Quick Links -->
{% if lk.items and lk.items.size > 0 %}
<div class="sec-title">Quick links</div>
{% for item in lk.items %}
<a class="q-link" href="{{ item.url }}" target="_blank">
  <span class="q-emoji">{{ item.emoji | default: '🔗' }}</span>
  <div class="q-body">
    <div class="q-label">{{ item.label }}</div>
    {% if item.sub != blank %}<div class="q-sub">{{ item.sub }}</div>{% endif %}
  </div>
  <i class="ti ti-chevron-right q-arr"></i>
</a>
{% endfor %}
{% endif %}

<!-- WhatsApp -->
{% if co.whatsapp != blank %}
<a class="wa-btn" href="https://wa.me/{{ co.whatsapp | remove:'+' | remove:' ' }}" target="_blank">
  <i class="ti ti-brand-whatsapp" style="font-size:20px;"></i> WhatsApp us now
</a>
{% endif %}

<!-- Contact info -->
{% if co.email != blank or co.phone != blank or co.address != blank %}
<div style="width:100%;margin-top:16px;">
  {% if co.email != blank %}<div class="contact-row"><i class="ti ti-mail"></i> {{ co.email }}</div>{% endif %}
  {% if co.phone != blank %}<div class="contact-row"><i class="ti ti-phone"></i> {{ co.phone }}</div>{% endif %}
  {% if co.address != blank %}<div class="contact-row"><i class="ti ti-map-pin"></i> {{ co.address }}</div>{% endif %}
</div>
{% endif %}

<!-- Socials -->
{% if sc %}
<div class="socials">
  {% if sc.linkedin != blank %}<a href="{{ sc.linkedin }}" class="soc-ic" target="_blank"><i class="ti ti-brand-linkedin"></i></a>{% endif %}
  {% if sc.instagram != blank %}<a href="{{ sc.instagram }}" class="soc-ic" target="_blank"><i class="ti ti-brand-instagram"></i></a>{% endif %}
  {% if sc.facebook != blank %}<a href="{{ sc.facebook }}" class="soc-ic" target="_blank"><i class="ti ti-brand-facebook"></i></a>{% endif %}
  {% if sc.youtube != blank %}<a href="{{ sc.youtube }}" class="soc-ic" target="_blank"><i class="ti ti-brand-youtube"></i></a>{% endif %}
</div>
{% endif %}

<div class="share-wrap">
  <button class="share-btn" onclick="pzShare()"><i class="ti ti-share" style="font-size:14px;"></i> Share this page</button>
  <button class="share-btn" onclick="pzSaveToPhone()"><i class="ti ti-device-mobile-down" style="font-size:14px;"></i> Save to phone</button>
  <div class="share-toast" id="pzToast">✓ Link copied!</div>
</div>
<div id="pzIOSHint" style="display:none;text-align:center;padding:8px 16px 2px;">
  <div style="display:inline-flex;align-items:flex-start;gap:10px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:11px 15px;font-size:12px;color:var(--sub);max-width:280px;text-align:left;line-height:1.5;">
    <span style="font-size:18px;flex-shrink:0;margin-top:1px;">📲</span>
    <span>Tap <strong style="color:var(--ink);">Share</strong> <svg style="display:inline;vertical-align:middle;" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg> in Safari, then tap <strong style="color:var(--ink);">"Add to Home Screen"</strong></span>
  </div>
</div>

</div>
<script>
function pzToggle(id){var s=document.getElementById(id);s.classList.toggle('open');}
function pzShare(){var u=location.href;if(navigator.share){navigator.share({title:document.title,url:u});}else{var t=document.createElement('textarea');t.value=u;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);var el=document.getElementById('pzToast');el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2200);}}
(function(){var _dp=null;var isIOS=/iPad|iPhone|iPod/.test(navigator.userAgent)&&!window.MSStream;if(window.navigator.standalone===true)return;if(navigator.serviceWorker){navigator.serviceWorker.register('/sw.js').catch(function(){});}window.addEventListener('beforeinstallprompt',function(e){e.preventDefault();_dp=e;});window.addEventListener('appinstalled',function(){_dp=null;});window.pzSaveToPhone=function(){if(_dp){_dp.prompt();_dp.userChoice.then(function(){_dp=null;});}else if(isIOS){var h=document.getElementById('pzIOSHint');if(h)h.style.display=h.style.display==='none'?'':'none';}else{var o=document.createElement('div');o.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:99999;display:flex;align-items:flex-end;justify-content:center;';o.innerHTML='<div style="background:#1a1a2e;border-radius:16px 16px 0 0;padding:24px;max-width:480px;width:100%;text-align:center;"><div style="font-size:15px;font-weight:600;color:#fff;margin-bottom:12px;">Save to your phone</div><div style="font-size:14px;color:#94A3B8;line-height:1.6;">Tap the <strong style="color:#fff;">⋮ menu</strong> at the top right, then tap <strong style="color:#fff;">"Install app"</strong> or <strong style="color:#fff;">"Add to Home screen"</strong></div><button onclick="this.parentElement.parentElement.remove()" style="margin-top:16px;padding:10px 24px;background:var(--ac);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">Got it</button></div>';document.body.appendChild(o);o.addEventListener('click',function(e){if(e.target===o)o.remove();});}};})();
</script>
</body>
</html>

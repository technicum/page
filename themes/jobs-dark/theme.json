{
  "name": "Jobs Dark Pro",
  "description": "Dark navy biolink for placement agencies & recruiters — job listings, hiring partners, CV submission CTA.",
  "for": ["minisite"],
  "categories": ["job-placement", "recruitment"],
  "tags": ["dark", "professional", "corporate", "navy", "india"],
  "order": 20,
  "default_appearance": {
    "bgColor": "#0f172a", "btnColor": "#3B82F6", "btnTextColor": "#ffffff",
    "textColor": "#e2e8f0", "btnStyle": "filled", "btnRadius": "8",
    "bgType": "color", "fontFamily": "inter",
    "animationStyle": "slide-up", "animationStagger": "100"
  },
  "default_blocks": [
    { "id":"b1", "type":"avatar",  "enabled":true, "photo":"", "name":"HireEdge Placements", "bio":"Connecting talent with opportunity · Mumbai · Pan India 🏢" },
    { "id":"b2", "type":"link",    "enabled":true, "title":"📋 Submit your CV →", "url":"#" },
    { "id":"b3", "type":"heading", "enabled":true, "text":"Active Openings", "size":"h3", "align":"center" },
    { "id":"b4", "type":"link",    "enabled":true, "title":"Senior Relationship Manager · HDFC Bank · ₹8–12 LPA", "url":"#" },
    { "id":"b5", "type":"link",    "enabled":true, "title":"React Developer · TCS · ₹10–16 LPA · Remote", "url":"#" },
    { "id":"b6", "type":"link",    "enabled":true, "title":"BPO Team Leader · Infosys BPM · ₹4–6 LPA", "url":"#" },
    { "id":"b7", "type":"socials", "enabled":true, "linkedin":"https://linkedin.com", "instagram":"https://instagram.com" }
  ],
  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "fields": [
        { "id": "avatar",   "label": "Logo / Photo URL",          "type": "image",  "default": "" },
        { "id": "emoji",    "label": "Logo Emoji (if no image)",  "type": "text",   "default": "🏢" },
        { "id": "name",     "label": "Agency / Recruiter Name",   "type": "text",   "default": "HireEdge Placements" },
        { "id": "tagline",  "label": "Tagline",                   "type": "text",   "default": "Connecting talent with opportunity" },
        { "id": "city",     "label": "City / Region",             "type": "text",   "default": "Mumbai · Pan India" },
        { "id": "hiring",   "label": "Show 'Actively Hiring' badge (yes/no)", "type": "text", "default": "yes" },
        { "id": "exp_tag",  "label": "Experience Tag (e.g. 12 yrs exp)", "type": "text", "default": "12 yrs experience" },
        { "id": "accent",   "label": "Accent Color",              "type": "color",  "default": "#3B82F6" }
      ]
    },
    {
      "id": "stats",
      "label": "Stats",
      "fields": [
        { "id": "stat1_val",   "label": "Stat 1 Value",   "type": "text", "default": "2,400+" },
        { "id": "stat1_label", "label": "Stat 1 Label",   "type": "text", "default": "Placed" },
        { "id": "stat2_val",   "label": "Stat 2 Value",   "type": "text", "default": "180+" },
        { "id": "stat2_label", "label": "Stat 2 Label",   "type": "text", "default": "Companies" },
        { "id": "stat3_val",   "label": "Stat 3 Value",   "type": "text", "default": "94%" },
        { "id": "stat3_label", "label": "Stat 3 Label",   "type": "text", "default": "Success rate" }
      ]
    },
    {
      "id": "cta",
      "label": "Primary CTA",
      "fields": [
        { "id": "label", "label": "Button Text", "type": "text", "default": "Submit your CV →" },
        { "id": "url",   "label": "Button URL",  "type": "text", "default": "" }
      ]
    },
    {
      "id": "jobs",
      "label": "Job Listings",
      "fields": [
        { "id": "heading", "label": "Section Heading", "type": "text", "default": "Active openings" },
        { "id": "items", "label": "Jobs", "type": "repeater",
          "default": [
            { "role": "Senior Relationship Manager", "company": "HDFC Bank",   "location": "Mumbai",    "description": "Manage HNI client portfolios and drive liability business growth across the branch.", "salary": "₹8–12 LPA",  "type": "Full-time", "exp": "2–5 yrs", "badge": "New", "url": "" },
            { "role": "BPO Team Leader",             "company": "Infosys BPM", "location": "Pune",      "description": "Lead a team of 15 agents, manage KPIs, and ensure SLA adherence for a UK banking client.", "salary": "₹4–6 LPA",  "type": "Full-time", "exp": "1–3 yrs", "badge": "", "url": "" },
            { "role": "React Developer",             "company": "TCS",         "location": "Bengaluru", "description": "Build and maintain React-based dashboards for a global financial services platform.", "salary": "₹10–16 LPA", "type": "Remote",    "exp": "2–4 yrs", "badge": "", "url": "" }
          ],
          "item_fields": [
            { "id": "role",        "label": "Job Role / Title",              "type": "text",     "default": "Job Title" },
            { "id": "company",     "label": "Company Name",                  "type": "text",     "default": "Company" },
            { "id": "location",    "label": "Location",                      "type": "text",     "default": "City" },
            { "id": "description", "label": "Job Description (1-2 lines)",   "type": "textarea", "default": "" },
            { "id": "salary",      "label": "Salary Range",                  "type": "text",     "default": "" },
            { "id": "type",        "label": "Job Type (Full-time etc)",      "type": "text",     "default": "Full-time" },
            { "id": "exp",         "label": "Experience Required",           "type": "text",     "default": "" },
            { "id": "badge",       "label": "Badge (New / Hot / Urgent)",    "type": "text",     "default": "" },
            { "id": "url",         "label": "Apply URL",                     "type": "text",     "default": "" }
          ]
        }
      ]
    },
    {
      "id": "partners",
      "label": "Hiring Partners",
      "fields": [
        { "id": "heading", "label": "Section Heading", "type": "text", "default": "Hiring partners" },
        { "id": "items", "label": "Companies", "type": "repeater",
          "default": [
            { "name": "HDFC Bank" }, { "name": "TCS" }, { "name": "Infosys" },
            { "name": "Wipro" },     { "name": "ICICI" }, { "name": "+175 more" }
          ],
          "item_fields": [
            { "id": "name", "label": "Company Name", "type": "text", "default": "Company" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Quick Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "emoji": "💬", "label": "WhatsApp us", "sub": "Quick reply", "url": "" },
            { "emoji": "📋", "label": "View all jobs", "sub": "", "url": "" }
          ],
          "item_fields": [
            { "id": "emoji", "label": "Emoji",    "type": "text", "default": "🔗" },
            { "id": "label", "label": "Label",    "type": "text", "default": "Link" },
            { "id": "sub",   "label": "Subtitle", "type": "text", "default": "" },
            { "id": "url",   "label": "URL",      "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "whatsapp", "label": "WhatsApp Number", "type": "text", "default": "" },
        { "id": "phone",    "label": "Phone Number",    "type": "text", "default": "" },
        { "id": "email",    "label": "Email",           "type": "text", "default": "" },
        { "id": "address",  "label": "Address / City",  "type": "text", "default": "" }
      ]
    },
    {
      "id": "socials",
      "label": "Social Media",
      "fields": [
        { "id": "linkedin",  "label": "LinkedIn URL",   "type": "text", "default": "" },
        { "id": "instagram", "label": "Instagram URL",  "type": "text", "default": "" },
        { "id": "facebook",  "label": "Facebook URL",   "type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube URL",    "type": "text", "default": "" }
      ]
    }
  ]
}

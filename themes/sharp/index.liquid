<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ settings.seo.meta_title | default: site.title }}</title>
<meta name="description" content="{{ settings.seo.meta_desc | default: settings.description }}">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{--c:{{ settings.accent_color }};--c15:{{ settings.accent_color }}26;--font-heading:'Space Grotesk',sans-serif;--font-body:'Space Grotesk',sans-serif;--font-mono:'Space Mono',monospace;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--font-body);background:#0f0f0f;color:#e5e5e5;line-height:1.6;}
a{color:var(--c);text-decoration:none;}
a:hover{text-decoration:underline;}

/* Nav */
nav{display:flex;align-items:center;justify-content:space-between;padding:20px 40px;border-bottom:1px solid #222;background:#0f0f0f;position:sticky;top:0;z-index:100;}
.nav-logo{font-family:var(--font-mono);font-weight:700;font-size:18px;color:#fff;text-decoration:none;letter-spacing:-0.5px;}
.nav-logo:hover{text-decoration:none;color:var(--c);}
.nav-links{display:flex;gap:28px;}
.nav-links a{font-size:13px;font-weight:500;color:#888;letter-spacing:0.3px;text-decoration:none;transition:color 0.15s;}
.nav-links a:hover{color:#fff;}

/* Sections */
.pz-sec{width:100%;}

/* Hero */
.pz-hero{padding:96px 40px;border-bottom:1px solid #222;background:#0f0f0f;}
.pz-hero-inner{max-width:900px;margin:0 auto;}
.pz-hero-tag{font-family:var(--font-mono);font-size:11px;color:var(--c);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px;}
.pz-hero h1{font-size:clamp(40px,6vw,72px);font-weight:700;color:#fff;line-height:1.05;letter-spacing:-2px;margin-bottom:20px;}
.pz-hero p{font-size:18px;color:#888;max-width:560px;line-height:1.7;margin-bottom:32px;}
.pz-hero-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn-p{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;background:var(--c);color:#fff;font-weight:700;font-size:14px;letter-spacing:0.3px;border-radius:var(--btn-radius,4px);text-decoration:none;transition:opacity 0.2s;}
.btn-p:hover{opacity:0.85;text-decoration:none;}
.btn-s{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;background:transparent;color:#e5e5e5;font-weight:700;font-size:14px;letter-spacing:0.3px;border:1px solid #333;border-radius:var(--btn-radius,4px);text-decoration:none;transition:all 0.2s;}
.btn-s:hover{border-color:var(--c);color:var(--c);text-decoration:none;}

/* About */
.pz-about{padding:80px 40px;border-bottom:1px solid #222;}
.pz-about-inner{max-width:900px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
.pz-about-label{font-family:var(--font-mono);font-size:10px;color:var(--c);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;}
.pz-about h2{font-size:clamp(24px,4vw,40px);font-weight:700;color:#fff;letter-spacing:-1px;margin-bottom:16px;}
.pz-about p{font-size:16px;color:#888;line-height:1.8;}
.pz-about-visual{background:#1a1a1a;border:1px solid #222;border-radius:4px;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;font-size:48px;}
@media(max-width:768px){.pz-about-inner{grid-template-columns:1fr;}}

/* Services */
.pz-services{padding:80px 40px;border-bottom:1px solid #222;}
.pz-services-inner{max-width:900px;margin:0 auto;}
.pz-sec-label{font-family:var(--font-mono);font-size:10px;color:var(--c);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px;}
.pz-sec-title{font-size:clamp(24px,4vw,40px);font-weight:700;color:#fff;letter-spacing:-1px;margin-bottom:40px;}
.pz-services-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1px;border:1px solid #222;overflow:hidden;}
.pz-service-card{background:#1a1a1a;padding:28px 24px;transition:background 0.2s;}
.pz-service-card:hover{background:#222;}
.pz-service-icon{font-size:24px;margin-bottom:12px;line-height:1;}
.pz-service-name{font-size:15px;font-weight:700;color:#fff;margin-bottom:8px;letter-spacing:-0.3px;}
.pz-service-desc{font-size:13px;color:#666;line-height:1.6;}

/* Contact */
.pz-contact{padding:80px 40px;border-bottom:1px solid #222;}
.pz-contact-inner{max-width:600px;margin:0 auto;}
.pz-contact-grid{display:flex;flex-direction:column;gap:14px;margin-top:24px;}
.pz-contact-item{display:flex;align-items:center;gap:14px;padding:16px 20px;background:#1a1a1a;border:1px solid #222;border-radius:4px;font-size:14px;color:#ccc;text-decoration:none;transition:border-color 0.2s;}
.pz-contact-item:hover{border-color:var(--c);color:#fff;text-decoration:none;}
.pz-contact-icon{font-size:18px;flex-shrink:0;width:28px;text-align:center;}

/* Testimonials */
.pz-testi{padding:80px 40px;border-bottom:1px solid #222;}
.pz-testi-inner{max-width:900px;margin:0 auto;}
.pz-testi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-top:24px;}
.testi-item{background:#1a1a1a;border:1px solid #222;border-radius:4px;padding:24px;}
.testi-stars{color:var(--c);font-size:14px;margin-bottom:10px;letter-spacing:2px;}
.testi-text{font-size:14px;color:#999;line-height:1.7;margin-bottom:14px;font-style:italic;}
.testi-name{font-size:13px;font-weight:700;color:#ccc;}

/* FAQ */
.pz-faq{padding:80px 40px;border-bottom:1px solid #222;}
.pz-faq-inner{max-width:700px;margin:0 auto;}
.faq-item{border-bottom:1px solid #222;padding:20px 0;}
.faq-q{font-size:15px;font-weight:700;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:16px;}
.faq-q::after{content:'+';font-size:20px;color:var(--c);flex-shrink:0;}
.faq-q.open::after{content:'−';}
.faq-a{font-size:14px;color:#888;line-height:1.8;margin-top:12px;display:none;}
.faq-q.open + .faq-a{display:block;}

/* Links / Bio */
.pz-links{padding:64px 20px;min-height:100vh;background:#0f0f0f;}
.pz-links-inner{max-width:440px;margin:0 auto;text-align:center;}
.pz-profile-avatar{font-size:64px;margin-bottom:16px;}
.pz-profile-name{font-size:24px;font-weight:700;color:#fff;letter-spacing:-0.5px;margin-bottom:6px;}
.pz-profile-bio{font-size:15px;color:#888;margin-bottom:32px;line-height:1.6;}
.pz-link-list{display:flex;flex-direction:column;gap:10px;}
.pz-link-btn{display:flex;align-items:center;gap:12px;padding:16px 20px;background:#1a1a1a;border:1px solid #222;border-radius:var(--btn-radius,4px);color:#e5e5e5;font-size:15px;font-weight:500;text-decoration:none;transition:all 0.15s;}
.pz-link-btn:hover{border-color:var(--c);color:#fff;text-decoration:none;}
.pz-link-emoji{font-size:18px;flex-shrink:0;}

/* Portfolio */
.pz-portfolio{padding:80px 40px;border-bottom:1px solid #222;}
.pz-portfolio-inner{max-width:900px;margin:0 auto;}
.pz-portfolio-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-top:24px;}
.pz-port-card{background:#1a1a1a;border:1px solid #222;border-radius:4px;overflow:hidden;transition:border-color 0.2s;}
.pz-port-card:hover{border-color:var(--c);}
.pz-port-img{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;background:#222;}
.pz-port-info{padding:16px;}
.pz-port-name{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px;}
.pz-port-desc{font-size:12px;color:#666;}

/* Footer */
footer{padding:32px 40px;border-top:1px solid #222;text-align:center;font-family:var(--font-mono);font-size:11px;color:#333;letter-spacing:0.5px;}
footer a{color:#555;}

/* Row/column layout */
.pz-row{width:100%;}
.pz-row-grid{width:100%;}
@media(max-width:768px){.pz-row-grid{grid-template-columns:1fr!important;}}
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="/">{{ site.title }}</a>
  <div class="nav-links">
    {% if nav_items.size > 0 %}
      {% for item in nav_items %}
        {% if item.show != false %}
        <a href="{{ item.url }}" {% if item.id == page_id %}style="color:#fff;"{% endif %}
           {% if item.external %}target="_blank" rel="noopener"{% endif %}>{{ item.label }}</a>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>
</nav>

{% for section in sections %}
  {% unless section._hidden %}
  {% assign f = section.fields %}

  {% if section._isRow %}
  {{ rendered_sections[section.id] }}

  {% elsif rendered_sections[section.id] %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  {{ rendered_sections[section.id] }}
  </div>

  {% elsif section.id == 'hero' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-hero">
    <div class="pz-hero-inner">
      <div class="pz-hero-tag">{{ settings.category | default: site_type }}</div>
      <h1>{{ f.headline | default: site.title }}</h1>
      {% if f.subheading != '' and f.subheading != nil %}<p>{{ f.subheading }}</p>{% endif %}
      <div class="pz-hero-btns">
        {% if f.btn_text != '' and f.btn_text != nil %}<a class="btn-p" href="{{ f.btn_link | default: '#contact' }}">{{ f.btn_text }}</a>{% endif %}
        {% if f.btn2_text != '' and f.btn2_text != nil %}<a class="btn-s" href="{{ f.btn2_link | default: '#about' }}">{{ f.btn2_text }}</a>{% endif %}
      </div>
    </div>
  </div>
  </div>

  {% elsif section.id == 'about' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-about">
    <div class="pz-about-inner">
      <div>
        <div class="pz-about-label">About</div>
        <h2>{{ f.title | default: 'About Us' }}</h2>
        <p>{{ f.text }}</p>
      </div>
      <div class="pz-about-visual">{{ f.emoji | default: '🏢' }}</div>
    </div>
  </div>
  </div>

  {% elsif section.id == 'services' or section.id == 'skills' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-services">
    <div class="pz-services-inner">
      <div class="pz-sec-label">{{ section.id | capitalize }}</div>
      <div class="pz-sec-title">{{ f.title | default: 'What We Do' }}</div>
      <div class="pz-services-grid">
        {% for item in f.items %}
        <div class="pz-service-card">
          <div class="pz-service-icon">{{ item.emoji | default: '⚡' }}</div>
          <div class="pz-service-name">{{ item.name }}</div>
          <div class="pz-service-desc">{{ item.description }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  </div>

  {% elsif section.id == 'contact' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-contact">
    <div class="pz-contact-inner">
      <div class="pz-sec-label">Contact</div>
      <div class="pz-sec-title">{{ f.title | default: 'Get In Touch' }}</div>
      <div class="pz-contact-grid">
        {% if f.phone != '' and f.phone != nil %}<a class="pz-contact-item" href="tel:{{ f.phone }}"><span class="pz-contact-icon">📞</span>{{ f.phone }}</a>{% endif %}
        {% if f.whatsapp != '' and f.whatsapp != nil %}<a class="pz-contact-item" href="https://wa.me/{{ f.whatsapp | wa }}" target="_blank"><span class="pz-contact-icon">💬</span>WhatsApp</a>{% endif %}
        {% if f.email != '' and f.email != nil %}<a class="pz-contact-item" href="mailto:{{ f.email }}"><span class="pz-contact-icon">✉️</span>{{ f.email }}</a>{% endif %}
        {% if f.address != '' and f.address != nil %}<div class="pz-contact-item"><span class="pz-contact-icon">📍</span>{{ f.address }}</div>{% endif %}
      </div>
    </div>
  </div>
  </div>

  {% elsif section.id == 'testimonials' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-testi">
    <div class="pz-testi-inner">
      <div class="pz-sec-label">Testimonials</div>
      <div class="pz-sec-title">{{ f.title | default: 'What They Say' }}</div>
      <div class="pz-testi-grid">
        {% for item in f.items %}
        <div class="testi-item">
          <div class="testi-stars">★★★★★</div>
          <div class="testi-text">"{{ item.text }}"</div>
          <div class="testi-name">— {{ item.name }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  </div>

  {% elsif section.id == 'faq' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-faq">
    <div class="pz-faq-inner">
      <div class="pz-sec-label">FAQ</div>
      <div class="pz-sec-title">{{ f.title | default: 'Frequently Asked Questions' }}</div>
      {% for item in f.items %}
      <div class="faq-item">
        <div class="faq-q" onclick="this.classList.toggle('open')">{{ item.question }}</div>
        <div class="faq-a">{{ item.answer }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  </div>

  {% elsif section.id == 'portfolio' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-portfolio">
    <div class="pz-portfolio-inner">
      <div class="pz-sec-label">Portfolio</div>
      <div class="pz-sec-title">{{ f.title | default: 'My Work' }}</div>
      <div class="pz-portfolio-grid">
        {% for item in f.items %}
        <div class="pz-port-card">
          {% if item.image != '' and item.image != nil %}<img class="pz-port-img" src="{{ item.image }}" alt="{{ item.name }}" loading="lazy">{% endif %}
          <div class="pz-port-info">
            <div class="pz-port-name">{{ item.name }}</div>
            <div class="pz-port-desc">{{ item.description }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  </div>

  {% elsif section.id == 'profile' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div class="pz-links">
    <div class="pz-links-inner">
      <div class="pz-profile-avatar">{{ f.avatar_emoji | default: '👤' }}</div>
      <div class="pz-profile-name">{{ f.name | default: site.title }}</div>
      {% if f.bio != '' and f.bio != nil %}<div class="pz-profile-bio">{{ f.bio }}</div>{% endif %}
    </div>
  </div>
  </div>

  {% elsif section.id == 'links' %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>
  <div style="padding:0 20px 16px;max-width:440px;margin:0 auto;">
    <div class="pz-link-list">
      {% for item in f.items %}
      {% if item.url != '' and item.url != nil %}
      <a class="pz-link-btn" href="{{ item.url }}" target="_blank" rel="noopener">
        {% if item.emoji != '' and item.emoji != nil %}<span class="pz-link-emoji">{{ item.emoji }}</span>{% endif %}
        {{ item.name }}
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
  </div>

  {% endif %}
  {% endunless %}
{% endfor %}

<footer>
  <a href="{{ app_url }}">{{ app_name }}</a>
</footer>

</body>
</html>

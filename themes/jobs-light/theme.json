{
  "name": "Jobs Clean Light",
  "description": "Clean white biolink for job placement agencies — modern card layout, green accents, two-CTA header.",
  "for": ["minisite"],
  "categories": ["job-placement", "recruitment"],
  "tags": ["light", "clean", "modern", "green", "professional"],
  "order": 21,
  "default_appearance": {
    "bgColor": "#f9fafb", "btnColor": "#059669", "btnTextColor": "#ffffff",
    "textColor": "#111827", "btnStyle": "filled", "btnRadius": "8",
    "bgType": "color", "fontFamily": "inter"
  },
  "default_blocks": [
    { "id":"b1", "type":"avatar",  "enabled":true, "photo":"", "name":"CareerBridge India", "bio":"Job Placement · Pune & Remote · 1,800+ candidates placed 🎯" },
    { "id":"b2", "type":"link",    "enabled":true, "title":"📄 Upload your resume", "url":"#" },
    { "id":"b3", "type":"link",    "enabled":true, "title":"💬 WhatsApp us now", "url":"#" },
    { "id":"b4", "type":"heading", "enabled":true, "text":"Active Openings", "size":"h3", "align":"center" },
    { "id":"b5", "type":"link",    "enabled":true, "title":"BPO Executive · Cognizant · ₹3–5 LPA · Fresher ok", "url":"#" },
    { "id":"b6", "type":"link",    "enabled":true, "title":"Sales Executive · ICICI Bank · ₹4–7 LPA", "url":"#" },
    { "id":"b7", "type":"socials", "enabled":true, "linkedin":"https://linkedin.com" }
  ],
  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "fields": [
        { "id": "avatar",   "label": "Logo / Photo URL",          "type": "image",  "default": "" },
        { "id": "emoji",    "label": "Logo Emoji (if no image)",  "type": "text",   "default": "🎯" },
        { "id": "name",     "label": "Agency / Recruiter Name",   "type": "text",   "default": "CareerBridge India" },
        { "id": "tagline",  "label": "Tagline",                   "type": "text",   "default": "Job Placement" },
        { "id": "city",     "label": "City / Region",             "type": "text",   "default": "Pune & Remote" },
        { "id": "hiring",   "label": "Show 'Actively Hiring' badge (yes/no)", "type": "text", "default": "yes" },
        { "id": "accent",   "label": "Accent Color",              "type": "color",  "default": "#059669" }
      ]
    },
    {
      "id": "stats",
      "label": "Stats",
      "fields": [
        { "id": "stat1_val",   "label": "Stat 1 Value",   "type": "text", "default": "1,800+" },
        { "id": "stat1_label", "label": "Stat 1 Label",   "type": "text", "default": "Placed" },
        { "id": "stat2_val",   "label": "Stat 2 Value",   "type": "text", "default": "120+" },
        { "id": "stat2_label", "label": "Stat 2 Label",   "type": "text", "default": "Companies" },
        { "id": "stat3_val",   "label": "Stat 3 Value",   "type": "text", "default": "96%" },
        { "id": "stat3_label", "label": "Stat 3 Label",   "type": "text", "default": "Success" }
      ]
    },
    {
      "id": "cta",
      "label": "Primary CTA",
      "fields": [
        { "id": "label",     "label": "Primary Button Text",   "type": "text", "default": "Upload your resume" },
        { "id": "url",       "label": "Primary Button URL",    "type": "text", "default": "" },
        { "id": "label2",    "label": "Secondary Button Text", "type": "text", "default": "WhatsApp us now" },
        { "id": "url2",      "label": "Secondary Button URL",  "type": "text", "default": "" }
      ]
    },
    {
      "id": "jobs",
      "label": "Job Listings",
      "fields": [
        { "id": "heading", "label": "Section Heading", "type": "text", "default": "Active openings" },
        { "id": "items", "label": "Jobs", "type": "repeater",
          "default": [
            { "role": "BPO Executive",  "company": "Cognizant", "location": "Hyderabad", "description": "Handle inbound/outbound calls for a US insurance client. Excellent communication skills required.", "salary": "₹3–5 LPA", "type": "Full-time", "exp": "Fresher ok", "badge": "New", "url": "" },
            { "role": "Sales Executive","company": "ICICI Bank","location": "Pune",      "description": "Acquire new CASA customers and cross-sell liability products across assigned territory.", "salary": "₹4–7 LPA", "type": "Full-time", "exp": "1–3 yrs",    "badge": "", "url": "" },
            { "role": "HR Recruiter",   "company": "Wipro",     "location": "Bengaluru", "description": "End-to-end recruitment for lateral and campus hiring across IT services business units.", "salary": "₹5–8 LPA", "type": "Full-time", "exp": "1–3 yrs",    "badge": "", "url": "" }
          ],
          "item_fields": [
            { "id": "role",        "label": "Job Role / Title",             "type": "text",     "default": "Job Title" },
            { "id": "company",     "label": "Company Name",                 "type": "text",     "default": "Company" },
            { "id": "location",    "label": "Location",                     "type": "text",     "default": "City" },
            { "id": "description", "label": "Job Description (1-2 lines)",  "type": "textarea", "default": "" },
            { "id": "salary",      "label": "Salary Range",                 "type": "text",     "default": "" },
            { "id": "type",        "label": "Job Type (Full-time etc)",     "type": "text",     "default": "Full-time" },
            { "id": "exp",         "label": "Experience Required",          "type": "text",     "default": "" },
            { "id": "badge",       "label": "Badge (New / Hot / Urgent)",   "type": "text",     "default": "" },
            { "id": "url",         "label": "Apply URL",                    "type": "text",     "default": "" }
          ]
        }
      ]
    },
    {
      "id": "industries",
      "label": "Industries",
      "fields": [
        { "id": "heading", "label": "Section Heading", "type": "text", "default": "Industries we serve" },
        { "id": "items", "label": "Industries", "type": "repeater",
          "default": [
            { "name": "Banking" }, { "name": "IT / BPO" }, { "name": "Finance" },
            { "name": "Healthcare" }, { "name": "Retail" }, { "name": "Logistics" }
          ],
          "item_fields": [
            { "id": "name", "label": "Industry Name", "type": "text", "default": "Industry" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Quick Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "emoji": "📋", "label": "View all jobs", "sub": "", "url": "" },
            { "emoji": "📞", "label": "Schedule a call", "sub": "Free career counselling", "url": "" }
          ],
          "item_fields": [
            { "id": "emoji", "label": "Emoji",    "type": "text", "default": "🔗" },
            { "id": "label", "label": "Label",    "type": "text", "default": "Link" },
            { "id": "sub",   "label": "Subtitle", "type": "text", "default": "" },
            { "id": "url",   "label": "URL",      "type": "text", "default": "" }
          ]
        }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "whatsapp", "label": "WhatsApp Number", "type": "text", "default": "" },
        { "id": "phone",    "label": "Phone Number",    "type": "text", "default": "" },
        { "id": "email",    "label": "Email",           "type": "text", "default": "" },
        { "id": "address",  "label": "Address / City",  "type": "text", "default": "" }
      ]
    },
    {
      "id": "socials",
      "label": "Social Media",
      "fields": [
        { "id": "linkedin",  "label": "LinkedIn URL",   "type": "text", "default": "" },
        { "id": "instagram", "label": "Instagram URL",  "type": "text", "default": "" },
        { "id": "facebook",  "label": "Facebook URL",   "type": "text", "default": "" },
        { "id": "youtube",   "label": "YouTube URL",    "type": "text", "default": "" }
      ]
    }
  ]
}

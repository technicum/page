<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ settings.profile.name | default: site.title }}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ac:{{ settings.profile.accent | default:'#059669' }};
  --bg:#F8FAFC;
  --card:#FFFFFF;
  --border:#E5E7EB;
  --ink:#111827;
  --muted:#6B7280;
  --faint:#F3F4F6;
  --ac-bg:#ECFDF5;
  --ac-text:#065F46;
  --ac-border:#D1FAE5;
}
body{background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;display:flex;justify-content:center;min-height:100vh;}
.page{width:100%;max-width:420px;padding:0 0 64px;display:flex;flex-direction:column;align-items:center;}

/* Hero band */
.hero{width:100%;background:linear-gradient(160deg,var(--ac-bg) 0%,#F0FDF4 100%);padding:40px 20px 28px;text-align:center;border-bottom:1px solid var(--ac-border);}
.av-wrap{position:relative;width:72px;height:72px;margin:0 auto 12px;animation:popIn .6s cubic-bezier(.34,1.56,.64,1) both,av-float 4s 1.2s ease-in-out infinite;}
.av-inner{position:absolute;inset:0;border-radius:16px;background:#fff;border:1px solid var(--ac-border);display:flex;align-items:center;justify-content:center;font-size:26px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);}
.av-inner img{width:100%;height:100%;object-fit:cover;}
.av-ring-o{position:absolute;inset:-7px;border-radius:22px;border:2px solid transparent;border-top-color:var(--ac);border-right-color:var(--ac-border);animation:av-spin 2.4s linear infinite;}
.av-ring-o2{position:absolute;inset:-13px;border-radius:28px;border:1.5px solid transparent;border-bottom-color:var(--ac-border);border-left-color:var(--ac-border);animation:av-spin 4.5s linear infinite reverse;}
@keyframes av-spin{to{transform:rotate(360deg)}}
@keyframes av-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.name{font-size:20px;font-weight:700;color:var(--ink);animation:fadeUp .4s .25s both;}
.tagline{font-size:12px;color:var(--muted);margin-top:4px;animation:fadeUp .4s .35s both;}
.badge-hiring{display:inline-block;background:var(--ac-bg);color:var(--ac-text);font-size:10px;padding:4px 12px;border-radius:20px;margin-top:10px;font-weight:500;border:1px solid var(--ac-border);animation:fadeUp .4s .45s both;}

/* Stats */
.stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;width:100%;padding:16px 16px 4px;}
.stat{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:10px 6px;text-align:center;}
.stat-val{color:var(--ac);font-size:17px;font-weight:700;}
.stat-label{color:var(--muted);font-size:9px;margin-top:2px;text-transform:uppercase;letter-spacing:.04em;}

/* CTA buttons */
.cta-group{display:flex;flex-direction:column;gap:8px;width:100%;padding:12px 16px 4px;}
.cta-primary{display:block;padding:13px;border-radius:12px;background:var(--ac);color:#fff;font-size:14px;font-weight:600;text-align:center;text-decoration:none;transition:opacity .2s;}
.cta-primary:hover{opacity:.88;}
.cta-secondary{display:block;padding:11px;border-radius:12px;background:var(--card);color:var(--ink);font-size:13px;font-weight:500;text-align:center;text-decoration:none;border:1px solid var(--border);transition:border-color .2s;}
.cta-secondary:hover{border-color:var(--ac);}

/* Section */
.sec-wrap{width:100%;padding:0 16px;}
.sec-title{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin:18px 0 10px;}

/* ── Accordion (shop style) ── */
.pz-sections{width:100%;padding:0 16px;margin:12px 0 4px;}
.pz-sec{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;transition:border-color .2s,box-shadow .2s;}
.pz-sec.open{border-color:var(--ac);box-shadow:0 4px 20px rgba(0,0,0,0.07);}
.pz-sec-head{display:flex;align-items:center;gap:12px;padding:14px 16px;cursor:pointer;user-select:none;}
.pz-sec-icon{width:40px;height:40px;border-radius:12px;background:var(--ac-bg);border:1px solid var(--ac-border);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.pz-sec-meta{flex:1;min-width:0;}
.pz-sec-title{font-size:14px;font-weight:700;color:var(--ink);line-height:1.2;}
.pz-sec-sub{font-size:12px;color:var(--muted);margin-top:2px;}
.pz-sec-right{display:flex;align-items:center;gap:8px;flex-shrink:0;}
.pz-count{font-size:11px;font-weight:700;background:var(--faint);border:1px solid var(--border);color:var(--muted);padding:3px 9px;border-radius:20px;}
.pz-sec.open .pz-count{background:var(--ac);border-color:var(--ac);color:#fff;}
.pz-chevron{color:var(--muted);transition:transform .3s;}
.pz-sec.open .pz-chevron{transform:rotate(180deg);color:var(--ac);}
.pz-sec-body{max-height:0;overflow:hidden;transition:max-height .4s ease;}
.pz-sec.open .pz-sec-body{max-height:4000px;}
.pz-sec-inner{padding:4px 14px 14px;}

/* ── Job grid (2-col like product grid) ── */
.jobs-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.job-card{background:var(--bg);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color .2s,transform .15s;}
.job-card:hover{border-color:var(--ac);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,0.07);}
.job-icon{width:100%;aspect-ratio:1;background:linear-gradient(135deg,var(--ac-bg),#F0FDF4);display:flex;align-items:center;justify-content:center;font-size:32px;}
.job-info{padding:10px 10px 12px;}
.job-role{font-size:12px;font-weight:600;color:var(--ink);line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.job-company{font-size:10px;color:var(--muted);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.job-salary{font-size:13px;font-weight:700;color:var(--ac);margin:6px 0 8px;}
.job-btn{display:block;width:100%;text-align:center;background:var(--ac);color:#fff;font-size:11px;font-weight:600;padding:7px 8px;border-radius:8px;text-decoration:none;border:none;cursor:pointer;font-family:inherit;transition:opacity .15s;}
.job-btn:hover{opacity:.88;}
.job-btn.wa{background:rgba(37,211,102,0.08);border:1px solid rgba(37,211,102,0.28);color:#16a34a;margin-top:5px;}
.job-btn.wa:hover{background:rgba(37,211,102,0.14);}
.job-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:5px;}
.job-tag{background:var(--faint);color:var(--muted);font-size:9px;padding:1px 6px;border-radius:4px;border:1px solid var(--border);}

/* Industries */
.industry-chips{display:flex;flex-wrap:wrap;gap:6px;}
.chip{background:var(--ac-bg);color:var(--ac-text);font-size:11px;padding:5px 12px;border-radius:20px;border:1px solid var(--ac-border);}
.chip-neutral{background:var(--faint);color:var(--muted);border-color:var(--border);}

/* Quick links */
.q-link{display:flex;align-items:center;gap:12px;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:12px 14px;margin-bottom:7px;text-decoration:none;transition:border-color .2s,transform .15s;}
.q-link:hover{border-color:var(--ac);transform:translateX(2px);}
.q-emoji{font-size:17px;width:28px;text-align:center;flex-shrink:0;}
.q-body{flex:1;}
.q-label{font-size:13px;font-weight:500;color:var(--ink);}
.q-sub{font-size:11px;color:var(--muted);margin-top:1px;}
.q-arr{color:var(--muted);}

/* WhatsApp */
.wa-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:13px;border-radius:12px;background:rgba(37,211,102,0.08);border:1.5px solid rgba(37,211,102,0.3);color:#16a34a;font-size:14px;font-weight:600;text-decoration:none;transition:background .2s;}
.wa-btn:hover{background:rgba(37,211,102,0.14);}

/* Contact */
.contact-row{display:flex;align-items:center;gap:10px;color:var(--muted);font-size:12px;margin-top:8px;}
.contact-row i{font-size:15px;color:var(--ac);flex-shrink:0;}

/* Socials */
.socials{display:flex;gap:10px;margin-top:20px;justify-content:center;}
.soc-ic{width:40px;height:40px;border-radius:50%;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;text-decoration:none;transition:border-color .2s,transform .15s;}
.soc-ic:hover{border-color:var(--ac);transform:scale(1.08);}
.soc-ic i{font-size:17px;color:var(--muted);}

/* Share */
.share-wrap{margin-top:24px;display:flex;flex-direction:column;align-items:center;gap:6px;}
.share-btn{background:transparent;border:1px solid var(--border);color:var(--muted);padding:7px 16px;border-radius:20px;font-size:12px;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:6px;transition:border-color .2s;}
.share-btn:hover{border-color:#9CA3AF;}
.share-toast{font-size:12px;color:var(--ac);opacity:0;transition:opacity .3s;}
.share-toast.show{opacity:1;}

@keyframes popIn{0%{transform:scale(.2);opacity:0;}65%{transform:scale(1.1);}100%{transform:scale(1);opacity:1;}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
</style>
</head>
<body>
<div class="page">

{% assign pr = settings.profile %}
{% assign st = settings.stats %}
{% assign ct = settings.cta %}
{% assign jb = settings.jobs %}
{% assign ind = settings.industries %}
{% assign lk = settings.links %}
{% assign co = settings.contact %}
{% assign sc = settings.socials %}

<!-- Hero -->
<div class="hero">
  <div class="av-wrap">
    <div class="av-ring-o"></div>
    <div class="av-ring-o2"></div>
    <div class="av-inner">
      {% if pr.avatar != blank %}<img src="{{ pr.avatar }}" alt="{{ pr.name }}">
      {% else %}{{ pr.emoji | default: '🎯' }}{% endif %}
    </div>
  </div>
  <h1 class="name">{{ pr.name | default: 'CareerBridge India' }}</h1>
  <p class="tagline">{{ pr.tagline | default: 'Job Placement' }}{% if pr.city != blank %} · {{ pr.city }}{% endif %}</p>
  {% if pr.hiring != 'no' %}<div class="badge-hiring">Actively hiring</div>{% endif %}
</div>

<!-- Stats -->
{% if st %}
<div class="stats">
  <div class="stat"><div class="stat-val">{{ st.stat1_val | default: '1,800+' }}</div><div class="stat-label">{{ st.stat1_label | default: 'Placed' }}</div></div>
  <div class="stat"><div class="stat-val">{{ st.stat2_val | default: '120+' }}</div><div class="stat-label">{{ st.stat2_label | default: 'Companies' }}</div></div>
  <div class="stat"><div class="stat-val">{{ st.stat3_val | default: '96%' }}</div><div class="stat-label">{{ st.stat3_label | default: 'Success' }}</div></div>
</div>
{% endif %}

<!-- CTAs -->
<div class="cta-group">
  {% if ct.label != blank %}<a class="cta-primary" href="{{ ct.url }}" target="_blank">{{ ct.label }}</a>{% endif %}
  {% if ct.label2 != blank %}
    {% assign wa_num = co.whatsapp | remove:'+' | remove:' ' %}
    {% assign cta2_url = ct.url2 %}{% if cta2_url == blank and wa_num != blank %}{% assign cta2_url = 'https://wa.me/' | append: wa_num %}{% endif %}
    <a class="cta-secondary" href="{{ cta2_url }}" target="_blank">{{ ct.label2 }}</a>
  {% endif %}
</div>

<!-- ── Job Listings — accordion + 2-col grid ── -->
{% if jb.items and jb.items.size > 0 %}
{% assign wa_num = co.whatsapp | remove:'+' | remove:' ' %}
<div class="pz-sections">
  <div class="pz-sec open" id="sec-jobs">
    <div class="pz-sec-head" onclick="pzToggle('sec-jobs')">
      <div class="pz-sec-icon">💼</div>
      <div class="pz-sec-meta">
        <div class="pz-sec-title">{{ jb.heading | default: 'Active openings' }}</div>
        <div class="pz-sec-sub">{{ jb.items.size }} position{% if jb.items.size != 1 %}s{% endif %}</div>
      </div>
      <div class="pz-sec-right">
        <span class="pz-count">{{ jb.items.size }}</span>
        <svg class="pz-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    </div>
    <div class="pz-sec-body">
      <div class="pz-sec-inner">
        <div class="jobs-grid">
          {% for job in jb.items %}
          <div class="job-card">
            <div class="job-icon">💼</div>
            <div class="job-info">
              <div class="job-role">{{ job.role }}</div>
              <div class="job-company">{{ job.company }}{% if job.location != blank %} · {{ job.location }}{% endif %}</div>
              {% if job.salary != blank %}<div class="job-salary">{{ job.salary }}</div>{% endif %}
              <div class="job-tags">
                {% if job.type != blank %}<span class="job-tag">{{ job.type }}</span>{% endif %}
                {% if job.exp != blank %}<span class="job-tag">{{ job.exp }}</span>{% endif %}
              </div>
              {% if job.url != blank %}
                <a class="job-btn" href="{{ job.url }}" target="_blank">Apply now →</a>
              {% endif %}
              {% if wa_num != blank %}
                {% assign wa_msg = 'Hi! I am interested in the ' | append: job.role | append: ' role' %}
                {% if job.company != blank %}{% assign wa_msg = wa_msg | append: ' at ' | append: job.company %}{% endif %}
                {% assign wa_msg = wa_msg | append: '. Please share details.' %}
                <a class="job-btn wa" href="https://wa.me/{{ wa_num }}?text={{ wa_msg | url_encode }}" target="_blank">💬 Send CV</a>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
{% endif %}

<!-- Industries -->
{% if ind.items and ind.items.size > 0 %}
<div class="sec-wrap">
  <div class="sec-title">{{ ind.heading | default: 'Industries we serve' }}</div>
  <div class="industry-chips">
    {% for item in ind.items %}
    {% if forloop.index <= 4 %}<span class="chip">{{ item.name }}</span>
    {% else %}<span class="chip chip-neutral">{{ item.name }}</span>{% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- Quick Links -->
{% if lk.items and lk.items.size > 0 %}
<div class="sec-wrap" style="margin-top:8px;">
  <div class="sec-title">Quick links</div>
  {% for item in lk.items %}
  <a class="q-link" href="{{ item.url }}" target="_blank">
    <span class="q-emoji">{{ item.emoji | default: '🔗' }}</span>
    <div class="q-body">
      <div class="q-label">{{ item.label }}</div>
      {% if item.sub != blank %}<div class="q-sub">{{ item.sub }}</div>{% endif %}
    </div>
    <i class="ti ti-chevron-right q-arr"></i>
  </a>
  {% endfor %}
</div>
{% endif %}

<!-- WhatsApp -->
{% if co.whatsapp != blank %}
<div class="sec-wrap" style="margin-top:8px;">
  <a class="wa-btn" href="https://wa.me/{{ co.whatsapp | remove:'+' | remove:' ' }}" target="_blank">
    <i class="ti ti-brand-whatsapp" style="font-size:20px;"></i> WhatsApp us now
  </a>
</div>
{% endif %}

<!-- Contact -->
{% if co.email != blank or co.phone != blank or co.address != blank %}
<div class="sec-wrap" style="margin-top:4px;">
  {% if co.email != blank %}<div class="contact-row"><i class="ti ti-mail"></i> {{ co.email }}</div>{% endif %}
  {% if co.phone != blank %}<div class="contact-row"><i class="ti ti-phone"></i> {{ co.phone }}</div>{% endif %}
  {% if co.address != blank %}<div class="contact-row"><i class="ti ti-map-pin"></i> {{ co.address }}</div>{% endif %}
</div>
{% endif %}

<!-- Socials -->
{% if sc %}
<div class="socials">
  {% if sc.linkedin != blank %}<a href="{{ sc.linkedin }}" class="soc-ic" target="_blank"><i class="ti ti-brand-linkedin"></i></a>{% endif %}
  {% if sc.instagram != blank %}<a href="{{ sc.instagram }}" class="soc-ic" target="_blank"><i class="ti ti-brand-instagram"></i></a>{% endif %}
  {% if sc.facebook != blank %}<a href="{{ sc.facebook }}" class="soc-ic" target="_blank"><i class="ti ti-brand-facebook"></i></a>{% endif %}
  {% if sc.youtube != blank %}<a href="{{ sc.youtube }}" class="soc-ic" target="_blank"><i class="ti ti-brand-youtube"></i></a>{% endif %}
</div>
{% endif %}

<div class="share-wrap">
  <button class="share-btn" onclick="pzShare()"><i class="ti ti-share" style="font-size:14px;"></i> Share this page</button>
  <button class="share-btn" onclick="pzSaveToPhone()"><i class="ti ti-device-mobile-down" style="font-size:14px;"></i> Save to phone</button>
  <div class="share-toast" id="pzToast">✓ Link copied!</div>
</div>
<div id="pzIOSHint" style="display:none;text-align:center;padding:8px 16px 2px;">
  <div style="display:inline-flex;align-items:flex-start;gap:10px;background:rgba(0,0,0,0.05);border:1px solid var(--border);border-radius:12px;padding:11px 15px;font-size:12px;color:var(--muted);max-width:280px;text-align:left;line-height:1.5;">
    <span style="font-size:18px;flex-shrink:0;margin-top:1px;">📲</span>
    <span>Tap <strong style="color:var(--ink);">Share</strong> <svg style="display:inline;vertical-align:middle;" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg> in Safari, then tap <strong style="color:var(--ink);">"Add to Home Screen"</strong></span>
  </div>
</div>

</div>
<script>
function pzToggle(id){var s=document.getElementById(id);s.classList.toggle('open');}
function pzShare(){var u=location.href;if(navigator.share){navigator.share({title:document.title,url:u});}else{var t=document.createElement('textarea');t.value=u;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);var el=document.getElementById('pzToast');el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2200);}}
(function(){var _dp=null;var isIOS=/iPad|iPhone|iPod/.test(navigator.userAgent)&&!window.MSStream;if(window.navigator.standalone===true)return;if(navigator.serviceWorker){navigator.serviceWorker.register('/sw.js').catch(function(){});}window.addEventListener('beforeinstallprompt',function(e){e.preventDefault();_dp=e;});window.addEventListener('appinstalled',function(){_dp=null;});window.pzSaveToPhone=function(){if(_dp){_dp.prompt();_dp.userChoice.then(function(){_dp=null;});}else if(isIOS){var h=document.getElementById('pzIOSHint');if(h)h.style.display=h.style.display==='none'?'':'none';}else{var o=document.createElement('div');o.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99999;display:flex;align-items:flex-end;justify-content:center;';o.innerHTML='<div style="background:#fff;border-radius:16px 16px 0 0;padding:24px;max-width:480px;width:100%;text-align:center;"><div style="font-size:15px;font-weight:600;color:#111;margin-bottom:12px;">Save to your phone</div><div style="font-size:14px;color:#6b7280;line-height:1.6;">Tap the <strong style="color:#111;">⋮ menu</strong> at the top right, then tap <strong style="color:#111;">"Install app"</strong> or <strong style="color:#111;">"Add to Home screen"</strong></div><button onclick="this.parentElement.parentElement.remove()" style="margin-top:16px;padding:10px 24px;background:var(--ac);color:#fff;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">Got it</button></div>';document.body.appendChild(o);o.addEventListener('click',function(e){if(e.target===o)o.remove();});}};})();
</script>
</body>
</html>

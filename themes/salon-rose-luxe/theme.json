{
  "name": "Salon Rose Luxe",
  "description": "Warm terracotta salon theme with animated avatar rings and shimmer CTA.",
  "for": ["linktree"],
  "preview": "",
  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "fields": [
        { "id": "avatar",       "label": "Avatar / Logo URL",       "type": "image",  "default": "" },

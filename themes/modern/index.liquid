<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ settings.seo.meta_title | default: site.title }}</title>
<meta name="description" content="{{ settings.seo.meta_desc | default: settings.description }}">
<meta name="robots" content="{{ settings.seo.robots | default: 'index, follow' }}">
<meta property="og:title" content="{{ settings.seo.meta_title | default: site.title }}">
<meta property="og:description" content="{{ settings.seo.meta_desc | default: settings.description }}">
<meta property="og:type" content="website"><meta property="og:url" content="{{ site.url }}">
{% if settings.seo.og_image != '' and settings.seo.og_image != nil %}<meta property="og:image" content="{{ settings.seo.og_image }}">{% endif %}
<meta name="twitter:card" content="summary_large_image">
<link rel="canonical" href="{{ site.url }}">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"{{ settings.seo.schema_type | default: 'LocalBusiness' }}","name":"{{ site.title }}","url":"{{ site.url }}"{% if settings.description %},"description":"{{ settings.description }}"{% endif %}}</script>
{% if settings.seo.google_analytics != '' and settings.seo.google_analytics != nil %}<script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.seo.google_analytics }}"></script><script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ settings.seo.google_analytics }}');</script>{% endif %}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/themes/modern/style.css">
<style>:root{--c:{{ settings.accent_color }};--c10:{{ settings.accent_color }}1a;--c20:{{ settings.accent_color }}33;}</style>
</head>
<body>

<nav>
  <div class="nav-logo">
    <span class="nav-logo-dot"></span>
    {{ site.title }}
  </div>
  <div class="nav-links">
    {% if nav_items.size > 0 %}
      {% for item in nav_items %}
        {% if item.id == 'contact' and item.external == false %}
          <a class="nav-cta" href="{{ item.url }}">{{ item.label }}</a>
        {% else %}
          <a href="{{ item.url }}" {% if item.id == page_id %}style="color:#111827;font-weight:600;"{% endif %}
             {% if item.external %}target="_blank" rel="noopener"{% endif %}>{{ item.label }}</a>
        {% endif %}
      {% endfor %}
    {% else %}
      {% for section in sections %}
        {% unless section.id == 'hero' or section.id == 'links' or section.id == 'hero_slider' or section.id == 'whatsapp_widget' %}
          <a href="#{{ section.id }}">{{ section.fields.title | default: section.id }}</a>
        {% endunless %}
      {% endfor %}
    {% endif %}
  </div>
</nav>

{% for section in sections %}
  {% unless section._hidden %}
  {% assign f = section.fields %}
  {% if section._isRow %}
  {{ rendered_sections[section.id] }}
  {% else %}
  <div class="pz-sec" data-pz="{{ section.id }}" {% if section._designCss != '' %}style="{{ section._designCss }}"{% endif %}>

  {% if rendered_sections[section.id] %}
  {{ rendered_sections[section.id] }}
  {% elsif section.id == 'hero_slider' %}
  {% assign interval = f.interval | default: 4000 %}
  <div class="hslider" id="hslider-{{ forloop.index }}">
    <div class="hslider-track" id="htrack-{{ forloop.index }}">
      {% for slide in f.slides %}
      <div class="hslide">
        <div class="hslide-content">
          <div class="hslide-badge"><span>✦</span><span>{{ site_type | capitalize }}</span></div>
          <h2 class="hslide-title">{{ slide.headline }}</h2>
          <p class="hslide-sub">{{ slide.subheading }}</p>
          {% if slide.btn_text != '' and slide.btn_text != nil %}
            <a class="btn-p" href="{{ slide.btn_link | default: '#contact' }}">{{ slide.btn_text }}</a>
          {% endif %}
        </div>
        <div class="hslide-icon">{{ slide.emoji | default: '✨' }}</div>
      </div>
      {% endfor %}
    </div>
    {% if f.slides.size > 1 %}
    <div class="hslider-arrow prev" onclick="hSlide('{{ forloop.index }}',-1)">‹</div>
    <div class="hslider-arrow next" onclick="hSlide('{{ forloop.index }}',1)">›</div>
    <div class="hslider-dots" id="hdots-{{ forloop.index }}">
      {% for slide in f.slides %}
      <div class="hslider-dot {% if forloop.first %}active{% endif %}" onclick="hGoTo('{{ forloop.parentloop.index }}',{{ forloop.index0 }})"></div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  <script>
  (function(){
    var id="{{ forloop.index }}",cur=0,total={{ f.slides.size }},iv={{ interval }};
    window.hSlide=window.hSlide||function(){};window.hGoTo=window.hGoTo||function(){};
    function go(n){cur=(n+total)%total;document.getElementById('htrack-'+id).style.transform='translateX(-'+cur*100+'%)';var dots=document.getElementById('hdots-'+id);if(dots)dots.querySelectorAll('.hslider-dot').forEach(function(d,i){d.classList.toggle('active',i===cur);});}
    var _hs=window.hSlide;window.hSlide=function(i,d){if(i===id)go(cur+d);else _hs(i,d);};
    var _hg=window.hGoTo;window.hGoTo=function(i,n){if(i===id)go(n);else _hg(i,n);};
    if(total>1)setInterval(function(){go(cur+1);},iv);
  })();
  </script>

  {% elsif section.id == 'testimonials_slider' %}
  {% assign tid = forloop.index %}
  <div class="s-wrap alt">
    <div class="s-inner">
      <div class="s-label">Testimonials</div>
      <div class="tslider-title">{{ f.title }}</div>
    </div>
    <div class="tslider-outer" style="padding-top:0;">
      <div style="overflow:hidden;max-width:1000px;margin:0 auto;">
        <div class="tslider-track" id="ttrack-{{ tid }}">
          {% for item in f.items %}
          <div class="tslide-card">
            <div class="tslide-avatar">{{ item.emoji | default: '😊' }}</div>
            <div class="tslide-stars">★★★★★</div>
            <p class="tslide-text">"{{ item.text }}"</p>
            <div class="tslide-name">{{ item.name }}</div>
            <div class="tslide-role">{{ item.role }}</div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% if f.items.size > 1 %}
      <div class="tslider-nav" style="max-width:1000px;margin:0 auto;">
        <button class="tslider-btn" onclick="tSlide('{{ tid }}',-1)">← Prev</button>
        <button class="tslider-btn" onclick="tSlide('{{ tid }}',1)">Next →</button>
      </div>
      {% endif %}
    </div>
  </div>
  <script>
  (function(){
    var id="{{ tid }}",cur=0,total={{ f.items.size }},cardW=320;
    var _ts=window.tSlide||function(){};
    window.tSlide=function(i,d){if(i===id){cur=Math.max(0,Math.min(cur+d,total-1));document.getElementById('ttrack-'+id).style.transform='translateX(-'+(cur*cardW)+'px)';}else _ts(i,d);};
  })();
  </script>

  {% elsif section.id == 'whatsapp_widget' %}
  {% if f.phone != '' and f.phone != nil %}
  {% assign wa_pos = f.position | default: 'right' %}
  {% assign wa_msg = f.message | default: 'Hi! I would like to know more.' | url_encode %}
  <div class="wa-widget {{ wa_pos }}">
    <a class="wa-bubble" href="https://wa.me/{{ f.phone | wa }}?text={{ wa_msg }}" target="_blank" rel="noopener">
      <span class="wa-icon">💬</span>
      <span>{{ f.label | default: 'Chat with us' }}</span>
    </a>
  </div>
  {% endif %}

  {% elsif section.id == 'hero' %}
  <div class="hero" id="hero">
    <div class="hero-left">
      <div class="hero-badge">
        <span>✦</span>
        <span>{{ site_type | capitalize }}{% if city %} · {{ city }}{% endif %}</span>
      </div>
      <h1 class="hero-title">{{ f.headline | default: site.title }}</h1>
      <p class="hero-sub">{{ f.subheading }}</p>
      <div class="hero-btns">
        {% if f.btn_text != '' and f.btn_text != nil %}
          <a class="btn-p" href="{{ f.btn_link | default: '#contact' }}">{{ f.btn_text }}</a>
        {% endif %}
        {% if f.btn2_text != '' and f.btn2_text != nil %}
          <a class="btn-o" href="{{ f.btn2_link | default: '#about' }}">{{ f.btn2_text }}</a>
        {% endif %}
      </div>
    </div>
    <div class="hero-right">
      <div class="hero-visual">
        <span class="hero-visual-icon">🚀</span>
        <div class="hero-visual-text">{{ site.title }}</div>
      </div>
    </div>
  </div>

  {% elsif section.id == 'about' %}
  <div class="s-wrap alt" id="about">
    <div class="s-inner">
      <div class="s-label">About</div>
      <div class="s-title">{{ f.title }}</div>
      <p class="s-text">{{ f.text }}</p>
    </div>
  </div>

  {% elsif section.id == 'services' %}
  <div class="s-wrap" id="services">
    <div class="s-inner">
      <div class="s-label">Services</div>
      <div class="s-title">{{ f.title }}</div>
      <div class="cards-grid">
        {% for item in f.items %}
        <div class="card">
          <div class="card-icon">{{ item.emoji }}</div>
          <div class="card-title">{{ item.name }}</div>
          <div class="card-desc">{{ item.desc }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% elsif section.id == 'portfolio' %}
  <div class="s-wrap alt" id="portfolio">
    <div class="s-inner">
      <div class="s-label">Portfolio</div>
      <div class="s-title">{{ f.title }}</div>
      <div class="portfolio-grid">
        {% for item in f.items %}
        <div class="pf-item">
          <div class="pf-emoji">{{ item.emoji }}</div>
          <div class="pf-name">{{ item.name }}</div>
          <div class="pf-desc">{{ item.desc }}</div>
          {% if item.link != '' and item.link != nil %}
            <a class="pf-link" href="{{ item.link }}" target="_blank">View project →</a>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% elsif section.id == 'testimonials' %}
  <div class="s-wrap" id="testimonials">
    <div class="s-inner">
      <div class="s-label">Testimonials</div>
      <div class="s-title">{{ f.title }}</div>
      <div class="testi-grid">
        {% for item in f.items %}
        <div class="testi-item">
          <div class="testi-stars">★★★★★</div>
          <p class="testi-quote">"{{ item.text }}"</p>
          <div class="testi-info">
            <div class="testi-avatar">{{ item.name | slice: 0 }}</div>
            <div>
              <div class="testi-name">{{ item.name }}</div>
              <div class="testi-role">{{ item.role }}</div>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% elsif section.id == 'faq' %}
  <div class="s-wrap alt" id="faq">
    <div class="s-inner">
      <div class="s-label">FAQ</div>
      <div class="s-title">{{ f.title }}</div>
      <div class="faq-list">
        {% for item in f.items %}
        <div class="faq-item">
          <div class="faq-q">{{ item.question }}</div>
          <div class="faq-a">{{ item.answer }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {% elsif section.id == 'links' %}
  <div class="links-wrap" id="links">
    {% for item in f.items %}
    <a class="link-item" href="{{ item.url }}" target="_blank">
      <span>{{ item.emoji }}</span>
      <span>{{ item.name }}</span>
    </a>
    {% endfor %}
  </div>

  {% elsif section.id == 'contact' %}
  <div class="contact-band" id="contact">
    <div class="contact-band-inner">
      <div>
        <div class="contact-headline">{{ f.title | default: "Let's talk" }}</div>
        <div class="contact-sub">Reach out and we'll get back to you shortly.</div>
      </div>
      <div class="contact-items">
        {% if f.phone != '' and f.phone != nil %}
          <a class="contact-item" href="tel:{{ f.phone }}">📞 {{ f.phone }}</a>
        {% endif %}
        {% if f.whatsapp != '' and f.whatsapp != nil %}
          <a class="contact-item" href="https://wa.me/{{ f.whatsapp | wa }}" target="_blank">💬 WhatsApp</a>
        {% endif %}
        {% if f.email != '' and f.email != nil %}
          <a class="contact-item" href="mailto:{{ f.email }}">✉️ {{ f.email }}</a>
        {% endif %}
        {% if f.address != '' and f.address != nil %}
          <span class="contact-item">📍 {{ f.address }}</span>
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}
  </div><!-- /pz-sec -->
  {% endif %}
  {% endunless %}
{% endfor %}

<footer>
  <div class="footer-name">{{ site.title }}</div>
  <div class="footer-credit">Powered by <a href="{{ app_url }}">{{ app_name }}</a></div>
</footer>
</body>
</html>

{
  "name": "Creator Link",
  "description": "Biolink for content creators — social links, latest content, collabs CTA.",
  "for": ["linktree"],
  "preview": "preview.jpg",
  "sections": [
    {
      "id": "profile",
      "label": "Profile",
      "fields": [
        { "id": "avatar",  "label": "Avatar URL",          "type": "image",    "default": "" },
        { "id": "name",    "label": "Your Name / Handle",  "type": "text",     "default": "Your Name" },
        { "id": "tagline", "label": "Tagline",             "type": "text",     "default": "Content Creator · Photographer" },
        { "id": "bio",     "label": "Short Bio",           "type": "textarea", "default": "Creating content that inspires ✨ Based in Mumbai 🇮🇳" },
        { "id": "accent",  "label": "Accent Color",        "type": "color",    "default": "#e11d48" }
      ]
    },
    {
      "id": "featured",
      "label": "Featured Content",
      "fields": [
        { "id": "heading", "label": "Section Heading", "type": "text", "default": "Latest Content" },
        { "id": "items", "label": "Content", "type": "repeater",
          "default": [
            { "thumbnail": "", "title": "My Latest Video", "platform": "YouTube", "link": "" },
            { "thumbnail": "", "title": "Behind the Scenes", "platform": "Instagram", "link": "" }
          ],
          "item_fields": [
            { "id": "thumbnail", "label": "Thumbnail URL",                    "type": "image", "default": "" },
            { "id": "title",     "label": "Title",                            "type": "text",  "default": "New Video" },
            { "id": "platform",  "label": "Platform (YouTube/Instagram/etc)", "type": "text",  "default": "YouTube" },
            { "id": "link",      "label": "Link",                             "type": "text",  "default": "" }
          ]
        }
      ]
    },
    {
      "id": "links",
      "label": "Links",
      "fields": [
        { "id": "items", "label": "Links", "type": "repeater",
          "default": [
            { "label": "Subscribe to my channel", "url": "", "emoji": "▶️", "primary": "yes" },
            { "label": "Follow on Instagram",      "url": "", "emoji": "📸", "primary": "no"  },
            { "label": "Shop my presets",          "url": "", "emoji": "🛍️", "primary": "no"  }
          ],
          "item_fields": [
            { "id": "label",   "label": "Label",            "type": "text", "default": "My Link" },
            { "id": "url",     "label": "URL",              "type": "text", "default": "" },
            { "id": "emoji",   "label": "Emoji",            "type": "text", "default": "🔗" },
            { "id": "primary", "label": "Primary (yes/no)", "type": "text", "default": "no" }
          ]
        }
      ]
    },
    {
      "id": "socials",
      "label": "Social Platforms",
      "fields": [
        { "id": "heading",    "label": "Section Heading",          "type": "text",  "default": "Follow me" },
        { "id": "sub",        "label": "Sub Heading (leave blank to hide)", "type": "text", "default": "" },
        { "id": "icon_color", "label": "Icon Color",                "type": "color", "default": "" },
        { "id": "icon_size",  "label": "Icon Size (sm / md / lg / xl)", "type": "text", "default": "md" },
        { "id": "youtube",   "label": "YouTube URL",     "type": "text", "default": "" },
        { "id": "instagram", "label": "Instagram URL",   "type": "text", "default": "" },
        { "id": "tiktok",    "label": "TikTok URL",      "type": "text", "default": "" },
        { "id": "twitter",   "label": "X / Twitter URL", "type": "text", "default": "" },
        { "id": "spotify",   "label": "Spotify URL",     "type": "text", "default": "" },
        { "id": "linkedin",  "label": "LinkedIn URL",    "type": "text", "default": "" },
        { "id": "github",    "label": "GitHub URL",      "type": "text", "default": "" }
      ]
    },
    {
      "id": "contact",
      "label": "Contact",
      "fields": [
        { "id": "email",     "label": "Collab / Business Email", "type": "text", "default": "" },
        { "id": "whatsapp",  "label": "WhatsApp Number",         "type": "text", "default": "" },
        { "id": "phone",     "label": "Phone Number",            "type": "text", "default": "" },
        { "id": "website",   "label": "Website URL",             "type": "text", "default": "" },
        { "id": "save_label","label": "Save Contact Button Label","type": "text", "default": "💾 Save Contact" }
      ]
    }
  ]
}

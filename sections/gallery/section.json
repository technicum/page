{
  "id": "gallery",
  "label": "Image Gallery",
  "emoji": "🖼️",
  "description": "Photo gallery with lightbox, grid or masonry layout.",
  "global": true,
  "fields": [
    { "id": "title",  "label": "Section Title",             "type": "text", "default": "Our Gallery" },
    { "id": "layout", "label": "Layout (grid/masonry/slider)", "type": "text", "default": "grid" },
    { "id": "cols",   "label": "Columns (2, 3 or 4)",       "type": "text", "default": "3" },
    {
      "id": "items", "label": "Images", "type": "list",
      "item_fields": [
        { "id": "image",   "label": "Image URL",         "type": "url",  "default": "" },
        { "id": "caption", "label": "Caption",           "type": "text", "default": "" },
        { "id": "link",    "label": "Click Link (optional)", "type": "url", "default": "" }
      ]
    }
  ]
}
